                "description": {
                  "en": "Service name",
                  "de": "Name der Dienstleistung"
                },
                "type": "string",
                "source": "field",
                "required": true
              },
              {
                "name": "Price",
                "as": "price",
                "description": {
                  "en": "Price in euros (e.g. 49 for €49). For subscriptions this is the monthly price.",
                  "de": "Preis in Euro (z.B. 49 für 49€). Bei Abos ist das der monatliche Preis."
                },
                "bot": "Ask for the price naturally. For subscriptions, ask if monthly or one-time.",
                "modifier": "transform:(value) => Number(value) * 100",
                "type": "number",
                "source": "field",
                "required": true
              },
              {
                "name": "Pricing model",
                "as": "pricingModel",
                "description": {
                  "en": "One-time payment or monthly subscription",
                  "de": "Einmalzahlung oder monatliches Abo"
                },
                "type": "string",
                "source": "field",
                "required": false,
                "options": [
                  "one-time",
                  "monthly"
                ]
              },
              {
                "name": "Duration (minutes)",
                "as": "duration_minutes",
                "description": {
                  "en": "Duration in minutes for appointments",
                  "de": "Dauer in Minuten für Termine"
                },
                "type": "number",
                "source": "field",
                "required": false
              },
              {
                "name": "Description",
                "as": "description",
                "description": {
                  "en": "Service description",
                  "de": "Beschreibung der Dienstleistung"
                },
                "type": "string",
                "source": "field",
                "required": false
              },
              {
                "name": "Tags",
                "as": "tags",
                "description": {
                  "en": "Tags (e.g. hourly, consultation, maintenance, repair)",
                  "de": "Tags (z.B. stundensatz, beratung, wartung, reparatur)"
                },
                "type": "string",
                "source": "field",
                "required": false
              }
            ]
          }
        ],
        "output": {
