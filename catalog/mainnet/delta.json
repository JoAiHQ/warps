            "de": "Dienstleistung erstellt: {{name}} ({{priceDisplay}} {{JOAI_TEAM_CURRENCY}})",
            "fr": "Service créé : {{name}} ({{priceDisplay}} {{JOAI_TEAM_CURRENCY}})",
            "es": "Servicio creado: {{name}} ({{priceDisplay}} {{JOAI_TEAM_CURRENCY}})",
            "it": "Servizio creato: {{name}} ({{priceDisplay}} {{JOAI_TEAM_CURRENCY}})",
            "ro": "Serviciu creat: {{name}} ({{priceDisplay}} {{JOAI_TEAM_CURRENCY}})"
          },
          "error": {
            "en": "Failed to create service: {{MESSAGE}}",
            "de": "Dienstleistung konnte nicht erstellt werden: {{MESSAGE}}"
          }
        },
        "actions": [
