      "warp": {
        "protocol": "warp:3.0.0",
        "name": "Appointments: Book",
        "title": {
          "en": "Book appointment",
          "de": "Termin buchen"
        },
        "description": {
          "en": "Book a confirmed appointment slot for the current agent.",
          "de": "Bucht einen bestaetigten Termin fuer den aktuellen Agenten."
        },
        "bot": "Use this only after running appointment-availability and the user has explicitly chosen a slot from the results. Never substitute this with direct calendar event creation — that skips booking policy, overlap checks, and attendee tracking. Always refer to bookings as 'appointments', never 'meetings'. The attendee is the person you are talking to — use their name and email from context without asking. Build a descriptive title combining purpose and name (e.g. 'Consultation with Anna Schmidt'). Pass exact start and end times from the chosen slot.",
        "actions": [
          {
            "type": "collect",
            "label": {
              "en": "Book now",
              "de": "Jetzt buchen"
            },
            "destination": {
              "url": "https://devnet-api.joai.ai/v1/agents/{{JOAI_AGENT_UUID}}/appointments/book",
              "method": "POST",
              "headers": {
                "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
              }
            },
            "inputs": [
              {
                "name": "Appointment Title",
                "as": "title",
                "description": {
                  "en": "Descriptive title shown on the calendar event",
                  "de": "Aussagekräftiger Titel für den Kalendereintrag"
                },
                "bot": "Required. A descriptive title that identifies the appointment at a glance. Always combine the meeting purpose AND the attendee name, e.g. 'Consultation with Anna Schmidt', 'Demo call with Acme Corp', 'Tax review with John Doe'. Never use generic titles like 'Appointment' or 'Meeting'.",
                "type": "string",
                "position": "arg:1",
                "source": "field",
                "required": true,
                "min": 3
              },
              {
                "name": "Scheduled At",
                "as": "scheduledAt",
                "description": {
                  "en": "Exact appointment start in ISO format",
                  "de": "Exakter Startzeitpunkt im ISO-Format"
                },
                "bot": "Exact confirmed appointment start in ISO 8601 format.",
                "type": "string",
                "position": "arg:2",
                "source": "field",
                "required": true
              },
              {
                "name": "Timezone",
                "as": "timezone",
                "description": {
                  "en": "Appointment timezone",
                  "de": "Zeitzone des Termins"
                },
                "bot": "Timezone identifier like Europe/Vienna, America/New_York, or UTC.",
                "type": "string",
                "source": "field",
                "required": false
              },
              {
                "name": "Service Slug",
                "as": "serviceSlug",
                "description": {
                  "en": "Optional configured service identifier",
                  "de": "Optionaler Bezeichner fuer einen konfigurierten Service"
                },
                "bot": "If the booking belongs to a configured service, pass the same service slug used for availability.",
                "type": "string",
                "source": "field",
                "required": false
              },
              {
                "name": "Routed Agent UUID",
                "as": "routedAgentUuid",
                "description": {
                  "en": "Optional staff agent UUID for routed bookings",
                  "de": "Optionale UUID des Mitarbeiter-Agenten fuer geroutete Buchungen"
                },
                "bot": "If appointment availability returned a specific agentUuid for the selected slot, pass it here unchanged.",
                "type": "string",
                "source": "field",
                "required": false
              },
              {
                "name": "Appointment Request ID",
                "as": "appointmentRequestId",
                "description": {
                  "en": "Optional linked appointment request id",
                  "de": "Optionale verknuepfte Terminanfrage-ID"
                },
                "bot": "If this booking is fulfilling a previously created appointment request, pass that request id.",
                "type": "string",
                "source": "field",
                "required": false
              },
              {
                "name": "Attendee Name",
                "as": "attendeeName",
                "description": {
                  "en": "Full name of the person the appointment is for",
                  "de": "Vollständiger Name der Person, für die der Termin ist"
                },
                "bot": "Full name of the attendee.",
                "type": "string",
                "source": "field",
                "required": true,
                "default": "{{JOAI_SENDER_NAME}}",
                "min": 2
              },
              {
                "name": "Attendee Email",
                "as": "attendeeEmail",
                "description": {
                  "en": "The attendee email",
                  "de": "E-Mail des Teilnehmers"
                },
                "bot": "Email address of the attendee if available.",
                "type": "string",
                "source": "field",
                "required": false
              },
              {
                "name": "Notes",
                "as": "description",
                "description": {
                  "en": "Optional notes or agenda",
                  "de": "Optionale Notizen oder Agenda"
                },
                "bot": "Optional notes, context, or agenda to include with the appointment.",
                "type": "string",
                "source": "field",
                "required": false
              },
              {
                "name": "Conference Provider",
                "as": "conferenceProvider",
                "description": {
                  "en": "Optional remote meeting provider",
                  "de": "Optionaler Anbieter fuer Videotermine"
                },
                "bot": "Use 'google_meet', 'teams', or 'zoom' only if the user explicitly wants a remote meeting link. Otherwise leave empty.",
                "type": "string",
                "source": "field",
                "required": false,
                "options": {
                  "google_meet": "Google Meet",
                  "teams": "Microsoft Teams",
                  "zoom": "Zoom"
                }
              }
            ]
          }
        ],
        "sections": [
          {
            "title": {
              "en": "Who's coming?",
              "de": "Wer kommt?"
            },
            "description": {
              "en": "We'll send your confirmation here.",
              "de": "Wir schicken die Bestätigung dorthin."
            },
            "inputs": [
              "attendeeName",
              "attendeeEmail"
            ]
          },
          {
            "title": {
              "en": "When is it?",
              "de": "Wann ist der Termin?"
            },
            "description": {
              "en": "Confirm the slot you've chosen.",
              "de": "Bestätige den gewählten Zeitslot."
            },
            "inputs": [
              "scheduledAt",
              "timezone"
            ]
          },
          {
            "title": {
              "en": "Anything else?",
              "de": "Noch etwas?"
            },
            "description": {
              "en": "Add a note or choose how you'd like to meet.",
              "de": "Füge eine Notiz hinzu oder wähle, wie ihr euch treffen wollt."
            },
            "inputs": [
              "description",
              "conferenceProvider"
            ]
          }
        ],
        "output": {
          "MEETING_ID": "out.data.id",
          "MEETING_URL": "out.data.inviteUrl",
          "CALENDAR_EVENT_ID": "out.data.calendarEventId",
          "ATTENDEE_EMAIL": "out.data.participants.0.email",
          "ATTENDEE_NAME": "out.data.participants.0.name",
          "MEETING_TITLE": "out.data.name",
          "SCHEDULED_AT": "out.data.scheduledAt"
        },
        "next": "appointment/email-confirm?MEETING_ID={{MEETING_ID}}&ATTENDEE_EMAIL={{ATTENDEE_EMAIL}}&ATTENDEE_NAME={{ATTENDEE_NAME}}&MEETING_TITLE={{MEETING_TITLE}}&SCHEDULED_AT={{SCHEDULED_AT}}&MEETING_URL={{MEETING_URL}}",
        "messages": {
