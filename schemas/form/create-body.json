{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["brand", "definition"],
  "additionalProperties": false,
  "properties": {
    "brand": { "type": "string", "const": "form" },
    "definition": {
      "type": "object",
      "required": ["name", "title", "actions", "messages"],
      "properties": {
        "name": { "type": "string" },
        "title": {
          "type": "object",
          "required": ["en", "de"],
          "properties": {
            "en": { "type": "string" },
            "de": { "type": "string" }
          }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type", "label", "inputs"],
            "properties": {
              "type": { "type": "string", "const": "collect" },
              "label": {
                "type": "object",
                "required": ["en", "de"],
                "properties": {
                  "en": { "type": "string" },
                  "de": { "type": "string" }
                }
              },
              "inputs": { "type": "array", "items": { "type": "object" } }
            }
          }
        },
        "messages": {
          "type": "object",
          "required": ["success"],
          "properties": {
            "success": {
              "type": "object",
              "required": ["en", "de"],
              "properties": {
                "en": { "type": "string" },
                "de": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
