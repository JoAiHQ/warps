{
  "protocol": "warp:3.0.0",
  "name": "Stripe: Get Balance",
  "title": {
    "en": "Get balance",
    "de": "Guthaben abrufen"
  },
  "description": {
    "en": "Retrieve the current balance of your Stripe account.",
    "de": "Das aktuelle Guthaben Ihres Stripe-Kontos abrufen."
  },
  "vars": {
    "API_KEY": "env:STRIPE_SECRET_KEY|Get your Secret Key from Stripe Dashboard."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Get Balance",
      "destination": {
        "url": "https://api.stripe.com/v1/balance",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}"
        }
      },
      "inputs": []
    }
  ],
  "output": {
    "AVAILABLE": "out.available",
    "PENDING": "out.pending"
  },
  "messages": {
    "success": {
      "en": "Balance retrieved.",
      "de": "Guthaben abgerufen."
    }
  }
}
