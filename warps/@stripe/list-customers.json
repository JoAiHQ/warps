{
  "protocol": "warp:3.0.0",
  "name": "Stripe: List Customers",
  "title": {
    "en": "List customers",
    "de": "Kunden auflisten",
    "es": "Listar clientes",
    "fr": "Liste des clients",
    "ro": "Listați clienții",
    "it": "Elenca i clienti"
  },
  "description": {
    "en": "List customers in your Stripe account.",
    "de": "Kunden in deinem Stripe-Konto auflisten.",
    "es": "Enumere los clientes en su cuenta Stripe.",
    "fr": "Répertoriez les clients dans votre compte Stripe.",
    "ro": "Listează clienții în contul tău Stripe.",
    "it": "Elenca i clienti nel tuo account Stripe."
  },
  "vars": {
    "API_KEY": "env:STRIPE_SECRET_KEY|Get your Secret Key from Stripe Dashboard."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Customers",
      "destination": {
        "url": "https://api.stripe.com/v1/customers",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Limit",
          "as": "limit",
          "description": {
            "en": "Number of customers to return (max 100).",
            "es": "Número de clientes a devolver (máximo 100).",
            "fr": "Nombre de clients à retourner (max 100).",
            "ro": "Număr de clienți de returnat (maxim 100).",
            "it": "Numero di clienti da restituire (max 100)."
          },
          "type": "number",
          "source": "field",
          "position": "query:limit",
          "default": "25"
        },
        {
          "name": "Email",
          "as": "email",
          "description": {
            "en": "Filter by customer email address.",
            "es": "Filtrar por dirección de correo electrónico del cliente.",
            "fr": "Filtrer par adresse e-mail du client.",
            "ro": "Filtrați după adresa de e-mail a clientului.",
            "it": "Filtra per indirizzo email del cliente."
          },
          "bot": "Optional email to filter customers by.",
          "type": "string",
          "source": "field",
          "position": "query:email"
        }
      ]
    }
  ],
  "output": {
    "CUSTOMERS": "out.data",
    "HAS_MORE": "out.has_more"
  },
  "messages": {
    "success": {
      "en": "Customers retrieved.",
      "de": "Kunden abgerufen.",
      "es": "Clientes recuperados.",
      "fr": "Clients récupérés.",
      "ro": "Clienții recuperați.",
      "it": "Clienti recuperati."
    }
  }
}
