{
  "protocol": "warp:3.0.0",
  "name": "Stripe: List Payments",
  "title": {
    "en": "List payments",
    "de": "Zahlungen auflisten",
    "es": "Listar pagos",
    "fr": "Liste des paiements",
    "ro": "Listați plățile",
    "it": "Elenca i pagamenti"
  },
  "description": {
    "en": "List recent payment intents from your Stripe account.",
    "de": "Aktuelle Zahlungsabsichten aus deinem Stripe-Konto auflisten.",
    "es": "Enumere las intenciones de pago recientes de su cuenta Stripe.",
    "fr": "Répertoriez les intentions de paiement récentes de votre compte Stripe.",
    "ro": "Listați intențiile de plată recente din contul dvs. Stripe.",
    "it": "Elenca le intenzioni di pagamento recenti dal tuo account Stripe."
  },
  "vars": {
    "API_KEY": "env:STRIPE_SECRET_KEY|Get your Secret Key from Stripe Dashboard."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Payments",
      "destination": {
        "url": "https://api.stripe.com/v1/payment_intents",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Limit",
          "as": "limit",
          "description": {
            "en": "Number of payments to return (max 100).",
            "es": "Número de pagos a devolver (máximo 100).",
            "fr": "Nombre de paiements à retourner (max 100).",
            "ro": "Numărul de plăți de returnat (maxim 100).",
            "it": "Numero di pagamenti da restituire (max 100)."
          },
          "type": "number",
          "source": "field",
          "position": "query:limit",
          "default": "25"
        },
        {
          "name": "Customer",
          "as": "customer",
          "description": {
            "en": "Filter by customer ID.",
            "es": "Filtrar por ID de cliente.",
            "fr": "Filtrer par numéro client.",
            "ro": "Filtrați după ID-ul clientului.",
            "it": "Filtra per ID cliente."
          },
          "bot": "Optional Stripe customer ID to filter payments by.",
          "type": "string",
          "source": "field",
          "position": "query:customer"
        }
      ]
    }
  ],
  "output": {
    "PAYMENTS": "out.data",
    "HAS_MORE": "out.has_more"
  },
  "messages": {
    "success": {
      "en": "Payments retrieved.",
      "de": "Zahlungen abgerufen.",
      "es": "Pagos recuperados.",
      "fr": "Paiements récupérés.",
      "ro": "Plăți recuperate.",
      "it": "Pagamenti recuperati."
    }
  }
}
