{
  "protocol": "warp:3.0.0",
  "name": "Stripe: List Subscriptions",
  "title": {
    "en": "List subscriptions",
    "de": "Abonnements auflisten",
    "es": "Listar suscripciones",
    "fr": "Liste des abonnements",
    "ro": "Listează abonamente",
    "it": "Elenco abbonamenti"
  },
  "description": {
    "en": "List active subscriptions in your Stripe account.",
    "de": "Aktive Abonnements in deinem Stripe-Konto auflisten.",
    "es": "Enumere las suscripciones activas en su cuenta Stripe.",
    "fr": "Répertoriez les abonnements actifs dans votre compte Stripe.",
    "ro": "Listați abonamentele active în contul dvs. Stripe.",
    "it": "Elenca gli abbonamenti attivi nel tuo account Stripe."
  },
  "vars": {
    "API_KEY": "env:STRIPE_SECRET_KEY|Get your Secret Key from Stripe Dashboard."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Subscriptions",
      "destination": {
        "url": "https://api.stripe.com/v1/subscriptions",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Limit",
          "as": "limit",
          "description": {
            "en": "Number of subscriptions to return (max 100).",
            "es": "Número de suscripciones a devolver (máximo 100).",
            "fr": "Nombre d'abonnements à retourner (max 100).",
            "ro": "Număr de abonamente de returnat (maxim 100).",
            "it": "Numero di abbonamenti da restituire (max 100)."
          },
          "type": "number",
          "source": "field",
          "position": "query:limit",
          "default": "25"
        },
        {
          "name": "Customer",
          "as": "customer",
          "description": {
            "en": "Filter by customer ID.",
            "es": "Filtrar por ID de cliente.",
            "fr": "Filtrer par numéro client.",
            "ro": "Filtrați după ID-ul clientului.",
            "it": "Filtra per ID cliente."
          },
          "type": "string",
          "source": "field",
          "position": "query:customer"
        },
        {
          "name": "Status",
          "as": "status",
          "description": {
            "en": "Filter by status: 'active', 'past_due', 'canceled', 'unpaid', 'trialing', or 'all'.",
            "es": "Filtrar por estado: \"activo\", \"vencido\", \"cancelado\", \"no pagado\", \"en prueba\" o \"todos\".",
            "fr": "Filtrer par statut : « actif », « past_due », « annulé », « impayé », « en essai » ou « tous ».",
            "ro": "Filtrați după stare: „activ”, „întârziat”, „anulat”, „neplătit”, „în încercare” sau „toate”.",
            "it": "Filtra per stato: \"attivo\", \"scaduto\", \"annullato\", \"non pagato\", \"in prova\" o \"tutti\"."
          },
          "bot": "Filter by subscription status. Options: active, past_due, canceled, unpaid, trialing, all.",
          "type": "string",
          "source": "field",
          "position": "query:status"
        }
      ]
    }
  ],
  "output": {
    "SUBSCRIPTIONS": "out.data",
    "HAS_MORE": "out.has_more"
  },
  "messages": {
    "success": {
      "en": "Subscriptions retrieved.",
      "de": "Abonnements abgerufen.",
      "es": "Suscripciones recuperadas.",
      "fr": "Abonnements récupérés.",
      "ro": "Abonamentele recuperate.",
      "it": "Iscrizioni recuperate."
    }
  }
}
