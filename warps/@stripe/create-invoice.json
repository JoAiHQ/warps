{
  "protocol": "warp:3.0.0",
  "name": "Stripe: Create Invoice",
  "title": {
    "en": "Create invoice",
    "de": "Rechnung erstellen",
    "es": "Crear factura",
    "fr": "Créer une facture",
    "ro": "Creați factura",
    "it": "Crea fattura"
  },
  "description": {
    "en": "Create a new invoice for a Stripe customer.",
    "de": "Eine neue Rechnung für einen Stripe-Kunden erstellen.",
    "es": "Cree una nueva factura para un cliente de Stripe.",
    "fr": "Créez une nouvelle facture pour un client Stripe.",
    "ro": "Creați o nouă factură pentru un client Stripe.",
    "it": "Crea una nuova fattura per un cliente Stripe."
  },
  "vars": {
    "API_KEY": "env:STRIPE_SECRET_KEY|Get your Secret Key from Stripe Dashboard."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Create Invoice",
      "destination": {
        "url": "https://api.stripe.com/v1/invoices",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Content-Type": "application/x-www-form-urlencoded"
        }
      },
      "inputs": [
        {
          "name": "Customer ID",
          "as": "customer",
          "description": {
            "en": "The ID of the customer to invoice.",
            "es": "El ID del cliente a facturar.",
            "fr": "L'identifiant du client à facturer.",
            "ro": "ID-ul clientului de facturat.",
            "it": "L'ID del cliente da fatturare."
          },
          "bot": "The Stripe customer ID (e.g. cus_12345).",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:customer"
        },
        {
          "name": "Collection Method",
          "as": "collection_method",
          "description": {
            "en": "'charge_automatically' or 'send_invoice'.",
            "es": "'cargar_automáticamente' o 'enviar_factura'.",
            "fr": "'charge_automatically' ou 'send_invoice'.",
            "ro": "„charge_automatically” sau „send_invoice”.",
            "it": "'addebita_automaticamente' o 'invia_fattura'."
          },
          "type": "string",
          "source": "field",
          "position": "payload:collection_method",
          "default": "send_invoice"
        },
        {
          "name": "Days Until Due",
          "as": "days_until_due",
          "description": {
            "en": "Number of days until the invoice is due (required for send_invoice).",
            "es": "Número de días hasta el vencimiento de la factura (obligatorio para send_invoice).",
            "fr": "Nombre de jours avant l'échéance de la facture (obligatoire pour send_invoice).",
            "ro": "Numărul de zile până la scadența facturii (necesar pentru send_invoice).",
            "it": "Numero di giorni fino alla scadenza della fattura (obbligatorio per send_invoice)."
          },
          "type": "number",
          "source": "field",
          "position": "payload:days_until_due",
          "default": "30"
        },
        {
          "name": "Description",
          "as": "description",
          "description": {
            "en": "Description for the invoice.",
            "es": "Descripción de la factura.",
            "fr": "Description de la facture.",
            "ro": "Descrierea facturii.",
            "it": "Descrizione per la fattura."
          },
          "type": "string",
          "source": "field",
          "position": "payload:description"
        }
      ]
    }
  ],
  "output": {
    "INVOICE_ID": "out.id",
    "STATUS": "out.status",
    "HOSTED_URL": "out.hosted_invoice_url"
  },
  "messages": {
    "success": {
      "en": "Invoice created ({{STATUS}}). ID: {{INVOICE_ID}}",
      "de": "Rechnung erstellt ({{STATUS}}). ID: {{INVOICE_ID}}",
      "es": "Factura creada ({{STATUS}}). ID: {{INVOICE_ID}}",
      "fr": "Facture créée ({{STATUS}}). ID : {{INVOICE_ID}}",
      "ro": "Factură creată ({{STATUS}}). ID: {{INVOICE_ID}}",
      "it": "Fattura creata ({{STATUS}}). ID: {{INVOICE_ID}}"
    }
  }
}
