{
  "protocol": "warp:3.0.0",
  "name": "Airtable: Create Table",
  "title": {
    "en": "Create a table",
    "de": "Eine Tabelle erstellen"
  },
  "description": {
    "en": "Create a new table in an Airtable base.",
    "de": "Erstelle eine neue Tabelle in einer Airtable-Base."
  },
  "vars": {
    "API_KEY": "env:AIRTABLE_API_KEY|Your Airtable Personal Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Create Table",
      "destination": {
        "url": "https://api.airtable.com/v0/meta/bases/{{BASE_ID}}/tables",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Base ID",
          "as": "BASE_ID",
          "description": "The ID of the base.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:BASE_ID"
        },
        {
          "name": "Table Name",
          "as": "name",
          "description": "The name of the new table.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:name"
        },
        {
          "name": "Description",
          "as": "description",
          "description": "A description for the table.",
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:description"
        },
        {
          "name": "Fields",
          "as": "fields",
          "description": "JSON array of field definitions.",
          "bot": "JSON array of field objects: [{\"name\": \"Name\", \"type\": \"singleLineText\"}, {\"name\": \"Status\", \"type\": \"singleSelect\"}]",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:fields"
        }
      ]
    }
  ],
  "output": {
    "TABLE_ID": "out.id",
    "TABLE_NAME": "out.name"
  },
  "messages": {
    "success": {
      "en": "Table '{{TABLE_NAME}}' created ({{TABLE_ID}}).",
      "de": "Tabelle '{{TABLE_NAME}}' erstellt ({{TABLE_ID}})."
    }
  }
}
