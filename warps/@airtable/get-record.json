{
  "protocol": "warp:3.0.0",
  "name": "Airtable: Get Record",
  "title": {
    "en": "Get a record",
    "de": "Einen Datensatz abrufen"
  },
  "description": {
    "en": "Retrieve a single record from an Airtable table by its ID.",
    "de": "Rufe einen einzelnen Datensatz aus einer Airtable-Tabelle anhand seiner ID ab."
  },
  "vars": {
    "API_KEY": "env:AIRTABLE_API_KEY|Your Airtable Personal Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Get Record",
      "destination": {
        "url": "https://api.airtable.com/v0/{{BASE_ID}}/{{TABLE_ID}}/{{RECORD_ID}}",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Base ID",
          "as": "BASE_ID",
          "description": "The ID of the base.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:BASE_ID"
        },
        {
          "name": "Table ID",
          "as": "TABLE_ID",
          "description": "The ID or name of the table.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:TABLE_ID"
        },
        {
          "name": "Record ID",
          "as": "RECORD_ID",
          "description": "The ID of the record (e.g., 'recABC123').",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:RECORD_ID"
        }
      ]
    }
  ],
  "output": {
    "RECORD_ID": "out.id",
    "FIELDS": "out.fields",
    "CREATED_TIME": "out.createdTime"
  },
  "messages": {
    "success": {
      "en": "Record {{RECORD_ID}} retrieved.",
      "de": "Datensatz {{RECORD_ID}} abgerufen."
    }
  }
}
