{
  "protocol": "warp:3.0.0",
  "name": "Airtable: Create Field",
  "title": {
    "en": "Create a field",
    "de": "Ein Feld erstellen"
  },
  "description": {
    "en": "Add a new field (column) to an Airtable table.",
    "de": "Füge ein neues Feld (Spalte) zu einer Airtable-Tabelle hinzu."
  },
  "vars": {
    "API_KEY": "env:AIRTABLE_API_KEY|Your Airtable Personal Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Create Field",
      "destination": {
        "url": "https://api.airtable.com/v0/meta/bases/{{BASE_ID}}/tables/{{TABLE_ID}}/fields",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Base ID",
          "as": "BASE_ID",
          "description": "The ID of the base.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:BASE_ID"
        },
        {
          "name": "Table ID",
          "as": "TABLE_ID",
          "description": "The ID of the table.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:TABLE_ID"
        },
        {
          "name": "Field Name",
          "as": "name",
          "description": "The name of the new field.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:name"
        },
        {
          "name": "Field Type",
          "as": "type",
          "description": "The type of the field (e.g., singleLineText, number, singleSelect, checkbox, date, email, url).",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:type"
        },
        {
          "name": "Description",
          "as": "description",
          "description": "A description for the field.",
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:description"
        },
        {
          "name": "Options",
          "as": "options",
          "description": "JSON object of type-specific options.",
          "bot": "JSON object of field options, e.g. for singleSelect: {\"choices\": [{\"name\": \"High\"}, {\"name\": \"Low\"}]}",
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:options"
        }
      ]
    }
  ],
  "output": {
    "FIELD_ID": "out.id",
    "FIELD_NAME": "out.name",
    "FIELD_TYPE": "out.type"
  },
  "messages": {
    "success": {
      "en": "Field '{{FIELD_NAME}}' ({{FIELD_TYPE}}) created.",
      "de": "Feld '{{FIELD_NAME}}' ({{FIELD_TYPE}}) erstellt."
    }
  }
}
