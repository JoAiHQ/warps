{
  "protocol": "warp:3.0.0",
  "name": "Airtable: Update Record",
  "title": {
    "en": "Update a record",
    "de": "Einen Datensatz aktualisieren"
  },
  "description": {
    "en": "Update fields of an existing record in an Airtable table.",
    "de": "Aktualisiere Felder eines bestehenden Datensatzes in einer Airtable-Tabelle."
  },
  "vars": {
    "API_KEY": "env:AIRTABLE_API_KEY|Your Airtable Personal Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Update Record",
      "destination": {
        "url": "https://api.airtable.com/v0/{{BASE_ID}}/{{TABLE_ID}}/{{RECORD_ID}}",
        "method": "PATCH",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Base ID",
          "as": "BASE_ID",
          "description": "The ID of the base.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:BASE_ID"
        },
        {
          "name": "Table ID",
          "as": "TABLE_ID",
          "description": "The ID or name of the table.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:TABLE_ID"
        },
        {
          "name": "Record ID",
          "as": "RECORD_ID",
          "description": "The ID of the record to update.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:RECORD_ID"
        },
        {
          "name": "Fields",
          "as": "fields",
          "description": "JSON object of fields and values to update.",
          "bot": "JSON object of fields to update: {\"Status\": \"Done\", \"Notes\": \"Completed\"}",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:fields"
        }
      ]
    }
  ],
  "output": {
    "RECORD_ID": "out.id",
    "FIELDS": "out.fields"
  },
  "messages": {
    "success": {
      "en": "Record {{RECORD_ID}} updated.",
      "de": "Datensatz {{RECORD_ID}} aktualisiert."
    }
  }
}
