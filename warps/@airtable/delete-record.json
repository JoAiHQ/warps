{
  "protocol": "warp:3.0.0",
  "name": "Airtable: Delete Record",
  "title": {
    "en": "Delete a record",
    "de": "Einen Datensatz löschen",
    "es": "Delete a record",
    "fr": "Delete a record",
    "ro": "Delete a record",
    "it": "Delete a record"
  },
  "description": {
    "en": "Delete a record from an Airtable table.",
    "de": "Lösche einen Datensatz aus einer Airtable-Tabelle.",
    "es": "Delete a record from an Airtable table.",
    "fr": "Delete a record from an Airtable table.",
    "ro": "Delete a record from an Airtable table.",
    "it": "Delete a record from an Airtable table."
  },
  "vars": {
    "API_KEY": "env:AIRTABLE_API_KEY|Your Airtable Personal Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Delete Record",
      "destination": {
        "url": "https://api.airtable.com/v0/{{BASE_ID}}/{{TABLE_ID}}/{{RECORD_ID}}",
        "method": "DELETE",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Base ID",
          "as": "BASE_ID",
          "description": "The ID of the base.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:BASE_ID"
        },
        {
          "name": "Table ID",
          "as": "TABLE_ID",
          "description": "The ID or name of the table.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:TABLE_ID"
        },
        {
          "name": "Record ID",
          "as": "RECORD_ID",
          "description": "The ID of the record to delete.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:RECORD_ID"
        }
      ]
    }
  ],
  "output": {
    "DELETED": "out.deleted",
    "RECORD_ID": "out.id"
  },
  "messages": {
    "success": {
      "en": "Record {{RECORD_ID}} deleted.",
      "de": "Datensatz {{RECORD_ID}} gelöscht.",
      "es": "Record {{RECORD_ID}} deleted.",
      "fr": "Record {{RECORD_ID}} deleted.",
      "ro": "Record {{RECORD_ID}} deleted.",
      "it": "Record {{RECORD_ID}} deleted."
    }
  }
}
