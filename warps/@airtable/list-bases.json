{
  "protocol": "warp:3.0.0",
  "name": "Airtable: List Bases",
  "title": {
    "en": "List bases",
    "de": "Bases auflisten",
    "es": "List bases",
    "fr": "List bases",
    "ro": "List bases",
    "it": "List bases"
  },
  "description": {
    "en": "List all Airtable bases accessible to the token.",
    "de": "Liste alle Airtable-Bases auf, auf die der Token Zugriff hat.",
    "es": "List all Airtable bases accessible to the token.",
    "fr": "List all Airtable bases accessible to the token.",
    "ro": "List all Airtable bases accessible to the token.",
    "it": "List all Airtable bases accessible to the token."
  },
  "vars": {
    "API_KEY": "env:AIRTABLE_API_KEY|Your Airtable Personal Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Bases",
      "destination": {
        "url": "https://api.airtable.com/v0/meta/bases",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}"
        }
      },
      "inputs": []
    }
  ],
  "output": {
    "BASES": "out.bases",
    "COUNT": "transform:() => { return Array.isArray(out.bases) ? out.bases.length : 0; }"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} base(s).",
      "de": "{{COUNT}} Base(s) gefunden.",
      "es": "Found {{COUNT}} base(s).",
      "fr": "Found {{COUNT}} base(s).",
      "ro": "Found {{COUNT}} base(s).",
      "it": "Found {{COUNT}} base(s)."
    }
  }
}
