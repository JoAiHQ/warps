{
  "protocol": "warp:3.0.0",
  "name": "Airtable: Get Base Schema",
  "title": {
    "en": "Get base schema",
    "de": "Base-Schema abrufen",
    "es": "Get base schema",
    "fr": "Get base schema",
    "ro": "Get base schema",
    "it": "Get base schema"
  },
  "description": {
    "en": "Get the schema (tables, fields, views) of an Airtable base.",
    "de": "Rufe das Schema (Tabellen, Felder, Ansichten) einer Airtable-Base ab.",
    "es": "Get the schema (tables, fields, views) of an Airtable base.",
    "fr": "Get the schema (tables, fields, views) of an Airtable base.",
    "ro": "Get the schema (tables, fields, views) of an Airtable base.",
    "it": "Get the schema (tables, fields, views) of an Airtable base."
  },
  "vars": {
    "API_KEY": "env:AIRTABLE_API_KEY|Your Airtable Personal Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Get Base Schema",
      "destination": {
        "url": "https://api.airtable.com/v0/meta/bases/{{BASE_ID}}/tables",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Base ID",
          "as": "BASE_ID",
          "description": "The ID of the base.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:BASE_ID"
        }
      ]
    }
  ],
  "output": {
    "TABLES": "out.tables",
    "TABLE_COUNT": "transform:() => { return Array.isArray(out.tables) ? out.tables.length : 0; }"
  },
  "messages": {
    "success": {
      "en": "Base has {{TABLE_COUNT}} table(s).",
      "de": "Base hat {{TABLE_COUNT}} Tabelle(n).",
      "es": "Base has {{TABLE_COUNT}} table(s).",
      "fr": "Base has {{TABLE_COUNT}} table(s).",
      "ro": "Base has {{TABLE_COUNT}} table(s).",
      "it": "Base has {{TABLE_COUNT}} table(s)."
    }
  }
}
