{
  "protocol": "warp:3.0.0",
  "name": "Instagram: List Media",
  "title": {
    "en": "List user media",
    "de": "Benutzerbeiträge auflisten",
    "es": "List user media",
    "fr": "List user media",
    "ro": "List user media",
    "it": "List user media"
  },
  "description": {
    "en": "List recent media posts for an Instagram Business or Creator account.",
    "de": "Liste aktuelle Beiträge eines Instagram Business- oder Creator-Kontos auf.",
    "es": "List recent media posts for an Instagram Business or Creator account.",
    "fr": "List recent media posts for an Instagram Business or Creator account.",
    "ro": "List recent media posts for an Instagram Business or Creator account.",
    "it": "List recent media posts for an Instagram Business or Creator account."
  },
  "vars": {
    "ACCESS_TOKEN": "env:INSTAGRAM_ACCESS_TOKEN|Instagram Graph API access token with instagram_business_basic permission."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Media",
      "destination": {
        "url": "https://graph.instagram.com/v21.0/{{IG_USER_ID}}/media",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "IG User ID",
          "as": "IG_USER_ID",
          "description": {
            "en": "Your Instagram Business/Creator account ID.",
            "es": "Your Instagram Business/Creator account ID.",
            "fr": "Your Instagram Business/Creator account ID.",
            "ro": "Your Instagram Business/Creator account ID.",
            "it": "Your Instagram Business/Creator account ID."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:IG_USER_ID"
        },
        {
          "name": "Fields",
          "as": "fields",
          "type": "string",
          "source": "hidden",
          "position": "query:fields",
          "default": "id,caption,media_type,media_url,thumbnail_url,timestamp,permalink,like_count,comments_count"
        }
      ]
    }
  ],
  "output": {
    "MEDIA": "out.data"
  },
  "messages": {
    "success": {
      "en": "Retrieved media posts.",
      "de": "Beiträge abgerufen.",
      "es": "Retrieved media posts.",
      "fr": "Retrieved media posts.",
      "ro": "Retrieved media posts.",
      "it": "Retrieved media posts."
    }
  }
}
