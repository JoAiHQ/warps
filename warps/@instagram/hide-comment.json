{
  "protocol": "warp:3.0.0",
  "name": "Instagram: Hide Comment",
  "title": {
    "en": "Hide or unhide a comment",
    "de": "Kommentar verbergen oder einblenden",
    "es": "Hide or unhide a comment",
    "fr": "Hide or unhide a comment",
    "ro": "Hide or unhide a comment",
    "it": "Hide or unhide a comment"
  },
  "description": {
    "en": "Hide or unhide a comment on your Instagram post.",
    "de": "Verberge oder blende einen Kommentar auf deinem Instagram-Beitrag ein.",
    "es": "Hide or unhide a comment on your Instagram post.",
    "fr": "Hide or unhide a comment on your Instagram post.",
    "ro": "Hide or unhide a comment on your Instagram post.",
    "it": "Hide or unhide a comment on your Instagram post."
  },
  "vars": {
    "ACCESS_TOKEN": "env:INSTAGRAM_ACCESS_TOKEN|Instagram Graph API access token with instagram_manage_comments permission."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Hide Comment",
      "destination": {
        "url": "https://graph.instagram.com/v21.0/{{COMMENT_ID}}",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Comment ID",
          "as": "COMMENT_ID",
          "description": {
            "en": "The ID of the comment.",
            "es": "The ID of the comment.",
            "fr": "The ID of the comment.",
            "ro": "The ID of the comment.",
            "it": "The ID of the comment."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:COMMENT_ID"
        },
        {
          "name": {
            "en": "Hide",
            "de": "Hide",
            "es": "Hide",
            "fr": "Hide",
            "ro": "Hide",
            "it": "Hide"
          },
          "as": {
            "en": "hide",
            "de": "hide",
            "es": "hide",
            "fr": "hide",
            "ro": "hide",
            "it": "hide"
          },
          "description": {
            "en": "Set to true to hide, false to unhide.",
            "es": "Set to true to hide, false to unhide.",
            "fr": "Set to true to hide, false to unhide.",
            "ro": "Set to true to hide, false to unhide.",
            "it": "Set to true to hide, false to unhide."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:hide",
          "default": {
            "en": "true",
            "de": "true",
            "es": "true",
            "fr": "true",
            "ro": "true",
            "it": "true"
          }
        }
      ]
    }
  ],
  "output": {
    "SUCCESS": "out.success"
  },
  "messages": {
    "success": {
      "en": "Comment visibility updated.",
      "de": "Kommentarsichtbarkeit aktualisiert.",
      "es": "Comment visibility updated.",
      "fr": "Comment visibility updated.",
      "ro": "Comment visibility updated.",
      "it": "Comment visibility updated."
    }
  }
}
