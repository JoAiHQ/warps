{
  "protocol": "warp:3.0.0",
  "name": "Instagram: Hide Comment",
  "title": {
    "en": "Hide or unhide a comment",
    "de": "Kommentar verbergen oder einblenden"
  },
  "description": {
    "en": "Hide or unhide a comment on your Instagram post.",
    "de": "Verberge oder blende einen Kommentar auf deinem Instagram-Beitrag ein."
  },
  "vars": {
    "ACCESS_TOKEN": "env:INSTAGRAM_ACCESS_TOKEN|Instagram Graph API access token with instagram_manage_comments permission."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Hide Comment",
      "destination": {
        "url": "https://graph.instagram.com/v21.0/{{COMMENT_ID}}",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Comment ID",
          "as": "COMMENT_ID",
          "description": {
            "en": "The ID of the comment."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:COMMENT_ID"
        },
        {
          "name": "Hide",
          "as": "hide",
          "description": {
            "en": "Set to true to hide, false to unhide."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:hide",
          "default": "true"
        }
      ]
    }
  ],
  "output": {
    "SUCCESS": "out.success"
  },
  "messages": {
    "success": {
      "en": "Comment visibility updated.",
      "de": "Kommentarsichtbarkeit aktualisiert."
    }
  }
}
