{
  "protocol": "warp:3.0.0",
  "name": "Form: Update Field",
  "title": {
    "en": "Edit a field",
    "de": "Feld bearbeiten"
  },
  "description": {
    "en": "Update the label, required flag, or display position of an existing field.",
    "de": "Beschriftung, Pflichtfeld-Status oder Anzeigeposition eines bestehenden Felds aktualisieren."
  },
  "bot": "Use this to change a field's label, required setting, or position on an existing form.",
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Update field",
        "de": "Feld aktualisieren"
      },
      "destination": {
        "url": "INJECT:FORM_CONTRACT",
        "func": "updateField"
      },
      "inputs": [
        {
          "name": "Form ID",
          "as": "formId",
          "description": { "en": "The form containing the field", "de": "Das Formular mit dem Feld" },
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Slug",
          "as": "slug",
          "description": { "en": "The field's slug (cannot be changed)", "de": "Der Slug des Felds (unveränderlich)" },
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Label",
          "as": "label",
          "description": { "en": "New label shown to submitters", "de": "Neue Beschriftung für Einreichende" },
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Required",
          "as": "required",
          "description": { "en": "Must submitters fill this in?", "de": "Pflichtfeld?" },
          "type": "bool",
          "position": "arg:4",
          "source": "field",
          "required": true,
          "default": "false"
        },
        {
          "name": "Position",
          "as": "position",
          "description": { "en": "Display order (0 = first)", "de": "Anzeigereihenfolge (0 = erstes)" },
          "type": "uint32",
          "position": "arg:5",
          "source": "field",
          "required": true,
          "default": "0"
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Field '{{slug}}' updated.",
      "de": "Feld '{{slug}}' aktualisiert."
    }
  }
}
