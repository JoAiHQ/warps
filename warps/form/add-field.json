{
  "protocol": "warp:3.0.0",
  "name": "Form: Add Field",
  "title": {
    "en": "Add a field",
    "de": "Feld hinzufügen"
  },
  "description": {
    "en": "Add a custom field to an existing form. Fields define what data gets collected from submitters.",
    "de": "Ein benutzerdefiniertes Feld zu einem bestehenden Formular hinzufügen. Felder bestimmen, welche Daten von Einreichenden erfasst werden."
  },
  "bot": "Use this to add a field to an existing form. Position 0 = first field shown.",
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Add field",
        "de": "Feld hinzufügen"
      },
      "destination": {
        "url": "INJECT:FORM_CONTRACT",
        "func": "addField"
      },
      "inputs": [
        {
          "name": "Form ID",
          "as": "formId",
          "description": {
            "en": "The form to add the field to",
            "de": "Das Formular, dem das Feld hinzugefügt wird"
          },
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Slug",
          "as": "slug",
          "description": {
            "en": "Internal key for this field (e.g. company, job-title)",
            "de": "Interner Schlüssel für dieses Feld (z.B. firma, berufsbezeichnung)"
          },
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Label",
          "as": "label",
          "description": {
            "en": "Label shown to the submitter",
            "de": "Beschriftung, die dem Einreichenden angezeigt wird"
          },
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Field Type",
          "as": "fieldType",
          "description": {
            "en": "Input type",
            "de": "Eingabetyp"
          },
          "type": "string",
          "position": "arg:4",
          "source": "field",
          "required": true,
          "default": "string",
          "options": {
            "string": "Short text",
            "email": "Email address",
            "phone": "Phone number",
            "text": "Long text",
            "select": "Dropdown"
          }
        },
        {
          "name": "Required",
          "as": "required",
          "description": {
            "en": "Must the submitter fill this in?",
            "de": "Muss dieses Feld ausgefüllt werden?"
          },
          "type": "bool",
          "position": "arg:5",
          "source": "field",
          "required": true,
          "default": "false"
        },
        {
          "name": "Position",
          "as": "position",
          "description": {
            "en": "Display order (0 = first)",
            "de": "Anzeigereihenfolge (0 = erstes)"
          },
          "type": "uint32",
          "position": "arg:6",
          "source": "field",
          "required": true,
          "default": "0"
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Field '{{slug}}' added to form '{{formId}}'.",
      "de": "Feld '{{slug}}' zu Formular '{{formId}}' hinzugefügt."
    }
  }
}
