{
  "protocol": "warp:3.0.0",
  "name": "Form: Remove Field",
  "title": {
    "en": "Remove a field",
    "de": "Feld entfernen"
  },
  "description": {
    "en": "Permanently remove a field from a form.",
    "de": "Ein Feld dauerhaft aus einem Formular entfernen."
  },
  "bot": "Use this to remove a field from an existing form.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Remove field",
        "de": "Feld entfernen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/warps/{{formId}}/inputs/{{slug}}",
        "method": "DELETE",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Form ID",
          "as": "formId",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "Slug",
          "as": "slug",
          "description": {
            "en": "The slug of the field to remove",
            "de": "Der Slug des zu entfernenden Felds"
          },
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Field '{{slug}}' removed.",
      "de": "Feld '{{slug}}' entfernt."
    }
  }
}
