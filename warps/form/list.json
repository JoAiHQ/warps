{
  "protocol": "warp:3.0.0",
  "name": "Form: List",
  "title": {
    "en": "List forms",
    "de": "Formulare auflisten"
  },
  "description": {
    "en": "List all forms created by your team.",
    "de": "Alle Formulare deines Teams auflisten."
  },
  "bot": "Use this to see all forms created by the team. Returns IDs and titles.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "List forms",
        "de": "Formulare auflisten"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/warps?brand=form",
        "method": "GET",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": []
    }
  ],
  "messages": {
    "success": {
      "en": "Forms loaded.",
      "de": "Formulare geladen."
    }
  }
}
