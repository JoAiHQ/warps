{
  "protocol": "warp:3.0.0",
  "name": "Form: Update Field",
  "title": {
    "en": "Edit a field",
    "de": "Feld bearbeiten"
  },
  "description": {
    "en": "Update the label or required flag of an existing field.",
    "de": "Beschriftung oder Pflichtfeld-Status eines bestehenden Felds aktualisieren."
  },
  "bot": "Use this to update a field's label or required setting on an existing form.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Update field",
        "de": "Feld aktualisieren"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/warps/{{formId}}/inputs/{{slug}}",
        "method": "PATCH",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Form ID",
          "as": "formId",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "Slug",
          "as": "slug",
          "description": {
            "en": "The field's slug (cannot be changed)",
            "de": "Der Slug des Felds (unveränderlich)"
          },
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        },
        {
          "name": "Label",
          "as": "label",
          "description": {
            "en": "New label shown to submitters",
            "de": "Neue Beschriftung für Einreichende"
          },
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": false
        },
        {
          "name": "Required",
          "as": "required",
          "description": {
            "en": "Must submitters fill this in?",
            "de": "Pflichtfeld?"
          },
          "type": "bool",
          "position": "arg:4",
          "source": "field",
          "required": false
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Field '{{slug}}' updated.",
      "de": "Feld '{{slug}}' aktualisiert."
    }
  }
}
