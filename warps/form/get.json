{
  "protocol": "warp:3.0.0",
  "name": "Form: Get",
  "title": {
    "en": "Get a form",
    "de": "Formular abrufen"
  },
  "description": {
    "en": "Fetch the current definition of a form.",
    "de": "Aktuelle Definition eines Formulars abrufen."
  },
  "bot": "Use this to read the current definition of a form before modifying it.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get form",
        "de": "Formular abrufen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/warps/{{formId}}",
        "method": "GET",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Form ID",
          "as": "formId",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Form retrieved.",
      "de": "Formular abgerufen."
    }
  }
}
