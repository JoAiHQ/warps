{
  "protocol": "warp:3.0.0",
  "name": "Form: Get",
  "title": {
    "en": "Get a form",
    "de": "Formular abrufen",
    "es": "Get a form",
    "fr": "Get a form",
    "ro": "Get a form",
    "it": "Get a form"
  },
  "description": {
    "en": "Fetch the current definition of a form.",
    "de": "Aktuelle Definition eines Formulars abrufen.",
    "es": "Fetch the current definition of a form.",
    "fr": "Fetch the current definition of a form.",
    "ro": "Fetch the current definition of a form.",
    "it": "Fetch the current definition of a form."
  },
  "bot": "Use this to read the current definition of a form before modifying it.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get form",
        "de": "Formular abrufen",
        "es": "Get form",
        "fr": "Get form",
        "ro": "Get form",
        "it": "Get form"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/warps/{{formId}}",
        "method": "GET",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Form ID",
          "as": "formId",
          "type": "string",
          "position": "url:formId",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Form retrieved.",
      "de": "Formular abgerufen.",
      "es": "Form retrieved.",
      "fr": "Form retrieved.",
      "ro": "Form retrieved.",
      "it": "Form retrieved."
    }
  }
}
