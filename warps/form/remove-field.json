{
  "protocol": "warp:3.0.0",
  "name": "Form: Remove Field",
  "title": {
    "en": "Remove a field",
    "de": "Feld entfernen"
  },
  "description": {
    "en": "Permanently remove a field from a form.",
    "de": "Ein Feld dauerhaft aus einem Formular entfernen."
  },
  "bot": "Use this to remove a field from an existing form. The change is permanent and on-chain.",
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Remove field",
        "de": "Feld entfernen"
      },
      "destination": {
        "url": "INJECT:FORM_CONTRACT",
        "func": "removeField"
      },
      "inputs": [
        {
          "name": "Form ID",
          "as": "formId",
          "description": {
            "en": "The form to remove the field from",
            "de": "Das Formular, aus dem das Feld entfernt wird"
          },
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Slug",
          "as": "slug",
          "description": {
            "en": "The slug of the field to remove",
            "de": "Der Slug des zu entfernenden Felds"
          },
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "min": 1
        }
      ],
      "gasLimit": 10000000
    }
  ],
  "messages": {
    "success": {
      "en": "Field '{{slug}}' removed from form '{{formId}}'.",
      "de": "Feld '{{slug}}' aus Formular '{{formId}}' entfernt."
    }
  }
}