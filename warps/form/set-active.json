{
  "protocol": "warp:3.0.0",
  "name": "Form: Activate / Pause",
  "title": {
    "en": "Activate or pause form",
    "de": "Formular aktivieren oder pausieren"
  },
  "description": {
    "en": "Enable or disable a form. Paused forms reject new submissions.",
    "de": "Ein Formular aktivieren oder deaktivieren. Pausierte Formulare lehnen neue Einreichungen ab."
  },
  "bot": "Use this to open or close a form for submissions. Set active=true to open, active=false to close.",
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Set status",
        "de": "Status setzen"
      },
      "destination": {
        "url": "INJECT:FORM_CONTRACT",
        "func": "setActive"
      },
      "inputs": [
        {
          "name": "Form ID",
          "as": "formId",
          "description": {
            "en": "The form to activate or pause",
            "de": "Das zu aktivierende oder zu pausierende Formular"
          },
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Active",
          "as": "active",
          "description": {
            "en": "true = accepting submissions, false = paused",
            "de": "true = offen, false = pausiert"
          },
          "type": "bool",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "default": "true"
        }
      ],
      "gasLimit": 10000000
    }
  ],
  "messages": {
    "success": {
      "en": "Form '{{formId}}' is now {{active}}.",
      "de": "Formular '{{formId}}' ist jetzt {{active}}."
    }
  }
}