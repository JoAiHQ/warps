{
  "protocol": "warp:3.0.0",
  "name": "Form: Add Field",
  "title": {
    "en": "Add a field",
    "de": "Feld hinzufügen"
  },
  "description": {
    "en": "Add an input field to an existing form.",
    "de": "Ein Eingabefeld zu einem bestehenden Formular hinzufügen."
  },
  "bot": "Use this to add a field to a form. The formId comes from the form creation response. Auto-generate the slug from the label as lowercase kebab-case.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Add field",
        "de": "Feld hinzufügen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/warps/{{formId}}/inputs",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Form ID",
          "as": "formId",
          "bot": "The form's ID from the create response. Never ask the user — carry it from the previous step.",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "Slug",
          "as": "slug",
          "description": {
            "en": "Internal key for this field (e.g. company, job-title)",
            "de": "Interner Schlüssel (z.B. firma, berufsbezeichnung)"
          },
          "bot": "Lowercase kebab-case key. Auto-generate from label.",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        },
        {
          "name": "Label",
          "as": "label",
          "description": {
            "en": "Label shown to the submitter",
            "de": "Beschriftung für Einreichende"
          },
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": true
        },
        {
          "name": "Field Type",
          "as": "fieldType",
          "description": {
            "en": "Input type",
            "de": "Eingabetyp"
          },
          "type": "string",
          "position": "arg:4",
          "source": "field",
          "required": false,
          "default": "string",
          "options": {
            "string": "Short text",
            "email": "Email address",
            "phone": "Phone number",
            "text": "Long text",
            "select": "Dropdown",
            "bool": "Yes / No"
          }
        },
        {
          "name": "Required",
          "as": "required",
          "description": {
            "en": "Must the submitter fill this in?",
            "de": "Pflichtfeld?"
          },
          "type": "bool",
          "position": "arg:5",
          "source": "field",
          "required": false,
          "default": "false"
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Field '{{label}}' added.",
      "de": "Feld '{{label}}' hinzugefügt."
    }
  }
}
