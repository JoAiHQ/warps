{
  "protocol": "warp:3.0.0",
  "name": "Form: Create Form",
  "title": {
    "en": "Create a form",
    "de": "Formular erstellen"
  },
  "description": {
    "en": "Register a new form. The form definition is stored on the Form smart contract. Add fields next using 'Add Field'.",
    "de": "Ein neues Formular registrieren. Die Formulardefinition wird im Form-Smart-Contract gespeichert. Felder danach mit 'Feld hinzufügen' ergänzen."
  },
  "bot": "Use this to create a new form. Collect the title and type from the user. The form ID is auto-generated — never ask the user for it. After creating, use add-field to define the form's inputs.",
  "vars": {},
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Create form",
        "de": "Formular erstellen"
      },
      "destination": {
        "url": "INJECT:FORM_CONTRACT",
        "func": "createForm"
      },
      "inputs": [
        {
          "name": "Form ID",
          "as": "formId",
          "bot": "Auto-generate as kebab-case slug from title + 4 random alphanumeric chars. Never ask the user.",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Agent ID",
          "as": "agentId",
          "type": "string",
          "position": "arg:2",
          "source": "hidden",
          "default": "{{JOAI_AGENT_UUID}}"
        },
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "Form title shown to submitters",
            "de": "Formulartitel, der Einreichenden angezeigt wird"
          },
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Description",
          "as": "description",
          "description": {
            "en": "Short description of the form's purpose (optional)",
            "de": "Kurze Beschreibung des Formularszwecks (optional)"
          },
          "type": "string",
          "position": "arg:4",
          "source": "field",
          "required": false,
          "default": ""
        },
        {
          "name": "Type",
          "as": "formType",
          "description": {
            "en": "What the form does with submissions",
            "de": "Was mit Einreichungen passiert"
          },
          "type": "string",
          "position": "arg:5",
          "source": "field",
          "required": true,
          "default": "lead",
          "options": {
            "lead": "Lead capture",
            "feedback": "Feedback",
            "rsvp": "RSVP",
            "custom": "Custom"
          }
        }
      ],
      "gasLimit": 10000000
    }
  ],
  "messages": {
    "success": {
      "en": "Form '{{title}}' created! Add fields next.",
      "de": "Formular '{{title}}' erstellt! Jetzt Felder hinzufügen."
    }
  },
  "next": "@form-field-add?formId={{formId}}"
}
