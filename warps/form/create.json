{
  "protocol": "warp:3.0.0",
  "name": "Form: Create",
  "title": {
    "en": "Create a form",
    "de": "Formular erstellen"
  },
  "description": {
    "en": "Create a new form. After creating, use 'Add Field' to define the inputs.",
    "de": "Ein neues Formular erstellen. Danach mit 'Feld hinzufügen' die Felder definieren."
  },
  "bot": "Use this to create a new form. Collect title and type from the user. After creating, use field-add to define the form's inputs.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create form",
        "de": "Formular erstellen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/warps",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "Form title shown to submitters",
            "de": "Formulartitel für Einreichende"
          },
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Description",
          "as": "description",
          "description": {
            "en": "Short description of the form's purpose (optional)",
            "de": "Kurze Beschreibung des Formularszwecks (optional)"
          },
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": false
        },
        {
          "name": "Type",
          "as": "type",
          "description": {
            "en": "What the form does with submissions",
            "de": "Was mit Einreichungen passiert"
          },
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "default": "lead",
          "options": {
            "lead": "Lead capture",
            "feedback": "Feedback",
            "rsvp": "RSVP",
            "custom": "Custom"
          }
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Form '{{title}}' created! Add fields next.",
      "de": "Formular '{{title}}' erstellt! Jetzt Felder hinzufügen."
    }
  }
}
