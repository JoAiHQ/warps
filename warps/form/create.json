{
  "protocol": "warp:3.0.0",
  "name": "Form: Create",
  "title": {
    "en": "Create a form",
    "de": "Formular erstellen"
  },
  "description": {
    "en": "Create a new form. After creating, use 'Add Field' to define the inputs.",
    "de": "Ein neues Formular erstellen. Danach mit 'Feld hinzufügen' die Felder definieren."
  },
  "bot": "Use this to create a new form. After creating, use field-add to define the form's inputs. Compose the full warp definition before submitting.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create form",
        "de": "Formular erstellen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/warps",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Brand",
          "as": "brand",
          "bot": "Always 'form' for form warps.",
          "type": "string",
          "position": "arg:0",
          "source": "field",
          "required": true,
          "default": "form"
        },
        {
          "name": "Name",
          "as": "definition.name",
          "bot": "Internal name of the form (same as title, English only).",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Title (EN)",
          "as": "definition.title.en",
          "description": {
            "en": "Form title shown to submitters (English)",
            "de": "Formulartitel für Einreichende (Englisch)"
          },
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Title (DE)",
          "as": "definition.title.de",
          "description": {
            "en": "Form title shown to submitters (German)",
            "de": "Formulartitel für Einreichende (Deutsch)"
          },
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": false
        },
        {
          "name": "Description (EN)",
          "as": "definition.description.en",
          "description": {
            "en": "Short description of the form's purpose (optional)",
            "de": "Kurze Beschreibung des Formularszwecks (optional)"
          },
          "type": "string",
          "position": "arg:4",
          "source": "field",
          "required": false
        },
        {
          "name": "Submit Label (EN)",
          "as": "definition.actions.0.label.en",
          "description": {
            "en": "Text on the submit button (English)",
            "de": "Text auf dem Absende-Button (Englisch)"
          },
          "bot": "Default: 'Submit'",
          "type": "string",
          "position": "arg:5",
          "source": "field",
          "required": true,
          "default": "Submit"
        },
        {
          "name": "Submit Label (DE)",
          "as": "definition.actions.0.label.de",
          "description": {
            "en": "Text on the submit button (German)",
            "de": "Text auf dem Absende-Button (Deutsch)"
          },
          "bot": "Default: 'Absenden'",
          "type": "string",
          "position": "arg:6",
          "source": "field",
          "required": false,
          "default": "Absenden"
        },
        {
          "name": "Success Message (EN)",
          "as": "definition.messages.success.en",
          "description": {
            "en": "Message shown after successful submission (English)",
            "de": "Nachricht nach erfolgreicher Einreichung (Englisch)"
          },
          "bot": "Default: 'Thanks! We\\'ll be in touch soon.'",
          "type": "string",
          "position": "arg:7",
          "source": "field",
          "required": true,
          "default": "Thanks! We'll be in touch soon."
        },
        {
          "name": "Success Message (DE)",
          "as": "definition.messages.success.de",
          "description": {
            "en": "Message shown after successful submission (German)",
            "de": "Nachricht nach erfolgreicher Einreichung (Deutsch)"
          },
          "bot": "Default: 'Danke! Wir melden uns bald.'",
          "type": "string",
          "position": "arg:8",
          "source": "field",
          "required": false,
          "default": "Danke! Wir melden uns bald."
        },
        {
          "name": "Action Type",
          "as": "definition.actions.0.type",
          "bot": "Always 'collect' for forms.",
          "type": "string",
          "position": "arg:9",
          "source": "field",
          "required": true,
          "default": "collect"
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Form created! Add fields next.",
      "de": "Formular erstellt! Jetzt Felder hinzufügen."
    }
  }
}
