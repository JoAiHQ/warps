{
  "protocol": "warp:3.0.0",
  "name": "Form: Create",
  "title": {
    "en": "Create a form",
    "de": "Formular erstellen",
    "es": "Create a form",
    "fr": "Create a form",
    "ro": "Create a form",
    "it": "Create a form"
  },
  "description": {
    "en": "Create a new lead capture, RSVP, or feedback form. Returns a public link ready to share.",
    "de": "Erstellt ein neues Lead-, RSVP- oder Feedback-Formular. Gibt einen öffentlichen Link zum Teilen zurück.",
    "es": "Create a new lead capture, RSVP, or feedback form. Returns a public link ready to share.",
    "fr": "Create a new lead capture, RSVP, or feedback form. Returns a public link ready to share.",
    "ro": "Create a new lead capture, RSVP, or feedback form. Returns a public link ready to share.",
    "it": "Create a new lead capture, RSVP, or feedback form. Returns a public link ready to share."
  },
  "bot": "Use this to create a new form. After creating, use form-field-add to add each field.",
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Configure form",
        "de": "Formular konfigurieren",
        "es": "Configure form",
        "fr": "Configure form",
        "ro": "Configure form",
        "it": "Configure form"
      },
      "prompt": "Build the form definition from the user's title and description. Translate the title into German. Write a friendly, context-appropriate success message in both English and German. The inputs array must be empty — fields are added in the next step. Set brand to a lowercase slug (e.g. 'form', 'feedback', 'rsvp') — only lowercase letters, digits, and hyphens allowed.",
      "inputs": [
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "Form title",
            "de": "Formular-Titel",
            "es": "Form title",
            "fr": "Form title",
            "ro": "Form title",
            "it": "Form title"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Description",
          "as": "description",
          "description": {
            "en": "What is this form for? (optional)",
            "de": "Wofür ist dieses Formular? (optional)",
            "es": "What is this form for? (optional)",
            "fr": "What is this form for? (optional)",
            "ro": "What is this form for? (optional)",
            "it": "What is this form for? (optional)"
          },
          "type": "string",
          "source": "field",
          "required": false
        }
      ],
      "expect": "https://raw.githubusercontent.com/JoAiHQ/warps/main/schemas/form/create-body.json",
      "auto": true
    },
    {
      "type": "collect",
      "label": {
        "en": "Create form",
        "de": "Formular erstellen",
        "es": "Create form",
        "fr": "Create form",
        "ro": "Create form",
        "it": "Create form"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/warps",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "PAYLOAD",
          "as": "PAYLOAD",
          "type": "string",
          "source": "hidden",
          "required": true,
          "default": "{{MESSAGE}}"
        }
      ]
    }
  ],
  "output": {
    "FORM_ID": "out.data.id",
    "FORM_URL": "out.data.url"
  },
  "next": "form/field-add?formId={{FORM_ID}}",
  "messages": {
    "success": {
      "en": "Form created! Your public link: {{FORM_URL}}",
      "de": "Formular erstellt! Dein öffentlicher Link: {{FORM_URL}}",
      "es": "Form created! Your public link: {{FORM_URL}}",
      "fr": "Form created! Your public link: {{FORM_URL}}",
      "ro": "Form created! Your public link: {{FORM_URL}}",
      "it": "Form created! Your public link: {{FORM_URL}}"
    }
  }
}
