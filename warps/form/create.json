{
  "protocol": "warp:3.0.0",
  "name": "Form: Create",
  "title": {
    "en": "Create a form",
    "de": "Formular erstellen"
  },
  "description": {
    "en": "Create a new form. After creating, use 'Add Field' to define the inputs.",
    "de": "Ein neues Formular erstellen. Danach mit 'Feld hinzufügen' die Felder definieren."
  },
  "bot": "Use this to create a new form. After creating, use form-field-add to add each field one by one.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create form",
        "de": "Formular erstellen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/warps",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Brand",
          "as": "brand",
          "bot": "Always 'form'.",
          "type": "string",
          "position": "arg:0",
          "source": "field",
          "required": true,
          "default": "form"
        },
        {
          "name": "Name",
          "as": "definition.name",
          "bot": "Internal name of the form, same as the English title.",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "Title",
          "as": "definition.title.en",
          "description": {
            "en": "Form title shown to submitters",
            "de": "Formulartitel für Einreichende"
          },
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        },
        {
          "name": "Title (DE)",
          "as": "definition.title.de",
          "description": {
            "en": "German translation of the title",
            "de": "Deutsche Übersetzung des Titels"
          },
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": false
        },
        {
          "name": "Description",
          "as": "definition.description.en",
          "description": {
            "en": "Short description of the form's purpose",
            "de": "Kurze Beschreibung des Formularszwecks"
          },
          "type": "string",
          "position": "arg:4",
          "source": "field",
          "required": false
        },
        {
          "name": "Submit Label",
          "as": "definition.actions.0.label.en",
          "description": {
            "en": "Text on the submit button",
            "de": "Text auf dem Absende-Button"
          },
          "bot": "Default: 'Submit'",
          "type": "string",
          "position": "arg:5",
          "source": "field",
          "required": true,
          "default": "Submit"
        },
        {
          "name": "Submit Label (DE)",
          "as": "definition.actions.0.label.de",
          "description": {
            "en": "German translation of the submit label",
            "de": "Deutsche Übersetzung des Absende-Buttons"
          },
          "bot": "Default: 'Absenden'",
          "type": "string",
          "position": "arg:6",
          "source": "field",
          "required": false,
          "default": "Absenden"
        },
        {
          "name": "Success Message",
          "as": "definition.messages.success.en",
          "description": {
            "en": "Message shown after successful submission",
            "de": "Nachricht nach erfolgreicher Einreichung"
          },
          "bot": "Default: 'Thanks! We\\'ll be in touch soon.'",
          "type": "string",
          "position": "arg:7",
          "source": "field",
          "required": true,
          "default": "Thanks! We'll be in touch soon."
        },
        {
          "name": "Success Message (DE)",
          "as": "definition.messages.success.de",
          "description": {
            "en": "German translation of the success message",
            "de": "Deutsche Übersetzung der Erfolgsmeldung"
          },
          "bot": "Default: 'Danke! Wir melden uns bald.'",
          "type": "string",
          "position": "arg:8",
          "source": "field",
          "required": false,
          "default": "Danke! Wir melden uns bald."
        },
        {
          "name": "Action Type",
          "as": "definition.actions.0.type",
          "bot": "Always 'collect'.",
          "type": "string",
          "position": "arg:9",
          "source": "field",
          "required": true,
          "default": "collect"
        }
      ]
    }
  ],
  "output": {
    "FORM_ID": "out.data.id",
    "FORM_URL": "out.data.url"
  },
  "next": "form/field-add?formId={{FORM_ID}}",
  "messages": {
    "success": {
      "en": "Form created! Your public link: {{FORM_URL}}",
      "de": "Formular erstellt! Dein öffentlicher Link: {{FORM_URL}}"
    }
  }
}
