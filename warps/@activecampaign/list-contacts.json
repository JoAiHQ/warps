{
  "protocol": "warp:3.0.0",
  "name": "ActiveCampaign: List Contacts",
  "title": {
    "en": "List contacts",
    "de": "Kontakte auflisten",
    "es": "List contacts",
    "fr": "List contacts",
    "ro": "List contacts",
    "it": "List contacts"
  },
  "description": {
    "en": "List contacts in ActiveCampaign.",
    "de": "Liste Kontakte in ActiveCampaign auf.",
    "es": "List contacts in ActiveCampaign.",
    "fr": "List contacts in ActiveCampaign.",
    "ro": "List contacts in ActiveCampaign.",
    "it": "List contacts in ActiveCampaign."
  },
  "vars": {
    "API_URL": "env:ACTIVECAMPAIGN_API_URL|Your API URL (e.g., https://account.api-us1.com).",
    "API_TOKEN": "env:ACTIVECAMPAIGN_API_TOKEN|Your API Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Contacts",
      "destination": {
        "url": "{{API_URL}}/api/3/contacts",
        "method": "GET",
        "headers": {
          "Api-Token": "{{API_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Limit",
          "as": "limit",
          "description": {
            "en": "Number of contacts to return.",
            "es": "Number of contacts to return.",
            "fr": "Number of contacts to return.",
            "ro": "Number of contacts to return.",
            "it": "Number of contacts to return."
          },
          "type": "number",
          "source": "field",
          "required": false,
          "position": "query:limit",
          "default": 20
        },
        {
          "name": {
            "en": "Search",
            "de": "Search",
            "es": "Buscar",
            "fr": "Recherche",
            "ro": "Căutare",
            "it": "Ricerca"
          },
          "as": "search",
          "description": {
            "en": "Search term for filtering contacts.",
            "es": "Search term for filtering contacts.",
            "fr": "Search term for filtering contacts.",
            "ro": "Search term for filtering contacts.",
            "it": "Search term for filtering contacts."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "query:search"
        }
      ]
    }
  ],
  "output": {
    "CONTACTS": "out.contacts",
    "COUNT": "out.meta.total"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} contact(s).",
      "de": "{{COUNT}} Kontakt(e) gefunden.",
      "es": "Found {{COUNT}} contact(s).",
      "fr": "Found {{COUNT}} contact(s).",
      "ro": "Found {{COUNT}} contact(s).",
      "it": "Found {{COUNT}} contact(s)."
    }
  }
}
