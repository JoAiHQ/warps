{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "Chess: My Games",
  "title": {
    "en": "My Chess Games",
    "de": "Meine Schachspiele"
  },
  "description": {
    "en": "View all your chess games on MultiversX. See active games waiting for your move, ongoing matches, and completed games with results.",
    "de": "Sieh alle deine Schachspiele auf MultiversX. Aktive Spiele, die auf deinen Zug warten, laufende Partien und beendete Spiele mit Ergebnissen."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:CHESS_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading games...",
        "de": "Spiele werden geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getPlayerGames",
      "args": [
        "{{PLAYER}}"
      ],
      "inputs": [
        {
          "name": "PLAYER",
          "type": "address",
          "position": "arg:1",
          "source": "field",
          "default": "{{USER_WALLET}}",
          "description": {
            "en": "Your wallet address",
            "de": "Deine Wallet-Adresse"
          }
        }
      ],
      "auto": true,
      "abi": "INJECT:../contract/output/chess.abi.json"
    }
  ],
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/@chess/list/chatapp.36db95b.dist.html",
  "messages": {
    "success": {
      "en": "Games loaded",
      "de": "Spiele geladen"
    }
  },
  "related": [
    "@chess-create",
    "@chess-game"
  ]
}