{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "Chess: Resign",
  "title": {
    "en": "Resign from Game",
    "de": "Spiel aufgeben"
  },
  "description": {
    "en": "Resign from an active chess game on MultiversX. Your opponent wins immediately and the result is recorded on-chain.",
    "de": "Gib ein aktives Schachspiel auf MultiversX auf. Dein Gegner gewinnt sofort und das Ergebnis wird On-Chain gespeichert."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:CHESS_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Resign",
        "de": "Aufgeben"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "resignGame",
      "args": [
        "u64:{{GAME_ID}}"
      ],
      "inputs": [
        {
          "name": "GAME_ID",
          "type": "uint64",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "description": {
            "en": "The game ID to resign from",
            "de": "Die Spiel-ID zum Aufgeben"
          }
        }
      ],
      "gasLimit": 10000000
    }
  ],
  "output": {
    "TX_HASH": "out"
  },
  "messages": {
    "success": {
      "en": "You resigned from game {{GAME_ID}}",
      "de": "Du hast Spiel {{GAME_ID}} aufgegeben"
    }
  },
  "related": ["@chess-game", "@chess-list"]
}
