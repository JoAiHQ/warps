{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "Chess: Open Games",
  "title": {
    "en": "Open Chess Games",
    "de": "Offene Schachspiele"
  },
  "description": {
    "en": "Browse chess games on MultiversX that are waiting for an opponent. Join any open game to start playing immediately as black.",
    "de": "Durchsuche Schachspiele auf MultiversX, die auf einen Gegner warten. Tritt einem offenen Spiel bei, um sofort als Schwarz zu spielen."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:CHESS_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading open games...",
        "de": "Offene Spiele werden geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getOpenGames",
      "args": [],
      "inputs": [],
      "auto": true,
      "abi": "INJECT:../contract/output/chess.abi.json"
    }
  ],
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/@chess/open-games/chatapp.c5f69024.dist.html",
  "messages": {
    "success": {
      "en": "Open games loaded",
      "de": "Offene Spiele geladen"
    }
  },
  "related": [
    "@chess-join",
    "@chess-create"
  ]
}