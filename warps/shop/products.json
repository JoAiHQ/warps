{
  "protocol": "warp:3.0.0",
  "name": "Shop: Products",
  "title": {
    "en": "{{SHOP_NAME}} — Products",
    "de": "{{SHOP_NAME}} — Produkte"
  },
  "description": {
    "en": "Browse available products and make a purchase.",
    "de": "Verfügbare Produkte ansehen und kaufen."
  },
  "bot": "Shows all products offered by the shop. SHOP_ID from query param or JOAI_WARP_BRAND.",
  "chain": "multiversx",
  "vars": {
    "SHOP_ID": "query:id",
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading products...",
        "de": "Produkte werden geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getProducts",
      "inputs": [
        {
          "name": "SHOP_ID",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{JOAI_WARP_BRAND}}",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:contract/output/shop.abi.json"
    }
  ],
  "output": {
    "PRODUCTS": "out.1"
  },
  "messages": {
    "success": {
      "en": "Products loaded.",
      "de": "Produkte geladen."
    }
  }
}
