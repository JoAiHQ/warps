{
  "protocol": "warp:3.0.0",
  "name": "Shop: Set Payment Destination",
  "title": {
    "en": "Set payment destination",
    "de": "Zahlungsziel festlegen"
  },
  "description": {
    "en": "Configure where you receive payments. Supports any chain.",
    "de": "Konfiguriere, wohin du Zahlungen erhältst. Unterstützt jede Chain."
  },
  "bot": "Sets the payment destination for the shop — chain, wallet address, and accepted token.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Set payment destination",
        "de": "Zahlungsziel festlegen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "setPaymentDestination",
      "inputs": [
        {
          "name": "ID",
          "as": "id",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{JOAI_WARP_BRAND}}",
          "required": true
        },
        {
          "name": "Chain",
          "as": "chain",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "description": {
            "en": "Payment chain (e.g. multiversx, solana, base, ethereum)",
            "de": "Zahlungs-Chain (z.B. multiversx, solana, base, ethereum)"
          }
        },
        {
          "name": "Address",
          "as": "address",
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "description": {
            "en": "Your wallet address on that chain",
            "de": "Deine Wallet-Adresse auf dieser Chain"
          }
        },
        {
          "name": "Token",
          "as": "token",
          "type": "string",
          "position": "arg:4",
          "source": "field",
          "required": true,
          "description": {
            "en": "Accepted token (e.g. USDC, EGLD, SOL)",
            "de": "Akzeptierter Token (z.B. USDC, EGLD, SOL)"
          }
        }
      ],
      "gasLimit": 10000000,
      "abi": "INJECT:contract/output/shop.abi.json"
    }
  ],
  "messages": {
    "success": {
      "en": "Payment destination set! Now add products or services.",
      "de": "Zahlungsziel eingerichtet! Füge jetzt Produkte oder Dienstleistungen hinzu."
    }
  },
  "next": "shop-product-add"
}
