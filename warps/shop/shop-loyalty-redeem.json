{
  "protocol": "warp:3.0.0",
  "name": "Shop: Loyalty Redeem Reward",
  "title": {
    "en": "Redeem Reward",
    "de": "Belohnung einlösen"
  },
  "description": {
    "en": "Redeem a customer's loyalty reward and reset their stamps.",
    "de": "Löse die Treuebelohnung eines Kunden ein und setze die Stempel zurück."
  },
  "bot": "Redeems reward via NFC. Log redemption activity on contact after success.",
  "chain": "multiversx",
  "vars": {
    "SHOP_ID": "query:SHOP_ID",
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Checking reward...",
        "de": "Belohnung wird überprüft..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getStatus",
      "args": [
        "uint64:{{SHOP_ID}}"
      ],
      "inputs": [
        {
          "name": "JOAI_TAG_ID",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        }
      ],
      "auto": true
    },
    {
      "type": "contract",
      "label": {
        "en": "Redeem reward",
        "de": "Belohnung einlösen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "redeemReward",
      "args": [
        "uint64:{{SHOP_ID}}",
        "string:{{JOAI_TAG_ID}}"
      ],
      "gasLimit": 10000000
    }
  ],
  "output": {
    "NAME": "out.1.name"
  },
  "messages": {
    "success": {
      "en": "Reward redeemed for {{NAME}}! Stamps reset to 0.",
      "de": "Belohnung für {{NAME}} eingelöst! Stempel auf 0 zurückgesetzt."
    }
  }
}
