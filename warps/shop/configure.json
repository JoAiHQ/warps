{
  "protocol": "warp:3.0.0",
  "name": "Shop: Configure",
  "title": {
    "en": "Update shop details",
    "de": "Shop-Details aktualisieren"
  },
  "description": {
    "en": "Update your shop's category, location, description, and more.",
    "de": "Aktualisiere Kategorie, Standort, Beschreibung und mehr deines Shops."
  },
  "bot": "Updates the shop metadata — category, location, description, image, website.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Update shop",
        "de": "Shop aktualisieren"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "updateShop",
      "inputs": [
        {
          "name": "Slug",
          "as": "slug",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{JOAI_WARP_BRAND}}",
          "required": true
        },
        {
          "name": "Category",
          "as": "category",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        },
        {
          "name": "Location",
          "as": "location",
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": true
        },
        {
          "name": "Description",
          "as": "description",
          "type": "string",
          "position": "arg:4",
          "source": "field"
        },
        {
          "name": "Image URL",
          "as": "image_url",
          "type": "string",
          "position": "arg:5",
          "source": "field"
        },
        {
          "name": "Website",
          "as": "website",
          "type": "string",
          "position": "arg:6",
          "source": "field"
        }
      ],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/shop.abi.json"
    }
  ],
  "messages": {
    "success": {
      "en": "Shop updated!",
      "de": "Shop aktualisiert!"
    }
  }
}
