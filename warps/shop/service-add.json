{
  "protocol": "warp:3.0.0",
  "name": "Shop: Add Service",
  "title": {
    "en": "Add service",
    "de": "Dienstleistung hinzufügen",
    "fr": "Ajouter un service",
    "es": "Anadir servicio",
    "ro": "Adauga serviciu"
  },
  "description": {
    "en": "Add a service to your shop — name, price, and duration.",
    "de": "Füge eine Dienstleistung hinzu — Name, Preis und Dauer.",
    "fr": "Ajoutez un service a votre boutique : nom, prix et duree.",
    "es": "Anade un servicio a tu tienda: nombre, precio y duracion.",
    "ro": "Adauga un serviciu in magazin: nume, pret si durata."
  },
  "bot": "Adds a service to the shop on-chain. Use slug as a short unique identifier (e.g. haircut, color-treatment).",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Add service",
        "de": "Dienstleistung hinzufügen",
        "fr": "Ajouter le service",
        "es": "Anadir servicio",
        "ro": "Adauga serviciul"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "addService",
      "inputs": [
        {
          "name": "SHOP_SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{JOAI_WARP_BRAND}}",
          "required": true
        },
        {
          "name": "Slug",
          "as": "serviceSlug",
          "description": {
            "en": "Short unique ID for this service (e.g. haircut)",
            "de": "Kurze eindeutige ID für diese Dienstleistung (z.B. haarschnitt)",
            "fr": "Identifiant court et unique pour ce service (par ex. coupe-cheveux)",
            "es": "ID corta y unica para este servicio (p. ej. corte-pelo)",
            "ro": "ID scurt si unic pentru acest serviciu (de ex. tuns)"
          },
          "bot": "Short slug for the service, lowercase, dashes only.",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        },
        {
          "name": "Name",
          "as": "name",
          "description": {
            "en": "Service name (e.g. Haircut)",
            "de": "Name der Dienstleistung (z.B. Haarschnitt)",
            "fr": "Nom du service (par ex. Coupe)",
            "es": "Nombre del servicio (p. ej. corte de pelo)",
            "ro": "Numele serviciului (de ex. tuns)"
          },
          "bot": "Display name for the service.",
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": true
        },
        {
          "name": "Price (cents)",
          "as": "priceCents",
          "description": {
            "en": "Price in cents (e.g. 2500 = €25.00)",
            "de": "Preis in Cent (z.B. 2500 = 25,00 €)",
            "fr": "Prix en centimes (par ex. 2500 = 25,00 EUR)",
            "es": "Precio en centimos (p. ej. 2500 = 25,00 EUR)",
            "ro": "Pret in centi (de ex. 2500 = 25,00 EUR)"
          },
          "bot": "Price in smallest currency unit (cents). Use 0 for free.",
          "type": "uint64",
          "position": "arg:4",
          "source": "field",
          "required": true
        },
        {
          "name": "Duration (minutes)",
          "as": "durationMinutes",
          "description": {
            "en": "How long does this service take? (e.g. 30)",
            "de": "Wie lange dauert diese Dienstleistung? (z.B. 30)",
            "fr": "Combien de temps dure ce service ? (par ex. 30)",
            "es": "Cuanto dura este servicio? (p. ej. 30)",
            "ro": "Cat dureaza acest serviciu? (de ex. 30)"
          },
          "bot": "Duration in minutes.",
          "type": "uint32",
          "position": "arg:5",
          "source": "field",
          "required": true
        },
        {
          "name": "Category",
          "as": "category",
          "description": {
            "en": "Optional category (e.g. hair, nails)",
            "de": "Optionale Kategorie (z.B. Haare, Nägel)",
            "fr": "Categorie facultative (par ex. cheveux, ongles)",
            "es": "Categoria opcional (p. ej. pelo, unas)",
            "ro": "Categorie optionala (de ex. par, unghii)"
          },
          "bot": "Category label, optional.",
          "type": "string",
          "position": "arg:6",
          "source": "field",
          "required": false
        }
      ],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/shop.abi.json"
    }
  ],
  "messages": {
    "success": {
      "en": "Service added to your shop.",
      "de": "Dienstleistung zum Shop hinzugefügt.",
      "fr": "Service ajoute a votre boutique.",
      "es": "Servicio anadido a tu tienda.",
      "ro": "Serviciul a fost adaugat in magazin."
    }
  }
}
