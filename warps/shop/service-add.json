{
  "protocol": "warp:3.0.0",
  "name": "Shop: Add Service",
  "title": {
    "en": "Add service",
    "de": "Dienstleistung hinzufügen"
  },
  "description": {
    "en": "Add a service to your shop — name, price, duration, and description.",
    "de": "Füge eine Dienstleistung hinzu — Name, Preis, Dauer und Beschreibung."
  },
  "bot": "Adds a service to the shop on-chain. Use slug as a short unique identifier (e.g. haircut, spa-60min).",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Add service",
        "de": "Dienstleistung hinzufügen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "addService",
      "inputs": [
        {
          "name": "Shop ID",
          "as": "id",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{JOAI_WARP_BRAND}}",
          "required": true
        },
        {
          "name": "Slug",
          "as": "service_slug",
          "description": {
            "en": "Short unique ID (e.g. haircut, spa-60min)",
            "de": "Kurze eindeutige ID (z.B. haarschnitt, spa-60min)"
          },
          "bot": "Short slug, lowercase, dashes only.",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        },
        {
          "name": "Name",
          "as": "name",
          "description": {
            "en": "Service name",
            "de": "Name der Dienstleistung"
          },
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": true
        },
        {
          "name": "Price",
          "as": "price",
          "description": {
            "en": "Price in token micro-units (e.g. 25000000 = 25 USDC)",
            "de": "Preis in Token-Mikroeinheiten (z.B. 25000000 = 25 USDC)"
          },
          "bot": "Price in smallest token unit. For USDC (6 decimals): multiply by 1000000.",
          "type": "uint64",
          "position": "arg:4",
          "source": "field",
          "required": true
        },
        {
          "name": "Duration (minutes)",
          "as": "duration_minutes",
          "description": {
            "en": "How long does this service take?",
            "de": "Wie lange dauert diese Dienstleistung?"
          },
          "type": "uint32",
          "position": "arg:5",
          "source": "field",
          "required": true
        },
        {
          "name": "Category",
          "as": "category",
          "description": {
            "en": "Category (e.g. hair, spa, fitness)",
            "de": "Kategorie (z.B. Haare, Spa, Fitness)"
          },
          "type": "string",
          "position": "arg:6",
          "source": "field"
        },
        {
          "name": "Description",
          "as": "description",
          "description": {
            "en": "Service description",
            "de": "Beschreibung der Dienstleistung"
          },
          "type": "string",
          "position": "arg:7",
          "source": "field"
        }
      ],
      "gasLimit": 10000000,
      "abi": "INJECT:contract/output/shop.abi.json"
    }
  ],
  "messages": {
    "success": {
      "en": "Service added to your shop.",
      "de": "Dienstleistung zum Shop hinzugefügt."
    }
  }
}
