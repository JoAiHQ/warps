{
  "protocol": "warp:3.0.0",
  "name": "Shop: Remove Service",
  "title": {
    "en": "Remove service",
    "de": "Dienstleistung entfernen",
    "fr": "Supprimer un service",
    "es": "Eliminar servicio",
    "ro": "Elimina serviciu"
  },
  "description": {
    "en": "Remove a service from your shop.",
    "de": "Entferne eine Dienstleistung aus deinem Shop.",
    "fr": "Supprimez un service de votre boutique.",
    "es": "Elimina un servicio de tu tienda.",
    "ro": "Elimina un serviciu din magazin."
  },
  "bot": "Removes a service from the shop on-chain by slug.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Remove service",
        "de": "Dienstleistung entfernen",
        "fr": "Supprimer le service",
        "es": "Eliminar servicio",
        "ro": "Elimina serviciul"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "removeService",
      "inputs": [
        {
          "name": "id",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{JOAI_WARP_BRAND}}",
          "required": true
        },
        {
          "name": "Service slug",
          "as": "service_slug",
          "description": {
            "en": "Slug of the service to remove",
            "de": "Slug der zu entfernenden Dienstleistung",
            "fr": "Slug du service a supprimer",
            "es": "Slug del servicio que quieres eliminar",
            "ro": "Slugul serviciului care trebuie eliminat"
          },
          "bot": "The slug of the service to remove.",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        }
      ],
      "gasLimit": 10000000,
      "abi": "INJECT:contract/output/shop.abi.json"
    }
  ],
  "messages": {
    "success": {
      "en": "Service removed from your shop.",
      "de": "Dienstleistung aus dem Shop entfernt.",
      "fr": "Service supprime de votre boutique.",
      "es": "Servicio eliminado de tu tienda.",
      "ro": "Serviciul a fost eliminat din magazin."
    }
  }
}
