{
  "protocol": "warp:3.0.0",
  "name": "Shop: Remove Product",
  "title": {
    "en": "Remove product",
    "de": "Produkt entfernen"
  },
  "description": {
    "en": "Remove a product from your shop.",
    "de": "Entferne ein Produkt aus deinem Shop."
  },
  "bot": "Removes a product from the shop on-chain by slug.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Remove product",
        "de": "Produkt entfernen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "removeProduct",
      "inputs": [
        {
          "name": "Shop ID",
          "as": "id",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{JOAI_WARP_BRAND}}",
          "required": true
        },
        {
          "name": "Product slug",
          "as": "product_slug",
          "description": {
            "en": "Slug of the product to remove",
            "de": "Slug des zu entfernenden Produkts"
          },
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        }
      ],
      "gasLimit": 10000000,
      "abi": "INJECT:contract/output/shop.abi.json"
    }
  ],
  "messages": {
    "success": {
      "en": "Product removed from your shop.",
      "de": "Produkt aus dem Shop entfernt."
    }
  }
}
