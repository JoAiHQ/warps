{
  "protocol": "warp:3.0.0",
  "name": "Shop: Register",
  "title": {
    "en": "Register shop",
    "de": "Shop registrieren"
  },
  "description": {
    "en": "Register your shop on-chain with category, location, and details.",
    "de": "Registriere deinen Shop on-chain mit Kategorie, Standort und Details."
  },
  "bot": "Registers the shop on-chain with full metadata. Run once to set up.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Register shop",
        "de": "Shop registrieren"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "registerShop",
      "inputs": [
        {
          "name": "Slug",
          "as": "slug",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{JOAI_WARP_BRAND}}",
          "required": true
        },
        {
          "name": "Category",
          "as": "category",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "description": {
            "en": "Shop category (e.g. hotel, restaurant, clinic, coach)",
            "de": "Shop-Kategorie (z.B. hotel, restaurant, klinik, coach)"
          }
        },
        {
          "name": "Location",
          "as": "location",
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "description": {
            "en": "City and country (e.g. Vienna, AT)",
            "de": "Stadt und Land (z.B. Wien, AT)"
          }
        },
        {
          "name": "Description",
          "as": "description",
          "type": "string",
          "position": "arg:4",
          "source": "field",
          "description": {
            "en": "Short description of your shop",
            "de": "Kurze Beschreibung deines Shops"
          }
        },
        {
          "name": "Image URL",
          "as": "image_url",
          "type": "string",
          "position": "arg:5",
          "source": "field",
          "description": {
            "en": "URL to shop image or logo",
            "de": "URL zu Shop-Bild oder Logo"
          }
        },
        {
          "name": "Website",
          "as": "website",
          "type": "string",
          "position": "arg:6",
          "source": "field",
          "description": {
            "en": "Shop website URL",
            "de": "Shop-Website-URL"
          }
        }
      ],
      "gasLimit": 15000000,
      "abi": "INJECT:abis/shop.abi.json"
    }
  ],
  "messages": {
    "success": {
      "en": "Shop registered! Set up your payment destination next.",
      "de": "Shop registriert! Richte als Nächstes dein Zahlungsziel ein."
    }
  },
  "next": "shop-set-payment"
}
