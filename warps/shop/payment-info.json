{
  "protocol": "warp:3.0.0",
  "name": "Shop: Payment Info",
  "title": {
    "en": "Get payment info",
    "de": "Zahlungsinfo abrufen"
  },
  "description": {
    "en": "Get the payment destination for a shop — chain, address, and accepted token.",
    "de": "Zahlungsziel eines Shops abrufen — Chain, Adresse und akzeptierter Token."
  },
  "bot": "Retrieves the shop's payment destination. Use this to know which chain, address, and token to pay with before making a purchase.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Get payment info",
        "de": "Zahlungsinfo abrufen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getPaymentDestination",
      "inputs": [
        {
          "name": "Shop ID",
          "as": "id",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "description": {
            "en": "Shop ID",
            "de": "Shop-ID"
          }
        }
      ],
      "abi": "INJECT:contract/output/shop.abi.json"
    }
  ],
  "output": {
    "CHAIN": "out.1.chain",
    "ADDRESS": "out.1.address",
    "TOKEN": "out.1.token"
  }
}
