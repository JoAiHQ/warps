{
  "protocol": "warp:3.0.0",
  "name": "Shop: Search",
  "title": {
    "en": "Search shops",
    "de": "Shops suchen"
  },
  "description": {
    "en": "Search registered shops by category.",
    "de": "Registrierte Shops nach Kategorie suchen."
  },
  "bot": "Searches the on-chain shop registry by category. Returns shop slug, name, location, and description for each match.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Search shops",
        "de": "Shops suchen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getShopsByCategory",
      "inputs": [
        {
          "name": "Category",
          "as": "category",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "description": {
            "en": "Category to search (e.g. hotel, restaurant, clinic)",
            "de": "Kategorie zum Suchen (z.B. hotel, restaurant, klinik)"
          }
        },
        {
          "name": "Offset",
          "as": "offset",
          "type": "number",
          "position": "arg:2",
          "source": "hidden",
          "default": "0"
        },
        {
          "name": "Limit",
          "as": "limit",
          "type": "number",
          "position": "arg:3",
          "source": "hidden",
          "default": "10"
        }
      ],
      "abi": "INJECT:abis/shop.abi.json"
    }
  ],
  "output": {
    "SHOPS": "out.1"
  }
}
