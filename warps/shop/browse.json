{
  "protocol": "warp:3.0.0",
  "name": "Shop: Browse Products",
  "title": {
    "en": "Browse shop products",
    "de": "Shop-Produkte durchsuchen"
  },
  "description": {
    "en": "View all products available in a shop.",
    "de": "Alle verfügbaren Produkte eines Shops anzeigen."
  },
  "bot": "Retrieves the full product catalog for a shop. Returns product slug, name, price, category, description, and stock status.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Browse products",
        "de": "Produkte durchsuchen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getProducts",
      "inputs": [
        {
          "name": "Shop ID",
          "as": "id",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "description": {
            "en": "Shop ID to browse",
            "de": "Shop-ID zum Durchsuchen"
          }
        }
      ],
      "abi": "INJECT:contract/output/shop.abi.json"
    }
  ],
  "output": {
    "PRODUCTS": "out.1"
  }
}
