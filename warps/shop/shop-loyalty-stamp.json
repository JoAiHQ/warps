{
  "protocol": "warp:3.0.0",
  "name": "Shop: Loyalty Stamp",
  "title": {
    "en": "Add Stamp",
    "de": "Stempel hinzufügen"
  },
  "description": {
    "en": "Scan a customer's loyalty card to add a stamp and track their reward progress. Automatically shows the current stamp count and notifies when a reward is ready to be redeemed.",
    "de": "Scanne die Treuekarte eines Kunden, um einen Stempel hinzuzufügen und den Prämienfortschritt zu verfolgen. Zeigt automatisch den aktuellen Stempelstand an und informiert, wenn eine Prämie eingelöst werden kann."
  },
  "bot": "Adds stamp via NFC. Log visit activity on contact after success.",
  "chain": "multiversx",
  "vars": {
    "SHOP_ID": "query:SHOP_ID",
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Looking up customer...",
        "de": "Kunde wird gesucht..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getStatus",
      "args": [
        "uint64:{{SHOP_ID}}",
        "string:{{JOAI_TAG_ID}}"
      ],
      "inputs": [
        {
          "name": "JOAI_TAG_ID",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:abis/shop.abi.json"
    },
    {
      "type": "contract",
      "label": {
        "en": "Add stamp",
        "de": "Stempel hinzufügen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "addStamp",
      "args": [
        "uint64:{{SHOP_ID}}",
        "string:{{JOAI_TAG_ID}}"
      ],
      "gasLimit": 10000000,
      "auto": true,
      "abi": "INJECT:abis/shop.abi.json"
    }
  ],
  "output": {
    "NAME": "out.1.name",
    "STAMPS": "out.1.stamps",
    "NEEDED": "out.1.stamps_for_reward",
    "DISCOUNT": "out.1.discount",
    "REWARD_READY": "out.1.reward_ready"
  },
  "messages": {
    "success": {
      "en": "{{NAME}} — {{STAMPS}}/{{NEEDED}} stamps",
      "de": "{{NAME}} — {{STAMPS}}/{{NEEDED}} Stempel"
    }
  }
}
