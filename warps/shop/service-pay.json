{
  "protocol": "warp:3.0.0",
  "name": "Shop: Book & Pay Service",
  "title": {
    "en": "{{SERVICE_NAME}}",
    "de": "{{SERVICE_NAME}}"
  },
  "description": {
    "en": "{{SERVICE_DESCRIPTION}}",
    "de": "{{SERVICE_DESCRIPTION}}"
  },
  "bot": "Shows a service offered by a shop with name, price, duration, and a pay button. SHOP_ID and SERVICE_SLUG from query params.",
  "chain": "multiversx",
  "vars": {
    "SHOP_ID": "query:shop",
    "SERVICE_SLUG": "query:service",
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading...",
        "de": "Wird geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getServiceWithPayment",
      "args": [
        "string:{{SHOP_ID}}",
        "string:{{SERVICE_SLUG}}"
      ],
      "inputs": [
        {
          "name": "SHOP_ID",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{JOAI_WARP_BRAND}}",
          "required": true
        },
        {
          "name": "SERVICE_SLUG",
          "type": "string",
          "position": "arg:2",
          "source": "hidden",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:contract/output/shop.abi.json"
    },
    {
      "type": "transfer",
      "label": {
        "en": "Pay now",
        "de": "Jetzt bezahlen"
      },
      "inputs": [
        {
          "name": "Chain",
          "as": "chain",
          "type": "string",
          "position": "chain",
          "source": "hidden",
          "default": "{{PAY_CHAIN}}",
          "required": true
        },
        {
          "name": "Receiver",
          "as": "receiver",
          "type": "address",
          "position": "receiver",
          "source": "hidden",
          "default": "{{PAY_ADDRESS}}",
          "required": true
        },
        {
          "name": "Asset",
          "as": "asset",
          "type": "asset",
          "position": "transfer",
          "source": "hidden",
          "default": "{{PAY_TOKEN}}|{{SERVICE_PRICE}}",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "SERVICE_NAME": "out.1.name",
    "SERVICE_PRICE": "out.1.price",
    "SERVICE_DESCRIPTION": "out.1.description",
    "SERVICE_DURATION": "out.1.duration_minutes",
    "PAY_CHAIN": "out.2.chain",
    "PAY_ADDRESS": "out.2.address",
    "PAY_TOKEN": "out.2.token"
  },
  "messages": {
    "success": {
      "en": "Payment sent for {{SERVICE_NAME}}!",
      "de": "Zahlung für {{SERVICE_NAME}} gesendet!"
    }
  }
}
