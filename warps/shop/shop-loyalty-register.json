{
  "protocol": "warp:3.0.0",
  "name": "Shop: Loyalty Register",
  "title": {
    "en": "Join our loyalty program!",
    "de": "Tritt unserem Treueprogramm bei!"
  },
  "description": {
    "en": "Register your loyalty card and start earning stamps towards free rewards.",
    "de": "Registriere deine Treuekarte und sammle Stempel für kostenlose Belohnungen."
  },
  "bot": "Registers NFC card on-chain. If already registered, redirects to status.",
  "chain": "multiversx",
  "vars": {
    "SHOP_ID": "query:shop",
    "SC_ADDRESS": "INJECT:SHOP_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Checking card...",
        "de": "Karte wird überprüft..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "isCardRegistered",
      "args": [
        "uint64:{{SHOP_ID}}"
      ],
      "inputs": [
        {
          "name": "JOAI_TAG_ID",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        }
      ],
      "auto": true,
      "next": {
        "success": "shop-loyalty-status?shop={{SHOP_ID}}&JOAI_TAG_ID={{JOAI_TAG_ID}}"
      }
    },
    {
      "type": "query",
      "label": {
        "en": "Loading shop...",
        "de": "Shop wird geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getShopInfo",
      "args": [
        "uint64:{{SHOP_ID}}"
      ],
      "auto": true
    },
    {
      "type": "collect",
      "label": {
        "en": "Register",
        "de": "Registrieren"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/contacts",
        "method": "POST"
      },
      "inputs": [
        {
          "name": "Name",
          "as": "name",
          "description": {
            "en": "Your name",
            "de": "Dein Name"
          },
          "bot": "Customer name.",
          "type": "string",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Email",
          "as": "email",
          "description": {
            "en": "Your email address",
            "de": "Deine E-Mail-Adresse"
          },
          "bot": "Customer email.",
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Phone",
          "as": "phone",
          "description": {
            "en": "Your phone number (optional)",
            "de": "Deine Telefonnummer (optional)"
          },
          "bot": "Optional.",
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Card",
          "as": "card",
          "type": "string",
          "source": "hidden",
          "default": "{{JOAI_TAG_ID}}",
          "position": "payload:props"
        }
      ]
    },
    {
      "type": "contract",
      "label": {
        "en": "Activate card",
        "de": "Karte aktivieren"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "register",
      "args": [
        "uint64:{{SHOP_ID}}",
        "string:{{JOAI_TAG_ID}}",
        "string:{{name}}"
      ],
      "gasLimit": 10000000,
      "auto": true
    }
  ],
  "output": {
    "IS_REGISTERED": "out.1",
    "SHOP_NAME": "out.2.name"
  },
  "messages": {
    "success": {
      "en": "Welcome to {{SHOP_NAME}}, {{name}}! Your first stamp has been earned.",
      "de": "Willkommen bei {{SHOP_NAME}}, {{name}}! Dein erster Stempel wurde gesammelt."
    }
  },
  "next": "shop-loyalty-review?shop={{SHOP_ID}}&JOAI_TAG_ID={{JOAI_TAG_ID}}"
}
