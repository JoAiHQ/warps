{
  "protocol": "warp:3.0.0",
  "name": "#wacli: Send Text",
  "title": {
    "en": "Send WhatsApp Message",
    "de": "WhatsApp-Nachricht senden"
  },
  "description": {
    "en": "Send a text message via WhatsApp using wacli.",
    "de": "Eine Textnachricht über WhatsApp mit wacli senden."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Send",
        "de": "Senden"
      },
      "prompt": "/wacli send text --to \"{{PHONE}}\" --message \"{{MESSAGE}}\"",
      "inputs": [
        {
          "name": "Phone",
          "as": "PHONE",
          "description": {
            "en": "Recipient phone number with country code (e.g. +43660...)",
            "de": "Telefonnummer mit Ländervorwahl (z.B. +43660...)"
          },
          "type": "string",
          "source": "field",
          "required": true,
          "modifier": "transform:(value) => value.replace(/^\\+/, '')"
        },
        {
          "name": "Message",
          "as": "MESSAGE",
          "description": {
            "en": "The message text to send",
            "de": "Der zu sendende Nachrichtentext"
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Message sent to {{PHONE}}.",
      "de": "Nachricht an {{PHONE}} gesendet."
    },
    "error": {
      "en": "Failed to send message to {{PHONE}}.",
      "de": "Nachricht an {{PHONE}} konnte nicht gesendet werden."
    }
  }
}
