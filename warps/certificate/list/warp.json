{
  "protocol": "warp:3.0.0",
  "name": "Certificate: List",
  "title": {
    "en": "Certificates issued by me",
    "de": "Von mir ausgestellte Zertifikate",
    "fr": "Certificats émis par moi",
    "es": "Certificados emitidos por mí",
    "ro": "Certificate emise de mine"
  },
  "description": {
    "en": "View all digital certificates you have issued on the blockchain.",
    "de": "Alle digitalen Zertifikate ansehen, die du auf der Blockchain ausgestellt hast.",
    "fr": "Consultez tous les certificats numériques que vous avez émis sur la blockchain.",
    "es": "Ve todos los certificados digitales que has emitido en la blockchain.",
    "ro": "Vizualizează toate certificatele digitale pe care le-ai emis pe blockchain."
  },
  "bot": "List all certificates issued by the connected wallet.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:CERTIFICATE_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "auto": true,
      "label": {
        "en": "Load certificates",
        "de": "Zertifikate laden",
        "fr": "Charger les certificats",
        "es": "Cargar certificados",
        "ro": "Încarcă certificatele"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getCertsByIssuer",
      "abi": "INJECT:../contract/output/certificate.abi.json",
      "inputs": [
        {
          "name": "Issuer",
          "as": "issuer",
          "type": "address",
          "position": "arg:1",
          "source": "user:wallet",
          "required": true
        },
        {
          "name": "Offset",
          "as": "offset",
          "type": "uint32",
          "position": "arg:2",
          "source": "hidden",
          "default": 0
        },
        {
          "name": "Limit",
          "as": "limit",
          "type": "uint32",
          "position": "arg:3",
          "source": "hidden",
          "default": 50
        }
      ]
    }
  ],
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/certificate/list/chatapp.c19a72f.dist.html"
}