{
  "protocol": "warp:3.0.0",
  "name": "OpenAI (Codex CLI): Cancel Task",
  "title": {
    "en": "Cancel task (Codex)",
    "es": "Cancelar tarea (Codex)",
    "fr": "Annuler la tâche (Codex)",
    "ro": "Anulați sarcina (Codex)",
    "it": "Annulla attività (Codice)"
  },
  "description": {
    "en": "Request cancellation through Codex exec mode.",
    "es": "Solicitar cancelación a través del modo ejecutivo de Codex.",
    "fr": "Demander l'annulation via le mode exécutable du Codex.",
    "ro": "Solicitați anularea prin modul Codex exec.",
    "it": "Richiedi la cancellazione tramite la modalità Codex exec."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Cancel Task",
        "es": "Cancelar tarea",
        "fr": "Annuler la tâche",
        "ro": "Anulează sarcina",
        "it": "Annulla attività"
      },
      "prompt": "/codex exec --json \"$(cat <<'JOAI_PROMPT'\nFor run ID {{RUN_ID}}, stop work now and return only: cancel_requested.\nJOAI_PROMPT\n)\"",
      "inputs": [
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "Run identifier to cancel.",
            "es": "Ejecute el identificador para cancelar.",
            "fr": "Exécutez l'identifiant pour annuler.",
            "ro": "Rulați identificatorul pentru a anula.",
            "it": "Esegui identificatore per annullare."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "in.RUN_ID",
    "RUN_STATUS": "transform:() => 'cancel_requested'",
    "SUMMARY": "transform:() => 'Cancellation requested via Codex.'"
  },
  "messages": {
    "success": {
      "en": "Cancellation requested for {{RUN_ID}}.",
      "es": "Cancelación solicitada para {{RUN_ID}}.",
      "fr": "Annulation demandée pour {{RUN_ID}}.",
      "ro": "Anularea a fost solicitată pentru {{RUN_ID}}.",
      "it": "Cancellazione richiesta per {{RUN_ID}}."
    }
  }
}
