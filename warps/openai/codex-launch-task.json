{
  "protocol": "warp:3.0.0",
  "name": "OpenAI (Codex CLI): Launch Task",
  "title": {
    "en": "Launch task (Codex)"
  },
  "description": {
    "en": "Launch a task through Codex CLI non-interactive exec mode."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Launch Task"
      },
      "prompt": "/codex exec --json \"$(cat <<'JOAI_PROMPT'\nRun ID {{RUN_ID}}.\nExecute this task:\n{{TASK}}\nJOAI_PROMPT\n)\"",
      "inputs": [
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "Tracking run ID used by JoAi orchestration."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Task",
          "as": "TASK",
          "description": {
            "en": "Task instruction to execute with Codex CLI."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "in.RUN_ID",
    "RUN_STATUS": "transform:() => 'submitted'",
    "SUMMARY": "transform:() => 'Task submitted to Codex exec mode.'"
  },
  "messages": {
    "success": {
      "en": "Codex task submitted."
    }
  }
}
