{
  "protocol": "warp:3.0.0",
  "name": "OpenAI (Codex CLI): Add Follow-up",
  "title": {
    "en": "Add follow-up (Codex)",
    "es": "Añadir seguimiento (Codex)",
    "fr": "Ajouter un suivi (Codex)",
    "ro": "Adăugați continuare (Codex)",
    "it": "Aggiungi follow-up (Codice)"
  },
  "description": {
    "en": "Send a follow-up instruction through Codex exec mode.",
    "es": "Enviar una instrucción de seguimiento a través del modo ejecutivo de Codex.",
    "fr": "Envoyez une instruction de suivi via le mode exécutable du Codex.",
    "ro": "Trimiteți o instrucțiune ulterioară prin modul Codex exec.",
    "it": "Invia un'istruzione di follow-up tramite la modalità Codex exec."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Add Follow-up",
        "es": "Agregar seguimiento",
        "fr": "Ajouter un suivi",
        "ro": "Adăugați urmărire",
        "it": "Aggiungi follow-up"
      },
      "prompt": "/codex exec --json \"$(cat <<'JOAI_PROMPT'\nFor run ID {{RUN_ID}}, continue with this follow-up:\n{{FOLLOWUP}}\nJOAI_PROMPT\n)\"",
      "inputs": [
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "Run identifier to continue.",
            "es": "Ejecute el identificador para continuar.",
            "fr": "Exécutez l'identifiant pour continuer.",
            "ro": "Rulați identificatorul pentru a continua.",
            "it": "Esegui identificatore per continuare."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Follow-up",
          "as": "FOLLOWUP",
          "description": {
            "en": "Additional instruction for Codex.",
            "es": "Instrucción adicional para el Codex.",
            "fr": "Instruction supplémentaire pour le Codex.",
            "ro": "Instrucțiuni suplimentare pentru Codex.",
            "it": "Istruzioni aggiuntive per il Codice."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "in.RUN_ID",
    "RUN_STATUS": "transform:() => 'submitted'",
    "SUMMARY": "transform:() => 'Follow-up submitted via Codex.'"
  },
  "messages": {
    "success": {
      "en": "Follow-up submitted for {{RUN_ID}}.",
      "es": "Seguimiento enviado para {{RUN_ID}}.",
      "fr": "Suivi soumis pour {{RUN_ID}}.",
      "ro": "Urmărire trimisă pentru {{RUN_ID}}.",
      "it": "Follow-up inviato per {{RUN_ID}}."
    }
  }
}
