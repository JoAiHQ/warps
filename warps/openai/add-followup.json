{
  "protocol": "warp:3.0.0",
  "name": "OpenAI: Add Followup",
  "title": {
    "en": "Add followup"
  },
  "description": {
    "en": "Create a followup run continuing from a previous OpenAI run."
  },
  "vars": {
    "API_KEY": "env:OPENAI_API_KEY|OpenAI API key"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Add Followup"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/responses",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "Previous run ID to continue from."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:previous_response_id"
        },
        {
          "name": "Followup",
          "as": "FOLLOWUP",
          "description": {
            "en": "Followup instruction."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:input"
        },
        {
          "name": "Model",
          "as": "MODEL",
          "description": {
            "en": "OpenAI model to use."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "default": "gpt-5",
          "position": "payload:model"
        },
        {
          "name": "Background",
          "as": "BACKGROUND",
          "description": {
            "en": "Run asynchronously in background mode."
          },
          "type": "boolean",
          "source": "field",
          "required": false,
          "default": true,
          "position": "payload:background"
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "out.id",
    "RUN_STATUS": "out.status",
    "SUMMARY": "out.output_text"
  },
  "messages": {
    "success": {
      "en": "Created followup run {{RUN_ID}} with status {{RUN_STATUS}}."
    }
  }
}
