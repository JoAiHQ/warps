{
  "protocol": "warp:3.0.0",
  "name": "Calendly: List Scheduled Events",
  "title": {
    "en": "List scheduled events",
    "de": "Geplante Ereignisse auflisten",
    "es": "List scheduled events",
    "fr": "List scheduled events",
    "ro": "List scheduled events",
    "it": "List scheduled events"
  },
  "description": {
    "en": "List events scheduled for a user.",
    "de": "Liste geplante Ereignisse für einen Benutzer auf.",
    "es": "List events scheduled for a user.",
    "fr": "List events scheduled for a user.",
    "ro": "List events scheduled for a user.",
    "it": "List events scheduled for a user."
  },
  "vars": {
    "ACCESS_TOKEN": "env:CALENDLY_ACCESS_TOKEN|Your Calendly Personal Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Events",
      "destination": {
        "url": "https://api.calendly.com/scheduled_events",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "User URI",
          "as": {
            "en": "user",
            "de": "user",
            "es": "user",
            "fr": "user",
            "ro": "user",
            "it": "user"
          },
          "description": {
            "en": "The user URI (required by Calendly API for this endpoint).",
            "es": "The user URI (required by Calendly API for this endpoint).",
            "fr": "The user URI (required by Calendly API for this endpoint).",
            "ro": "The user URI (required by Calendly API for this endpoint).",
            "it": "The user URI (required by Calendly API for this endpoint)."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "query:user"
        },
        {
          "name": "Status",
          "as": "status",
          "description": {
            "en": "Filter by status: 'active' or 'canceled'.",
            "es": "Filter by status: 'active' or 'canceled'.",
            "fr": "Filter by status: 'active' or 'canceled'.",
            "ro": "Filter by status: 'active' or 'canceled'.",
            "it": "Filter by status: 'active' or 'canceled'."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "query:status",
          "default": "active"
        },
        {
          "name": "Count",
          "as": "count",
          "description": {
            "en": "Number of items to return.",
            "es": "Number of items to return.",
            "fr": "Number of items to return.",
            "ro": "Number of items to return.",
            "it": "Number of items to return."
          },
          "type": "number",
          "source": "field",
          "required": false,
          "position": "query:count",
          "default": 20
        }
      ]
    }
  ],
  "output": {
    "EVENTS": "out.collection",
    "COUNT": "out.collection.length"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} scheduled event(s).",
      "de": "{{COUNT}} geplante(s) Ereignis(se) gefunden.",
      "es": "Found {{COUNT}} scheduled event(s).",
      "fr": "Found {{COUNT}} scheduled event(s).",
      "ro": "Found {{COUNT}} scheduled event(s).",
      "it": "Found {{COUNT}} scheduled event(s)."
    }
  }
}
