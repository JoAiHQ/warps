{
  "protocol": "warp:3.0.0",
  "name": "Running Coach: Log Run",
  "title": {
    "en": "Log a run",
    "de": "Lauf eintragen",
    "es": "Log a run",
    "fr": "Log a run",
    "ro": "Log a run",
    "it": "Log a run"
  },
  "description": {
    "en": "Record a completed run so the coach can track your progress and adjust the plan.",
    "de": "Trage einen abgeschlossenen Lauf ein, damit der Coach deinen Fortschritt verfolgen und den Plan anpassen kann.",
    "es": "Record a completed run so the coach can track your progress and adjust the plan.",
    "fr": "Record a completed run so the coach can track your progress and adjust the plan.",
    "ro": "Record a completed run so the coach can track your progress and adjust the plan.",
    "it": "Record a completed run so the coach can track your progress and adjust the plan."
  },
  "bot": "Use this after the user completes a run. Acknowledge their effort, note if they're on track with the plan, and tell them what the next session is.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Log run",
        "de": "Lauf speichern",
        "es": "Log run",
        "fr": "Log run",
        "ro": "Log run",
        "it": "Log run"
      },
      "inputs": [
        {
          "name": "Distance",
          "as": "distance",
          "description": {
            "en": "How far did you run? (km)",
            "de": "Wie weit bist du gelaufen? (km)",
            "es": "How far did you run? (km)",
            "fr": "How far did you run? (km)",
            "ro": "How far did you run? (km)",
            "it": "How far did you run? (km)"
          },
          "bot": "Distance covered in kilometers.",
          "type": "number",
          "source": "field",
          "required": true,
          "min": 0.1,
          "max": 100
        },
        {
          "name": "Duration",
          "as": "duration",
          "description": {
            "en": "How long did you run? (minutes)",
            "de": "Wie lange bist du gelaufen? (Minuten)",
            "es": "How long did you run? (minutes)",
            "fr": "How long did you run? (minutes)",
            "ro": "How long did you run? (minutes)",
            "it": "How long did you run? (minutes)"
          },
          "bot": "Duration in minutes. Used to calculate pace.",
          "type": "number",
          "source": "field",
          "required": true,
          "min": 1,
          "max": 600
        },
        {
          "name": "How did it feel?",
          "as": "effort",
          "description": {
            "en": "Rate your perceived effort",
            "de": "Bewerte deine wahrgenommene Anstrengung",
            "es": "Rate your perceived effort",
            "fr": "Rate your perceived effort",
            "ro": "Rate your perceived effort",
            "it": "Rate your perceived effort"
          },
          "bot": "Perceived effort level. Easy means below conversational pace, hard means pushing limits. Use this to calibrate future session intensity.",
          "type": "string",
          "source": "field",
          "required": true,
          "options": {
            "easy": {
              "en": "Easy",
              "de": "Easy",
              "es": "Easy",
              "fr": "Easy",
              "ro": "Easy",
              "it": "Easy"
            },
            "moderate": "Moderate",
            "hard": {
              "en": "Hard",
              "de": "Hard",
              "es": "Hard",
              "fr": "Hard",
              "ro": "Hard",
              "it": "Hard"
            },
            "exhausted": "Exhausted"
          }
        },
        {
          "name": "Notes",
          "as": "notes",
          "description": {
            "en": "Anything to note? (optional)",
            "de": "Etwas anzumerken? (optional)",
            "es": "Anything to note? (optional)",
            "fr": "Anything to note? (optional)",
            "ro": "Anything to note? (optional)",
            "it": "Anything to note? (optional)"
          },
          "bot": "Optional freeform note — terrain, weather, how legs felt, injuries, anything relevant.",
          "type": "string",
          "source": "field",
          "required": false,
          "max": 300
        }
      ]
    }
  ],
  "next": "@joai-store-append?storeName=running-logs&value={{distance}}km+in+{{duration}}min+({{effort}})&label=Run",
  "messages": {
    "success": {
      "en": "Run logged. Nice work.",
      "de": "Lauf eingetragen. Gut gemacht.",
      "es": "Run logged. Nice work.",
      "fr": "Run logged. Nice work.",
      "ro": "Run logged. Nice work.",
      "it": "Run logged. Nice work."
    }
  }
}
