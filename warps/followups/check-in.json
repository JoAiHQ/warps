{
  "protocol": "warp:3.0.0",
  "name": "Followups: Check In",
  "title": {
    "en": "Check in with a customer",
    "de": "Bei einem Kunden nachfragen",
    "fr": "Prendre des nouvelles d un client",
    "es": "Hacer seguimiento con un cliente",
    "ro": "Interogheaza un client"
  },
  "description": {
    "en": "Send a friendly check-in message to a customer you haven't heard from recently.",
    "de": "Eine freundliche Nachfrage-Nachricht an einen Kunden senden, von dem du laengere Zeit nichts gehoert hast.",
    "fr": "Envoyer un message de prise de nouvelles amical a un client dont tu n as pas eu de nouvelles recemment.",
    "es": "Enviar un mensaje amigable de seguimiento a un cliente del que no has sabido recientemente.",
    "ro": "Trimite un mesaj prietenos de verificare unui client de care nu ai mai auzit recent."
  },
  "bot": "When this warp is triggered: fetches the contact, composes a friendly check-in message, and sends it via WhatsApp.",
  "output": {
    "CONTACT_NAME": "out.name",
    "CONTACT_PHONE": "out.phone",
    "CONTACT_EMAIL": "out.email"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Send check-in",
        "de": "Nachfrage senden",
        "fr": "Envoyer le message",
        "es": "Enviar seguimiento",
        "ro": "Trimite verificarea"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/contacts/{{contactId}}",
        "method": "GET",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Contact",
          "as": "contactId",
          "description": {
            "en": "Which customer to check in with?",
            "de": "Bei welchem Kunden nachfragen?",
            "fr": "Quel client contacter ?",
            "es": "Con cual cliente hacer seguimiento?",
            "ro": "Cu care client sa verifici?"
          },
          "bot": "The contact ID of the customer to check in with.",
          "type": "string",
          "position": "url:contactId",
          "source": "field",
          "required": true
        },
        {
          "name": "Last Visit Date",
          "as": "lastVisitDate",
          "description": {
            "en": "When was their last visit?",
            "de": "Wann war ihr letzter Besuch?",
            "fr": "Quand etait leur derniere visite ?",
            "es": "Cuando fue su ultima visita?",
            "ro": "Cand a fost ultima vizita?"
          },
          "bot": "The date of the customer's last visit. Used to personalize the check-in message.",
          "type": "string",
          "source": "field",
          "position": "local",
          "required": false
        }
      ]
    },
    {
      "type": "prompt",
      "label": {
        "en": "Compose message",
        "de": "Nachricht verfassen",
        "fr": "Rediger le message",
        "es": "Redactar mensaje",
        "ro": "Compune mesajul"
      },
      "prompt": "Compose a friendly check-in message in German (du-form) for {{CONTACT_NAME}}. If last visit date is known ({{lastVisitDate}}), mention how long it's been. Casual and warm, not salesy."
    },
    {
      "type": "collect",
      "label": {
        "en": "Send message",
        "de": "Nachricht senden",
        "fr": "Envoyer le message",
        "es": "Enviar mensaje",
        "ro": "Trimite mesajul"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/agents/{{JOAI_AGENT_UUID}}/room/message",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "auto": true,
      "inputs": [
        {
          "name": "Integration",
          "as": "integration",
          "type": "string",
          "source": "field",
          "value": "whatsapp",
          "hidden": true
        },
        {
          "name": "Recipient ID",
          "as": "recipientId",
          "type": "string",
          "source": "field",
          "value": "{{CONTACT_PHONE}}",
          "hidden": true
        },
        {
          "name": "Recipient Name",
          "as": "recipientName",
          "type": "string",
          "source": "field",
          "value": "{{CONTACT_NAME}}",
          "hidden": true
        },
        {
          "name": "Message",
          "as": "message",
          "type": "string",
          "source": "field",
          "value": "{{MESSAGE}}",
          "hidden": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Sending check-in message...",
      "de": "Nachfrage-Nachricht wird gesendet...",
      "fr": "Envoi du message de prise de nouvelles...",
      "es": "Enviando mensaje de seguimiento...",
      "ro": "Se trimite mesajul de verificare..."
    }
  }
}
