{
  "protocol": "warp:3.0.0",
  "name": "Followups: Enroll Contact",
  "title": {
    "en": "Enroll a contact in follow-ups",
    "de": "Kontakt für Follow-up anmelden",
    "es": "Enroll a contact in follow-ups",
    "fr": "Enroll a contact in follow-ups",
    "ro": "Enroll a contact in follow-ups",
    "it": "Enroll a contact in follow-ups"
  },
  "description": {
    "en": "Enroll a CRM contact into a follow-up sequence by setting the sequence name and step. The host system schedules execution of the appropriate template.",
    "de": "Einen CRM-Kontakt in eine Follow-up-Sequenz aufnehmen, indem der Sequenz-Name und Schritt gesetzt werden. Das Host-System plant die Ausführung des entsprechenden Templates.",
    "es": "Enroll a CRM contact into a follow-up sequence by setting the sequence name and step. The host system schedules execution of the appropriate template.",
    "fr": "Enroll a CRM contact into a follow-up sequence by setting the sequence name and step. The host system schedules execution of the appropriate template.",
    "ro": "Enroll a CRM contact into a follow-up sequence by setting the sequence name and step. The host system schedules execution of the appropriate template.",
    "it": "Enroll a CRM contact into a follow-up sequence by setting the sequence name and step. The host system schedules execution of the appropriate template."
  },
  "bot": "Use this to enroll a contact into a follow-up sequence. Sets followups_sequence and followups_step properties on the contact.",
  "vars": {
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Set sequence",
        "de": "Sequenz setzen",
        "es": "Set sequence",
        "fr": "Set sequence",
        "ro": "Set sequence",
        "it": "Set sequence"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/contacts/{{contactId}}/properties",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Contact",
          "as": "contactId",
          "description": {
            "en": "Which contact to enroll?",
            "de": "Welchen Kontakt anmelden?",
            "es": "Which contact to enroll?",
            "fr": "Which contact to enroll?",
            "ro": "Which contact to enroll?",
            "it": "Which contact to enroll?"
          },
          "bot": "The hashid of the CRM contact to enroll in the follow-up sequence.",
          "type": "string",
          "position": "url:contactId",
          "source": "field",
          "required": true
        },
        {
          "name": "Sequence",
          "as": "followups_sequence",
          "description": {
            "en": "Sequence name (e.g. 'birthday-followup')",
            "de": "Sequenz-Name (z.B. 'geburtstags-followup')",
            "es": "Sequence name (e.g. 'birthday-followup')",
            "fr": "Sequence name (e.g. 'birthday-followup')",
            "ro": "Sequence name (e.g. 'birthday-followup')",
            "it": "Sequence name (e.g. 'birthday-followup')"
          },
          "bot": "The sequence to enroll the contact into.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:value"
        },
        {
          "name": "Sequence Key",
          "as": "key",
          "type": "string",
          "source": "field",
          "required": true,
          "value": "followups_sequence",
          "position": "payload:key",
          "hidden": true
        }
      ]
    },
    {
      "type": "collect",
      "label": {
        "en": "Set step",
        "de": "Schritt setzen",
        "es": "Set step",
        "fr": "Set step",
        "ro": "Set step",
        "it": "Set step"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/contacts/{{contactId}}/properties",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": {
            "en": "Step",
            "de": "Step",
            "es": "Step",
            "fr": "Step",
            "ro": "Step",
            "it": "Step"
          },
          "as": "followups_step",
          "description": {
            "en": "Starting step (default: 1)",
            "de": "Startschritt (Standard: 1)",
            "es": "Starting step (default: 1)",
            "fr": "Starting step (default: 1)",
            "ro": "Starting step (default: 1)",
            "it": "Starting step (default: 1)"
          },
          "bot": "The sequence step to start at. Defaults to 1.",
          "type": "uint16",
          "source": "field",
          "required": false,
          "value": "1",
          "position": "payload:value"
        },
        {
          "name": "Step Key",
          "as": "key",
          "type": "string",
          "source": "field",
          "required": true,
          "value": "followups_step",
          "position": "payload:key",
          "hidden": true
        }
      ]
    },
    {
      "type": "collect",
      "label": {
        "en": "Tag contact",
        "de": "Kontakt taggen",
        "es": "Tag contact",
        "fr": "Tag contact",
        "ro": "Tag contact",
        "it": "Tag contact"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/contacts/{{contactId}}",
        "method": "PUT",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Tag",
          "as": "tag",
          "description": {
            "en": "Tag to add (e.g. 'followups-enrolled')",
            "de": "Tag zum Hinzufügen (z.B. 'followups-enrolled')",
            "es": "Tag to add (e.g. 'followups-enrolled')",
            "fr": "Tag to add (e.g. 'followups-enrolled')",
            "ro": "Tag to add (e.g. 'followups-enrolled')",
            "it": "Tag to add (e.g. 'followups-enrolled')"
          },
          "bot": "Tag to mark the contact as enrolled.",
          "type": "string",
          "source": "field",
          "required": false,
          "value": "followups-enrolled",
          "position": "payload:tagsAppend[]"
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Contact enrolled in {{followups_sequence}}.",
      "de": "Kontakt in {{followups_sequence}} angemeldet.",
      "es": "Contact enrolled in {{followups_sequence}}.",
      "fr": "Contact enrolled in {{followups_sequence}}.",
      "ro": "Contact enrolled in {{followups_sequence}}.",
      "it": "Contact enrolled in {{followups_sequence}}."
    }
  }
}
