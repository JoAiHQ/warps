{
  "protocol": "warp:3.0.0",
  "name": "Followups: Post Treatment",
  "title": {
    "en": "Send aftercare instructions",
    "de": "Nachsorge-Anweisungen senden",
    "fr": "Envoyer les instructions de suivi",
    "es": "Enviar instrucciones de cuidado posterior",
    "ro": "Trimite instructiuni de ingrijire post-tratament"
  },
  "description": {
    "en": "Send aftercare tips and instructions to a customer following their treatment.",
    "de": "Nachsorge-Tipps und Anweisungen an einen Kunden nach seiner Behandlung senden.",
    "fr": "Envoyer des conseils et instructions de suivi a un client apres son traitement.",
    "es": "Enviar consejos e instrucciones de cuidado posterior a un cliente despues de su tratamiento.",
    "ro": "Trimite sfaturi si instructiuni de ingrijire unui client dupa tratamentul sau."
  },
  "bot": "When this warp is triggered: fetches the contact, composes aftercare tips for their treatment, and sends them via WhatsApp.",
  "output": {
    "CONTACT_NAME": "out.name",
    "CONTACT_PHONE": "out.phone",
    "CONTACT_EMAIL": "out.email"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Send aftercare",
        "de": "Nachsorge senden",
        "fr": "Envoyer le suivi",
        "es": "Enviar cuidado posterior",
        "ro": "Trimite ingrijirea"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/contacts/{{contactId}}",
        "method": "GET",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Contact",
          "as": "contactId",
          "description": {
            "en": "Which customer to send aftercare instructions to?",
            "de": "An welchen Kunden sollen Nachsorge-Anweisungen gesendet werden?",
            "fr": "A quel client envoyer les instructions de suivi ?",
            "es": "A cual cliente enviar las instrucciones de cuidado posterior?",
            "ro": "Caruia client sa trimiti instructiunile de ingrijire?"
          },
          "bot": "The contact ID of the customer who received the treatment.",
          "type": "string",
          "position": "url:contactId",
          "source": "field",
          "required": true
        },
        {
          "name": "Treatment",
          "as": "treatment",
          "description": {
            "en": "What treatment did they receive?",
            "de": "Welche Behandlung haben sie erhalten?",
            "fr": "Quel traitement ont-ils recu ?",
            "es": "Que tratamiento recibieron?",
            "ro": "Ce tratament au primit?"
          },
          "bot": "The treatment or service the customer received. Used to tailor aftercare advice.",
          "type": "string",
          "source": "field",
          "position": "local",
          "required": true
        }
      ]
    },
    {
      "type": "prompt",
      "label": {
        "en": "Compose aftercare",
        "de": "Nachsorge verfassen",
        "fr": "Rediger le suivi",
        "es": "Redactar cuidados",
        "ro": "Compune ingrijirea"
      },
      "prompt": "Compose aftercare tips for {{CONTACT_NAME}} who just had this treatment: {{treatment}}. Keep it short, practical, and caring. German du-form."
    },
    {
      "type": "collect",
      "label": {
        "en": "Send message",
        "de": "Nachricht senden",
        "fr": "Envoyer le message",
        "es": "Enviar mensaje",
        "ro": "Trimite mesajul"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/agents/{{JOAI_AGENT_UUID}}/message",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "auto": true,
      "inputs": [
        {
          "name": "Integration Type",
          "as": "integrationType",
          "type": "string",
          "source": "field",
          "value": "whatsapp",
          "hidden": true
        },
        {
          "name": "Recipient ID",
          "as": "recipientId",
          "type": "string",
          "source": "field",
          "value": "{{CONTACT_PHONE}}",
          "hidden": true
        },
        {
          "name": "Recipient Name",
          "as": "recipientName",
          "type": "string",
          "source": "field",
          "value": "{{CONTACT_NAME}}",
          "hidden": true
        },
        {
          "name": "Message",
          "as": "message",
          "type": "string",
          "source": "field",
          "value": "{{MESSAGE}}",
          "hidden": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Sending aftercare instructions...",
      "de": "Nachsorge-Anweisungen werden gesendet...",
      "fr": "Envoi des instructions de suivi...",
      "es": "Enviando instrucciones de cuidado posterior...",
      "ro": "Se trimit instructiunile de ingrijire..."
    }
  }
}
