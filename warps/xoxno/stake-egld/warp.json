{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "XOXNO: Stake eGold",
  "title": {
    "en": "Stake eGold with XOXNO",
    "de": "Stake eGold mit XOXNO"
  },
  "description": {
    "en": "Stake your EGLD with XOXNO, a leading NFT marketplace and validator on MultiversX. Earn staking rewards while supporting the team behind one of the blockchain's most active ecosystem projects.",
    "de": "Stake dein EGLD bei XOXNO, einem fuehrenden NFT-Marktplatz und Validator auf MultiversX. Verdiene Staking-Belohnungen und unterstuetze das Team hinter einem der aktivsten Oekosystem-Projekte der Blockchain."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Stake now",
        "de": "Jetzt staken"
      },
      "address": "INJECT:PROVIDER",
      "func": "delegate",
      "args": [],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "value",
          "description": {
            "en": "Amount of eGold to delegate.",
            "de": "Betrag an eGold zum Delegieren."
          },
          "type": "biguint",
          "position": "value",
          "source": "field",
          "required": true,
          "min": 1,
          "modifier": "scale:18"
        }
      ]
    },
    {
      "type": "link",
      "label": {
        "en": "Learn more",
        "de": "Mehr erfahren"
      },
      "description": {
        "en": "Find more information about staking eGold.",
        "de": "Erfahre mehr über das Staken von eGold."
      },
      "url": "https://multiversx.com/egld"
    }
  ],
  "output": {
    "TX_HASH": "out",
    "AMOUNT_EGLD": "transform:() => Number(inputs.value) / 10 ** 18"
  },
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/xoxno/stake-egld/chatapp.fff4ef3.dist.html",
  "messages": {
    "success": {
      "en": "eGold staked successfully",
      "de": "eGold erfolgreich gestakt"
    }
  },
  "related": [
    "multiversx-staking-claimable-rewards",
    "multiversx-staking-redelegate-all"
  ]
}