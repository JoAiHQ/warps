{
  "protocol": "warp:3.0.0",
  "chain": "ethereum",
  "name": "OmniSet: Deposit Ethereum",
  "title": {
    "en": "Deposit assets on Ethereum to OmniSet",
    "de": "Assets auf Ethereum bei OmniSet einzahlen",
    "es": "Deposit assets on Ethereum to OmniSet",
    "fr": "Deposit assets on Ethereum to OmniSet",
    "ro": "Deposit assets on Ethereum to OmniSet",
    "it": "Deposit assets on Ethereum to OmniSet"
  },
  "description": {
    "en": "Deposit a blockchain asset from Ethereum to OmniSet.",
    "de": "Zahle einen Blockchain-Asset von Ethereum bei OmniSet ein.",
    "es": "Deposit a blockchain asset from Ethereum to OmniSet.",
    "fr": "Deposit a blockchain asset from Ethereum to OmniSet.",
    "ro": "Deposit a blockchain asset from Ethereum to OmniSet.",
    "it": "Deposit a blockchain asset from Ethereum to OmniSet."
  },
  "vars": {
    "BRIDGE": "INJECT:DEPOSIT_ETHEREUM"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Approve now",
        "de": "Jetzt genehmigen",
        "es": "Approve now",
        "fr": "Approve now",
        "ro": "Approve now",
        "it": "Approve now"
      },
      "address": "{{primary.asset.token}}",
      "func": "approve",
      "args": [
        "address:{{BRIDGE}}",
        "uint256:{{primary.asset.amount}}"
      ],
      "gasLimit": 200000,
      "abi": "function approve(address spender, uint256 amount) public returns (bool)",
      "when": "{{primary.asset.token}} !== '0x0000000000000000000000000000000000000000'"
    },
    {
      "type": "contract",
      "label": {
        "en": "Deposit now",
        "de": "Jetzt einzahlen",
        "es": "Deposit now",
        "fr": "Deposit now",
        "ro": "Deposit now",
        "it": "Deposit now"
      },
      "address": "{{BRIDGE}}",
      "func": "deposit",
      "args": [],
      "gasLimit": 200000,
      "abi": "function deposit(address token, uint256 amount, bytes32 receiver) public payable",
      "inputs": [
        {
          "name": "Asset",
          "as": "asset",
          "description": {
            "en": "The asset to deposit.",
            "de": "Der einzuzahlende Asset.",
            "es": "The asset to deposit.",
            "fr": "The asset to deposit.",
            "ro": "The asset to deposit.",
            "it": "The asset to deposit."
          },
          "type": "asset",
          "position": {
            "token": "arg:1",
            "amount": "arg:2"
          },
          "source": "field",
          "required": true,
          "modifier": "transform:(inputs) => inputs.asset?.identifier === 'ETH' ? {identifier: '0x0000000000000000000000000000000000000000', amount: inputs.asset.amount} : inputs.asset"
        },
        {
          "name": "Receiver",
          "description": {
            "en": "The blockchain wallet address of the receiver.",
            "de": "Die Blockchain-Wallet-Adresse des Empfängers.",
            "es": "The blockchain wallet address of the receiver.",
            "fr": "The blockchain wallet address of the receiver.",
            "ro": "The blockchain wallet address of the receiver.",
            "it": "The blockchain wallet address of the receiver."
          },
          "type": "hex",
          "position": "arg:3",
          "source": "hidden",
          "default": "{{USER_WALLET_PUBLICKEY:fastset}}"
        }
      ]
    },
    {
      "type": {
        "en": "link",
        "de": "link",
        "es": "link",
        "fr": "link",
        "ro": "link",
        "it": "link"
      },
      "label": {
        "en": "Learn more about FastSet",
        "de": "Mehr über FastSet erfahren",
        "es": "Learn more about FastSet",
        "fr": "Learn more about FastSet",
        "ro": "Learn more about FastSet",
        "it": "Learn more about FastSet"
      },
      "url": "https://pi2.network"
    }
  ],
  "messages": {
    "success": {
      "en": "Assets deposited successfully",
      "de": "Assets erfolgreich eingezahlt",
      "es": "Assets deposited successfully",
      "fr": "Assets deposited successfully",
      "ro": "Assets deposited successfully",
      "it": "Assets deposited successfully"
    }
  }
}
