{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "PeerMe MultiSig: Perform Action",
  "title": "Execute a proposal",
  "description": "Use when a user wants to execute a multi-sig proposal that has already reached quorum. Only board members can execute. The proposal must have enough signatures before it can be performed.",
  "actions": [
    {
      "type": "contract",
      "label": "Execute proposal",
      "address": "{{multisig}}",
      "func": "performAction",
      "args": [],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/multisig.abi.json",
      "inputs": [
        {
          "name": "MultiSig address",
          "as": "multisig",
          "type": "address",
          "source": "query"
        },
        {
          "name": "Action ID",
          "as": "ACTION_ID",
          "description": "The ID of the proposal to execute.",
          "bot": "If the user hasn't specified an action ID, first run 'Get Pending Actions' to show what's available.",
          "type": "uint32",
          "position": "arg:1",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "RESULT": "out",
    "DEPLOYED_ADDRESS": "transform:() => results.RESULT && results.RESULT[0] ? results.RESULT[0] : null"
  },
  "messages": {
    "success": "Proposal {{ACTION_ID}} executed successfully. {{DEPLOYED_ADDRESS ? 'Deployed contract: ' + DEPLOYED_ADDRESS : ''}}",
    "card": "Executed Proposal #{{ACTION_ID}}"
  },
  "trigger": {
    "type": "webhook",
    "source": "multiversx",
    "match": {
      "outcome": "success"
    },
    "label": {
      "en": "Get notified about successful executions",
      "de": "Benachrichtigung erhalten über erfolgreiche Ausführungen"
    },
    "subject": {
      "en": "MultiSig proposal executed",
      "de": "MultiSig-Vorschlag ausgeführt"
    },
    "body": {
      "en": "Proposal #{{ACTION_ID}} has been successfully executed",
      "de": "Vorschlag #{{ACTION_ID}} wurde erfolgreich ausgeführt"
    }
  }
}
