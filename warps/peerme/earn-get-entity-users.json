{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "PeerMe Earn: Get Entity Users",
  "title": { "en": "Get Entity Users", "de": "Entitätsbenutzer abrufen" },
  "description": { "en": "Get the users of an entity in the PeerMe Earn module.", "de": "Die Benutzer einer Entität im PeerMe Earn-Modul abrufen." },
  "actions": [
    {
      "type": "query",
      "label": { "en": "Get Users", "de": "Benutzer abrufen" },
      "address": "INJECT:EARN",
      "func": "getEntityUsers",
      "args": ["address:{{entity}}"],
      "abi": "INJECT:abis/earn.abi.json",
      "inputs": [
        {
          "name": { "en": "Entity", "de": "Entität" },
          "as": "entity",
          "type": "address",
          "source": "query"
        }
      ]
    }
  ]
}
