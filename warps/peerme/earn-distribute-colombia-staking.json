{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "PeerMe Earn: Distribute - Colombia Staking",
  "title": "Distribute COLS via PeerMe Earn",
  "description": "Distribute COLS to stakers of COLS via the PeerMe Earn module.",
  "preview": "https://vleap.ai/images/external/warps/staking-colombia.jpg",
  "actions": [
    {
      "type": "contract",
      "label": "Distribute now",
      "address": "INJECT:EARN",
      "func": "distribute",
      "args": [
        "address:{{ENTITY}}"
      ],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/earn.abi.json",
      "inputs": [
        {
          "name": "Entity",
          "as": "ENTITY",
          "type": "address",
          "source": "query",
          "default": "erd1qqqqqqqqqqqqqpgq7khr5sqd4cnjh5j5dz0atfz03r3l99y727rsulfjj0"
        },
        {
          "name": "Rewards",
          "type": "asset",
          "position": "transfer",
          "source": "field",
          "required": true
        }
      ]
    },
    {
      "type": "link",
      "label": "View Colombia Staking on PeerMe",
      "url": "https://peerme.io/{{ENTITY}}"
    }
  ],
  "trigger": {
    "type": "webhook",
    "source": "multiversx",
    "match": {
      "outcome": "success"
    },
    "label": {
      "en": "Get notified about new distributions",
      "de": "Erhalte Benachrichtigungen über neue Verteilungen",
      "es": "Recibe notificaciones sobre nuevas distribuciones",
      "fr": "Sois informé des nouvelles distributions",
      "ro": "Fii notificat despre noile distribuții",
      "it": "Ricevi notifiche sulle nuove distribuzioni"
    },
    "subject": {
      "en": "COLS distributed",
      "de": "COLS wurden verteilt",
      "es": "COLS distribuido",
      "fr": "COLS distribué",
      "ro": "COLS distribuit",
      "it": "COLS distribuito"
    },
    "body": {
      "en": "COLS distributed to the stakers of Colombia Staking",
      "de": "COLS wurden den Stakern von Colombia Staking verteilt",
      "es": "COLS distribuido a los stakers de Colombia Staking",
      "fr": "COLS distribué aux stakeurs de Colombia Staking",
      "ro": "COLS distribuit către staker-ii Colombia Staking",
      "it": "COLS distribuito agli staker di Colombia Staking"
    }
  }
}
