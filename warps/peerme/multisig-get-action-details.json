{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "PeerMe MultiSig: Get Action Details",
  "title": {
    "en": "View proposal details",
    "de": "Vorschlagsdetails anzeigen",
    "es": "View proposal details",
    "fr": "View proposal details",
    "ro": "View proposal details",
    "it": "View proposal details"
  },
  "description": {
    "en": "Get detailed information about a specific MultiSig proposal including its type, signers, and whether quorum has been reached. Use this to inspect a proposal before signing or executing it.",
    "de": "Get detailed information about a specific MultiSig proposal including its type, signers, and whether quorum has been reached. Use this to inspect a proposal before signing or executing it.",
    "es": "Get detailed information about a specific MultiSig proposal including its type, signers, and whether quorum has been reached. Use this to inspect a proposal before signing or executing it.",
    "fr": "Get detailed information about a specific MultiSig proposal including its type, signers, and whether quorum has been reached. Use this to inspect a proposal before signing or executing it.",
    "ro": "Get detailed information about a specific MultiSig proposal including its type, signers, and whether quorum has been reached. Use this to inspect a proposal before signing or executing it.",
    "it": "Get detailed information about a specific MultiSig proposal including its type, signers, and whether quorum has been reached. Use this to inspect a proposal before signing or executing it."
  },
  "actions": [
    {
      "type": "query",
      "label": "Get action data",
      "address": "{{multisig}}",
      "func": "getActionData",
      "abi": "INJECT:abis/multisig.abi.json",
      "inputs": [
        {
          "name": "MultiSig address",
          "as": "multisig",
          "type": "address",
          "source": "query",
          "label": {
            "en": "MultiSig address",
            "de": "MultiSig address",
            "es": "Dirección de Multifirma",
            "fr": "Adresse MultiSig",
            "ro": "Adresă MultiSemnătură",
            "it": "Indirizzo MultiFirma"
          }
        },
        {
          "name": "Action ID",
          "as": "ACTION_ID",
          "description": {
            "en": "The ID of the proposal to view.",
            "de": "Die ID des anzuzeigenden Vorschlags.",
            "es": "The ID of the proposal to view.",
            "fr": "The ID of the proposal to view.",
            "ro": "The ID of the proposal to view.",
            "it": "The ID of the proposal to view."
          },
          "bot": "If the user hasn't specified an action ID, first run 'Get Pending Actions' to show what's available.",
          "type": "uint32",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Action ID",
            "de": "Action ID",
            "es": "ID de acción",
            "fr": "ID d'action",
            "ro": "ID acțiune",
            "it": "ID azione"
          }
        }
      ]
    },
    {
      "type": "query",
      "label": "Get signers",
      "address": "{{multisig}}",
      "func": "getActionSigners",
      "abi": "INJECT:abis/multisig.abi.json",
      "inputs": [
        {
          "name": "Action ID",
          "type": "uint32",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{ACTION_ID}}",
          "label": {
            "en": "Action ID",
            "de": "Action ID",
            "es": "ID de acción",
            "fr": "ID d'action",
            "ro": "ID acțiune",
            "it": "ID azione"
          }
        }
      ]
    },
    {
      "type": "query",
      "label": "Get signer count",
      "address": "{{multisig}}",
      "func": "getActionSignerCount",
      "abi": "INJECT:abis/multisig.abi.json",
      "inputs": [
        {
          "name": "Action ID",
          "type": "uint32",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{ACTION_ID}}",
          "label": {
            "en": "Action ID",
            "de": "Action ID",
            "es": "ID de acción",
            "fr": "ID d'action",
            "ro": "ID acțiune",
            "it": "ID azione"
          }
        }
      ]
    },
    {
      "type": "query",
      "label": "Get valid signer count",
      "address": "{{multisig}}",
      "func": "getActionValidSignerCount",
      "abi": "INJECT:abis/multisig.abi.json",
      "inputs": [
        {
          "name": "Action ID",
          "type": "uint32",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{ACTION_ID}}",
          "label": {
            "en": "Action ID",
            "de": "Action ID",
            "es": "ID de acción",
            "fr": "ID d'action",
            "ro": "ID acțiune",
            "it": "ID azione"
          }
        }
      ]
    },
    {
      "type": "query",
      "label": "Check quorum reached",
      "address": "{{multisig}}",
      "func": "quorumReached",
      "abi": "INJECT:abis/multisig.abi.json",
      "inputs": [
        {
          "name": "Action ID",
          "type": "uint32",
          "position": "arg:1",
          "source": "hidden",
          "default": "{{ACTION_ID}}",
          "label": {
            "en": "Action ID",
            "de": "Action ID",
            "es": "ID de acción",
            "fr": "ID d'action",
            "ro": "ID acțiune",
            "it": "ID azione"
          }
        }
      ]
    }
  ],
  "output": {
    "ACTION_DATA": "out[0]",
    "SIGNERS": "out[1]",
    "SIGNER_COUNT": "out[2]",
    "VALID_SIGNER_COUNT": "out[3]",
    "QUORUM_REACHED": "out[4]",
    "SIGNER_COUNT_NUMBER": "transform:() => Number(results.SIGNER_COUNT)",
    "VALID_SIGNER_COUNT_NUMBER": "transform:() => Number(results.VALID_SIGNER_COUNT)",
    "STATUS": "transform:() => results.QUORUM_REACHED ? 'Ready to execute' : 'Awaiting signatures'"
  },
  "messages": {
    "success": "Proposal #{{ACTION_ID}}: {{STATUS}}. {{VALID_SIGNER_COUNT_NUMBER}} valid signature(s) collected.",
    "card": "Proposal #{{ACTION_ID}}: {{STATUS}} ({{VALID_SIGNER_COUNT_NUMBER}} signatures)"
  }
}
