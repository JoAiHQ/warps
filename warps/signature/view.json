{
  "protocol": "warp:3.0.0",
  "name": "Signature: View",
  "title": {
    "en": "View signature request",
    "de": "Signaturanfrage ansehen",
    "fr": "Voir la demande de signature",
    "es": "Ver solicitud de firma",
    "ro": "Vezi cererea de semnatura"
  },
  "description": {
    "en": "See the details and current status of a signature request.",
    "de": "Details und aktuellen Status einer Signaturanfrage ansehen.",
    "fr": "Consultez les details et le statut actuel d une demande de signature.",
    "es": "Consulta los detalles y el estado actual de una solicitud de firma.",
    "ro": "Vezi detaliile si starea actuala a unei cereri de semnatura."
  },
  "bot": "Fetches a signature request by ID. Shows the document title, hash, creator, signer count, and current status.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SIGNATURE_SC_ADDRESS",
    "REQUEST_ID": "query:id"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading request...",
        "de": "Anfrage wird geladen...",
        "fr": "Chargement de la demande...",
        "es": "Cargando solicitud...",
        "ro": "Se incarca cererea..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getRequest",
      "args": [],
      "inputs": [
        {
          "name": "Request ID",
          "as": "requestId",
          "type": "u64",
          "position": "arg:1",
          "source": "var",
          "default": "{{REQUEST_ID}}",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:contract/output/signature.abi.json"
    }
  ],
  "output": {
    "TITLE": "out.title",
    "CREATOR": "out.creator",
    "DOCUMENT_HASH": "out.document_hash",
    "SIGNER_COUNT": "out.signer_count",
    "SIGNED_COUNT": "out.signed_count",
    "STATUS": "out.status"
  },
  "messages": {
    "success": {
      "en": "{{TITLE}} — {{SIGNED_COUNT}}/{{SIGNER_COUNT}} signed",
      "de": "{{TITLE}} — {{SIGNED_COUNT}}/{{SIGNER_COUNT}} unterzeichnet",
      "fr": "{{TITLE}} — {{SIGNED_COUNT}}/{{SIGNER_COUNT}} signatures",
      "es": "{{TITLE}} — {{SIGNED_COUNT}}/{{SIGNER_COUNT}} firmas",
      "ro": "{{TITLE}} — {{SIGNED_COUNT}}/{{SIGNER_COUNT}} semnaturi"
    }
  }
}
