{
  "protocol": "warp:3.0.0",
  "name": "Signature: List",
  "title": {
    "en": "My signature requests",
    "de": "Meine Signaturanfragen"
  },
  "description": {
    "en": "View all signature requests you have created.",
    "de": "Alle von dir erstellten Signaturanfragen ansehen."
  },
  "bot": "Lists all signature requests created by the connected wallet. Shows pending, completed, cancelled, and expired requests.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SIGNATURE_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading your requests...",
        "de": "Deine Anfragen werden geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getRequestsByCreator",
      "args": [
        "Address:{{JOAI_WALLET_ADDRESS}}",
        "u32:0",
        "u32:20"
      ],
      "inputs": [],
      "auto": true,
      "abi": "INJECT:abis/signature.abi.json"
    }
  ],
  "output": {
    "REQUESTS": "out"
  },
  "messages": {
    "success": {
      "en": "Signature requests loaded.",
      "de": "Signaturanfragen geladen."
    }
  }
}
