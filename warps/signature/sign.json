{
  "protocol": "warp:3.0.0",
  "name": "Signature: Sign",
  "title": {
    "en": "Sign document",
    "de": "Dokument unterzeichnen"
  },
  "description": {
    "en": "Review the document and confirm your signature. Your approval is permanent and tamper-proof.",
    "de": "Dokument prüfen und deine Signatur bestätigen. Deine Zustimmung ist dauerhaft und fälschungssicher."
  },
  "bot": "Signs a specific signature request by ID. Query getRequest first to show the document title and hash so the user can confirm before signing.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:SIGNATURE_SC_ADDRESS",
    "REQUEST_ID": "query:id"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading document details...",
        "de": "Dokumentdetails werden geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getRequest",
      "args": [],
      "inputs": [
        {
          "name": "Request ID",
          "as": "requestId",
          "type": "u64",
          "position": "arg:1",
          "source": "var",
          "default": "{{REQUEST_ID}}",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:abis/signature.abi.json"
    },
    {
      "type": "contract",
      "label": {
        "en": "Sign document",
        "de": "Dokument unterzeichnen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "sign",
      "gasLimit": 10000000,
      "abi": "INJECT:abis/signature.abi.json",
      "inputs": [
        {
          "name": "Request ID",
          "as": "requestId",
          "type": "u64",
          "position": "arg:1",
          "source": "var",
          "default": "{{REQUEST_ID}}",
          "required": true,
          "hidden": true
        }
      ]
    }
  ],
  "output": {
    "REQUEST_TITLE": "out.0.title",
    "DOCUMENT_HASH": "out.0.document_hash"
  },
  "messages": {
    "success": {
      "en": "Document signed! Your signature is permanently recorded.",
      "de": "Dokument unterzeichnet! Deine Signatur ist dauerhaft gespeichert."
    }
  }
}
