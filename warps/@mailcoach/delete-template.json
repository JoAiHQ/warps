{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Delete Template",
  "title": {
    "en": "Delete a template",
    "de": "Vorlage löschen",
    "es": "Delete a template",
    "fr": "Delete a template",
    "ro": "Delete a template",
    "it": "Delete a template"
  },
  "description": {
    "en": "Permanently delete an email template from Mailcoach.",
    "de": "Eine E-Mail-Vorlage dauerhaft aus Mailcoach löschen.",
    "es": "Permanently delete an email template from Mailcoach.",
    "fr": "Permanently delete an email template from Mailcoach.",
    "ro": "Permanently delete an email template from Mailcoach.",
    "it": "Permanently delete an email template from Mailcoach."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Delete Template",
        "de": "Vorlage löschen",
        "es": "Delete Template",
        "fr": "Delete Template",
        "ro": "Delete Template",
        "it": "Delete Template"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/templates/{{TEMPLATE_UUID}}",
        "method": "DELETE",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Template UUID",
          "as": "TEMPLATE_UUID",
          "description": {
            "en": "The UUID of the template to delete.",
            "es": "The UUID of the template to delete.",
            "fr": "The UUID of the template to delete.",
            "ro": "The UUID of the template to delete.",
            "it": "The UUID of the template to delete."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {},
  "messages": {
    "success": {
      "en": "Template {{TEMPLATE_UUID}} has been deleted.",
      "de": "Vorlage {{TEMPLATE_UUID}} wurde gelöscht.",
      "es": "Template {{TEMPLATE_UUID}} has been deleted.",
      "fr": "Template {{TEMPLATE_UUID}} has been deleted.",
      "ro": "Template {{TEMPLATE_UUID}} has been deleted.",
      "it": "Template {{TEMPLATE_UUID}} has been deleted."
    }
  }
}
