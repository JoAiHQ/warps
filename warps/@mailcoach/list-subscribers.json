{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: List Subscribers",
  "title": {
    "en": "List subscribers",
    "de": "Abonnenten auflisten"
  },
  "description": {
    "en": "List all subscribers for a given email list. Filter by status or search by email.",
    "de": "Alle Abonnenten einer E-Mail-Liste auflisten. Nach Status filtern oder per E-Mail suchen."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "List Subscribers",
        "de": "Abonnenten abrufen"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/email-lists/{{LIST_UUID}}/subscribers",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "List UUID",
          "as": "LIST_UUID",
          "description": {
            "en": "The UUID of the email list."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Search",
          "as": "filter[search]",
          "description": {
            "en": "Filter subscribers by email or name."
          },
          "type": "string",
          "source": "field",
          "position": "query:filter[search]",
          "required": false
        },
        {
          "name": "Status",
          "as": "filter[status]",
          "description": {
            "en": "Filter by status: unconfirmed, subscribed, unsubscribed."
          },
          "type": "string",
          "source": "field",
          "position": "query:filter[status]",
          "required": false
        },
        {
          "name": "Per Page",
          "as": "per_page",
          "description": {
            "en": "Number of results per page."
          },
          "type": "number",
          "source": "field",
          "position": "query:per_page",
          "required": false
        }
      ]
    }
  ],
  "output": {
    "SUBSCRIBERS": "out.data",
    "COUNT": "transform:() => { return Array.isArray(out?.data) ? out.data.length : 0; }",
    "TOTAL": "out.meta.total"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} subscriber(s) ({{TOTAL}} total).",
      "de": "{{COUNT}} Abonnent(en) gefunden ({{TOTAL}} insgesamt)."
    }
  }
}
