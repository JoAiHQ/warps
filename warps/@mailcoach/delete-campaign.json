{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Delete Campaign",
  "title": {
    "en": "Delete a campaign",
    "de": "Kampagne löschen",
    "es": "Delete a campaign",
    "fr": "Delete a campaign",
    "ro": "Delete a campaign",
    "it": "Delete a campaign"
  },
  "description": {
    "en": "Permanently delete a campaign from Mailcoach.",
    "de": "Eine Kampagne dauerhaft aus Mailcoach löschen.",
    "es": "Permanently delete a campaign from Mailcoach.",
    "fr": "Permanently delete a campaign from Mailcoach.",
    "ro": "Permanently delete a campaign from Mailcoach.",
    "it": "Permanently delete a campaign from Mailcoach."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Delete Campaign",
        "de": "Kampagne löschen",
        "es": "Delete Campaign",
        "fr": "Delete Campaign",
        "ro": "Delete Campaign",
        "it": "Delete Campaign"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/campaigns/{{CAMPAIGN_UUID}}",
        "method": "DELETE",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Campaign UUID",
          "as": "CAMPAIGN_UUID",
          "description": {
            "en": "The UUID of the campaign to delete.",
            "es": "The UUID of the campaign to delete.",
            "fr": "The UUID of the campaign to delete.",
            "ro": "The UUID of the campaign to delete.",
            "it": "The UUID of the campaign to delete."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {},
  "messages": {
    "success": {
      "en": "Campaign {{CAMPAIGN_UUID}} has been deleted.",
      "de": "Kampagne {{CAMPAIGN_UUID}} wurde gelöscht.",
      "es": "Campaign {{CAMPAIGN_UUID}} has been deleted.",
      "fr": "Campaign {{CAMPAIGN_UUID}} has been deleted.",
      "ro": "Campaign {{CAMPAIGN_UUID}} has been deleted.",
      "it": "Campaign {{CAMPAIGN_UUID}} has been deleted."
    }
  }
}
