{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Get Campaign Opens",
  "title": {
    "en": "Get campaign opens",
    "de": "Kampagnenöffnungen abrufen",
    "es": "Get campaign opens",
    "fr": "Get campaign opens",
    "ro": "Get campaign opens",
    "it": "Get campaign opens"
  },
  "description": {
    "en": "Retrieve the opens report for a campaign, showing which subscribers opened the email.",
    "de": "Den Öffnungsbericht einer Kampagne abrufen, der zeigt, welche Abonnenten die E-Mail geöffnet haben.",
    "es": "Retrieve the opens report for a campaign, showing which subscribers opened the email.",
    "fr": "Retrieve the opens report for a campaign, showing which subscribers opened the email.",
    "ro": "Retrieve the opens report for a campaign, showing which subscribers opened the email.",
    "it": "Retrieve the opens report for a campaign, showing which subscribers opened the email."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Opens",
        "de": "Öffnungen abrufen",
        "es": "Get Opens",
        "fr": "Get Opens",
        "ro": "Get Opens",
        "it": "Get Opens"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/campaigns/{{CAMPAIGN_UUID}}/opens",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Campaign UUID",
          "as": "CAMPAIGN_UUID",
          "description": {
            "en": "The UUID of the campaign.",
            "es": "The UUID of the campaign.",
            "fr": "The UUID of the campaign.",
            "ro": "The UUID of the campaign.",
            "it": "The UUID of the campaign."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Search",
          "as": "filter[search]",
          "description": {
            "en": "Filter by subscriber email.",
            "es": "Filter by subscriber email.",
            "fr": "Filter by subscriber email.",
            "ro": "Filter by subscriber email.",
            "it": "Filter by subscriber email."
          },
          "type": "string",
          "source": "field",
          "position": "query:filter[search]",
          "required": false,
          "label": {
            "en": "Search",
            "de": "Search",
            "es": "Buscar",
            "fr": "Recherche",
            "ro": "Căutare",
            "it": "Ricerca"
          }
        },
        {
          "name": "Sort",
          "as": "sort",
          "description": {
            "en": "Sort by: email, open_count, first_opened_at. Prefix with - for descending.",
            "es": "Sort by: email, open_count, first_opened_at. Prefix with - for descending.",
            "fr": "Sort by: email, open_count, first_opened_at. Prefix with - for descending.",
            "ro": "Sort by: email, open_count, first_opened_at. Prefix with - for descending.",
            "it": "Sort by: email, open_count, first_opened_at. Prefix with - for descending."
          },
          "type": "string",
          "source": "field",
          "position": "query:sort",
          "required": false,
          "label": {
            "en": "Sort",
            "de": "Sort",
            "es": "Sort",
            "fr": "Sort",
            "ro": "Sort",
            "it": "Sort"
          }
        },
        {
          "name": "Per Page",
          "as": "per_page",
          "description": {
            "en": "Number of results per page.",
            "es": "Number of results per page.",
            "fr": "Number of results per page.",
            "ro": "Number of results per page.",
            "it": "Number of results per page."
          },
          "type": "number",
          "source": "field",
          "position": "query:per_page",
          "required": false
        }
      ]
    }
  ],
  "output": {
    "OPENS": "out.data",
    "COUNT": "transform:() => { return Array.isArray(out?.data) ? out.data.length : 0; }",
    "TOTAL": "out.meta.total"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} open(s) ({{TOTAL}} total).",
      "de": "{{COUNT}} Öffnung(en) gefunden ({{TOTAL}} insgesamt).",
      "es": "Found {{COUNT}} open(s) ({{TOTAL}} total).",
      "fr": "Found {{COUNT}} open(s) ({{TOTAL}} total).",
      "ro": "Found {{COUNT}} open(s) ({{TOTAL}} total).",
      "it": "Found {{COUNT}} open(s) ({{TOTAL}} total)."
    }
  }
}
