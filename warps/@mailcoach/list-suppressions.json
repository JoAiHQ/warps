{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: List Suppressions",
  "title": {
    "en": "List suppressions",
    "de": "Unterdrückungen auflisten"
  },
  "description": {
    "en": "Retrieve all suppressed email addresses. Filter by reason: hard_bounce, spam_complaint, manual.",
    "de": "Alle unterdrückten E-Mail-Adressen abrufen. Nach Grund filtern: hard_bounce, spam_complaint, manual."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "List Suppressions",
        "de": "Unterdrückungen abrufen"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/suppressions",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Search",
          "as": "filter[search]",
          "description": {
            "en": "Filter by email address."
          },
          "type": "string",
          "source": "field",
          "position": "query:filter[search]",
          "required": false
        },
        {
          "name": "Reason",
          "as": "filter[reason]",
          "description": {
            "en": "Filter by reason: hard_bounce, spam_complaint, manual."
          },
          "type": "string",
          "source": "field",
          "position": "query:filter[reason]",
          "required": false
        },
        {
          "name": "Per Page",
          "as": "per_page",
          "description": {
            "en": "Number of results per page."
          },
          "type": "number",
          "source": "field",
          "position": "query:per_page",
          "required": false
        }
      ]
    }
  ],
  "output": {
    "SUPPRESSIONS": "out.data",
    "COUNT": "transform:() => { return Array.isArray(out?.data) ? out.data.length : 0; }",
    "TOTAL": "out.meta.total"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} suppression(s) ({{TOTAL}} total).",
      "de": "{{COUNT}} Unterdrückung(en) gefunden ({{TOTAL}} insgesamt)."
    }
  }
}
