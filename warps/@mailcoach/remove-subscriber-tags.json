{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Remove Subscriber Tags",
  "title": {
    "en": "Remove tags from a subscriber",
    "de": "Tags von Abonnenten entfernen",
    "es": "Remove tags from a subscriber",
    "fr": "Remove tags from a subscriber",
    "ro": "Remove tags from a subscriber",
    "it": "Remove tags from a subscriber"
  },
  "description": {
    "en": "Remove one or more tags from a Mailcoach subscriber.",
    "de": "Einen oder mehrere Tags von einem Mailcoach-Abonnenten entfernen.",
    "es": "Remove one or more tags from a Mailcoach subscriber.",
    "fr": "Remove one or more tags from a Mailcoach subscriber.",
    "ro": "Remove one or more tags from a Mailcoach subscriber.",
    "it": "Remove one or more tags from a Mailcoach subscriber."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Remove Tags",
        "de": "Tags entfernen",
        "es": "Remove Tags",
        "fr": "Remove Tags",
        "ro": "Remove Tags",
        "it": "Remove Tags"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/subscribers/{{SUBSCRIBER_UUID}}/tags",
        "method": "DELETE",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Subscriber UUID",
          "as": "SUBSCRIBER_UUID",
          "description": {
            "en": "The UUID of the subscriber.",
            "es": "The UUID of the subscriber.",
            "fr": "The UUID of the subscriber.",
            "ro": "The UUID of the subscriber.",
            "it": "The UUID of the subscriber."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Tags",
          "as": "tags",
          "description": {
            "en": "JSON array of tag names to remove, e.g. [\"premium\", \"newsletter\"].",
            "es": "JSON array of tag names to remove, e.g. [\"premium\", \"newsletter\"].",
            "fr": "JSON array of tag names to remove, e.g. [\"premium\", \"newsletter\"].",
            "ro": "JSON array of tag names to remove, e.g. [\"premium\", \"newsletter\"].",
            "it": "JSON array of tag names to remove, e.g. [\"premium\", \"newsletter\"]."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:tags",
          "label": {
            "en": "Tags",
            "de": "Tags",
            "es": "Tags",
            "fr": "Tags",
            "ro": "Tags",
            "it": "Tags"
          }
        }
      ]
    }
  ],
  "output": {},
  "messages": {
    "success": {
      "en": "Tags removed from subscriber {{SUBSCRIBER_UUID}}.",
      "de": "Tags von Abonnent {{SUBSCRIBER_UUID}} entfernt.",
      "es": "Tags removed from subscriber {{SUBSCRIBER_UUID}}.",
      "fr": "Tags removed from subscriber {{SUBSCRIBER_UUID}}.",
      "ro": "Tags removed from subscriber {{SUBSCRIBER_UUID}}.",
      "it": "Tags removed from subscriber {{SUBSCRIBER_UUID}}."
    }
  }
}
