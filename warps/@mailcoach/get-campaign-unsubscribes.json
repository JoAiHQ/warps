{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Get Campaign Unsubscribes",
  "title": {
    "en": "Get campaign unsubscribes",
    "de": "Kampagnen-Abmeldungen abrufen",
    "es": "Get campaign unsubscribes",
    "fr": "Get campaign unsubscribes",
    "ro": "Get campaign unsubscribes",
    "it": "Get campaign unsubscribes"
  },
  "description": {
    "en": "Retrieve the unsubscribes report for a campaign.",
    "de": "Den Abmeldebericht einer Kampagne abrufen.",
    "es": "Retrieve the unsubscribes report for a campaign.",
    "fr": "Retrieve the unsubscribes report for a campaign.",
    "ro": "Retrieve the unsubscribes report for a campaign.",
    "it": "Retrieve the unsubscribes report for a campaign."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Unsubscribes",
        "de": "Abmeldungen abrufen",
        "es": "Get Unsubscribes",
        "fr": "Get Unsubscribes",
        "ro": "Get Unsubscribes",
        "it": "Get Unsubscribes"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/campaigns/{{CAMPAIGN_UUID}}/unsubscribes",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Campaign UUID",
          "as": "CAMPAIGN_UUID",
          "description": {
            "en": "The UUID of the campaign.",
            "es": "The UUID of the campaign.",
            "fr": "The UUID of the campaign.",
            "ro": "The UUID of the campaign.",
            "it": "The UUID of the campaign."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Per Page",
          "as": "per_page",
          "description": {
            "en": "Number of results per page.",
            "es": "Number of results per page.",
            "fr": "Number of results per page.",
            "ro": "Number of results per page.",
            "it": "Number of results per page."
          },
          "type": "number",
          "source": "field",
          "position": "query:per_page",
          "required": false
        }
      ]
    }
  ],
  "output": {
    "UNSUBSCRIBES": "out.data",
    "COUNT": "transform:() => { return Array.isArray(out?.data) ? out.data.length : 0; }",
    "TOTAL": "out.meta.total"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} unsubscribe(s) ({{TOTAL}} total).",
      "de": "{{COUNT}} Abmeldung(en) gefunden ({{TOTAL}} insgesamt).",
      "es": "Found {{COUNT}} unsubscribe(s) ({{TOTAL}} total).",
      "fr": "Found {{COUNT}} unsubscribe(s) ({{TOTAL}} total).",
      "ro": "Found {{COUNT}} unsubscribe(s) ({{TOTAL}} total).",
      "it": "Found {{COUNT}} unsubscribe(s) ({{TOTAL}} total)."
    }
  }
}
