{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: List Templates",
  "title": {
    "en": "List templates",
    "de": "Vorlagen auflisten",
    "es": "List templates",
    "fr": "List templates",
    "ro": "List templates",
    "it": "List templates"
  },
  "description": {
    "en": "Retrieve all email templates in your Mailcoach account.",
    "de": "Alle E-Mail-Vorlagen in deinem Mailcoach-Konto abrufen.",
    "es": "Retrieve all email templates in your Mailcoach account.",
    "fr": "Retrieve all email templates in your Mailcoach account.",
    "ro": "Retrieve all email templates in your Mailcoach account.",
    "it": "Retrieve all email templates in your Mailcoach account."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "List Templates",
        "de": "Vorlagen abrufen",
        "es": "List Templates",
        "fr": "List Templates",
        "ro": "List Templates",
        "it": "List Templates"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/templates",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Search",
          "as": "filter[search]",
          "description": {
            "en": "Filter templates by search term.",
            "es": "Filter templates by search term.",
            "fr": "Filter templates by search term.",
            "ro": "Filter templates by search term.",
            "it": "Filter templates by search term."
          },
          "type": "string",
          "source": "field",
          "position": "query:filter[search]",
          "required": false,
          "label": {
            "en": "Search",
            "de": "Search",
            "es": "Buscar",
            "fr": "Recherche",
            "ro": "Căutare",
            "it": "Ricerca"
          }
        },
        {
          "name": "Sort",
          "as": "sort",
          "description": {
            "en": "Sort by: name, updated_at. Prefix with - for descending.",
            "es": "Sort by: name, updated_at. Prefix with - for descending.",
            "fr": "Sort by: name, updated_at. Prefix with - for descending.",
            "ro": "Sort by: name, updated_at. Prefix with - for descending.",
            "it": "Sort by: name, updated_at. Prefix with - for descending."
          },
          "type": "string",
          "source": "field",
          "position": "query:sort",
          "required": false,
          "label": {
            "en": "Sort",
            "de": "Sort",
            "es": "Sort",
            "fr": "Sort",
            "ro": "Sort",
            "it": "Sort"
          }
        }
      ]
    }
  ],
  "output": {
    "TEMPLATES": "out.data",
    "COUNT": "transform:() => { return Array.isArray(out?.data) ? out.data.length : 0; }",
    "TOTAL": "out.meta.total"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} template(s) ({{TOTAL}} total).",
      "de": "{{COUNT}} Vorlage(n) gefunden ({{TOTAL}} insgesamt).",
      "es": "Found {{COUNT}} template(s) ({{TOTAL}} total).",
      "fr": "Found {{COUNT}} template(s) ({{TOTAL}} total).",
      "ro": "Found {{COUNT}} template(s) ({{TOTAL}} total).",
      "it": "Found {{COUNT}} template(s) ({{TOTAL}} total)."
    }
  }
}
