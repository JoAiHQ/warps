{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Update Template",
  "title": {
    "en": "Update a template",
    "de": "Vorlage aktualisieren",
    "es": "Update a template",
    "fr": "Update a template",
    "ro": "Update a template",
    "it": "Update a template"
  },
  "description": {
    "en": "Update an existing email template in Mailcoach.",
    "de": "Eine bestehende E-Mail-Vorlage in Mailcoach aktualisieren.",
    "es": "Update an existing email template in Mailcoach.",
    "fr": "Update an existing email template in Mailcoach.",
    "ro": "Update an existing email template in Mailcoach.",
    "it": "Update an existing email template in Mailcoach."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Update Template",
        "de": "Vorlage aktualisieren",
        "es": "Update Template",
        "fr": "Update Template",
        "ro": "Update Template",
        "it": "Update Template"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/templates/{{TEMPLATE_UUID}}",
        "method": "PUT",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Template UUID",
          "as": "TEMPLATE_UUID",
          "description": {
            "en": "The UUID of the template to update.",
            "es": "The UUID of the template to update.",
            "fr": "The UUID of the template to update.",
            "ro": "The UUID of the template to update.",
            "it": "The UUID of the template to update."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": {
            "en": "Name",
            "de": "Name",
            "es": "Name",
            "fr": "Name",
            "ro": "Name",
            "it": "Name"
          },
          "as": {
            "en": "name",
            "de": "name",
            "es": "name",
            "fr": "name",
            "ro": "name",
            "it": "name"
          },
          "description": {
            "en": "The new name for the template.",
            "es": "The new name for the template.",
            "fr": "The new name for the template.",
            "ro": "The new name for the template.",
            "it": "The new name for the template."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:name"
        },
        {
          "name": "HTML",
          "as": {
            "en": "html",
            "de": "html",
            "es": "html",
            "fr": "html",
            "ro": "html",
            "it": "html"
          },
          "description": {
            "en": "The updated HTML content of the template.",
            "es": "The updated HTML content of the template.",
            "fr": "The updated HTML content of the template.",
            "ro": "The updated HTML content of the template.",
            "it": "The updated HTML content of the template."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:html"
        }
      ]
    }
  ],
  "output": {
    "TEMPLATE_UUID": "out.data.uuid",
    "TEMPLATE_NAME": "out.data.name"
  },
  "messages": {
    "success": {
      "en": "Template '{{TEMPLATE_NAME}}' updated.",
      "de": "Vorlage '{{TEMPLATE_NAME}}' aktualisiert.",
      "es": "Template '{{TEMPLATE_NAME}}' updated.",
      "fr": "Template '{{TEMPLATE_NAME}}' updated.",
      "ro": "Template '{{TEMPLATE_NAME}}' updated.",
      "it": "Template '{{TEMPLATE_NAME}}' updated."
    }
  }
}
