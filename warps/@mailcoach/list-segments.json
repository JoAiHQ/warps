{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: List Segments",
  "title": {
    "en": "List segments",
    "de": "Segmente auflisten",
    "es": "List segments",
    "fr": "List segments",
    "ro": "List segments",
    "it": "List segments"
  },
  "description": {
    "en": "Retrieve all segments for a given email list.",
    "de": "Alle Segmente für eine bestimmte E-Mail-Liste abrufen.",
    "es": "Retrieve all segments for a given email list.",
    "fr": "Retrieve all segments for a given email list.",
    "ro": "Retrieve all segments for a given email list.",
    "it": "Retrieve all segments for a given email list."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "List Segments",
        "de": "Segmente abrufen",
        "es": "List Segments",
        "fr": "List Segments",
        "ro": "List Segments",
        "it": "List Segments"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/email-lists/{{LIST_UUID}}/segments",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "List UUID",
          "as": "LIST_UUID",
          "description": {
            "en": "The UUID of the email list.",
            "es": "The UUID of the email list.",
            "fr": "The UUID of the email list.",
            "ro": "The UUID of the email list.",
            "it": "The UUID of the email list."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "SEGMENTS": "out.data",
    "COUNT": "transform:() => { return Array.isArray(out?.data) ? out.data.length : 0; }"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} segment(s).",
      "de": "{{COUNT}} Segment(e) gefunden.",
      "es": "Found {{COUNT}} segment(s).",
      "fr": "Found {{COUNT}} segment(s).",
      "ro": "Found {{COUNT}} segment(s).",
      "it": "Found {{COUNT}} segment(s)."
    }
  }
}
