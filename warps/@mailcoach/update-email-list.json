{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Update Email List",
  "title": {
    "en": "Update an email list",
    "de": "E-Mail-Liste aktualisieren",
    "es": "Update an email list",
    "fr": "Update an email list",
    "ro": "Update an email list",
    "it": "Update an email list"
  },
  "description": {
    "en": "Update settings of an existing Mailcoach email list.",
    "de": "Einstellungen einer bestehenden Mailcoach-E-Mail-Liste aktualisieren.",
    "es": "Update settings of an existing Mailcoach email list.",
    "fr": "Update settings of an existing Mailcoach email list.",
    "ro": "Update settings of an existing Mailcoach email list.",
    "it": "Update settings of an existing Mailcoach email list."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Update Email List",
        "de": "E-Mail-Liste aktualisieren",
        "es": "Update Email List",
        "fr": "Update Email List",
        "ro": "Update Email List",
        "it": "Update Email List"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/email-lists/{{LIST_UUID}}",
        "method": "PUT",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "List UUID",
          "as": "LIST_UUID",
          "description": {
            "en": "The UUID of the email list to update.",
            "es": "The UUID of the email list to update.",
            "fr": "The UUID of the email list to update.",
            "ro": "The UUID of the email list to update.",
            "it": "The UUID of the email list to update."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Name",
          "as": "name",
          "description": {
            "en": "The name of the email list.",
            "es": "The name of the email list.",
            "fr": "The name of the email list.",
            "ro": "The name of the email list.",
            "it": "The name of the email list."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:name",
          "label": {
            "en": "Name",
            "de": "Name",
            "es": "Name",
            "fr": "Name",
            "ro": "Name",
            "it": "Name"
          }
        },
        {
          "name": "Default From Email",
          "as": "default_from_email",
          "description": {
            "en": "The default sender email address.",
            "es": "The default sender email address.",
            "fr": "The default sender email address.",
            "ro": "The default sender email address.",
            "it": "The default sender email address."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:default_from_email"
        },
        {
          "name": "Default From Name",
          "as": "default_from_name",
          "description": {
            "en": "The default sender name.",
            "es": "The default sender name.",
            "fr": "The default sender name.",
            "ro": "The default sender name.",
            "it": "The default sender name."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:default_from_name"
        },
        {
          "name": "Default Reply-To Email",
          "as": "default_reply_to_email",
          "description": {
            "en": "The default reply-to email address.",
            "es": "The default reply-to email address.",
            "fr": "The default reply-to email address.",
            "ro": "The default reply-to email address.",
            "it": "The default reply-to email address."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:default_reply_to_email"
        },
        {
          "name": "Requires Confirmation",
          "as": "requires_confirmation",
          "description": {
            "en": "Whether new subscribers must confirm their subscription.",
            "es": "Whether new subscribers must confirm their subscription.",
            "fr": "Whether new subscribers must confirm their subscription.",
            "ro": "Whether new subscribers must confirm their subscription.",
            "it": "Whether new subscribers must confirm their subscription."
          },
          "type": "boolean",
          "source": "field",
          "required": false,
          "position": "payload:requires_confirmation"
        }
      ]
    }
  ],
  "output": {
    "LIST_UUID": "out.data.uuid",
    "LIST_NAME": "out.data.name"
  },
  "messages": {
    "success": {
      "en": "Email list '{{LIST_NAME}}' updated successfully.",
      "de": "E-Mail-Liste '{{LIST_NAME}}' erfolgreich aktualisiert.",
      "es": "Email list '{{LIST_NAME}}' updated successfully.",
      "fr": "Email list '{{LIST_NAME}}' updated successfully.",
      "ro": "Email list '{{LIST_NAME}}' updated successfully.",
      "it": "Email list '{{LIST_NAME}}' updated successfully."
    }
  }
}
