{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Delete Send",
  "title": {
    "en": "Delete a send record",
    "de": "Versendungsdatensatz löschen",
    "es": "Delete a send record",
    "fr": "Delete a send record",
    "ro": "Delete a send record",
    "it": "Delete a send record"
  },
  "description": {
    "en": "Delete a send record from Mailcoach.",
    "de": "Einen Versendungsdatensatz aus Mailcoach löschen.",
    "es": "Delete a send record from Mailcoach.",
    "fr": "Delete a send record from Mailcoach.",
    "ro": "Delete a send record from Mailcoach.",
    "it": "Delete a send record from Mailcoach."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Delete Send",
        "de": "Versendung löschen",
        "es": "Delete Send",
        "fr": "Delete Send",
        "ro": "Delete Send",
        "it": "Delete Send"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/sends/{{SEND_UUID}}",
        "method": "DELETE",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Send UUID",
          "as": "SEND_UUID",
          "description": {
            "en": "The UUID of the send record to delete.",
            "es": "The UUID of the send record to delete.",
            "fr": "The UUID of the send record to delete.",
            "ro": "The UUID of the send record to delete.",
            "it": "The UUID of the send record to delete."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {},
  "messages": {
    "success": {
      "en": "Send record {{SEND_UUID}} has been deleted.",
      "de": "Versendungsdatensatz {{SEND_UUID}} wurde gelöscht.",
      "es": "Send record {{SEND_UUID}} has been deleted.",
      "fr": "Send record {{SEND_UUID}} has been deleted.",
      "ro": "Send record {{SEND_UUID}} has been deleted.",
      "it": "Send record {{SEND_UUID}} has been deleted."
    }
  }
}
