{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Delete Subscriber",
  "title": {
    "en": "Delete a subscriber",
    "de": "Abonnenten löschen",
    "es": "Delete a subscriber",
    "fr": "Delete a subscriber",
    "ro": "Delete a subscriber",
    "it": "Delete a subscriber"
  },
  "description": {
    "en": "Permanently delete a subscriber from Mailcoach.",
    "de": "Einen Abonnenten dauerhaft aus Mailcoach löschen.",
    "es": "Permanently delete a subscriber from Mailcoach.",
    "fr": "Permanently delete a subscriber from Mailcoach.",
    "ro": "Permanently delete a subscriber from Mailcoach.",
    "it": "Permanently delete a subscriber from Mailcoach."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Delete Subscriber",
        "de": "Abonnenten löschen",
        "es": "Delete Subscriber",
        "fr": "Delete Subscriber",
        "ro": "Delete Subscriber",
        "it": "Delete Subscriber"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/subscribers/{{SUBSCRIBER_UUID}}",
        "method": "DELETE",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Subscriber UUID",
          "as": "SUBSCRIBER_UUID",
          "description": {
            "en": "The UUID of the subscriber to delete.",
            "es": "The UUID of the subscriber to delete.",
            "fr": "The UUID of the subscriber to delete.",
            "ro": "The UUID of the subscriber to delete.",
            "it": "The UUID of the subscriber to delete."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {},
  "messages": {
    "success": {
      "en": "Subscriber {{SUBSCRIBER_UUID}} has been deleted.",
      "de": "Abonnent {{SUBSCRIBER_UUID}} wurde gelöscht.",
      "es": "Subscriber {{SUBSCRIBER_UUID}} has been deleted.",
      "fr": "Subscriber {{SUBSCRIBER_UUID}} has been deleted.",
      "ro": "Subscriber {{SUBSCRIBER_UUID}} has been deleted.",
      "it": "Subscriber {{SUBSCRIBER_UUID}} has been deleted."
    }
  }
}
