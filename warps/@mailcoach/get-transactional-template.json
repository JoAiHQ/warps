{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Get Transactional Template",
  "title": {
    "en": "Get a transactional template",
    "de": "Transaktionsvorlage abrufen",
    "es": "Get a transactional template",
    "fr": "Get a transactional template",
    "ro": "Get a transactional template",
    "it": "Get a transactional template"
  },
  "description": {
    "en": "Retrieve a specific transactional email template by UUID.",
    "de": "Eine bestimmte Transaktions-E-Mail-Vorlage anhand der UUID abrufen.",
    "es": "Retrieve a specific transactional email template by UUID.",
    "fr": "Retrieve a specific transactional email template by UUID.",
    "ro": "Retrieve a specific transactional email template by UUID.",
    "it": "Retrieve a specific transactional email template by UUID."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Transactional Template",
        "de": "Transaktionsvorlage abrufen",
        "es": "Get Transactional Template",
        "fr": "Get Transactional Template",
        "ro": "Get Transactional Template",
        "it": "Get Transactional Template"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/transactional-mails/templates/{{TEMPLATE_UUID}}",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Template UUID",
          "as": "TEMPLATE_UUID",
          "description": {
            "en": "The UUID of the transactional template.",
            "es": "The UUID of the transactional template.",
            "fr": "The UUID of the transactional template.",
            "ro": "The UUID of the transactional template.",
            "it": "The UUID of the transactional template."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "TEMPLATE_DATA": "out.data",
    "TEMPLATE_NAME": "out.data.name"
  },
  "messages": {
    "success": {
      "en": "Retrieved transactional template '{{TEMPLATE_NAME}}'.",
      "de": "Transaktionsvorlage '{{TEMPLATE_NAME}}' abgerufen.",
      "es": "Retrieved transactional template '{{TEMPLATE_NAME}}'.",
      "fr": "Retrieved transactional template '{{TEMPLATE_NAME}}'.",
      "ro": "Retrieved transactional template '{{TEMPLATE_NAME}}'.",
      "it": "Retrieved transactional template '{{TEMPLATE_NAME}}'."
    }
  }
}
