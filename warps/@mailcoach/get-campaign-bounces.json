{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Get Campaign Bounces",
  "title": {
    "en": "Get campaign bounces",
    "de": "Kampagnen-Bounces abrufen",
    "es": "Get campaign bounces",
    "fr": "Get campaign bounces",
    "ro": "Get campaign bounces",
    "it": "Get campaign bounces"
  },
  "description": {
    "en": "Retrieve the bounces report for a campaign. Filter by type: bounce, soft_bounce, complaint.",
    "de": "Den Bounce-Bericht einer Kampagne abrufen. Nach Typ filtern: bounce, soft_bounce, complaint.",
    "es": "Retrieve the bounces report for a campaign. Filter by type: bounce, soft_bounce, complaint.",
    "fr": "Retrieve the bounces report for a campaign. Filter by type: bounce, soft_bounce, complaint.",
    "ro": "Retrieve the bounces report for a campaign. Filter by type: bounce, soft_bounce, complaint.",
    "it": "Retrieve the bounces report for a campaign. Filter by type: bounce, soft_bounce, complaint."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Bounces",
        "de": "Bounces abrufen",
        "es": "Get Bounces",
        "fr": "Get Bounces",
        "ro": "Get Bounces",
        "it": "Get Bounces"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/campaigns/{{CAMPAIGN_UUID}}/bounces",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Campaign UUID",
          "as": "CAMPAIGN_UUID",
          "description": {
            "en": "The UUID of the campaign.",
            "es": "The UUID of the campaign.",
            "fr": "The UUID of the campaign.",
            "ro": "The UUID of the campaign.",
            "it": "The UUID of the campaign."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Type",
          "as": "filter[type]",
          "description": {
            "en": "Filter by bounce type: bounce, soft_bounce, complaint.",
            "es": "Filter by bounce type: bounce, soft_bounce, complaint.",
            "fr": "Filter by bounce type: bounce, soft_bounce, complaint.",
            "ro": "Filter by bounce type: bounce, soft_bounce, complaint.",
            "it": "Filter by bounce type: bounce, soft_bounce, complaint."
          },
          "type": "string",
          "source": "field",
          "position": "query:filter[type]",
          "required": false,
          "label": {
            "en": "Type",
            "de": "Type",
            "es": "Type",
            "fr": "Type",
            "ro": "Type",
            "it": "Type"
          }
        },
        {
          "name": "Per Page",
          "as": "per_page",
          "description": {
            "en": "Number of results per page.",
            "es": "Number of results per page.",
            "fr": "Number of results per page.",
            "ro": "Number of results per page.",
            "it": "Number of results per page."
          },
          "type": "number",
          "source": "field",
          "position": "query:per_page",
          "required": false
        }
      ]
    }
  ],
  "output": {
    "BOUNCES": "out.data",
    "COUNT": "transform:() => { return Array.isArray(out?.data) ? out.data.length : 0; }",
    "TOTAL": "out.meta.total"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} bounce(s) ({{TOTAL}} total).",
      "de": "{{COUNT}} Bounce(s) gefunden ({{TOTAL}} insgesamt).",
      "es": "Found {{COUNT}} bounce(s) ({{TOTAL}} total).",
      "fr": "Found {{COUNT}} bounce(s) ({{TOTAL}} total).",
      "ro": "Found {{COUNT}} bounce(s) ({{TOTAL}} total).",
      "it": "Found {{COUNT}} bounce(s) ({{TOTAL}} total)."
    }
  }
}
