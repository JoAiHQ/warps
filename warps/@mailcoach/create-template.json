{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Create Template",
  "title": {
    "en": "Create a template",
    "de": "Vorlage erstellen",
    "es": "Create a template",
    "fr": "Create a template",
    "ro": "Create a template",
    "it": "Create a template"
  },
  "description": {
    "en": "Create a new reusable email template in Mailcoach.",
    "de": "Eine neue wiederverwendbare E-Mail-Vorlage in Mailcoach erstellen.",
    "es": "Create a new reusable email template in Mailcoach.",
    "fr": "Create a new reusable email template in Mailcoach.",
    "ro": "Create a new reusable email template in Mailcoach.",
    "it": "Create a new reusable email template in Mailcoach."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create Template",
        "de": "Vorlage erstellen",
        "es": "Create Template",
        "fr": "Create Template",
        "ro": "Create Template",
        "it": "Create Template"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/templates",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": {
            "en": "Name",
            "de": "Name",
            "es": "Name",
            "fr": "Name",
            "ro": "Name",
            "it": "Name"
          },
          "as": {
            "en": "name",
            "de": "name",
            "es": "name",
            "fr": "name",
            "ro": "name",
            "it": "name"
          },
          "description": {
            "en": "The name of the template.",
            "es": "The name of the template.",
            "fr": "The name of the template.",
            "ro": "The name of the template.",
            "it": "The name of the template."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:name"
        },
        {
          "name": "HTML",
          "as": {
            "en": "html",
            "de": "html",
            "es": "html",
            "fr": "html",
            "ro": "html",
            "it": "html"
          },
          "description": {
            "en": "The HTML content of the template.",
            "es": "The HTML content of the template.",
            "fr": "The HTML content of the template.",
            "ro": "The HTML content of the template.",
            "it": "The HTML content of the template."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:html"
        }
      ]
    }
  ],
  "output": {
    "TEMPLATE_UUID": "out.data.uuid",
    "TEMPLATE_NAME": "out.data.name"
  },
  "messages": {
    "success": {
      "en": "Template '{{TEMPLATE_NAME}}' created! UUID: {{TEMPLATE_UUID}}",
      "de": "Vorlage '{{TEMPLATE_NAME}}' erstellt! UUID: {{TEMPLATE_UUID}}",
      "es": "Template '{{TEMPLATE_NAME}}' created! UUID: {{TEMPLATE_UUID}}",
      "fr": "Template '{{TEMPLATE_NAME}}' created! UUID: {{TEMPLATE_UUID}}",
      "ro": "Template '{{TEMPLATE_NAME}}' created! UUID: {{TEMPLATE_UUID}}",
      "it": "Template '{{TEMPLATE_NAME}}' created! UUID: {{TEMPLATE_UUID}}"
    }
  }
}
