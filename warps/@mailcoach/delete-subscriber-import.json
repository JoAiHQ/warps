{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Delete Subscriber Import",
  "title": {
    "en": "Delete a subscriber import",
    "de": "Abonnenten-Import löschen",
    "es": "Delete a subscriber import",
    "fr": "Delete a subscriber import",
    "ro": "Delete a subscriber import",
    "it": "Delete a subscriber import"
  },
  "description": {
    "en": "Delete a subscriber import from Mailcoach.",
    "de": "Einen Abonnenten-Import aus Mailcoach löschen.",
    "es": "Delete a subscriber import from Mailcoach.",
    "fr": "Delete a subscriber import from Mailcoach.",
    "ro": "Delete a subscriber import from Mailcoach.",
    "it": "Delete a subscriber import from Mailcoach."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Delete Import",
        "de": "Import löschen",
        "es": "Delete Import",
        "fr": "Delete Import",
        "ro": "Delete Import",
        "it": "Delete Import"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/subscriber-imports/{{IMPORT_UUID}}",
        "method": "DELETE",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Import UUID",
          "as": "IMPORT_UUID",
          "description": {
            "en": "The UUID of the subscriber import to delete.",
            "es": "The UUID of the subscriber import to delete.",
            "fr": "The UUID of the subscriber import to delete.",
            "ro": "The UUID of the subscriber import to delete.",
            "it": "The UUID of the subscriber import to delete."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {},
  "messages": {
    "success": {
      "en": "Subscriber import {{IMPORT_UUID}} has been deleted.",
      "de": "Abonnenten-Import {{IMPORT_UUID}} wurde gelöscht.",
      "es": "Subscriber import {{IMPORT_UUID}} has been deleted.",
      "fr": "Subscriber import {{IMPORT_UUID}} has been deleted.",
      "ro": "Subscriber import {{IMPORT_UUID}} has been deleted.",
      "it": "Subscriber import {{IMPORT_UUID}} has been deleted."
    }
  }
}
