{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: Get Send",
  "title": {
    "en": "Get a send record",
    "de": "Versendungsdatensatz abrufen",
    "es": "Get a send record",
    "fr": "Get a send record",
    "ro": "Get a send record",
    "it": "Get a send record"
  },
  "description": {
    "en": "Retrieve a specific send record including open and click engagement metrics.",
    "de": "Einen bestimmten Versendungsdatensatz einschließlich Öffnungs- und Klick-Engagement-Metriken abrufen.",
    "es": "Retrieve a specific send record including open and click engagement metrics.",
    "fr": "Retrieve a specific send record including open and click engagement metrics.",
    "ro": "Retrieve a specific send record including open and click engagement metrics.",
    "it": "Retrieve a specific send record including open and click engagement metrics."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Send",
        "de": "Versendung abrufen",
        "es": "Get Send",
        "fr": "Get Send",
        "ro": "Get Send",
        "it": "Get Send"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/sends/{{SEND_UUID}}",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Send UUID",
          "as": "SEND_UUID",
          "description": {
            "en": "The UUID of the send record.",
            "es": "The UUID of the send record.",
            "fr": "The UUID of the send record.",
            "ro": "The UUID of the send record.",
            "it": "The UUID of the send record."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "SEND_DATA": "out.data",
    "OPEN_COUNT": "out.data.open_count",
    "CLICK_COUNT": "out.data.click_count",
    "FAILURE_REASON": "out.data.failure_reason"
  },
  "messages": {
    "success": {
      "en": "Send record retrieved. Opens: {{OPEN_COUNT}}, Clicks: {{CLICK_COUNT}}.",
      "de": "Versendungsdatensatz abgerufen. Öffnungen: {{OPEN_COUNT}}, Klicks: {{CLICK_COUNT}}.",
      "es": "Send record retrieved. Opens: {{OPEN_COUNT}}, Clicks: {{CLICK_COUNT}}.",
      "fr": "Send record retrieved. Opens: {{OPEN_COUNT}}, Clicks: {{CLICK_COUNT}}.",
      "ro": "Send record retrieved. Opens: {{OPEN_COUNT}}, Clicks: {{CLICK_COUNT}}.",
      "it": "Send record retrieved. Opens: {{OPEN_COUNT}}, Clicks: {{CLICK_COUNT}}."
    }
  }
}
