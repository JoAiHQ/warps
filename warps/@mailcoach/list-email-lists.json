{
  "protocol": "warp:3.0.0",
  "name": "Mailcoach: List Email Lists",
  "title": {
    "en": "List email lists",
    "de": "E-Mail-Listen auflisten",
    "es": "List email lists",
    "fr": "List email lists",
    "ro": "List email lists",
    "it": "List email lists"
  },
  "description": {
    "en": "Retrieve all email lists in your Mailcoach account. Supports search filtering and sorting.",
    "de": "Alle E-Mail-Listen in deinem Mailcoach-Konto abrufen. Unterstützt Suchfilter und Sortierung.",
    "es": "Retrieve all email lists in your Mailcoach account. Supports search filtering and sorting.",
    "fr": "Retrieve all email lists in your Mailcoach account. Supports search filtering and sorting.",
    "ro": "Retrieve all email lists in your Mailcoach account. Supports search filtering and sorting.",
    "it": "Retrieve all email lists in your Mailcoach account. Supports search filtering and sorting."
  },
  "vars": {
    "API_TOKEN": "env:MAILCOACH_API_TOKEN|Your Mailcoach API token from /settings/account/tokens",
    "MAILCOACH_URL": "env:MAILCOACH_URL|Your Mailcoach base URL (e.g. https://yourapp.mailcoach.app)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "List Email Lists",
        "de": "E-Mail-Listen abrufen",
        "es": "List Email Lists",
        "fr": "List Email Lists",
        "ro": "List Email Lists",
        "it": "List Email Lists"
      },
      "destination": {
        "url": "{{MAILCOACH_URL}}/api/email-lists",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}",
          "Accept": "application/json",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Search",
          "as": "filter[search]",
          "description": {
            "en": "Filter lists by search term.",
            "es": "Filter lists by search term.",
            "fr": "Filter lists by search term.",
            "ro": "Filter lists by search term.",
            "it": "Filter lists by search term."
          },
          "type": "string",
          "source": "field",
          "position": "query:filter[search]",
          "required": false,
          "label": {
            "en": "Search",
            "de": "Search",
            "es": "Buscar",
            "fr": "Recherche",
            "ro": "Căutare",
            "it": "Ricerca"
          }
        },
        {
          "name": "Sort",
          "as": "sort",
          "description": {
            "en": "Sort by field: name, created_at, active_subscribers_count. Prefix with - for descending.",
            "es": "Sort by field: name, created_at, active_subscribers_count. Prefix with - for descending.",
            "fr": "Sort by field: name, created_at, active_subscribers_count. Prefix with - for descending.",
            "ro": "Sort by field: name, created_at, active_subscribers_count. Prefix with - for descending.",
            "it": "Sort by field: name, created_at, active_subscribers_count. Prefix with - for descending."
          },
          "type": "string",
          "source": "field",
          "position": "query:sort",
          "required": false,
          "label": {
            "en": "Sort",
            "de": "Sort",
            "es": "Sort",
            "fr": "Sort",
            "ro": "Sort",
            "it": "Sort"
          }
        },
        {
          "name": "Per Page",
          "as": "per_page",
          "description": {
            "en": "Number of results per page.",
            "es": "Number of results per page.",
            "fr": "Number of results per page.",
            "ro": "Number of results per page.",
            "it": "Number of results per page."
          },
          "type": "number",
          "source": "field",
          "position": "query:per_page",
          "required": false
        }
      ]
    }
  ],
  "output": {
    "LISTS": "out.data",
    "COUNT": "transform:() => { return Array.isArray(out?.data) ? out.data.length : 0; }",
    "TOTAL": "out.meta.total"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} email list(s) ({{TOTAL}} total).",
      "de": "{{COUNT}} E-Mail-Liste(n) gefunden ({{TOTAL}} insgesamt).",
      "es": "Found {{COUNT}} email list(s) ({{TOTAL}} total).",
      "fr": "Found {{COUNT}} email list(s) ({{TOTAL}} total).",
      "ro": "Found {{COUNT}} email list(s) ({{TOTAL}} total).",
      "it": "Found {{COUNT}} email list(s) ({{TOTAL}} total)."
    }
  }
}
