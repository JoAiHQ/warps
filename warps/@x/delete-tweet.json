{
  "protocol": "warp:3.0.0",
  "name": "X: Delete Tweet",
  "title": {
    "en": "Delete a tweet",
    "de": "Einen Tweet löschen",
    "es": "Eliminar un tuit",
    "fr": "Supprimer un tweet",
    "ro": "Ștergeți un tweet",
    "it": "Elimina un tweet"
  },
  "description": {
    "en": "Delete a tweet from X.com.",
    "de": "Einen Tweet von X.com löschen.",
    "es": "Eliminar un tweet de X.com.",
    "fr": "Supprimez un tweet de X.com.",
    "ro": "Ștergeți un tweet de pe X.com.",
    "it": "Elimina un tweet da X.com."
  },
  "vars": {
    "ACCESS_TOKEN": "env:X_ACCESS_TOKEN|OAuth 2.0 user access token with tweet.write scope from the X Developer Portal."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Delete Tweet",
      "destination": {
        "url": "https://api.x.com/2/tweets/{{TWEET_ID}}",
        "method": "DELETE",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Tweet ID",
          "as": "TWEET_ID",
          "description": {
            "en": "The ID of the tweet to delete.",
            "es": "El ID del tweet a eliminar.",
            "fr": "L'ID du tweet à supprimer.",
            "ro": "ID-ul tweet-ului de șters.",
            "it": "L'ID del tweet da eliminare."
          },
          "bot": "The numeric ID of the tweet to delete.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:TWEET_ID"
        }
      ]
    }
  ],
  "output": {
    "DELETED": "out.data.deleted"
  },
  "messages": {
    "success": {
      "en": "Tweet deleted.",
      "de": "Tweet gelöscht.",
      "es": "Tweet eliminado.",
      "fr": "Tweet supprimé.",
      "ro": "Tweetul a fost șters.",
      "it": "Tweet cancellato."
    }
  }
}
