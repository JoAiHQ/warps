{
  "protocol": "warp:3.0.0",
  "name": "X: List User Tweets",
  "title": {
    "en": "List user's tweets",
    "de": "Tweets eines Benutzers auflisten",
    "es": "Listar los tweets del usuario",
    "fr": "Répertorier les tweets de l'utilisateur",
    "ro": "Listați tweet-urile utilizatorului",
    "it": "Elenca i tweet dell'utente"
  },
  "description": {
    "en": "List recent tweets posted by a user on X.com, including engagement metrics.",
    "de": "Aktuelle Tweets eines Benutzers auf X.com auflisten, einschließlich Engagement-Metriken.",
    "es": "Enumere los tweets recientes publicados por un usuario en X.com, incluidas las métricas de participación.",
    "fr": "Répertoriez les tweets récents publiés par un utilisateur sur X.com, y compris les mesures d'engagement.",
    "ro": "Enumerați tweet-urile recente postate de un utilizator pe X.com, inclusiv valorile de implicare.",
    "it": "Elenca i tweet recenti pubblicati da un utente su X.com, comprese le metriche di coinvolgimento."
  },
  "vars": {
    "ACCESS_TOKEN": "env:X_ACCESS_TOKEN|OAuth 2.0 access token from the X Developer Portal."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Tweets",
      "destination": {
        "url": "https://api.x.com/2/users/{{USER_ID}}/tweets",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "User ID",
          "as": "USER_ID",
          "description": {
            "en": "The X user ID (numeric).",
            "es": "El ID de usuario X (numérico).",
            "fr": "L'ID utilisateur X (numérique).",
            "ro": "ID-ul utilizatorului X (numeric).",
            "it": "L'ID utente X (numerico)."
          },
          "bot": "The numeric X/Twitter user ID. Use the get-user warp to look up a user ID from a username.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:USER_ID"
        },
        {
          "name": "Max Results",
          "as": "maxResults",
          "description": {
            "en": "Number of tweets to return (5-100).",
            "es": "Número de tweets a devolver (5-100).",
            "fr": "Nombre de tweets à renvoyer (5-100).",
            "ro": "Numărul de tweet-uri de returnat (5-100).",
            "it": "Numero di tweet da restituire (5-100)."
          },
          "bot": "Number of tweets to return, between 5 and 100.",
          "type": "number",
          "source": "field",
          "position": "query:max_results",
          "default": "10"
        },
        {
          "name": "Tweet Fields",
          "as": "tweetFields",
          "type": "string",
          "source": "hidden",
          "position": "query:tweet.fields",
          "default": "created_at,public_metrics,text"
        }
      ]
    }
  ],
  "output": {
    "TWEETS": "out.data",
    "COUNT": "out.meta.result_count"
  },
  "messages": {
    "success": {
      "en": "Retrieved {{COUNT}} tweet(s).",
      "de": "{{COUNT}} Tweet(s) abgerufen.",
      "es": "Recuperados {{COUNT}} tweet(s).",
      "fr": "{{COUNT}} tweet(s) récupéré(s).",
      "ro": "Au fost preluate {{COUNT}} tweet(uri).",
      "it": "{{COUNT}} tweet recuperati."
    }
  }
}
