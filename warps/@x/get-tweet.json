{
  "protocol": "warp:3.0.0",
  "name": "X: Get Tweet",
  "title": {
    "en": "Get tweet details",
    "de": "Tweet-Details abrufen",
    "es": "Obtener detalles del tweet",
    "fr": "Obtenir les détails du tweet",
    "ro": "Obțineți detalii despre tweet",
    "it": "Ottieni i dettagli del tweet"
  },
  "description": {
    "en": "Get a tweet's details and engagement metrics from X.com.",
    "de": "Details und Engagement-Metriken eines Tweets von X.com abrufen.",
    "es": "Obtenga los detalles de un tweet y las métricas de participación de X.com.",
    "fr": "Obtenez les détails d'un tweet et les mesures d'engagement sur X.com.",
    "ro": "Obțineți detaliile unui tweet și valorile de implicare de la X.com.",
    "it": "Ottieni i dettagli di un tweet e le metriche di coinvolgimento da X.com."
  },
  "vars": {
    "ACCESS_TOKEN": "env:X_ACCESS_TOKEN|OAuth 2.0 access token from the X Developer Portal."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Get Tweet",
      "destination": {
        "url": "https://api.x.com/2/tweets/{{TWEET_ID}}",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Tweet ID",
          "as": "TWEET_ID",
          "description": {
            "en": "The ID of the tweet.",
            "es": "El ID del tweet.",
            "fr": "L'identifiant du tweet.",
            "ro": "ID-ul tweet-ului.",
            "it": "L'ID del tweet."
          },
          "bot": "The numeric tweet ID.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:TWEET_ID"
        },
        {
          "name": "Tweet Fields",
          "as": "tweetFields",
          "type": "string",
          "source": "hidden",
          "position": "query:tweet.fields",
          "default": "created_at,public_metrics,text,author_id,conversation_id"
        },
        {
          "name": "Expansions",
          "as": "expansions",
          "type": "string",
          "source": "hidden",
          "position": "query:expansions",
          "default": "author_id"
        },
        {
          "name": "User Fields",
          "as": "userFields",
          "type": "string",
          "source": "hidden",
          "position": "query:user.fields",
          "default": "name,username"
        }
      ]
    }
  ],
  "output": {
    "TEXT": "out.data.text",
    "AUTHOR_ID": "out.data.author_id",
    "LIKES": "out.data.public_metrics.like_count",
    "RETWEETS": "out.data.public_metrics.retweet_count",
    "REPLIES": "out.data.public_metrics.reply_count",
    "QUOTES": "out.data.public_metrics.quote_count",
    "IMPRESSIONS": "out.data.public_metrics.impression_count",
    "BOOKMARKS": "out.data.public_metrics.bookmark_count",
    "CREATED_AT": "out.data.created_at"
  },
  "messages": {
    "success": {
      "en": "Tweet: {{TEXT}} — Likes: {{LIKES}}, Retweets: {{RETWEETS}}, Replies: {{REPLIES}}, Impressions: {{IMPRESSIONS}}",
      "de": "Tweet: {{TEXT}} — Likes: {{LIKES}}, Retweets: {{RETWEETS}}, Antworten: {{REPLIES}}, Impressionen: {{IMPRESSIONS}}",
      "es": "Tweet: {{TEXT}} — Me gusta: {{LIKES}}, Retweets: {{RETWEETS}}, Respuestas: {{REPLIES}}, Impresiones: {{IMPRESSIONS}}",
      "fr": "Tweet : {{TEXT}} — J'aime : {{LIKES}}, Retweets : {{RETWEETS}}, Réponses : {{REPLIES}}, Impressions : {{IMPRESSIONS}}",
      "ro": "Tweet: {{TEXT}} — Aprecieri: {{LIKES}}, Retweets: {{RETWEETS}}, Răspunsuri: {{REPLIES}}, Afișări: {{IMPRESSIONS}}",
      "it": "Tweet: {{TEXT}} — Mi piace: {{LIKES}}, Retweet: {{RETWEETS}}, Risposte: {{REPLIES}}, Impressioni: {{IMPRESSIONS}}"
    }
  }
}
