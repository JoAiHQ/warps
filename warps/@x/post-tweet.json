{
  "protocol": "warp:3.0.0",
  "name": "X: Post Tweet",
  "title": {
    "en": "Post a tweet",
    "de": "Einen Tweet posten",
    "es": "Publicar un tweet",
    "fr": "Publier un tweet",
    "ro": "Postează un tweet",
    "it": "Pubblica un tweet"
  },
  "description": {
    "en": "Post a new tweet on X.com (Twitter).",
    "de": "Einen neuen Tweet auf X.com (Twitter) veröffentlichen.",
    "es": "Publique un nuevo tweet en X.com (Twitter).",
    "fr": "Postez un nouveau tweet sur X.com (Twitter).",
    "ro": "Postați un tweet nou pe X.com (Twitter).",
    "it": "Pubblica un nuovo tweet su X.com (Twitter)."
  },
  "vars": {
    "ACCESS_TOKEN": "env:X_ACCESS_TOKEN|OAuth 2.0 user access token with tweet.write scope from the X Developer Portal."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Post Tweet",
      "destination": {
        "url": "https://api.x.com/2/tweets",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Text",
          "as": "text",
          "description": {
            "en": "The text of the tweet (max 280 characters).",
            "es": "El texto del tweet (máximo 280 caracteres).",
            "fr": "Le texte du tweet (max 280 caractères).",
            "ro": "Textul tweet-ului (maximum 280 de caractere).",
            "it": "Il testo del tweet (max 280 caratteri)."
          },
          "bot": "The tweet text content. Max 280 characters. Can include hashtags, mentions, and URLs.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:text",
          "label": {
            "en": "Text",
            "de": "Text",
            "es": "Text",
            "fr": "Text",
            "ro": "Text",
            "it": "Text"
          }
        },
        {
          "name": "Reply To",
          "as": "replyTo",
          "description": {
            "en": "Tweet ID to reply to (optional).",
            "es": "ID del Tweet al que responder (opcional).",
            "fr": "Identifiant du tweet auquel répondre (facultatif).",
            "ro": "Tweet ID la care să răspundeți (opțional).",
            "it": "ID del tweet a cui rispondere (facoltativo)."
          },
          "bot": "If this tweet is a reply, provide the ID of the tweet being replied to.",
          "type": "string",
          "source": "field",
          "position": "payload:reply.in_reply_to_tweet_id"
        },
        {
          "name": "Quote Tweet ID",
          "as": "quoteTweetId",
          "description": {
            "en": "Tweet ID to quote (optional).",
            "es": "ID del tweet para citar (opcional).",
            "fr": "Identifiant du tweet à citer (facultatif).",
            "ro": "Tweet ID pentru a cita (opțional).",
            "it": "ID del tweet per citare (facoltativo)."
          },
          "bot": "If this is a quote tweet, provide the ID of the tweet being quoted.",
          "type": "string",
          "source": "field",
          "position": "payload:quote_tweet_id"
        }
      ]
    }
  ],
  "output": {
    "TWEET_ID": "out.data.id",
    "TWEET_TEXT": "out.data.text"
  },
  "messages": {
    "success": {
      "en": "Tweet posted! ID: {{TWEET_ID}}",
      "de": "Tweet gepostet! ID: {{TWEET_ID}}",
      "es": "¡Tuiteo publicado! Identificación: {{TWEET_ID}}",
      "fr": "Tweet posté ! ID : {{TWEET_ID}}",
      "ro": "Tweet postat! ID: {{TWEET_ID}}",
      "it": "Tweet pubblicato! ID: {{TWEET_ID}}"
    }
  }
}
