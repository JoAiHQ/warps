{
  "protocol": "warp:3.0.0",
  "name": "Anthropic (Claude Code): Add Follow-up",
  "title": {
    "en": "Add follow-up (Claude Code)"
  },
  "description": {
    "en": "Send a follow-up instruction through Claude Code print mode."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Add Follow-up"
      },
      "prompt": "/claude --print --output-format json \"$(cat <<'JOAI_PROMPT'\nFor run ID {{RUN_ID}}, continue with this follow-up:\n{{FOLLOWUP}}\nJOAI_PROMPT\n)\"",
      "inputs": [
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "Run identifier to continue."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Follow-up",
          "as": "FOLLOWUP",
          "description": {
            "en": "Additional instruction for Claude Code."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "in.RUN_ID",
    "RUN_STATUS": "transform:() => 'submitted'",
    "SUMMARY": "transform:() => 'Follow-up submitted to Claude Code.'"
  },
  "messages": {
    "success": {
      "en": "Follow-up submitted for {{RUN_ID}}."
    }
  }
}
