{
  "protocol": "warp:3.0.0",
  "name": "Anthropic (Claude Code): Add Follow-up",
  "title": {
    "en": "Add follow-up (Claude Code)",
    "es": "Agregar seguimiento (Código Claude)",
    "fr": "Ajouter un suivi (Claude Code)",
    "ro": "Adăugați o continuare (Claude Code)",
    "it": "Aggiungi follow-up (codice Claude)"
  },
  "description": {
    "en": "Send a follow-up instruction through Claude Code print mode.",
    "es": "Envíe una instrucción de seguimiento a través del modo de impresión Claude Code.",
    "fr": "Envoyez une instruction de suivi via le mode d’impression Claude Code.",
    "ro": "Trimiteți o instrucțiune ulterioară prin modul de imprimare Claude Code.",
    "it": "Invia un'istruzione di follow-up tramite la modalità di stampa del codice Claude."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Add Follow-up",
        "es": "Agregar seguimiento",
        "fr": "Ajouter un suivi",
        "ro": "Adăugați urmărire",
        "it": "Aggiungi follow-up"
      },
      "prompt": "/claude --print --output-format json \"$(cat <<'JOAI_PROMPT'\nFor run ID {{RUN_ID}}, continue with this follow-up:\n{{FOLLOWUP}}\nJOAI_PROMPT\n)\"",
      "inputs": [
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "Run identifier to continue.",
            "es": "Ejecute el identificador para continuar.",
            "fr": "Exécutez l'identifiant pour continuer.",
            "ro": "Rulați identificatorul pentru a continua.",
            "it": "Esegui identificatore per continuare."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Follow-up",
          "as": "FOLLOWUP",
          "description": {
            "en": "Additional instruction for Claude Code.",
            "es": "Instrucción adicional para Claude Code.",
            "fr": "Instruction complémentaire pour Claude Code.",
            "ro": "Instrucțiuni suplimentare pentru Claude Code.",
            "it": "Istruzioni aggiuntive per Claude Code."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "in.RUN_ID",
    "RUN_STATUS": "transform:() => 'submitted'",
    "SUMMARY": "transform:() => 'Follow-up submitted to Claude Code.'"
  },
  "messages": {
    "success": {
      "en": "Follow-up submitted for {{RUN_ID}}.",
      "es": "Seguimiento enviado para {{RUN_ID}}.",
      "fr": "Suivi soumis pour {{RUN_ID}}.",
      "ro": "Urmărire trimisă pentru {{RUN_ID}}.",
      "it": "Follow-up inviato per {{RUN_ID}}."
    }
  }
}
