{
  "protocol": "warp:3.0.0",
  "name": "Anthropic: Add Followup",
  "title": {
    "en": "Add followup",
    "es": "Agregar seguimiento",
    "fr": "Ajouter un suivi",
    "ro": "Adăugați continuarea",
    "it": "Aggiungi il follow-up"
  },
  "description": {
    "en": "Launch a followup Anthropic run using Message Batches.",
    "es": "Inicie una ejecución antrópica de seguimiento utilizando Message Batches.",
    "fr": "Lancez une exécution Anthropique de suivi à l'aide de lots de messages.",
    "ro": "Lansați o rulare antropică ulterioară folosind Loturi de mesaje.",
    "it": "Avvia una corsa Anthropic di follow-up utilizzando i batch di messaggi."
  },
  "vars": {
    "API_KEY": "env:ANTHROPIC_API_KEY|Anthropic API key"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Add Followup",
        "es": "Agregar seguimiento",
        "fr": "Ajouter un suivi",
        "ro": "Adăugați urmărire",
        "it": "Aggiungi follow-up"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/messages/batches",
        "method": "POST",
        "headers": {
          "x-api-key": "{{API_KEY}}",
          "anthropic-version": "2023-06-01",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "Previous run ID for traceability.",
            "es": "ID de ejecución anterior para trazabilidad.",
            "fr": "ID d’exécution précédente pour la traçabilité.",
            "ro": "ID-ul rulării anterioare pentru trasabilitate.",
            "it": "ID esecuzione precedente per la tracciabilità."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:requests.0.custom_id"
        },
        {
          "name": "Followup",
          "as": "FOLLOWUP",
          "description": {
            "en": "Followup instruction.",
            "es": "Instrucción de seguimiento.",
            "fr": "Instruction de suivi.",
            "ro": "Instrucțiuni ulterioare.",
            "it": "Istruzioni di follow-up."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:requests.0.params.messages.0.content"
        },
        {
          "name": "Model",
          "as": "MODEL",
          "description": {
            "en": "Anthropic model to use.",
            "es": "Modelo antrópico a utilizar.",
            "fr": "Modèle anthropique à utiliser.",
            "ro": "Model antropic de utilizat.",
            "it": "Modello antropico da utilizzare."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "default": "claude-sonnet-4-5",
          "position": "payload:requests.0.params.model"
        },
        {
          "name": "Max Tokens",
          "as": "MAX_TOKENS",
          "description": {
            "en": "Maximum output tokens.",
            "es": "Tokens de salida máximos.",
            "fr": "Jetons de sortie maximum.",
            "ro": "Jetoane de ieșire maxime.",
            "it": "Token di output massimo."
          },
          "type": "number",
          "source": "field",
          "required": false,
          "default": 2048,
          "position": "payload:requests.0.params.max_tokens"
        },
        {
          "name": "Role",
          "as": "ROLE",
          "description": {
            "en": "Message role.",
            "es": "Rol del mensaje.",
            "fr": "Rôle de message.",
            "ro": "Rolul mesajului.",
            "it": "Ruolo del messaggio."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "default": "user",
          "position": "payload:requests.0.params.messages.0.role"
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "out.id",
    "RUN_STATUS": "out.processing_status",
    "SUMMARY": "transform:() => `Followup batch ${out.id} is ${out.processing_status}`"
  },
  "messages": {
    "success": {
      "en": "Anthropic followup run {{RUN_ID}} created with status {{RUN_STATUS}}.",
      "es": "Ejecución de seguimiento antrópico {{RUN_ID}} creada con estado {{RUN_STATUS}}.",
      "fr": "Exécution de suivi anthropique {{RUN_ID}} créée avec le statut {{RUN_STATUS}}.",
      "ro": "Urmărirea antropică {{RUN_ID}} creată cu starea {{RUN_STATUS}}.",
      "it": "Corsa di follow-up antropica {{RUN_ID}} creata con stato {{RUN_STATUS}}."
    }
  }
}
