{
  "protocol": "warp:3.0.0",
  "name": "Anthropic (Claude Code): Cancel Task",
  "title": {
    "en": "Cancel task (Claude Code)",
    "es": "Cancelar tarea (Código Claude)",
    "fr": "Annuler la tâche (Claude Code)",
    "ro": "Anulați sarcina (Claude Code)",
    "it": "Annulla attività (codice Claude)"
  },
  "description": {
    "en": "Request cancellation through Claude Code print mode.",
    "es": "Solicitar cancelación a través del modo de impresión Claude Code.",
    "fr": "Demander l'annulation via le mode d'impression Claude Code.",
    "ro": "Solicitați anularea prin modul de imprimare Claude Code.",
    "it": "Richiedere l'annullamento tramite la modalità stampa Codice Claude."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Cancel Task",
        "es": "Cancelar tarea",
        "fr": "Annuler la tâche",
        "ro": "Anulează sarcina",
        "it": "Annulla attività"
      },
      "prompt": "/claude --print --output-format json \"$(cat <<'JOAI_PROMPT'\nFor run ID {{RUN_ID}}, stop work now and return only: cancel_requested.\nJOAI_PROMPT\n)\"",
      "inputs": [
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "Run identifier to cancel.",
            "es": "Ejecute el identificador para cancelar.",
            "fr": "Exécutez l'identifiant pour annuler.",
            "ro": "Rulați identificatorul pentru a anula.",
            "it": "Esegui identificatore per annullare."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "in.RUN_ID",
    "RUN_STATUS": "transform:() => 'cancel_requested'",
    "SUMMARY": "transform:() => 'Cancellation requested via Claude Code.'"
  },
  "messages": {
    "success": {
      "en": "Cancellation requested for {{RUN_ID}}.",
      "es": "Cancelación solicitada para {{RUN_ID}}.",
      "fr": "Annulation demandée pour {{RUN_ID}}.",
      "ro": "Anularea a fost solicitată pentru {{RUN_ID}}.",
      "it": "Cancellazione richiesta per {{RUN_ID}}."
    }
  }
}
