{
  "protocol": "warp:3.0.0",
  "name": "Gmail: Send Email",
  "title": {
    "en": "Send email",
    "de": "E-Mail senden",
    "es": "Send email",
    "fr": "Send email",
    "ro": "Send email",
    "it": "Send email"
  },
  "description": {
    "en": "Send an email using Gmail.",
    "de": "Eine E-Mail über Gmail senden.",
    "es": "Send an email using Gmail.",
    "fr": "Send an email using Gmail.",
    "ro": "Send an email using Gmail.",
    "it": "Send an email using Gmail."
  },
  "vars": {
    "ACCESS_TOKEN": "env:GMAIL_ACCESS_TOKEN|OAuth 2.0 access token with https://www.googleapis.com/auth/gmail.send scope."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Send Email",
      "destination": {
        "url": "https://gmail.googleapis.com/gmail/v1/users/me/messages/send",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Raw Message",
          "as": "raw",
          "description": {
            "en": "The base64url encoded email message (RFC 822 format).",
            "de": "Die base64url-kodierte E-Mail-Nachricht (RFC 822 Format).",
            "es": "The base64url encoded email message (RFC 822 format).",
            "fr": "The base64url encoded email message (RFC 822 format).",
            "ro": "The base64url encoded email message (RFC 822 format).",
            "it": "The base64url encoded email message (RFC 822 format)."
          },
          "bot": "Construct the email headers (To, Subject, Content-Type) and body, then base64url encode the entire string.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:raw"
        }
      ]
    }
  ],
  "output": {
    "MESSAGE_ID": "out.id",
    "THREAD_ID": "out.threadId"
  },
  "messages": {
    "success": {
      "en": "Email sent! ID: {{MESSAGE_ID}}",
      "de": "E-Mail gesendet! ID: {{MESSAGE_ID}}",
      "es": "Email sent! ID: {{MESSAGE_ID}}",
      "fr": "Email sent! ID: {{MESSAGE_ID}}",
      "ro": "Email sent! ID: {{MESSAGE_ID}}",
      "it": "Email sent! ID: {{MESSAGE_ID}}"
    }
  }
}
