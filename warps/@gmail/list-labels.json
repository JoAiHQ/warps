{
  "protocol": "warp:3.0.0",
  "name": "Gmail: List Labels",
  "title": {
    "en": "List labels",
    "de": "Labels auflisten",
    "es": "List labels",
    "fr": "List labels",
    "ro": "List labels",
    "it": "List labels"
  },
  "description": {
    "en": "List all labels in the user's Gmail account.",
    "de": "Alle Labels im Gmail-Konto des Benutzers auflisten.",
    "es": "List all labels in the user's Gmail account.",
    "fr": "List all labels in the user's Gmail account.",
    "ro": "List all labels in the user's Gmail account.",
    "it": "List all labels in the user's Gmail account."
  },
  "vars": {
    "ACCESS_TOKEN": "env:GMAIL_ACCESS_TOKEN|OAuth 2.0 access token with https://www.googleapis.com/auth/gmail.readonly scope."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Labels",
      "destination": {
        "url": "https://gmail.googleapis.com/gmail/v1/users/me/labels",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": []
    }
  ],
  "output": {
    "LABELS": "out.labels",
    "COUNT": "out.labels.length"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} label(s).",
      "de": "{{COUNT}} Label(s) gefunden.",
      "es": "Found {{COUNT}} label(s).",
      "fr": "Found {{COUNT}} label(s).",
      "ro": "Found {{COUNT}} label(s).",
      "it": "Found {{COUNT}} label(s)."
    }
  }
}
