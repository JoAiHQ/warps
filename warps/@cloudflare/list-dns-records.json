{
  "protocol": "warp:3.0.0",
  "name": "Cloudflare: List DNS Records",
  "title": {
    "en": "List DNS records",
    "de": "DNS-Einträge auflisten",
    "es": "List DNS records",
    "fr": "List DNS records",
    "ro": "List DNS records",
    "it": "List DNS records"
  },
  "description": {
    "en": "List DNS records for a Cloudflare zone.",
    "de": "DNS-Einträge für eine Cloudflare-Zone auflisten.",
    "es": "List DNS records for a Cloudflare zone.",
    "fr": "List DNS records for a Cloudflare zone.",
    "ro": "List DNS records for a Cloudflare zone.",
    "it": "List DNS records for a Cloudflare zone."
  },
  "vars": {
    "API_TOKEN": "env:CLOUDFLARE_API_TOKEN|Get your API token from Cloudflare Dashboard > My Profile > API Tokens."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List DNS Records",
      "destination": {
        "url": "https://api.cloudflare.com/client/v4/zones/{{ZONE_ID}}/dns_records",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Zone ID",
          "as": "ZONE_ID",
          "description": {
            "en": "The zone ID.",
            "es": "The zone ID.",
            "fr": "The zone ID.",
            "ro": "The zone ID.",
            "it": "The zone ID."
          },
          "bot": "The Cloudflare zone ID. Get this from the list-zones warp.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:ZONE_ID"
        },
        {
          "name": {
            "en": "Type",
            "de": "Type",
            "es": "Type",
            "fr": "Type",
            "ro": "Type",
            "it": "Type"
          },
          "as": {
            "en": "type",
            "de": "type",
            "es": "type",
            "fr": "type",
            "ro": "type",
            "it": "type"
          },
          "description": {
            "en": "Filter by record type (A, AAAA, CNAME, MX, TXT, etc.).",
            "es": "Filter by record type (A, AAAA, CNAME, MX, TXT, etc.).",
            "fr": "Filter by record type (A, AAAA, CNAME, MX, TXT, etc.).",
            "ro": "Filter by record type (A, AAAA, CNAME, MX, TXT, etc.).",
            "it": "Filter by record type (A, AAAA, CNAME, MX, TXT, etc.)."
          },
          "type": "string",
          "source": "field",
          "position": "query:type"
        },
        {
          "name": {
            "en": "Name",
            "de": "Name",
            "es": "Name",
            "fr": "Name",
            "ro": "Name",
            "it": "Name"
          },
          "as": {
            "en": "name",
            "de": "name",
            "es": "name",
            "fr": "name",
            "ro": "name",
            "it": "name"
          },
          "description": {
            "en": "Filter by record name.",
            "es": "Filter by record name.",
            "fr": "Filter by record name.",
            "ro": "Filter by record name.",
            "it": "Filter by record name."
          },
          "type": "string",
          "source": "field",
          "position": "query:name"
        }
      ]
    }
  ],
  "output": {
    "RECORDS": "out.result",
    "COUNT": "out.result_info.total_count"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} DNS record(s).",
      "de": "{{COUNT}} DNS-Eintrag/Einträge gefunden.",
      "es": "Found {{COUNT}} DNS record(s).",
      "fr": "Found {{COUNT}} DNS record(s).",
      "ro": "Found {{COUNT}} DNS record(s).",
      "it": "Found {{COUNT}} DNS record(s)."
    }
  }
}
