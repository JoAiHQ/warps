{
  "protocol": "warp:3.0.0",
  "name": "Loyalty: Register",
  "title": {
    "en": "Join our loyalty program!",
    "de": "Tritt unserem Treueprogramm bei!",
    "fr": "Rejoignez notre programme de fidelite !",
    "es": "Unete a nuestro programa de fidelizacion",
    "ro": "Intra in programul nostru de loialitate!"
  },
  "description": {
    "en": "Register your loyalty card and start earning stamps towards free rewards.",
    "de": "Registriere deine Treuekarte und sammle Stempel für kostenlose Belohnungen.",
    "fr": "Enregistrez votre carte de fidelite et commencez a cumuler des tampons pour obtenir des recompenses.",
    "es": "Registra tu tarjeta de fidelizacion y empieza a acumular sellos para conseguir recompensas.",
    "ro": "Inregistreaza-ti cardul de loialitate si incepe sa aduni stampile pentru recompense."
  },
  "bot": "Registers NFC card on-chain. If already registered, redirects to status. After registration, offer to generate a wallet pass via @pass-generate.",
  "chain": "multiversx",
  "vars": {
    "LOYALTY_SLUG": "query:slug",
    "SC_ADDRESS": "INJECT:LOYALTY_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Checking card...",
        "de": "Karte wird überprüft...",
        "fr": "Verification de la carte...",
        "es": "Comprobando tarjeta...",
        "ro": "Se verifica cardul..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "isCardRegistered",
      "args": [
        "string:{{LOYALTY_SLUG}}"
      ],
      "inputs": [
        {
          "name": "JOAI_TAG_ID",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        }
      ],
      "auto": true,
      "next": {
        "success": "loyalty-status?slug={{LOYALTY_SLUG}}&JOAI_TAG_ID={{JOAI_TAG_ID}}"
      },
      "abi": "INJECT:contract/output/loyalty.abi.json"
    },
    {
      "type": "collect",
      "label": {
        "en": "Register",
        "de": "Registrieren",
        "fr": "S inscrire",
        "es": "Registrarse",
        "ro": "Inregistreaza-te"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/contacts",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Name",
          "as": "name",
          "description": {
            "en": "Your name",
            "de": "Dein Name",
            "fr": "Votre nom",
            "es": "Tu nombre",
            "ro": "Numele tau"
          },
          "bot": "Customer name.",
          "type": "string",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Email",
          "as": "email",
          "description": {
            "en": "Your email address",
            "de": "Deine E-Mail-Adresse",
            "fr": "Votre adresse e-mail",
            "es": "Tu correo electronico",
            "ro": "Adresa ta de e-mail"
          },
          "bot": "Customer email.",
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Phone",
          "as": "phone",
          "description": {
            "en": "Your phone number (optional)",
            "de": "Deine Telefonnummer (optional)",
            "fr": "Votre numero de telephone (facultatif)",
            "es": "Tu numero de telefono (opcional)",
            "ro": "Numarul tau de telefon (optional)"
          },
          "bot": "Optional.",
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Card",
          "as": "card",
          "type": "string",
          "source": "hidden",
          "default": "{{JOAI_TAG_ID}}",
          "position": "payload:props"
        }
      ]
    },
    {
      "type": "contract",
      "label": {
        "en": "Activate card",
        "de": "Karte aktivieren",
        "fr": "Activer la carte",
        "es": "Activar tarjeta",
        "ro": "Activeaza cardul"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "register",
      "args": [
        "string:{{LOYALTY_SLUG}}",
        "string:{{JOAI_TAG_ID}}",
        "string:{{name}}"
      ],
      "gasLimit": 10000000,
      "auto": true,
      "abi": "INJECT:contract/output/loyalty.abi.json"
    }
  ],
  "output": {
    "IS_REGISTERED": "out.1"
  },
  "messages": {
    "success": {
      "en": "Welcome, {{name}}! Your first stamp has been earned.",
      "de": "Willkommen, {{name}}! Dein erster Stempel wurde gesammelt.",
      "fr": "Bienvenue, {{name}} ! Votre premier tampon a bien ete ajoute.",
      "es": "Bienvenido, {{name}}. Ya has conseguido tu primer sello.",
      "ro": "Bine ai venit, {{name}}! Ai primit prima ta stampila."
    }
  },
  "next": "loyalty-review?slug={{LOYALTY_SLUG}}&JOAI_TAG_ID={{JOAI_TAG_ID}}"
}
