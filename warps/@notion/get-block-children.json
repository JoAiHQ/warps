{
  "protocol": "warp:3.0.0",
  "name": "Notion: Get Block Children",
  "title": {
    "en": "Get page content",
    "de": "Seiteninhalt abrufen"
  },
  "description": {
    "en": "Retrieve the content blocks of a Notion page or block.",
    "de": "Inhaltsblöcke einer Notion-Seite oder eines Blocks abrufen."
  },
  "vars": {
    "API_KEY": "env:NOTION_API_KEY|Get your API key from Notion Integrations at https://www.notion.so/my-integrations"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Content",
        "de": "Inhalt abrufen"
      },
      "destination": {
        "url": "https://api.notion.com/v1/blocks/{{BLOCK_ID}}/children",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Notion-Version": "2022-06-28"
        }
      },
      "inputs": [
        {
          "name": "Block/Page ID",
          "as": "BLOCK_ID",
          "description": {
            "en": "The ID of the page or block to read content from."
          },
          "bot": "The Notion page or block ID. A page ID works here to get all top-level blocks of the page.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:BLOCK_ID"
        },
        {
          "name": "Page Size",
          "as": "page_size",
          "description": {
            "en": "Number of blocks to return (max 100)."
          },
          "type": "number",
          "source": "field",
          "position": "query:page_size",
          "default": "100"
        }
      ]
    }
  ],
  "output": {
    "BLOCKS": "out.results",
    "COUNT": "out.results.length",
    "HAS_MORE": "out.has_more"
  },
  "messages": {
    "success": {
      "en": "Retrieved {{COUNT}} block(s).",
      "de": "{{COUNT}} Block/Blöcke abgerufen."
    }
  }
}
