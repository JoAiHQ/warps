{
  "protocol": "warp:3.0.0",
  "name": "Notion: Update Page",
  "title": {
    "en": "Update page properties",
    "de": "Seiteneigenschaften aktualisieren"
  },
  "description": {
    "en": "Update properties of an existing Notion page.",
    "de": "Eigenschaften einer bestehenden Notion-Seite aktualisieren."
  },
  "vars": {
    "API_KEY": "env:NOTION_API_KEY|Get your API key from Notion Integrations at https://www.notion.so/my-integrations"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Update Page",
        "de": "Seite aktualisieren"
      },
      "destination": {
        "url": "https://api.notion.com/v1/pages/{{PAGE_ID}}",
        "method": "PATCH",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Content-Type": "application/json",
          "Notion-Version": "2022-06-28"
        }
      },
      "inputs": [
        {
          "name": "Page ID",
          "as": "PAGE_ID",
          "description": {
            "en": "The ID of the Notion page to update."
          },
          "bot": "The Notion page ID to update.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:PAGE_ID"
        },
        {
          "name": "Properties",
          "as": "properties",
          "description": {
            "en": "JSON object of properties to update. See Notion API docs for property value format."
          },
          "bot": "JSON object of properties to update. Example: {\"Status\": {\"select\": {\"name\": \"Done\"}}, \"Priority\": {\"number\": 1}}",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:properties"
        }
      ]
    }
  ],
  "output": {
    "PAGE_ID": "out.id",
    "URL": "out.url",
    "LAST_EDITED_TIME": "out.last_edited_time"
  },
  "messages": {
    "success": {
      "en": "Page updated: {{URL}}",
      "de": "Seite aktualisiert: {{URL}}"
    }
  }
}
