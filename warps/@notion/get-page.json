{
  "protocol": "warp:3.0.0",
  "name": "Notion: Get Page",
  "title": {
    "en": "Get a page",
    "de": "Eine Seite abrufen"
  },
  "description": {
    "en": "Retrieve a Notion page's properties by its ID.",
    "de": "Eigenschaften einer Notion-Seite anhand ihrer ID abrufen."
  },
  "vars": {
    "API_KEY": "env:NOTION_API_KEY|Get your API key from Notion Integrations at https://www.notion.so/my-integrations"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Page",
        "de": "Seite abrufen"
      },
      "destination": {
        "url": "https://api.notion.com/v1/pages/{{PAGE_ID}}",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Notion-Version": "2022-06-28"
        }
      },
      "inputs": [
        {
          "name": "Page ID",
          "as": "PAGE_ID",
          "description": {
            "en": "The ID of the Notion page."
          },
          "bot": "The Notion page ID. You can find this in the page URL or via the search warp.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:PAGE_ID"
        }
      ]
    }
  ],
  "output": {
    "PAGE_ID": "out.id",
    "URL": "out.url",
    "PROPERTIES": "out.properties",
    "CREATED_TIME": "out.created_time",
    "LAST_EDITED_TIME": "out.last_edited_time"
  },
  "messages": {
    "success": {
      "en": "Page retrieved: {{URL}}",
      "de": "Seite abgerufen: {{URL}}"
    }
  }
}
