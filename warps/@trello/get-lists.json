{
  "protocol": "warp:3.0.0",
  "name": "Trello: Get Lists",
  "title": {
    "en": "Get lists",
    "de": "Listen abrufen",
    "es": "Get lists",
    "fr": "Get lists",
    "ro": "Get lists",
    "it": "Get lists"
  },
  "description": {
    "en": "Get the lists on a Trello board.",
    "de": "Rufe die Listen eines Trello-Boards ab.",
    "es": "Get the lists on a Trello board.",
    "fr": "Get the lists on a Trello board.",
    "ro": "Get the lists on a Trello board.",
    "it": "Get the lists on a Trello board."
  },
  "vars": {
    "API_KEY": "env:TRELLO_API_KEY|Get your API Key from https://trello.com/app-key",
    "TOKEN": "env:TRELLO_TOKEN|Get your Token from https://trello.com/app-key (Generate Token)"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Lists",
        "de": "Listen abrufen",
        "es": "Get Lists",
        "fr": "Get Lists",
        "ro": "Get Lists",
        "it": "Get Lists"
      },
      "destination": {
        "url": "https://api.trello.com/1/boards/{{BOARD_ID}}/lists?key={{API_KEY}}&token={{TOKEN}}",
        "method": "GET"
      },
      "inputs": [
        {
          "name": "Board ID",
          "as": "BOARD_ID",
          "description": {
            "en": "The ID of the board.",
            "es": "The ID of the board.",
            "fr": "The ID of the board.",
            "ro": "The ID of the board.",
            "it": "The ID of the board."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "LISTS": "out"
  },
  "messages": {
    "success": {
      "en": "Retrieved {{LISTS.length}} lists.",
      "de": "{{LISTS.length}} Listen abgerufen.",
      "es": "Retrieved {{LISTS.length}} lists.",
      "fr": "Retrieved {{LISTS.length}} lists.",
      "ro": "Retrieved {{LISTS.length}} lists.",
      "it": "Retrieved {{LISTS.length}} lists."
    }
  }
}
