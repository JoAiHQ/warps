{
  "protocol": "warp:3.0.0",
  "name": "LinkedIn: Create Post",
  "title": {
    "en": "Create post",
    "de": "Beitrag erstellen",
    "es": "Crear publicación",
    "fr": "Créer un message",
    "ro": "Creați postare",
    "it": "Crea posta"
  },
  "description": {
    "en": "Create a text post on LinkedIn.",
    "de": "Erstelle einen Textbeitrag auf LinkedIn.",
    "es": "Crea una publicación de texto en LinkedIn.",
    "fr": "Créez une publication texte sur LinkedIn.",
    "ro": "Creați o postare text pe LinkedIn.",
    "it": "Crea un post di testo su LinkedIn."
  },
  "vars": {
    "ACCESS_TOKEN": "env:LINKEDIN_ACCESS_TOKEN|Your LinkedIn OAuth 2.0 Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create Post",
        "de": "Create Post",
        "es": "Crear publicación",
        "fr": "Créer un message",
        "ro": "Creați postare",
        "it": "Crea messaggio"
      },
      "destination": {
        "url": "https://api.linkedin.com/v2/ugcPosts",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Author URN",
          "as": "author",
          "description": {
            "en": "The URN of the author (e.g., 'urn:li:person:12345').",
            "es": "La URN del autor (por ejemplo, 'urna:li:persona:12345').",
            "fr": "L'URN de l'auteur (par exemple, 'urn:li:person:12345').",
            "ro": "URN-ul autorului (de exemplu, „urn:li:person:12345”).",
            "it": "L'URN dell'autore (ad esempio, 'urn:li:person:12345')."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:author"
        },
        {
          "name": {
            "en": "Text",
            "de": "Text",
            "es": "Text",
            "fr": "Text",
            "ro": "Text",
            "it": "Text"
          },
          "as": {
            "en": "text",
            "de": "text",
            "es": "text",
            "fr": "text",
            "ro": "text",
            "it": "text"
          },
          "description": {
            "en": "The content of the post.",
            "es": "El contenido de la publicación.",
            "fr": "Le contenu du message.",
            "ro": "Conținutul postării.",
            "it": "Il contenuto del post."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:specificContent.com.linkedin.ugc.ShareContent.shareCommentary.text"
        },
        {
          "name": "Visibility",
          "as": "visibility",
          "description": {
            "en": "Visibility: 'PUBLIC' or 'CONNECTIONS'.",
            "es": "Visibilidad: 'PÚBLICO' o 'CONEXIONES'.",
            "fr": "Visibilité : 'PUBLIC' ou 'CONNEXIONS'.",
            "ro": "Vizibilitate: „PUBLIC” sau „CONEXIUNI”.",
            "it": "Visibilità: 'PUBBLICO' o 'CONNESSIONI'."
          },
          "type": "string",
          "source": "hidden",
          "position": "payload:visibility.com.linkedin.ugc.MemberNetworkVisibility",
          "default": "PUBLIC"
        },
        {
          "name": "Share Media Category",
          "as": "shareMediaCategory",
          "description": {
            "en": "Category of share.",
            "es": "Categoría de acción.",
            "fr": "Catégorie d'action.",
            "ro": "Categoria acțiunii.",
            "it": "Categoria di condivisione."
          },
          "type": "string",
          "source": "hidden",
          "position": "payload:specificContent.com.linkedin.ugc.ShareContent.shareMediaCategory",
          "default": "NONE"
        },
        {
          "name": "Lifecycle State",
          "as": "lifecycleState",
          "description": {
            "en": "State of the post.",
            "es": "Estado del puesto.",
            "fr": "Etat du poste.",
            "ro": "Starea postului.",
            "it": "Stato della posta."
          },
          "type": "string",
          "source": "hidden",
          "position": "payload:lifecycleState",
          "default": "PUBLISHED"
        }
      ]
    }
  ],
  "output": {
    "POST_ID": "out.id"
  },
  "messages": {
    "success": {
      "en": "Post created! ID: {{POST_ID}}",
      "de": "Beitrag erstellt! ID: {{POST_ID}}",
      "es": "Publicación creada! ID: {{POST_ID}}",
      "fr": "Post créé ! ID : {{POST_ID}}",
      "ro": "Postare creată! ID: {{POST_ID}}",
      "it": "Post creato! ID: {{POST_ID}}"
    }
  }
}
