{
  "protocol": "warp:3.0.0",
  "name": "LinkedIn: Get Profile",
  "title": {
    "en": "Get profile",
    "de": "Profil abrufen",
    "es": "Obtener perfil",
    "fr": "Obtenir un profil",
    "ro": "Obțineți profilul",
    "it": "Ottieni il profilo"
  },
  "description": {
    "en": "Get the authenticated user's LinkedIn profile information.",
    "de": "Profilinformationen des authentifizierten LinkedIn-Benutzers abrufen.",
    "es": "Obtenga la información del perfil de LinkedIn del usuario autenticado.",
    "fr": "Obtenez les informations de profil LinkedIn de l'utilisateur authentifié.",
    "ro": "Obțineți informațiile de profil LinkedIn ale utilizatorului autentificat.",
    "it": "Ottieni le informazioni sul profilo LinkedIn dell'utente autenticato."
  },
  "vars": {
    "ACCESS_TOKEN": "env:LINKEDIN_ACCESS_TOKEN|Your LinkedIn OAuth 2.0 Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Get Profile",
      "destination": {
        "url": "https://api.linkedin.com/v2/userinfo",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": []
    }
  ],
  "output": {
    "SUB": "out.sub",
    "NAME": "out.name",
    "EMAIL": "out.email",
    "PICTURE": "out.picture"
  },
  "messages": {
    "success": {
      "en": "Profile: {{NAME}} ({{EMAIL}})",
      "de": "Profil: {{NAME}} ({{EMAIL}})",
      "es": "Perfil: {{NOMBRE}} ({{EMAIL}})",
      "fr": "Profil : {{NAME}} ({{EMAIL}})",
      "ro": "Profil: {{NAME}} ({{EMAIL}})",
      "it": "Profilo: {{NOME}} ({{EMAIL}})"
    }
  }
}
