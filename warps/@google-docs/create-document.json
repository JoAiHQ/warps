{
  "protocol": "warp:3.0.0",
  "name": "Google Docs: Create Document",
  "title": {
    "en": "Create document",
    "de": "Dokument erstellen",
    "es": "Create document",
    "fr": "Create document",
    "ro": "Create document",
    "it": "Create document"
  },
  "description": {
    "en": "Create a new Google Doc.",
    "de": "Erstelle ein neues Google Doc.",
    "es": "Create a new Google Doc.",
    "fr": "Create a new Google Doc.",
    "ro": "Create a new Google Doc.",
    "it": "Create a new Google Doc."
  },
  "vars": {
    "ACCESS_TOKEN": "env:GOOGLE_DOCS_ACCESS_TOKEN|OAuth 2.0 access token with https://www.googleapis.com/auth/documents scope."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Create Document",
      "destination": {
        "url": "https://docs.googleapis.com/v1/documents",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "The title of the new document.",
            "es": "The title of the new document.",
            "fr": "The title of the new document.",
            "ro": "The title of the new document.",
            "it": "The title of the new document."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:title"
        }
      ]
    }
  ],
  "output": {
    "DOCUMENT_ID": "out.documentId",
    "TITLE": "out.title"
  },
  "messages": {
    "success": {
      "en": "Document '{{TITLE}}' created! ID: {{DOCUMENT_ID}}",
      "de": "Dokument '{{TITLE}}' erstellt! ID: {{DOCUMENT_ID}}",
      "es": "Document '{{TITLE}}' created! ID: {{DOCUMENT_ID}}",
      "fr": "Document '{{TITLE}}' created! ID: {{DOCUMENT_ID}}",
      "ro": "Document '{{TITLE}}' created! ID: {{DOCUMENT_ID}}",
      "it": "Document '{{TITLE}}' created! ID: {{DOCUMENT_ID}}"
    }
  }
}
