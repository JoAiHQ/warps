{
  "protocol": "warp:3.0.0",
  "name": "Typeform: Get Responses",
  "title": {
    "en": "Get responses",
    "de": "Antworten abrufen",
    "es": "Get responses",
    "fr": "Get responses",
    "ro": "Get responses",
    "it": "Get responses"
  },
  "description": {
    "en": "Retrieve responses for a specific Typeform form.",
    "de": "Rufe Antworten für ein bestimmtes Typeform-Formular ab.",
    "es": "Retrieve responses for a specific Typeform form.",
    "fr": "Retrieve responses for a specific Typeform form.",
    "ro": "Retrieve responses for a specific Typeform form.",
    "it": "Retrieve responses for a specific Typeform form."
  },
  "vars": {
    "ACCESS_TOKEN": "env:TYPEFORM_ACCESS_TOKEN|Your Typeform Personal Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Get Responses",
      "destination": {
        "url": "https://api.typeform.com/forms/{{FORM_ID}}/responses",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Form ID",
          "as": "FORM_ID",
          "description": {
            "en": "The ID of the form.",
            "es": "The ID of the form.",
            "fr": "The ID of the form.",
            "ro": "The ID of the form.",
            "it": "The ID of the form."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:FORM_ID"
        },
        {
          "name": "Page Size",
          "as": "page_size",
          "description": {
            "en": "Number of responses to return.",
            "es": "Number of responses to return.",
            "fr": "Number of responses to return.",
            "ro": "Number of responses to return.",
            "it": "Number of responses to return."
          },
          "type": "number",
          "source": "field",
          "required": false,
          "position": "query:page_size",
          "default": 25
        }
      ]
    }
  ],
  "output": {
    "RESPONSES": "out.items",
    "COUNT": "out.total_items"
  },
  "messages": {
    "success": {
      "en": "Retrieved {{COUNT}} response(s).",
      "de": "{{COUNT}} Antwort(en) abgerufen.",
      "es": "Retrieved {{COUNT}} response(s).",
      "fr": "Retrieved {{COUNT}} response(s).",
      "ro": "Retrieved {{COUNT}} response(s).",
      "it": "Retrieved {{COUNT}} response(s)."
    }
  }
}
