{
  "protocol": "warp:3.0.0",
  "name": "Typeform: List Forms",
  "title": {
    "en": "List forms",
    "de": "Formulare auflisten",
    "es": "List forms",
    "fr": "List forms",
    "ro": "List forms",
    "it": "List forms"
  },
  "description": {
    "en": "List your Typeform forms.",
    "de": "Liste deine Typeform-Formulare auf.",
    "es": "List your Typeform forms.",
    "fr": "List your Typeform forms.",
    "ro": "List your Typeform forms.",
    "it": "List your Typeform forms."
  },
  "vars": {
    "ACCESS_TOKEN": "env:TYPEFORM_ACCESS_TOKEN|Your Typeform Personal Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Forms",
      "destination": {
        "url": "https://api.typeform.com/forms",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": {
            "en": "Page",
            "de": "Page",
            "es": "Page",
            "fr": "Page",
            "ro": "Page",
            "it": "Page"
          },
          "as": {
            "en": "page",
            "de": "page",
            "es": "page",
            "fr": "page",
            "ro": "page",
            "it": "page"
          },
          "description": {
            "en": "Page number.",
            "es": "Page number.",
            "fr": "Page number.",
            "ro": "Page number.",
            "it": "Page number."
          },
          "type": "number",
          "source": "field",
          "required": false,
          "position": "query:page",
          "default": 1
        },
        {
          "name": "Page Size",
          "as": "page_size",
          "description": {
            "en": "Number of forms per page.",
            "es": "Number of forms per page.",
            "fr": "Number of forms per page.",
            "ro": "Number of forms per page.",
            "it": "Number of forms per page."
          },
          "type": "number",
          "source": "field",
          "required": false,
          "position": "query:page_size",
          "default": 10
        }
      ]
    }
  ],
  "output": {
    "FORMS": "out.items",
    "COUNT": "out.total_items"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} form(s).",
      "de": "{{COUNT}} Formular(e) gefunden.",
      "es": "Found {{COUNT}} form(s).",
      "fr": "Found {{COUNT}} form(s).",
      "ro": "Found {{COUNT}} form(s).",
      "it": "Found {{COUNT}} form(s)."
    }
  }
}
