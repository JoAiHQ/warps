{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "Inception Network: Stake eGold",
  "title": {
    "en": "Stake eGold with Inception Network",
    "de": "eGold bei Inception Network staken"
  },
  "description": {
    "en": "Delegate your EGLD to Inception Network and earn staking rewards on MultiversX. Inception Network provides reliable validator infrastructure, helping you grow your eGold while securing the blockchain.",
    "de": "Delegiere dein EGLD an Inception Network und verdiene Staking-Belohnungen auf MultiversX. Inception Network bietet zuverlaessige Validator-Infrastruktur, damit du dein eGold vermehren und gleichzeitig die Blockchain sichern kannst."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Stake now",
        "de": "Jetzt staken"
      },
      "address": "INJECT:PROVIDER",
      "func": "delegate",
      "args": [],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "value",
          "description": {
            "en": "Amount of eGold to delegate.",
            "de": "Betrag an eGold zum Delegieren."
          },
          "type": "biguint",
          "position": "value",
          "source": "field",
          "required": true,
          "min": 1,
          "modifier": "scale:18"
        }
      ]
    },
    {
      "type": "link",
      "label": {
        "en": "Learn more",
        "de": "Mehr erfahren"
      },
      "description": {
        "en": "Find more information about staking eGold.",
        "de": "Weitere Informationen zum Staking von eGold finden."
      },
      "url": "https://multiversx.com/egld"
    }
  ],
  "output": {
    "TX_HASH": "out",
    "AMOUNT_EGLD": "transform:() => Number(inputs.value) / 10 ** 18"
  },
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/inception-network/stake-egld/chatapp.ec9ddc5.dist.html",
  "messages": {
    "success": {
      "en": "eGold staked successfully",
      "de": "eGold erfolgreich gestaked"
    }
  },
  "related": [
    "multiversx-staking-claimable-rewards",
    "multiversx-staking-redelegate-all"
  ]
}