{
  "protocol": "warp:3.0.0",
  "name": "OpenAI: Launch Task",
  "title": {
    "en": "Launch task"
  },
  "description": {
    "en": "Launch a new background task run using the OpenAI Responses API."
  },
  "vars": {
    "API_KEY": "env:OPENAI_API_KEY|OpenAI API key"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Launch Task"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/responses",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Task",
          "as": "TASK",
          "description": {
            "en": "Task instruction to execute."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:input"
        },
        {
          "name": "Model",
          "as": "MODEL",
          "description": {
            "en": "OpenAI model to use."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "default": "gpt-5",
          "position": "payload:model"
        },
        {
          "name": "Background",
          "as": "BACKGROUND",
          "description": {
            "en": "Run asynchronously in background mode."
          },
          "type": "boolean",
          "source": "field",
          "required": false,
          "default": true,
          "position": "payload:background"
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "out.id",
    "RUN_STATUS": "out.status",
    "SUMMARY": "out.output_text"
  },
  "messages": {
    "success": {
      "en": "OpenAI run {{RUN_ID}} launched with status {{RUN_STATUS}}."
    }
  }
}
