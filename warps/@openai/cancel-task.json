{
  "protocol": "warp:3.0.0",
  "name": "OpenAI: Cancel Task",
  "title": {
    "en": "Cancel task"
  },
  "description": {
    "en": "Cancel an in-progress OpenAI run."
  },
  "vars": {
    "API_KEY": "env:OPENAI_API_KEY|OpenAI API key"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Cancel Task"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/responses/{{RUN_ID}}/cancel",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "Run ID to cancel."
          },
          "type": "string",
          "position": "path:RUN_ID",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "out.id",
    "RUN_STATUS": "out.status",
    "SUMMARY": "out.output_text"
  },
  "messages": {
    "success": {
      "en": "Run {{RUN_ID}} cancellation requested. Current status: {{RUN_STATUS}}."
    }
  }
}
