{
  "protocol": "warp:3.0.0",
  "name": "Medium: Create Post",
  "title": {
    "en": "Create a post on Medium",
    "de": "Einen Beitrag auf Medium erstellen",
    "es": "Create a post on Medium",
    "fr": "Create a post on Medium",
    "ro": "Create a post on Medium",
    "it": "Create a post on Medium"
  },
  "description": {
    "en": "Create a new post on Medium with HTML content. Supports draft and public publish statuses, and tags.",
    "de": "Erstelle einen neuen Beitrag auf Medium mit HTML-Inhalt. Unterstützt Entwurf- und öffentliche Veröffentlichungsstatus sowie Tags.",
    "es": "Create a new post on Medium with HTML content. Supports draft and public publish statuses, and tags.",
    "fr": "Create a new post on Medium with HTML content. Supports draft and public publish statuses, and tags.",
    "ro": "Create a new post on Medium with HTML content. Supports draft and public publish statuses, and tags.",
    "it": "Create a new post on Medium with HTML content. Supports draft and public publish statuses, and tags."
  },
  "vars": {
    "API_KEY": "env:MEDIUM_INTEGRATION_TOKEN|Get your integration token from Medium Settings > Security and apps"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create Post",
        "de": "Beitrag erstellen",
        "es": "Crear publicación",
        "fr": "Créer un message",
        "ro": "Creați postare",
        "it": "Crea messaggio"
      },
      "destination": {
        "url": "INJECT:API_USER_POSTS/{{USER_ID}}/posts",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Content-Type": "application/json",
          "Accept": "application/json"
        }
      },
      "inputs": [
        {
          "name": "User ID",
          "as": "USER_ID",
          "description": {
            "en": "The user ID from the get-user warp.",
            "es": "The user ID from the get-user warp.",
            "fr": "The user ID from the get-user warp.",
            "ro": "The user ID from the get-user warp.",
            "it": "The user ID from the get-user warp."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:USER_ID"
        },
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "The title of the post.",
            "es": "El título de la publicación.",
            "fr": "Le titre du message.",
            "ro": "Titlul postării.",
            "it": "Il titolo del post."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:title"
        },
        {
          "name": "Content",
          "as": "content",
          "description": {
            "en": "HTML content of the post.",
            "es": "HTML content of the post.",
            "fr": "HTML content of the post.",
            "ro": "HTML content of the post.",
            "it": "HTML content of the post."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:content"
        },
        {
          "name": "Content Format",
          "as": "contentFormat",
          "type": "string",
          "source": "hidden",
          "position": "payload:contentFormat",
          "default": {
            "en": "html",
            "de": "html",
            "es": "html",
            "fr": "html",
            "ro": "html",
            "it": "html"
          }
        },
        {
          "name": "Publish Status",
          "as": "publishStatus",
          "description": {
            "en": "Publish status: draft or public.",
            "es": "Publish status: draft or public.",
            "fr": "Publish status: draft or public.",
            "ro": "Publish status: draft or public.",
            "it": "Publish status: draft or public."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:publishStatus",
          "default": "draft"
        },
        {
          "name": {
            "en": "Tags",
            "de": "Tags",
            "es": "Tags",
            "fr": "Tags",
            "ro": "Tags",
            "it": "Tags"
          },
          "as": {
            "en": "tags",
            "de": "tags",
            "es": "tags",
            "fr": "tags",
            "ro": "tags",
            "it": "tags"
          },
          "description": {
            "en": "Comma-separated tags for the post.",
            "es": "Comma-separated tags for the post.",
            "fr": "Comma-separated tags for the post.",
            "ro": "Comma-separated tags for the post.",
            "it": "Comma-separated tags for the post."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:tags"
        }
      ]
    }
  ],
  "output": {
    "POST_ID": "out.data.id",
    "TITLE": "out.data.title",
    "URL": "out.data.url"
  },
  "messages": {
    "success": {
      "en": "Post '{{TITLE}}' created.",
      "de": "Beitrag '{{TITLE}}' erstellt.",
      "es": "Post '{{TITLE}}' created.",
      "fr": "Post '{{TITLE}}' created.",
      "ro": "Post '{{TITLE}}' created.",
      "it": "Post '{{TITLE}}' created."
    }
  }
}
