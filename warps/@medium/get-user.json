{
  "protocol": "warp:3.0.0",
  "name": "Medium: Get User",
  "title": {
    "en": "Get authenticated user info",
    "de": "Authentifizierte Benutzerinfos abrufen"
  },
  "description": {
    "en": "Retrieve information about the authenticated Medium user including username, name, and profile URL.",
    "de": "Ruft Informationen über den authentifizierten Medium-Benutzer ab, einschließlich Benutzername, Name und Profil-URL."
  },
  "vars": {
    "API_KEY": "env:MEDIUM_INTEGRATION_TOKEN|Get your integration token from Medium Settings > Security and apps"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get User",
        "de": "Benutzer abrufen"
      },
      "destination": {
        "url": "INJECT:API_ME",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Accept": "application/json"
        }
      },
      "inputs": []
    }
  ],
  "output": {
    "ID": "out.data.id",
    "USERNAME": "out.data.username",
    "NAME": "out.data.name",
    "URL": "out.data.url"
  },
  "messages": {
    "success": {
      "en": "Retrieved user {{NAME}} (@{{USERNAME}}).",
      "de": "Benutzer {{NAME}} (@{{USERNAME}}) abgerufen."
    }
  }
}
