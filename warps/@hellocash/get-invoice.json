{
  "protocol": "warp:3.0.0",
  "name": "helloCash: Get Invoice",
  "title": {
    "en": "Get invoice",
    "de": "Rechnung abrufen",
    "es": "Get invoice",
    "fr": "Get invoice",
    "ro": "Get invoice",
    "it": "Get invoice"
  },
  "description": {
    "en": "Retrieve a specific invoice by ID from your helloCash account.",
    "de": "Eine bestimmte Rechnung anhand der ID aus deinem helloCash-Konto abrufen.",
    "es": "Retrieve a specific invoice by ID from your helloCash account.",
    "fr": "Retrieve a specific invoice by ID from your helloCash account.",
    "ro": "Retrieve a specific invoice by ID from your helloCash account.",
    "it": "Retrieve a specific invoice by ID from your helloCash account."
  },
  "vars": {
    "API_TOKEN": "env:HELLOCASH_API_TOKEN|Get your API token from helloCash Dashboard under Settings → API."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Fetch invoice",
        "de": "Rechnung abrufen",
        "es": "Fetch invoice",
        "fr": "Fetch invoice",
        "ro": "Fetch invoice",
        "it": "Fetch invoice"
      },
      "destination": {
        "url": "INJECT:API_URL/invoices/{{INVOICE_ID}}",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Invoice ID",
          "as": "INVOICE_ID",
          "description": {
            "en": "The helloCash invoice ID.",
            "de": "Die helloCash-Rechnungs-ID.",
            "es": "The helloCash invoice ID.",
            "fr": "The helloCash invoice ID.",
            "ro": "The helloCash invoice ID.",
            "it": "The helloCash invoice ID."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "INVOICE": "out"
  },
  "messages": {
    "success": {
      "en": "Invoice retrieved.",
      "de": "Rechnung abgerufen.",
      "es": "Invoice retrieved.",
      "fr": "Invoice retrieved.",
      "ro": "Invoice retrieved.",
      "it": "Invoice retrieved."
    },
    "error": {
      "en": "Invoice not found.",
      "de": "Rechnung nicht gefunden.",
      "es": "Invoice not found.",
      "fr": "Invoice not found.",
      "ro": "Invoice not found.",
      "it": "Invoice not found."
    }
  }
}
