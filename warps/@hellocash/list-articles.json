{
  "protocol": "warp:3.0.0",
  "name": "helloCash: List Articles",
  "title": {
    "en": "List articles",
    "de": "Artikel auflisten",
    "es": "List articles",
    "fr": "List articles",
    "ro": "List articles",
    "it": "List articles"
  },
  "description": {
    "en": "Retrieve articles and products from your helloCash catalog.",
    "de": "Artikel und Produkte aus deinem helloCash-Katalog abrufen.",
    "es": "Retrieve articles and products from your helloCash catalog.",
    "fr": "Retrieve articles and products from your helloCash catalog.",
    "ro": "Retrieve articles and products from your helloCash catalog.",
    "it": "Retrieve articles and products from your helloCash catalog."
  },
  "vars": {
    "API_TOKEN": "env:HELLOCASH_API_TOKEN|Get your API token from helloCash Dashboard under Settings → API."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Fetch articles",
        "de": "Artikel abrufen",
        "es": "Fetch articles",
        "fr": "Fetch articles",
        "ro": "Fetch articles",
        "it": "Fetch articles"
      },
      "destination": {
        "url": "INJECT:API_URL/articles",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Limit",
          "as": "limit",
          "description": {
            "en": "Number of articles to return (max 500).",
            "de": "Anzahl der zurückzugebenden Artikel (max. 500).",
            "es": "Number of articles to return (max 500).",
            "fr": "Number of articles to return (max 500).",
            "ro": "Number of articles to return (max 500).",
            "it": "Number of articles to return (max 500)."
          },
          "type": "number",
          "source": "field",
          "position": "query:limit",
          "default": "200"
        },
        {
          "name": {
            "en": "Search",
            "de": "Search",
            "es": "Buscar",
            "fr": "Recherche",
            "ro": "Căutare",
            "it": "Ricerca"
          },
          "as": "search",
          "description": {
            "en": "Filter articles by name.",
            "de": "Artikel nach Name filtern.",
            "es": "Filter articles by name.",
            "fr": "Filter articles by name.",
            "ro": "Filter articles by name.",
            "it": "Filter articles by name."
          },
          "type": "string",
          "source": "field",
          "position": "query:search"
        }
      ]
    }
  ],
  "output": {
    "ARTICLES": "out"
  },
  "messages": {
    "success": {
      "en": "Articles retrieved.",
      "de": "Artikel abgerufen.",
      "es": "Articles retrieved.",
      "fr": "Articles retrieved.",
      "ro": "Articles retrieved.",
      "it": "Articles retrieved."
    },
    "error": {
      "en": "Failed to fetch articles. Check your API token.",
      "de": "Artikel konnten nicht abgerufen werden. Überprüfe deinen API-Token.",
      "es": "Failed to fetch articles. Check your API token.",
      "fr": "Failed to fetch articles. Check your API token.",
      "ro": "Failed to fetch articles. Check your API token.",
      "it": "Failed to fetch articles. Check your API token."
    }
  }
}
