{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "ProjectX: Stake eGold",
  "title": {
    "en": "Stake eGold with ProjectX",
    "de": "Stake eGold mit ProjectX"
  },
  "description": {
    "en": "Delegate your EGLD to ProjectX and earn staking rewards on the MultiversX blockchain. ProjectX offers a high-performance validator node, giving you a seamless way to grow your eGold through secure delegation.",
    "de": "Delegiere dein EGLD an ProjectX und verdiene Staking-Belohnungen auf der MultiversX-Blockchain. ProjectX betreibt einen leistungsstarken Validator-Node und bietet dir eine einfache Moeglichkeit, dein eGold durch sichere Delegation zu vermehren."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Stake now",
        "de": "Jetzt staken"
      },
      "address": "INJECT:PROVIDER",
      "func": "delegate",
      "args": [],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "value",
          "description": {
            "en": "Amount of eGold to delegate.",
            "de": "Betrag an eGold zum Delegieren."
          },
          "type": "biguint",
          "position": "value",
          "source": "field",
          "required": true,
          "min": 1,
          "modifier": "scale:18"
        }
      ]
    },
    {
      "type": "link",
      "label": {
        "en": "Learn more",
        "de": "Mehr erfahren"
      },
      "description": {
        "en": "Find more information about staking eGold.",
        "de": "Erfahre mehr über das Staken von eGold."
      },
      "url": "https://multiversx.com/egld"
    }
  ],
  "output": {
    "TX_HASH": "out",
    "AMOUNT_EGLD": "transform:() => Number(inputs.value) / 10 ** 18"
  },
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/projectx/stake-egld/chatapp.d536c438.dist.html",
  "messages": {
    "success": {
      "en": "eGold staked successfully",
      "de": "eGold erfolgreich gestakt"
    }
  },
  "related": [
    "multiversx-staking-claimable-rewards",
    "multiversx-staking-redelegate-all"
  ]
}