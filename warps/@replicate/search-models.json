{
  "protocol": "warp:3.0.0",
  "name": "Replicate: Search Models",
  "title": {
    "en": "Search models",
    "de": "Modelle suchen",
    "es": "Search models",
    "fr": "Search models",
    "ro": "Search models",
    "it": "Search models"
  },
  "description": {
    "en": "Search for AI models available on Replicate.",
    "de": "Nach verfügbaren KI-Modellen auf Replicate suchen.",
    "es": "Search for AI models available on Replicate.",
    "fr": "Search for AI models available on Replicate.",
    "ro": "Search for AI models available on Replicate.",
    "it": "Search for AI models available on Replicate."
  },
  "vars": {
    "API_TOKEN": "env:REPLICATE_API_TOKEN|Get your API token from https://replicate.com/account/api-tokens"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Search",
        "de": "Search",
        "es": "Buscar",
        "fr": "Recherche",
        "ro": "Căutare",
        "it": "Ricerca"
      },
      "destination": {
        "url": "INJECT:API_MODELS",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Query",
          "as": "query",
          "description": {
            "en": "Search query (e.g., 'stable diffusion', 'text to speech').",
            "es": "Search query (e.g., 'stable diffusion', 'text to speech').",
            "fr": "Search query (e.g., 'stable diffusion', 'text to speech').",
            "ro": "Search query (e.g., 'stable diffusion', 'text to speech').",
            "it": "Search query (e.g., 'stable diffusion', 'text to speech')."
          },
          "bot": "Search query to find models. Examples: 'stable diffusion', 'text to speech', 'video generation'.",
          "type": "string",
          "source": "field",
          "position": "query:query"
        }
      ]
    }
  ],
  "output": {
    "MODELS": "out.results",
    "COUNT": "out.results.length"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} model(s).",
      "de": "{{COUNT}} Modell(e) gefunden.",
      "es": "Found {{COUNT}} model(s).",
      "fr": "Found {{COUNT}} model(s).",
      "ro": "Found {{COUNT}} model(s).",
      "it": "Found {{COUNT}} model(s)."
    }
  }
}
