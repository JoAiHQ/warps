{
  "protocol": "warp:3.0.0",
  "name": "Jira: Get Issue",
  "title": {
    "en": "Get Jira issue",
    "de": "Jira-Issue abrufen",
    "es": "Get Jira issue",
    "fr": "Get Jira issue",
    "ro": "Get Jira issue",
    "it": "Get Jira issue"
  },
  "description": {
    "en": "Retrieve details of a Jira issue.",
    "de": "Rufe Details eines Jira-Issues ab.",
    "es": "Retrieve details of a Jira issue.",
    "fr": "Retrieve details of a Jira issue.",
    "ro": "Retrieve details of a Jira issue.",
    "it": "Retrieve details of a Jira issue."
  },
  "vars": {
    "DOMAIN": "env:JIRA_DOMAIN|Your Jira domain (e.g., 'your-domain' for your-domain.atlassian.net).",
    "AUTH": "env:JIRA_AUTH|Your Base64-encoded 'email:api_token' for Basic authentication."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Issue",
        "de": "Get Issue",
        "es": "Obtener problema",
        "fr": "Obtenir un problème",
        "ro": "Obțineți problema",
        "it": "Ottieni problema"
      },
      "destination": {
        "url": "https://{{DOMAIN}}.atlassian.net/rest/api/3/issue/{{ISSUE_KEY}}",
        "method": "GET",
        "headers": {
          "Authorization": "Basic {{AUTH}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Issue Key",
          "as": "ISSUE_KEY",
          "description": {
            "en": "The key or ID of the issue (e.g., 'PROJ-123').",
            "es": "The key or ID of the issue (e.g., 'PROJ-123').",
            "fr": "The key or ID of the issue (e.g., 'PROJ-123').",
            "ro": "The key or ID of the issue (e.g., 'PROJ-123').",
            "it": "The key or ID of the issue (e.g., 'PROJ-123')."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "KEY": "out.key",
    "SUMMARY": "out.fields.summary",
    "STATUS": "out.fields.status.name",
    "ASSIGNEE": "out.fields.assignee.displayName"
  },
  "messages": {
    "success": {
      "en": "{{KEY}}: {{SUMMARY}} ({{STATUS}})",
      "de": "{{KEY}}: {{SUMMARY}} ({{STATUS}})",
      "es": "{{KEY}}: {{SUMMARY}} ({{STATUS}})",
      "fr": "{{KEY}}: {{SUMMARY}} ({{STATUS}})",
      "ro": "{{KEY}}: {{SUMMARY}} ({{STATUS}})",
      "it": "{{KEY}}: {{SUMMARY}} ({{STATUS}})"
    }
  }
}
