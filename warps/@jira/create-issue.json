{
  "protocol": "warp:3.0.0",
  "name": "Jira: Create Issue",
  "title": {
    "en": "Create Jira issue",
    "de": "Jira-Issue erstellen",
    "es": "Create Jira issue",
    "fr": "Create Jira issue",
    "ro": "Create Jira issue",
    "it": "Create Jira issue"
  },
  "description": {
    "en": "Create a new issue in a Jira project.",
    "de": "Erstelle ein neues Issue in einem Jira-Projekt.",
    "es": "Create a new issue in a Jira project.",
    "fr": "Create a new issue in a Jira project.",
    "ro": "Create a new issue in a Jira project.",
    "it": "Create a new issue in a Jira project."
  },
  "vars": {
    "DOMAIN": "env:JIRA_DOMAIN|Your Jira domain (e.g., 'your-domain' for your-domain.atlassian.net).",
    "AUTH": "env:JIRA_AUTH|Your Base64-encoded 'email:api_token' for Basic authentication."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create Issue",
        "de": "Create Issue",
        "es": "Crear problema",
        "fr": "Créer un problème",
        "ro": "Creați problema",
        "it": "Crea problema"
      },
      "destination": {
        "url": "https://{{DOMAIN}}.atlassian.net/rest/api/3/issue",
        "method": "POST",
        "headers": {
          "Authorization": "Basic {{AUTH}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Project Key",
          "as": "projectKey",
          "description": {
            "en": "The key of the project (e.g., 'PROJ').",
            "es": "The key of the project (e.g., 'PROJ').",
            "fr": "The key of the project (e.g., 'PROJ').",
            "ro": "The key of the project (e.g., 'PROJ').",
            "it": "The key of the project (e.g., 'PROJ')."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:fields.project.key"
        },
        {
          "name": "Summary",
          "as": "summary",
          "description": {
            "en": "The title or summary of the issue.",
            "es": "The title or summary of the issue.",
            "fr": "The title or summary of the issue.",
            "ro": "The title or summary of the issue.",
            "it": "The title or summary of the issue."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:fields.summary"
        },
        {
          "name": "Issue Type",
          "as": "issuetype",
          "description": {
            "en": "The type of issue (e.g., 'Task', 'Bug', 'Story').",
            "es": "The type of issue (e.g., 'Task', 'Bug', 'Story').",
            "fr": "The type of issue (e.g., 'Task', 'Bug', 'Story').",
            "ro": "The type of issue (e.g., 'Task', 'Bug', 'Story').",
            "it": "The type of issue (e.g., 'Task', 'Bug', 'Story')."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:fields.issuetype.name",
          "default": {
            "en": "Task",
            "de": "Task",
            "es": "Task",
            "fr": "Task",
            "ro": "Task",
            "it": "Task"
          }
        },
        {
          "name": "Description",
          "as": "description",
          "description": {
            "en": "The description of the issue (ADF format or plain text if handled by middleware).",
            "es": "The description of the issue (ADF format or plain text if handled by middleware).",
            "fr": "The description of the issue (ADF format or plain text if handled by middleware).",
            "ro": "The description of the issue (ADF format or plain text if handled by middleware).",
            "it": "The description of the issue (ADF format or plain text if handled by middleware)."
          },
          "bot": "Note: Jira uses Atlassian Document Format (ADF) for descriptions. For simple text, middleware or complex JSON construction is needed. This warp expects a simplified structure or assumes the user knows ADF.",
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:fields.description"
        }
      ]
    }
  ],
  "output": {
    "ISSUE_ID": "out.id",
    "ISSUE_KEY": "out.key",
    "ISSUE_URL": "out.self"
  },
  "messages": {
    "success": {
      "en": "Issue {{ISSUE_KEY}} created! ID: {{ISSUE_ID}}",
      "de": "Issue {{ISSUE_KEY}} erstellt! ID: {{ISSUE_ID}}",
      "es": "Issue {{ISSUE_KEY}} created! ID: {{ISSUE_ID}}",
      "fr": "Issue {{ISSUE_KEY}} created! ID: {{ISSUE_ID}}",
      "ro": "Issue {{ISSUE_KEY}} created! ID: {{ISSUE_ID}}",
      "it": "Issue {{ISSUE_KEY}} created! ID: {{ISSUE_ID}}"
    }
  }
}
