{
  "protocol": "warp:3.0.0",
  "name": "Apple Music: Get Song",
  "title": {
    "en": "Get song details",
    "de": "Song-Details abrufen",
    "es": "Get song details",
    "fr": "Get song details",
    "ro": "Get song details",
    "it": "Get song details"
  },
  "description": {
    "en": "Fetch details for a specific song by ID from Apple Music.",
    "de": "Rufe Details für einen bestimmten Song per ID von Apple Music ab.",
    "es": "Fetch details for a specific song by ID from Apple Music.",
    "fr": "Fetch details for a specific song by ID from Apple Music.",
    "ro": "Fetch details for a specific song by ID from Apple Music.",
    "it": "Fetch details for a specific song by ID from Apple Music."
  },
  "vars": {
    "DEVELOPER_TOKEN": "env:APPLE_MUSIC_DEVELOPER_TOKEN|Signed JWT (ES256) from Apple Developer Account."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Song",
        "de": "Song abrufen",
        "es": "Get Song",
        "fr": "Get Song",
        "ro": "Get Song",
        "it": "Get Song"
      },
      "destination": {
        "url": "https://api.music.apple.com/v1/catalog/{{storefront}}/songs/{{id}}",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{DEVELOPER_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Song ID",
          "as": "id",
          "description": {
            "en": "The unique Apple Music ID for the song.",
            "es": "The unique Apple Music ID for the song.",
            "fr": "The unique Apple Music ID for the song.",
            "ro": "The unique Apple Music ID for the song.",
            "it": "The unique Apple Music ID for the song."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:id"
        },
        {
          "name": "Storefront",
          "as": "storefront",
          "description": {
            "en": "The two-letter country code (e.g., 'us').",
            "es": "The two-letter country code (e.g., 'us').",
            "fr": "The two-letter country code (e.g., 'us').",
            "ro": "The two-letter country code (e.g., 'us').",
            "it": "The two-letter country code (e.g., 'us')."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:storefront",
          "default": "us"
        }
      ]
    }
  ],
  "output": {
    "NAME": "out.data.0.attributes.name",
    "ARTIST": "out.data.0.attributes.artistName",
    "ALBUM": "out.data.0.attributes.albumName",
    "URL": "out.data.0.attributes.url",
    "PREVIEW": "out.data.0.attributes.previews.0.url"
  },
  "messages": {
    "success": {
      "en": "Song: {{NAME}} by {{ARTIST}} ({{ALBUM}}). Link: {{URL}}",
      "de": "Song: {{NAME}} von {{ARTIST}} ({{ALBUM}}). Link: {{URL}}",
      "es": "Song: {{NAME}} by {{ARTIST}} ({{ALBUM}}). Link: {{URL}}",
      "fr": "Song: {{NAME}} by {{ARTIST}} ({{ALBUM}}). Link: {{URL}}",
      "ro": "Song: {{NAME}} by {{ARTIST}} ({{ALBUM}}). Link: {{URL}}",
      "it": "Song: {{NAME}} by {{ARTIST}} ({{ALBUM}}). Link: {{URL}}"
    }
  }
}
