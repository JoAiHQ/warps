{
  "protocol": "warp:3.0.0",
  "name": "Mailgun: Send Email",
  "title": {
    "en": "Send email",
    "de": "E-Mail senden",
    "es": "Send email",
    "fr": "Send email",
    "ro": "Send email",
    "it": "Send email"
  },
  "description": {
    "en": "Send an email using Mailgun's API.",
    "de": "Sende eine E-Mail über die Mailgun-API.",
    "es": "Send an email using Mailgun's API.",
    "fr": "Send an email using Mailgun's API.",
    "ro": "Send an email using Mailgun's API.",
    "it": "Send an email using Mailgun's API."
  },
  "vars": {
    "AUTH_TOKEN": "env:MAILGUN_AUTH_TOKEN|Your Base64-encoded 'api:YOUR_API_KEY' for Basic authentication.",
    "DOMAIN": "env:MAILGUN_DOMAIN|Your Mailgun domain (e.g., mg.example.com)."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Send Email",
      "destination": {
        "url": "https://api.mailgun.net/v3/{{DOMAIN}}/messages",
        "method": "POST",
        "headers": {
          "Authorization": "Basic {{AUTH_TOKEN}}",
          "Content-Type": "application/x-www-form-urlencoded"
        }
      },
      "inputs": [
        {
          "name": "To",
          "as": "to",
          "description": "Recipient email address.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:to"
        },
        {
          "name": {
            "en": "From",
            "de": "From",
            "es": "From",
            "fr": "From",
            "ro": "From",
            "it": "From"
          },
          "as": {
            "en": "from",
            "de": "from",
            "es": "from",
            "fr": "from",
            "ro": "from",
            "it": "from"
          },
          "description": "Sender email address (e.g., 'Excited User <mailgun@YOUR_DOMAIN_NAME>').",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:from"
        },
        {
          "name": "Subject",
          "as": "subject",
          "description": "Email subject.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:subject"
        },
        {
          "name": {
            "en": "Text",
            "de": "Text",
            "es": "Text",
            "fr": "Text",
            "ro": "Text",
            "it": "Text"
          },
          "as": {
            "en": "text",
            "de": "text",
            "es": "text",
            "fr": "text",
            "ro": "text",
            "it": "text"
          },
          "description": "Body of the email (text version).",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:text"
        }
      ]
    }
  ],
  "output": {
    "ID": "out.id",
    "MESSAGE": "out.message"
  },
  "messages": {
    "success": {
      "en": "Email sent! ID: {{ID}}",
      "de": "E-Mail gesendet! ID: {{ID}}",
      "es": "Email sent! ID: {{ID}}",
      "fr": "Email sent! ID: {{ID}}",
      "ro": "Email sent! ID: {{ID}}",
      "it": "Email sent! ID: {{ID}}"
    }
  }
}
