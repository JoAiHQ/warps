{
  "protocol": "warp:3.0.0",
  "name": "Dropbox: List Folder",
  "title": {
    "en": "List folder",
    "de": "Ordner auflisten",
    "es": "List folder",
    "fr": "List folder",
    "ro": "List folder",
    "it": "List folder"
  },
  "description": {
    "en": "List files and folders in Dropbox.",
    "de": "Liste Dateien und Ordner in Dropbox auf.",
    "es": "List files and folders in Dropbox.",
    "fr": "List files and folders in Dropbox.",
    "ro": "List files and folders in Dropbox.",
    "it": "List files and folders in Dropbox."
  },
  "vars": {
    "ACCESS_TOKEN": "env:DROPBOX_ACCESS_TOKEN|Your Dropbox Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Folder",
      "destination": {
        "url": "https://api.dropboxapi.com/2/files/list_folder",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Path",
          "as": "path",
          "description": {
            "en": "The path to the folder. Empty string for root.",
            "es": "The path to the folder. Empty string for root.",
            "fr": "The path to the folder. Empty string for root.",
            "ro": "The path to the folder. Empty string for root.",
            "it": "The path to the folder. Empty string for root."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:path",
          "default": "",
          "label": {
            "en": "Path",
            "de": "Path",
            "es": "Path",
            "fr": "Path",
            "ro": "Path",
            "it": "Path"
          }
        }
      ]
    }
  ],
  "output": {
    "ENTRIES": "out.entries",
    "COUNT": "out.entries.length"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} item(s).",
      "de": "{{COUNT}} Element(e) gefunden.",
      "es": "Found {{COUNT}} item(s).",
      "fr": "Found {{COUNT}} item(s).",
      "ro": "Found {{COUNT}} item(s).",
      "it": "Found {{COUNT}} item(s)."
    }
  }
}
