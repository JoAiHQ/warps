{
  "protocol": "warp:3.0.0",
  "name": "Dropbox: Upload File",
  "title": {
    "en": "Upload file",
    "de": "Datei hochladen",
    "es": "Upload file",
    "fr": "Upload file",
    "ro": "Upload file",
    "it": "Upload file"
  },
  "description": {
    "en": "Upload a text file to Dropbox.",
    "de": "Lade eine Textdatei auf Dropbox hoch.",
    "es": "Upload a text file to Dropbox.",
    "fr": "Upload a text file to Dropbox.",
    "ro": "Upload a text file to Dropbox.",
    "it": "Upload a text file to Dropbox."
  },
  "vars": {
    "ACCESS_TOKEN": "env:DROPBOX_ACCESS_TOKEN|Your Dropbox Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Upload File",
      "destination": {
        "url": "https://content.dropboxapi.com/2/files/upload",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/octet-stream",
          "Dropbox-API-Arg": "{\"path\": \"{{PATH}}\", \"mode\": \"add\", \"autorename\": true, \"mute\": false}"
        }
      },
      "inputs": [
        {
          "name": {
            "en": "Path",
            "de": "Path",
            "es": "Path",
            "fr": "Path",
            "ro": "Path",
            "it": "Path"
          },
          "as": "PATH",
          "description": {
            "en": "The path where the file should be saved (e.g., /notes.txt).",
            "es": "The path where the file should be saved (e.g., /notes.txt).",
            "fr": "The path where the file should be saved (e.g., /notes.txt).",
            "ro": "The path where the file should be saved (e.g., /notes.txt).",
            "it": "The path where the file should be saved (e.g., /notes.txt)."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "header:Dropbox-API-Arg"
        },
        {
          "name": "Content",
          "as": "content",
          "description": {
            "en": "The content of the file.",
            "es": "The content of the file.",
            "fr": "The content of the file.",
            "ro": "The content of the file.",
            "it": "The content of the file."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": {
            "en": "body",
            "de": "body",
            "es": "body",
            "fr": "body",
            "ro": "body",
            "it": "body"
          }
        }
      ]
    }
  ],
  "output": {
    "NAME": "out.name",
    "PATH": "out.path_display"
  },
  "messages": {
    "success": {
      "en": "File uploaded: {{NAME}} at {{PATH}}",
      "de": "Datei hochgeladen: {{NAME}} unter {{PATH}}",
      "es": "File uploaded: {{NAME}} at {{PATH}}",
      "fr": "File uploaded: {{NAME}} at {{PATH}}",
      "ro": "File uploaded: {{NAME}} at {{PATH}}",
      "it": "File uploaded: {{NAME}} at {{PATH}}"
    }
  }
}
