{
  "protocol": "warp:3.0.0",
  "chain": "polygon",
  "name": "Polymarket: Get Latest Markets",
  "title": {
    "en": "Get Latest Markets",
    "de": "Neueste Märkte abrufen",
    "es": "Get Latest Markets",
    "fr": "Get Latest Markets",
    "ro": "Get Latest Markets",
    "it": "Get Latest Markets"
  },
  "description": {
    "en": "Retrieve the latest active prediction markets from Polymarket using the Data API.",
    "de": "Rufe die neuesten aktiven Prognosemärkte von Polymarket über die Data API ab.",
    "es": "Retrieve the latest active prediction markets from Polymarket using the Data API.",
    "fr": "Retrieve the latest active prediction markets from Polymarket using the Data API.",
    "ro": "Retrieve the latest active prediction markets from Polymarket using the Data API.",
    "it": "Retrieve the latest active prediction markets from Polymarket using the Data API."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Markets",
        "de": "Märkte abrufen",
        "es": "Get Markets",
        "fr": "Get Markets",
        "ro": "Get Markets",
        "it": "Get Markets"
      },
      "destination": {
        "url": "INJECT:API_GAMMA/markets",
        "method": "GET"
      },
      "inputs": [
        {
          "name": "Limit",
          "as": "limit",
          "description": {
            "en": "Number of markets to retrieve (default: 10).",
            "de": "Anzahl der abzurufenden Märkte (Standard: 10).",
            "es": "Number of markets to retrieve (default: 10).",
            "fr": "Number of markets to retrieve (default: 10).",
            "ro": "Number of markets to retrieve (default: 10).",
            "it": "Number of markets to retrieve (default: 10)."
          },
          "type": "string",
          "position": "query:limit",
          "source": "field",
          "required": false,
          "default": "10"
        },
        {
          "name": "Active",
          "as": "active",
          "description": {
            "en": "Filter for active markets only (true/false).",
            "de": "Nur aktive Märkte filtern (true/false).",
            "es": "Filter for active markets only (true/false).",
            "fr": "Filter for active markets only (true/false).",
            "ro": "Filter for active markets only (true/false).",
            "it": "Filter for active markets only (true/false)."
          },
          "type": "string",
          "position": "query:active",
          "source": "field",
          "required": false,
          "default": {
            "en": "true",
            "de": "true",
            "es": "true",
            "fr": "true",
            "ro": "true",
            "it": "true"
          }
        }
      ]
    }
  ],
  "output": {
    "MARKET_COUNT": "transform:() => Array.isArray(out) ? out.length : 0",
    "ACTIVE_MARKETS": "transform:() => Array.isArray(out) ? out.filter((m: any) => m.active && !m.closed).length : 0",
    "LATEST_MARKETS": "transform:() => Array.isArray(out) ? out.filter((m: any) => m.active && !m.closed).slice(0, 5).map((m: any) => ({ question: m.question, volume: m.volumeNum, conditionId: m.conditionId, endDate: m.endDate })) : []"
  },
  "messages": {
    "success": {
      "en": "Retrieved {{MARKET_COUNT}} markets ({{ACTIVE_MARKETS}} active)",
      "de": "{{MARKET_COUNT}} Märkte abgerufen ({{ACTIVE_MARKETS}} aktiv)",
      "es": "Retrieved {{MARKET_COUNT}} markets ({{ACTIVE_MARKETS}} active)",
      "fr": "Retrieved {{MARKET_COUNT}} markets ({{ACTIVE_MARKETS}} active)",
      "ro": "Retrieved {{MARKET_COUNT}} markets ({{ACTIVE_MARKETS}} active)",
      "it": "Retrieved {{MARKET_COUNT}} markets ({{ACTIVE_MARKETS}} active)"
    }
  }
}
