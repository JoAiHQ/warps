{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "MrEGLD: Stake eGold",
  "title": {
    "en": "Stake eGold with MrEGLD",
    "de": "Stake eGold mit MrEGLD"
  },
  "description": {
    "en": "Stake your EGLD with MrEGLD, a trusted staking provider on the MultiversX network. Earn consistent delegation rewards while helping secure the blockchain with one of the ecosystem's dedicated validators.",
    "de": "Stake dein EGLD bei MrEGLD, einem vertrauenswuerdigen Staking-Anbieter im MultiversX-Netzwerk. Verdiene zuverlaessige Delegations-Belohnungen und hilf, die Blockchain mit einem der engagiertesten Validatoren des Oekosystems zu sichern."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Stake now",
        "de": "Jetzt staken"
      },
      "address": "INJECT:PROVIDER",
      "func": "delegate",
      "args": [],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "value",
          "description": {
            "en": "Amount of eGold to delegate.",
            "de": "Betrag an eGold zum Delegieren."
          },
          "type": "biguint",
          "position": "value",
          "source": "field",
          "required": true,
          "min": 1,
          "modifier": "scale:18"
        }
      ]
    },
    {
      "type": "link",
      "label": {
        "en": "Learn more",
        "de": "Mehr erfahren"
      },
      "description": {
        "en": "Find more information about staking eGold.",
        "de": "Erfahre mehr über das Staken von eGold."
      },
      "url": "https://multiversx.com/egld"
    }
  ],
  "output": {
    "TX_HASH": "out",
    "AMOUNT_EGLD": "transform:() => Number(inputs.value) / 10 ** 18"
  },
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/mregld/stake-egld/chatapp.118712c.dist.html",
  "messages": {
    "success": {
      "en": "eGold staked successfully",
      "de": "eGold erfolgreich gestakt"
    }
  },
  "related": [
    "multiversx-staking-claimable-rewards",
    "multiversx-staking-redelegate-all"
  ]
}