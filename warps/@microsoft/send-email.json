{
  "protocol": "warp:3.0.0",
  "name": "Microsoft: Send Email",
  "title": {
    "en": "Send Outlook email",
    "de": "Outlook-E-Mail senden",
    "es": "Send Outlook email",
    "fr": "Send Outlook email",
    "ro": "Send Outlook email",
    "it": "Send Outlook email"
  },
  "description": {
    "en": "Send an email using Microsoft Outlook (Graph API).",
    "de": "Sende eine E-Mail über Microsoft Outlook (Graph API).",
    "es": "Send an email using Microsoft Outlook (Graph API).",
    "fr": "Send an email using Microsoft Outlook (Graph API).",
    "ro": "Send an email using Microsoft Outlook (Graph API).",
    "it": "Send an email using Microsoft Outlook (Graph API)."
  },
  "vars": {
    "ACCESS_TOKEN": "env:MICROSOFT_ACCESS_TOKEN|Your Microsoft Graph Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Send Email",
      "destination": {
        "url": "https://graph.microsoft.com/v1.0/me/sendMail",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "To",
          "as": "to",
          "description": {
            "en": "Recipient email address.",
            "es": "Recipient email address.",
            "fr": "Recipient email address.",
            "ro": "Recipient email address.",
            "it": "Recipient email address."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:message.toRecipients.0.emailAddress.address"
        },
        {
          "name": "Subject",
          "as": "subject",
          "description": {
            "en": "Email subject.",
            "es": "Email subject.",
            "fr": "Email subject.",
            "ro": "Email subject.",
            "it": "Email subject."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:message.subject"
        },
        {
          "name": {
            "en": "Body",
            "de": "Body",
            "es": "Body",
            "fr": "Body",
            "ro": "Body",
            "it": "Body"
          },
          "as": "content",
          "description": {
            "en": "Email body content.",
            "es": "Email body content.",
            "fr": "Email body content.",
            "ro": "Email body content.",
            "it": "Email body content."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:message.body.content"
        },
        {
          "name": "Content Type",
          "as": "contentType",
          "description": {
            "en": "Body type: 'Text' or 'HTML'.",
            "es": "Body type: 'Text' or 'HTML'.",
            "fr": "Body type: 'Text' or 'HTML'.",
            "ro": "Body type: 'Text' or 'HTML'.",
            "it": "Body type: 'Text' or 'HTML'."
          },
          "type": "string",
          "source": "hidden",
          "position": "payload:message.body.contentType",
          "default": {
            "en": "Text",
            "de": "Text",
            "es": "Text",
            "fr": "Text",
            "ro": "Text",
            "it": "Text"
          }
        }
      ]
    }
  ],
  "output": {
    "STATUS": "out.status"
  },
  "messages": {
    "success": {
      "en": "Email sent successfully.",
      "de": "E-Mail erfolgreich gesendet.",
      "es": "Email sent successfully.",
      "fr": "Email sent successfully.",
      "ro": "Email sent successfully.",
      "it": "Email sent successfully."
    }
  }
}
