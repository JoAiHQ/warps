{
  "protocol": "warp:3.0.0",
  "name": "Threads: Get Profile",
  "title": {
    "en": "Get profile",
    "de": "Profil abrufen",
    "es": "Obtener perfil",
    "fr": "Obtenir un profil",
    "ro": "Obțineți profilul",
    "it": "Ottieni il profilo"
  },
  "description": {
    "en": "Get your Threads profile information.",
    "de": "Deine Threads-Profilinformationen abrufen.",
    "es": "Get your Threads profile information.",
    "fr": "Get your Threads profile information.",
    "ro": "Get your Threads profile information.",
    "it": "Get your Threads profile information."
  },
  "vars": {
    "ACCESS_TOKEN": "env:THREADS_ACCESS_TOKEN|Get your access token from Meta Developer Portal"
  },
  "actions": [
    {
      "type": "collect",
      "label": "Get Profile",
      "destination": {
        "url": "INJECT:API_PROFILE",
        "method": "GET",
        "headers": {}
      },
      "inputs": [
        {
          "name": "Fields",
          "as": "fields",
          "type": "string",
          "source": "hidden",
          "default": "id,username,threads_profile_picture_url,threads_biography",
          "position": "query:fields"
        },
        {
          "name": "Access Token",
          "as": "access_token",
          "type": "string",
          "source": "hidden",
          "default": "{{ACCESS_TOKEN}}",
          "position": "query:access_token"
        }
      ]
    }
  ],
  "output": {
    "ID": "out.id",
    "USERNAME": "out.username",
    "BIO": "out.threads_biography"
  },
  "messages": {
    "success": {
      "en": "Profile for @{{USERNAME}}: {{BIO}}",
      "de": "Profil von @{{USERNAME}}: {{BIO}}",
      "es": "Profile for @{{USERNAME}}: {{BIO}}",
      "fr": "Profile for @{{USERNAME}}: {{BIO}}",
      "ro": "Profile for @{{USERNAME}}: {{BIO}}",
      "it": "Profile for @{{USERNAME}}: {{BIO}}"
    }
  }
}
