{
  "protocol": "warp:3.0.0",
  "name": "Challenge: Browse",
  "title": {
    "en": "Live challenges",
    "de": "Laufende Challenges"
  },
  "description": {
    "en": "Browse open challenges waiting for someone to take the bet.",
    "de": "Offene Challenges, die auf einen Challenger warten."
  },
  "bot": "Lists all open challenges on-chain. Show the user what challenges are available to accept.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:CHALLENGE_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading challenges...",
        "de": "Challenges werden geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getOpenChallenges",
      "args": [
        "u32:0",
        "u32:20"
      ],
      "inputs": [],
      "auto": true,
      "abi": "INJECT:abis/challenge.abi.json"
    }
  ],
  "output": {
    "CHALLENGES": "out"
  },
  "messages": {
    "success": {
      "en": "Open challenges loaded.",
      "de": "Offene Challenges geladen."
    }
  }
}
