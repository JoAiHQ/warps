{
  "protocol": "warp:3.0.0",
  "name": "Challenge: View",
  "title": {
    "en": "View challenge",
    "de": "Challenge ansehen",
    "fr": "Voir le defi",
    "es": "Ver reto",
    "ro": "Vezi provocarea"
  },
  "description": {
    "en": "See the details, stake, and status of a challenge.",
    "de": "Details, Einsatz und Status einer Challenge ansehen.",
    "fr": "Consultez les details, la mise et le statut d un defi.",
    "es": "Consulta los detalles, la apuesta y el estado del reto.",
    "ro": "Vezi detaliile, miza si starea provocarii."
  },
  "bot": "Fetches challenge details by ID. Use this before accepting to see the exact stake amount.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:CHALLENGE_SC_ADDRESS",
    "CHALLENGE_ID": "query:id"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading challenge...",
        "de": "Challenge wird geladen...",
        "fr": "Chargement du defi...",
        "es": "Cargando reto...",
        "ro": "Se incarca provocarea..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getChallenge",
      "args": [],
      "inputs": [
        {
          "name": "Challenge ID",
          "as": "challengeId",
          "type": "uint64",
          "position": "arg:1",
          "source": "var",
          "default": "{{CHALLENGE_ID}}",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:contract/output/challenge.abi.json"
    }
  ],
  "output": {
    "CREATOR": "out.creator",
    "TITLE": "out.title",
    "STAKE": "out.stake",
    "ENDS_AT": "out.ends_at",
    "STATUS": "out.status",
    "ACCEPTOR": "out.acceptor"
  },
  "messages": {
    "success": {
      "en": "{{TITLE}} — {{STAKE}} EGLD at stake",
      "de": "{{TITLE}} — {{STAKE}} EGLD im Einsatz",
      "fr": "{{TITLE}} — {{STAKE}} EGLD en jeu",
      "es": "{{TITLE}} — {{STAKE}} EGLD en juego",
      "ro": "{{TITLE}} — {{STAKE}} EGLD pusi in joc"
    }
  }
}
