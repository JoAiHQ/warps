{
  "protocol": "warp:3.0.0",
  "name": "GitLab: List Projects",
  "title": {
    "en": "List projects",
    "de": "Projekte auflisten",
    "es": "List projects",
    "fr": "List projects",
    "ro": "List projects",
    "it": "List projects"
  },
  "description": {
    "en": "List GitLab projects.",
    "de": "Liste GitLab-Projekte auf.",
    "es": "List GitLab projects.",
    "fr": "List GitLab projects.",
    "ro": "List GitLab projects.",
    "it": "List GitLab projects."
  },
  "vars": {
    "ACCESS_TOKEN": "env:GITLAB_ACCESS_TOKEN|Your GitLab Personal Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Projects",
      "destination": {
        "url": "https://gitlab.com/api/v4/projects",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Limit",
          "as": "per_page",
          "description": {
            "en": "Number of projects to return.",
            "es": "Number of projects to return.",
            "fr": "Number of projects to return.",
            "ro": "Number of projects to return.",
            "it": "Number of projects to return."
          },
          "type": "number",
          "source": "field",
          "required": false,
          "position": "query:per_page",
          "default": 20
        },
        {
          "name": "Owned",
          "as": "owned",
          "description": {
            "en": "Limit to projects owned by the authenticated user.",
            "es": "Limit to projects owned by the authenticated user.",
            "fr": "Limit to projects owned by the authenticated user.",
            "ro": "Limit to projects owned by the authenticated user.",
            "it": "Limit to projects owned by the authenticated user."
          },
          "type": "boolean",
          "source": "field",
          "required": false,
          "position": "query:owned"
        },
        {
          "name": {
            "en": "Search",
            "de": "Search",
            "es": "Buscar",
            "fr": "Recherche",
            "ro": "Căutare",
            "it": "Ricerca"
          },
          "as": "search",
          "description": {
            "en": "Search for specific projects.",
            "es": "Search for specific projects.",
            "fr": "Search for specific projects.",
            "ro": "Search for specific projects.",
            "it": "Search for specific projects."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "query:search"
        }
      ]
    }
  ],
  "output": {
    "PROJECTS": "out"
  },
  "messages": {
    "success": {
      "en": "Retrieved {{PROJECTS.length}} project(s).",
      "de": "{{PROJECTS.length}} Projekt(e) abgerufen.",
      "es": "Retrieved {{PROJECTS.length}} project(s).",
      "fr": "Retrieved {{PROJECTS.length}} project(s).",
      "ro": "Retrieved {{PROJECTS.length}} project(s).",
      "it": "Retrieved {{PROJECTS.length}} project(s)."
    }
  }
}
