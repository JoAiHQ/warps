{
  "protocol": "warp:3.0.0",
  "name": "GitLab: Create Issue",
  "title": {
    "en": "Create issue",
    "de": "Issue erstellen",
    "es": "Create issue",
    "fr": "Create issue",
    "ro": "Create issue",
    "it": "Create issue"
  },
  "description": {
    "en": "Create a new issue in a GitLab project.",
    "de": "Erstelle ein neues Issue in einem GitLab-Projekt.",
    "es": "Create a new issue in a GitLab project.",
    "fr": "Create a new issue in a GitLab project.",
    "ro": "Create a new issue in a GitLab project.",
    "it": "Create a new issue in a GitLab project."
  },
  "vars": {
    "ACCESS_TOKEN": "env:GITLAB_ACCESS_TOKEN|Your GitLab Personal Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create Issue",
        "de": "Create Issue",
        "es": "Crear problema",
        "fr": "Créer un problème",
        "ro": "Creați problema",
        "it": "Crea problema"
      },
      "destination": {
        "url": "https://gitlab.com/api/v4/projects/{{PROJECT_ID}}/issues",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Project ID",
          "as": "PROJECT_ID",
          "description": {
            "en": "The ID or URL-encoded path of the project.",
            "es": "The ID or URL-encoded path of the project.",
            "fr": "The ID or URL-encoded path of the project.",
            "ro": "The ID or URL-encoded path of the project.",
            "it": "The ID or URL-encoded path of the project."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:PROJECT_ID"
        },
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "The title of the issue.",
            "es": "El título del tema.",
            "fr": "Le titre du numéro.",
            "ro": "Titlul problemei.",
            "it": "Il titolo del problema."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:title"
        },
        {
          "name": "Description",
          "as": "description",
          "description": {
            "en": "The description of the issue.",
            "es": "The description of the issue.",
            "fr": "The description of the issue.",
            "ro": "The description of the issue.",
            "it": "The description of the issue."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:description"
        }
      ]
    }
  ],
  "output": {
    "ISSUE_ID": "out.iid",
    "WEB_URL": "out.web_url",
    "TITLE": "out.title"
  },
  "messages": {
    "success": {
      "en": "Issue #{{ISSUE_ID}} created! Link: {{WEB_URL}}",
      "de": "Issue #{{ISSUE_ID}} erstellt! Link: {{WEB_URL}}",
      "es": "Issue #{{ISSUE_ID}} created! Link: {{WEB_URL}}",
      "fr": "Issue #{{ISSUE_ID}} created! Link: {{WEB_URL}}",
      "ro": "Issue #{{ISSUE_ID}} created! Link: {{WEB_URL}}",
      "it": "Issue #{{ISSUE_ID}} created! Link: {{WEB_URL}}"
    }
  }
}
