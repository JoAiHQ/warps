{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Set Agent Setting",
  "title": {
    "en": "Save an agent setting",
    "de": "Agent-Einstellung speichern"
  },
  "description": {
    "en": "Save a key-value setting on this agent. Overrides team settings.",
    "de": "Speichere eine Schlüssel-Wert-Einstellung auf diesem Agenten. Überschreibt Team-Einstellungen."
  },
  "bot": "Saves an unencrypted agent config value. Brand is auto-scoped from the calling warp.",
  "vars": {
    "AGENT_UUID": "query:agent"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Save setting",
        "de": "Einstellung speichern"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/agents/{{AGENT_UUID}}/settings",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "brand",
          "as": "brand",
          "type": "string",
          "source": "hidden",
          "default": "{{JOAI_WARP_BRAND}}"
        },
        {
          "name": "key",
          "as": "key",
          "type": "string",
          "source": "query",
          "required": true
        },
        {
          "name": "value",
          "as": "value",
          "type": "string",
          "source": "query",
          "required": true
        }
      ],
      "auto": true
    }
  ],
  "messages": {
    "success": {
      "en": "Setting '{{key}}' saved.",
      "de": "Einstellung '{{key}}' gespeichert."
    }
  }
}
