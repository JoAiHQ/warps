{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Send Message",
  "title": {
    "en": "Send a message",
    "de": "Nachricht senden"
  },
  "description": {
    "en": "Send a pre-written message to a room or social channel. Use this to deliver messages generated by other warps.",
    "de": "Sende eine vorbereitete Nachricht an einen Raum oder sozialen Kanal. Nutze dies, um Nachrichten zu versenden, die von anderen Warps generiert wurden."
  },
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY",
    "MESSAGE": "query:message",
    "DESTINATION": "query:destination"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Send Message",
        "de": "Nachricht senden"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/agents/{{JOAI_AGENT_UUID}}/room/message",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Message",
          "as": "message",
          "type": "string",
          "position": "payload:message",
          "source": "hidden",
          "default": "{{MESSAGE}}"
        },
        {
          "name": "Destination",
          "as": "destination",
          "type": "string",
          "position": "payload:destination",
          "source": "hidden",
          "default": "{{DESTINATION}}"
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Message sent.",
      "de": "Nachricht gesendet."
    }
  }
}
