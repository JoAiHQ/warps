{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Send Message",
  "title": {
    "en": "Send a message",
    "de": "Nachricht senden"
  },
  "description": {
    "en": "Send a pre-written message to a room or social channel. Use this to deliver messages generated by other warps.",
    "de": "Sende eine vorbereitete Nachricht an einen Raum oder sozialen Kanal. Nutze dies, um Nachrichten zu versenden, die von anderen Warps generiert wurden."
  },
  "vars": {
    "MESSAGE": "query:message",
    "DESTINATION": "query:destination"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Send Message",
        "de": "Nachricht senden"
      },
      "inputs": [
        {
          "name": "Message",
          "as": "message",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "default": "{{MESSAGE}}",
          "required": true
        },
        {
          "name": "Destination",
          "as": "destination",
          "type": "string",
          "position": "destination",
          "source": "hidden",
          "default": "{{DESTINATION}}",
          "required": false
        }
      ]
    }
  ],
  "messages": {
    "destination": "{{message}}",
    "success": {
      "en": "Message sent.",
      "de": "Nachricht gesendet."
    }
  }
}
