{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Set Team Setting",
  "title": {
    "en": "Save a team setting",
    "de": "Team-Einstellung speichern"
  },
  "description": {
    "en": "Save a key-value setting on the team for use across all agents.",
    "de": "Speichere eine Schlüssel-Wert-Einstellung auf dem Team für alle Agenten."
  },
  "bot": "Saves an unencrypted team-level config value. Brand is auto-scoped from the calling warp.",
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Save setting",
        "de": "Einstellung speichern"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/settings",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "brand",
          "as": "brand",
          "type": "string",
          "source": "hidden",
          "default": "{{JOAI_WARP_BRAND}}"
        },
        {
          "name": "key",
          "as": "key",
          "type": "string",
          "source": "query",
          "required": true
        },
        {
          "name": "value",
          "as": "value",
          "type": "string",
          "source": "query",
          "required": true
        }
      ],
      "auto": true
    }
  ],
  "messages": {
    "success": {
      "en": "Saved {{key}} = {{value}} to your team settings.",
      "de": "{{key}} = {{value}} in deinen Team-Einstellungen gespeichert."
    }
  }
}
