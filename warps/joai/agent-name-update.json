{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Agent Name Update",
  "title": {
    "en": "Update agent name",
    "de": "Agentenname aktualisieren"
  },
  "description": {
    "en": "Rename your AI agent to better reflect its purpose or brand identity. The updated name will appear across all conversations and shared links.",
    "de": "Benenne deinen KI-Agenten um, damit er besser zu seinem Zweck oder deiner Marke passt. Der neue Name wird in allen Unterhaltungen und geteilten Links angezeigt."
  },
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Update now",
        "de": "Jetzt aktualisieren"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/agents/{{JOAI_AGENT_UUID}}",
        "method": "PATCH",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Agent Name",
          "as": "name",
          "description": {
            "en": "The agent's name",
            "de": "Der Name des Agenten"
          },
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 3
        }
      ]
    }
  ],
  "output": {
    "AGENT_NAME": "in.name"
  },
  "messages": {
    "success": {
      "en": "I have updated the agent name to {{AGENT_NAME}}.",
      "de": "Ich habe den Agentennamen auf {{AGENT_NAME}} aktualisiert."
    }
  }
}
