{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Create Product Variation",
  "title": {
    "en": "Add a variation to a product",
    "de": "Variante zu einem Produkt hinzufügen"
  },
  "description": {
    "en": "Add a volume-based pricing variation to an existing product. Each variation has its own SKU, name, price per unit, and a quantity range (min/max). Use this for volume discounts or multi-tier pricing.",
    "de": "Füge eine mengenbasierte Preisvariante zu einem bestehenden Produkt hinzu. Jede Variante hat eigene SKU, Namen, Preis pro Einheit und einen Mengenbereich (min/max). Verwende dies für Mengenrabatte oder Preisstaffeln."
  },
  "bot": "Use when the user wants to add volume pricing tiers to an existing product, e.g. '10 pieces at €4, 50 pieces at €3'. The product must already exist. Pass the product ID/SKU, and for each tier: a name, unique SKU, price in cents, min quantity, and optional max quantity.",
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create variation",
        "de": "Variante erstellen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/products/{{productId}}/variations",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Product",
          "as": "productId",
          "description": {
            "en": "The hash ID or slug of the existing product",
            "de": "Die Hash-ID oder der Slug des bestehenden Produkts"
          },
          "type": "string",
          "source": "field",
          "position": "url:productId",
          "required": true
        },
        {
          "name": "Name",
          "as": "name",
          "description": {
            "en": "Variation name, e.g. '10-49 cards'",
            "de": "Variantenname, z.B. '10-49 Karten'"
          },
          "type": "string",
          "source": "field",
          "position": "body",
          "required": true
        },
        {
          "name": "SKU",
          "as": "sku",
          "description": {
            "en": "Unique SKU for this variation",
            "de": "Eindeutige SKU für diese Variante"
          },
          "type": "string",
          "source": "field",
          "position": "body",
          "required": true
        },
        {
          "name": "Price",
          "as": "price",
          "description": {
            "en": "Price per unit in cents",
            "de": "Preis pro Einheit in Cent"
          },
          "type": "number",
          "source": "field",
          "position": "body",
          "required": true
        },
        {
          "name": "Type",
          "as": "type",
          "description": {
            "en": "Variation type (default: volume)",
            "de": "Variantentyp (Standard: volume)"
          },
          "type": "string",
          "source": "field",
          "value": "volume",
          "position": "body"
        },
        {
          "name": "Min quantity",
          "as": "volumeMin",
          "description": {
            "en": "Minimum quantity for this tier",
            "de": "Mindestmenge für diese Stufe"
          },
          "type": "number",
          "source": "field",
          "position": "body"
        },
        {
          "name": "Max quantity",
          "as": "volumeMax",
          "description": {
            "en": "Maximum quantity for this tier (leave empty for unlimited)",
            "de": "Maximalmenge für diese Stufe (leer für unbegrenzt)"
          },
          "type": "number",
          "source": "field",
          "position": "body"
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Variation '{{name}}' ({{sku}}) added.",
      "de": "Variante '{{name}}' ({{sku}}) hinzugefügt."
    }
  }
}
