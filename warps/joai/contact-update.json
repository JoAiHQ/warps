{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Update Contact",
  "title": {
    "en": "Update a contact",
    "de": "Kontakt aktualisieren"
  },
  "description": {
    "en": "Edit an existing contact's details such as name, email, phone, company, or tags. Keep your address book up to date so your AI agent always has the latest information for personalized communication.",
    "de": "Bearbeite die Details eines bestehenden Kontakts wie Name, E-Mail, Telefon, Firma oder Tags. Halte dein Adressbuch aktuell, damit dein KI-Agent immer die neuesten Infos für personalisierte Kommunikation hat."
  },
  "bot": "Help the user update a contact's details. If the user refers to a contact by name, list contacts first to find the matching ID.",
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Update contact",
        "de": "Kontakt aktualisieren"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/contacts/{{contactId}}",
        "method": "PUT",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Contact ID",
          "as": "contactId",
          "description": {
            "en": "The ID of the contact to update",
            "de": "Die ID des zu aktualisierenden Kontakts"
          },
          "bot": "The contact hash ID. If the user refers to a contact by name, list contacts first to find the matching ID.",
          "type": "string",
          "position": "url:contactId",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Name",
          "as": "name",
          "description": {
            "en": "New name for the contact",
            "de": "Neuer Name für den Kontakt"
          },
          "bot": "A new name for this contact, if they want to rename it.",
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Email",
          "as": "email",
          "description": {
            "en": "Email address",
            "de": "E-Mail-Adresse"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Phone",
          "as": "phone",
          "description": {
            "en": "Phone number",
            "de": "Telefonnummer"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Company",
          "as": "company",
          "description": {
            "en": "Company or organization",
            "de": "Unternehmen oder Organisation"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "Job title or role",
            "de": "Jobtitel oder Rolle"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Notes",
          "as": "notes",
          "description": {
            "en": "Free-form notes about the contact",
            "de": "Freitext-Notizen zum Kontakt"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Website",
          "as": "website",
          "description": {
            "en": "Website URL",
            "de": "Website-URL"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Birthday",
          "as": "birthday",
          "description": {
            "en": "Birthday (YYYY-MM-DD)",
            "de": "Geburtstag (JJJJ-MM-TT)"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Socials",
          "as": "socials",
          "description": {
            "en": "Social media profiles as a JSON array",
            "de": "Social-Media-Profile als JSON-Array"
          },
          "bot": "Pass as JSON string, e.g. [{\"platform\":\"linkedin\",\"url\":\"https://...\"}]",
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Tags",
          "as": "tags",
          "description": {
            "en": "Replace all tags with this set (use tagsAppend to merge with existing)",
            "de": "Alle Tags mit dieser Liste ersetzen (für Merge mit bestehenden Tags tagsAppend verwenden)"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Tags Append",
          "as": "tagsAppend",
          "description": {
            "en": "Tags to add without removing existing ones",
            "de": "Tags hinzufügen ohne bestehende zu entfernen"
          },
          "bot": "Use this for adding tier:strong, segment:research, etc. without wiping existing tags. Pass as JSON string array.",
          "type": "string",
          "source": "field",
          "required": false
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Contact updated!",
      "de": "Kontakt aktualisiert!"
    }
  }
}
