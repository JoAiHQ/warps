{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Create Link",
  "title": {
    "en": "Create a short link",
    "de": "Kurzlink erstellen"
  },
  "description": {
    "en": "Create a short link that redirects to any URL. Tracks scans automatically. The slug is auto-generated from the title or URL.",
    "de": "Erstelle einen Kurzlink, der auf jede URL weiterleitet. Scannt automatisch mit. Der Slug wird automatisch aus dem Titel oder der URL generiert."
  },
  "bot": "Use this to create a short link (start.joai.ai/slug). Provide a name and the target URL. The slug is auto-generated from the name or URL.",
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create link",
        "de": "Link erstellen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/links",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Name",
          "as": "title",
          "description": {
            "en": "A name for the link — the slug is auto-generated from this",
            "de": "Ein Name für den Link — der Slug wird daraus generiert"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "URL",
          "as": "url",
          "description": {
            "en": "The URL to redirect to",
            "de": "Die Ziel-URL"
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ],
      "output": {
        "id": "out.data.id",
        "slug": "out.data.slug",
        "shortUrl": "out.data.shortUrl",
        "url": "out.data.url"
      }
    }
  ],
  "output": {
    "SHORT_URL": "out.1.shortUrl",
    "SLUG": "out.1.slug"
  },
  "messages": {
    "success": {
      "en": "Link created: {{SHORT_URL}}",
      "de": "Link erstellt: {{SHORT_URL}}"
    }
  }
}
