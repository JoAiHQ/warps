{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Create Document",
  "title": {
    "en": "Save a document",
    "de": "Dokument speichern"
  },
  "description": {
    "en": "Save a document with a title and content for your agent.",
    "de": "Speichere ein Dokument mit Titel und Inhalt für deinen Agenten."
  },
  "bot": "Use this when the user shares a piece of content that should be saved as a document, such as an article, note, or reference material.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Save document",
        "de": "Dokument speichern"
      },
      "destination": {
        "url": "INJECT:API_BASE/documents",
        "method": "POST"
      },
      "inputs": [
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "The title of the document",
            "de": "Der Titel des Dokuments"
          },
          "bot": "A concise title for the document.",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 3
        },
        {
          "name": "Content",
          "as": "content",
          "description": {
            "en": "The content of the document",
            "de": "Der Inhalt des Dokuments"
          },
          "bot": "The full content of the document.",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "min": 20
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Saved document: {{title}}",
      "de": "Dokument gespeichert: {{title}}"
    }
  }
}
