{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Create Update",
  "title": {
    "en": "Post an update",
    "de": "Update veröffentlichen"
  },
  "description": {
    "en": "Post a deal, event, or news-style update for your team so it can appear in connected websites, directories, and public feeds. Supports scheduled publishing windows, links, and draft or published status for local business communication.",
    "de": "Veröffentliche ein Angebot, Event oder eine News für dein Team, damit sie auf verbundenen Websites, in Verzeichnissen und öffentlichen Feeds erscheinen kann. Unterstützt geplante Zeiträume, Links sowie Entwurf- oder Veröffentlichungsstatus für lokale Betriebsinfos."
  },
  "bot": "Use this to create a deal, event, or news-style update for customers. Use type=update for news. Set startsAt/endsAt for time-limited offers or events.",
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Post update",
        "de": "Update veröffentlichen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/updates",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "Headline of the update",
            "de": "Überschrift des Updates"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Type",
          "as": "type",
          "description": {
            "en": "Type of update",
            "de": "Art des Updates"
          },
          "type": "string",
          "source": "field",
          "required": true,
          "options": {
            "deal": "Deal",
            "event": "Event",
            "update": "News / Update"
          }
        },
        {
          "name": "Body",
          "as": "body",
          "description": {
            "en": "Detailed description (supports markdown)",
            "de": "Detailbeschreibung (unterstützt Markdown)"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Starts At",
          "as": "startsAt",
          "description": {
            "en": "When the update becomes active (ISO date, optional)",
            "de": "Wann das Update aktiv wird (ISO-Datum, optional)"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Ends At",
          "as": "endsAt",
          "description": {
            "en": "When the update expires (ISO date, optional)",
            "de": "Wann das Update abläuft (ISO-Datum, optional)"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Status",
          "as": "status",
          "description": {
            "en": "Publication status",
            "de": "Veröffentlichungsstatus"
          },
          "type": "string",
          "source": "field",
          "required": false,
          "options": {
            "draft": "Draft",
            "published": "Published",
            "archived": "Archived"
          }
        },
        {
          "name": "Link URL",
          "as": "linkUrl",
          "description": {
            "en": "URL to link from the update",
            "de": "URL, auf die das Update verlinkt"
          },
          "type": "string",
          "source": "field",
          "required": false
        }
      ],
      "output": {
        "id": "out.data.id",
        "title": "out.data.title",
        "type": "out.data.type",
        "status": "out.data.status"
      }
    }
  ],
  "output": {
    "UPDATE_ID": "out.1.id",
    "UPDATE_TITLE": "out.1.title"
  },
  "messages": {
    "success": {
      "en": "Update '{{UPDATE_TITLE}}' posted!",
      "de": "Update '{{UPDATE_TITLE}}' veröffentlicht!"
    }
  }
}
