{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Create Store",
  "title": {
    "en": "Create a data store",
    "de": "Datenspeicher erstellen",
    "es": "Create a data store",
    "fr": "Create a data store",
    "ro": "Create a data store",
    "it": "Create a data store"
  },
  "description": {
    "en": "Create a new tracked data store for time-series or scalar data (weight, expenses, habits, etc.).",
    "de": "Erstelle einen neuen Datenspeicher für Zeitreihen- oder Einzelwerte (Gewicht, Ausgaben, Gewohnheiten usw.).",
    "es": "Create a new tracked data store for time-series or scalar data (weight, expenses, habits, etc.).",
    "fr": "Create a new tracked data store for time-series or scalar data (weight, expenses, habits, etc.).",
    "ro": "Create a new tracked data store for time-series or scalar data (weight, expenses, habits, etc.).",
    "it": "Create a new tracked data store for time-series or scalar data (weight, expenses, habits, etc.)."
  },
  "bot": "Use this when the user wants to start tracking something new over time — weight, expenses, habits, metrics, counters, or any recurring measurement.",
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create store",
        "de": "Speicher erstellen",
        "es": "Create store",
        "fr": "Create store",
        "ro": "Create store",
        "it": "Create store"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/stores",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": {
            "en": "Name",
            "de": "Name",
            "es": "Name",
            "fr": "Name",
            "ro": "Name",
            "it": "Name"
          },
          "as": {
            "en": "name",
            "de": "name",
            "es": "name",
            "fr": "name",
            "ro": "name",
            "it": "name"
          },
          "description": {
            "en": "Store name (e.g. \"weight\", \"expense:food\", \"habit:meditation\")",
            "de": "Name des Speichers (z.B. \"weight\", \"expense:food\", \"habit:meditation\")",
            "es": "Store name (e.g. \"weight\", \"expense:food\", \"habit:meditation\")",
            "fr": "Store name (e.g. \"weight\", \"expense:food\", \"habit:meditation\")",
            "ro": "Store name (e.g. \"weight\", \"expense:food\", \"habit:meditation\")",
            "it": "Store name (e.g. \"weight\", \"expense:food\", \"habit:meditation\")"
          },
          "bot": "Short, lowercase store name. Use colons for namespacing (e.g. \"habit:meditation\", \"expense:food\"). Must be 2-50 chars, alphanumeric with colons/hyphens.",
          "type": "string",
          "source": "field",
          "required": true,
          "min": 2
        },
        {
          "name": "Description",
          "as": "description",
          "description": {
            "en": "What this store tracks",
            "de": "Was dieser Speicher verfolgt",
            "es": "What this store tracks",
            "fr": "What this store tracks",
            "ro": "What this store tracks",
            "it": "What this store tracks"
          },
          "bot": "A human-readable purpose for this store.",
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Value Type",
          "as": "valueType",
          "description": {
            "en": "scalar (single value) or series (time-series data)",
            "de": "scalar (Einzelwert) oder series (Zeitreihe)",
            "es": "scalar (single value) or series (time-series data)",
            "fr": "scalar (single value) or series (time-series data)",
            "ro": "scalar (single value) or series (time-series data)",
            "it": "scalar (single value) or series (time-series data)"
          },
          "bot": "Use 'scalar' for a single changing value (e.g. portfolio balance). Use 'series' for data points over time (e.g. daily weight, expenses).",
          "type": "string",
          "source": "field",
          "required": false,
          "default": "series",
          "options": {
            "scalar": "Scalar (single value)",
            "series": "Series (time-series)"
          }
        },
        {
          "name": {
            "en": "Unit",
            "de": "Unit",
            "es": "Unit",
            "fr": "Unit",
            "ro": "Unit",
            "it": "Unit"
          },
          "as": {
            "en": "unit",
            "de": "unit",
            "es": "unit",
            "fr": "unit",
            "ro": "unit",
            "it": "unit"
          },
          "description": {
            "en": "Unit of measurement (e.g. \"lbs\", \"USD\", \"minutes\")",
            "de": "Maßeinheit (z.B. \"kg\", \"EUR\", \"Minuten\")",
            "es": "Unit of measurement (e.g. \"lbs\", \"USD\", \"minutes\")",
            "fr": "Unit of measurement (e.g. \"lbs\", \"USD\", \"minutes\")",
            "ro": "Unit of measurement (e.g. \"lbs\", \"USD\", \"minutes\")",
            "it": "Unit of measurement (e.g. \"lbs\", \"USD\", \"minutes\")"
          },
          "bot": "Optional unit of measurement like 'lbs', 'USD', 'minutes', 'km'.",
          "type": "string",
          "source": "field",
          "required": false
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Now tracking '{{name}}'!",
      "de": "'{{name}}' wird jetzt verfolgt!",
      "es": "Now tracking '{{name}}'!",
      "fr": "Now tracking '{{name}}'!",
      "ro": "Now tracking '{{name}}'!",
      "it": "Now tracking '{{name}}'!"
    }
  }
}
