{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Onboarding Business Info",
  "title": {
    "en": "Submit Business Information",
    "de": "Geschaeftsinformationen einreichen"
  },
  "description": {
    "en": "Collect business details during onboarding for demo qualification.",
    "de": "Geschaeftsdaten waehrend des Onboardings zur Demo-Qualifizierung erfassen."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Submit",
        "de": "Absenden"
      },
      "inputs": [
        {
          "name": "Company Name",
          "as": "companyName",
          "description": {
            "en": "Name of your company or business."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Company Website",
          "as": "companyWebsite",
          "description": {
            "en": "Your company website URL."
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Team Size",
          "as": "teamSize",
          "description": {
            "en": "Number of people in your team."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Annual Revenue",
          "as": "annualRevenue",
          "description": {
            "en": "Approximate annual revenue range."
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Role",
          "as": "role",
          "description": {
            "en": "Your role in the company."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Business information submitted successfully.",
      "de": "Geschaeftsinformationen erfolgreich eingereicht."
    }
  }
}
