{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Create Product",
  "title": {
    "en": "Create a product",
    "de": "Produkt erstellen"
  },
          "description": {
            "en": "Price in cents for the base product. For variations, set each variation's price in the input below.",
            "de": "Preis in Cent für das Basisprodukt. Bei Varianten den Preis jeder Variante unten eingeben."
          },
  "bot": "Use when the user wants to create a new product, material, or billable item with multiple variations/pricing tiers. Extract name, price, and variation names/SKUs/prices from their description. For example: '10 pieces at €4, 50 pieces at €3' becomes variations with different SKUs.",
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create product",
        "de": "Produkt erstellen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/products",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Name",
          "as": "name",
          "description": {
            "en": "Product name",
            "de": "Produktname"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Price",
          "as": "price",
          "description": {
            "en": "Price in cents",
            "de": "Preis in Cent"
          },
          "type": "number",
          "source": "field",
          "required": true
        },
        {
          "name": "Unit",
          "as": "unit",
          "description": {
            "en": "Unit (e.g. Stück, kg, h)",
            "de": "Einheit (z.B. Stück, kg, h)"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Category",
          "as": "category",
          "description": {
            "en": "Category (material, service, part)",
            "de": "Kategorie (material, service, part)"
          },
          "type": "string",
          "source": "field",
          "required": false
        }
      ]
    }
  ]
}
