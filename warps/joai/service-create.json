{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Create Service",
  "title": {
    "en": "Create a service",
    "de": "Dienstleistung erstellen"
  },
  "description": {
    "en": "Create a new billable service with name, price, pricing model, and duration for your team catalog. Services can be one-time or monthly subscription. Monthly services use Stripe for recurring billing.",
    "de": "Erstelle eine neue abrechenbare Dienstleistung mit Name, Preis, Abrechnungsmodell und Dauer für deinen Team-Katalog. Dienstleistungen können einmalig oder monatlich als Abo sein. Monatliche Services nutzen Stripe für wiederkehrende Zahlungen."
  },
  "bot": "Use when the user wants to create a new service, billable offering, appointment type, or subscription plan. Extract name, price, pricing model (one-time/monthly), and duration from their description. If they say 'monthly' or 'subscription', set pricingModel to 'monthly'. The price modifier automatically converts euros to cents.",
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY",
    "JOAI_TEAM_CURRENCY": "env:JOAI_TEAM_CURRENCY|USD"
  },
  "messages": {
    "success": {
      "en": "Service created: {{name}} ({{priceDisplay}} {{JOAI_TEAM_CURRENCY}})",
      "de": "Dienstleistung erstellt: {{name}} ({{priceDisplay}} {{JOAI_TEAM_CURRENCY}})",
      "fr": "Service créé : {{name}} ({{priceDisplay}} {{JOAI_TEAM_CURRENCY}})",
      "es": "Servicio creado: {{name}} ({{priceDisplay}} {{JOAI_TEAM_CURRENCY}})",
      "it": "Servizio creato: {{name}} ({{priceDisplay}} {{JOAI_TEAM_CURRENCY}})",
      "ro": "Serviciu creat: {{name}} ({{priceDisplay}} {{JOAI_TEAM_CURRENCY}})"
    },
    "error": {
      "en": "Failed to create service: {{MESSAGE}}",
      "de": "Dienstleistung konnte nicht erstellt werden: {{MESSAGE}}"
    }
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create service",
        "de": "Dienstleistung erstellen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/services",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Name",
          "as": "name",
          "description": {
            "en": "Service name",
            "de": "Name der Dienstleistung"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Price",
          "as": "price",
          "description": {
            "en": "Price in euros (e.g. 49 for €49). For subscriptions this is the monthly price.",
            "de": "Preis in Euro (z.B. 49 für 49€). Bei Abos ist das der monatliche Preis."
          },
          "bot": "Ask for the price naturally. For subscriptions, ask if monthly or one-time.",
          "modifier": "transform:(value) => Number(value) * 100",
          "type": "number",
          "source": "field",
          "required": true
        },
        {
          "name": "Pricing model",
          "as": "pricingModel",
          "description": {
            "en": "One-time payment or monthly subscription",
            "de": "Einmalzahlung oder monatliches Abo"
          },
          "type": "string",
          "source": "field",
          "required": false,
          "options": ["one-time", "monthly"]
        },
        {
          "name": "Duration (minutes)",
          "as": "duration_minutes",
          "description": {
            "en": "Duration in minutes for appointments",
            "de": "Dauer in Minuten für Termine"
          },
          "type": "number",
          "source": "field",
          "required": false
        },
        {
          "name": "Description",
          "as": "description",
          "description": {
            "en": "Service description",
            "de": "Beschreibung der Dienstleistung"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Tags",
          "as": "tags",
          "description": {
            "en": "Tags (e.g. hourly, consultation, maintenance, repair)",
            "de": "Tags (z.B. stundensatz, beratung, wartung, reparatur)"
          },
          "type": "string",
          "source": "field",
          "required": false
        }
      ]
    }
  ],
  "output": {
    "id": "out.data.id",
    "name": "out.data.name",
    "price": "out.data.price",
    "priceDisplay": "transform:() => (Number(out.data.price || 0) / 100).toFixed(2)"
  }
}
