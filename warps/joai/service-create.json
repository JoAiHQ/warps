{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Create Service",
  "title": {
    "en": "Create a service",
    "de": "Dienstleistung erstellen"
  },
  "description": {
    "en": "Create a new billable service with name, price, and duration for your team catalog. Services can be used for appointment booking and invoices.",
    "de": "Eine neue abrechenbare Dienstleistung mit Name, Preis und Dauer für deinen Team-Katalog erstellen. Dienstleistungen können für Terminbuchungen und Rechnungen verwendet werden."
  },
  "bot": "Use when the user wants to create a new service, billable offering, or appointment type. Extract name, price, and duration from their description.",
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "messages": {
    "error": {
      "en": "Failed to create service: {{MESSAGE}}",
      "de": "Dienstleistung konnte nicht erstellt werden: {{MESSAGE}}"
    }
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create service",
        "de": "Dienstleistung erstellen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/services",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Name",
          "as": "name",
          "description": {
            "en": "Service name",
            "de": "Name der Dienstleistung"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Price",
          "as": "price",
          "description": {
            "en": "Price in cents",
            "de": "Preis in Cent"
          },
          "type": "number",
          "source": "field",
          "required": true
        },
        {
          "name": "Duration (minutes)",
          "as": "duration_minutes",
          "description": {
            "en": "Duration in minutes",
            "de": "Dauer in Minuten"
          },
          "type": "number",
          "source": "field",
          "required": false
        },
        {
          "name": "Description",
          "as": "description",
          "description": {
            "en": "Service description",
            "de": "Beschreibung der Dienstleistung"
          },
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Tags",
          "as": "tags",
          "description": {
            "en": "Tags (e.g. hourly, consultation, maintenance, repair)",
            "de": "Tags (z.B. stundensatz, beratung, wartung, reparatur)"
          },
          "type": "string",
          "source": "field",
          "required": false
        }
      ]
    }
  ]
}
