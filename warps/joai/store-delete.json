{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Delete Store",
  "title": {
    "en": "Delete a data store",
    "de": "Datenspeicher löschen"
  },
  "description": {
    "en": "Stop tracking and delete a data store and all its entries.",
    "de": "Einen Datenspeicher und alle seine Einträge löschen."
  },
  "bot": "Use this when the user wants to stop tracking something or delete a store entirely.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Delete store",
        "de": "Speicher löschen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/stores/{{storeName}}",
        "method": "DELETE",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Store Name",
          "as": "storeName",
          "description": {
            "en": "The name of the store to delete",
            "de": "Name des zu löschenden Speichers"
          },
          "bot": "The exact name of the store to delete.",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Stopped tracking '{{storeName}}'.",
      "de": "'{{storeName}}' wird nicht mehr verfolgt."
    }
  }
}
