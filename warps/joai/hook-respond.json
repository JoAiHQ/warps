{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Respond to Hook",
  "title": {
    "en": "Respond to hook request",
    "de": "Auf Hook-Anfrage antworten"
  },
  "description": {
    "en": "Approve or deny an external runtime hook request (e.g. a tool permission request from Claude Code).",
    "de": "Genehmige oder verweigere eine externe Laufzeitanfrage (z.B. eine Werkzeugberechtigung von Claude Code)."
  },
  "bot": "Responds to a pending hook approval request. Used internally when the user approves or denies a permission request from an external runtime like Claude Code.",
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Respond",
        "de": "Antworten"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/hooks/respond",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "requestId",
          "as": "requestId",
          "type": "string",
          "source": "query",
          "required": true
        },
        {
          "name": "decision",
          "as": "decision",
          "type": "string",
          "source": "query",
          "required": true
        }
      ],
      "auto": true
    }
  ],
  "messages": {
    "success": {
      "en": "Hook request {{decision}}.",
      "de": "Hook-Anfrage {{decision}}."
    }
  }
}
