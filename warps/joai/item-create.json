{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Create Action Item",
  "title": {
    "en": "Create an action item",
    "de": "Aufgabe erstellen"
  },
  "description": {
    "en": "Create a trackable action item or task for your agent.",
    "de": "Erstelle eine verfolgbare Aufgabe für deinen Agenten."
  },
  "bot": "Use this when the user mentions a task, to-do, or action item. Extract a clear title and optional details.",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create item",
        "de": "Aufgabe erstellen"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/items",
        "method": "POST"
      },
      "inputs": [
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "A clear, actionable title",
            "de": "Ein klarer, umsetzbarer Titel"
          },
          "bot": "Short, clear title describing what needs to be done.",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 3
        },
        {
          "name": "Description",
          "as": "description",
          "description": {
            "en": "Additional details",
            "de": "Zusätzliche Details"
          },
          "bot": "Optional extra context about this action item.",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": false
        },
        {
          "name": "Priority",
          "as": "priority",
          "description": {
            "en": "How urgent is this?",
            "de": "Wie dringend ist das?"
          },
          "bot": "Priority level. Use 'normal' unless the user indicates urgency.",
          "type": "string",
          "source": "field",
          "required": false,
          "default": "normal",
          "options": {
            "low": "Low",
            "normal": "Normal",
            "high": "High",
            "urgent": "Urgent"
          }
        },
        {
          "name": "Due Date",
          "as": "dueDate",
          "description": {
            "en": "When is this due?",
            "de": "Wann ist das fällig?"
          },
          "bot": "Optional due date in ISO format (YYYY-MM-DD), if mentioned.",
          "type": "string",
          "source": "field",
          "required": false
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Action item '{{title}}' created!",
      "de": "Aufgabe '{{title}}' erstellt!"
    }
  }
}
