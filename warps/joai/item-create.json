{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Create Action Item",
  "title": {
    "en": "Create an action item",
    "de": "Aufgabe erstellen",
    "es": "Create an action item",
    "fr": "Create an action item",
    "ro": "Create an action item",
    "it": "Create an action item"
  },
  "description": {
    "en": "Create a trackable task or to-do item that your AI agent will remember and follow up on. Set a title, priority, and optional due date to stay organized and never miss a deadline.",
    "de": "Erstelle eine verfolgbare Aufgabe oder ein To-do, das dein KI-Agent sich merkt und nachverfolgt. Lege Titel, Priorität und optional ein Fälligkeitsdatum fest, um organisiert zu bleiben und keine Deadline zu verpassen.",
    "es": "Create a trackable task or to-do item that your AI agent will remember and follow up on. Set a title, priority, and optional due date to stay organized and never miss a deadline.",
    "fr": "Create a trackable task or to-do item that your AI agent will remember and follow up on. Set a title, priority, and optional due date to stay organized and never miss a deadline.",
    "ro": "Create a trackable task or to-do item that your AI agent will remember and follow up on. Set a title, priority, and optional due date to stay organized and never miss a deadline.",
    "it": "Create a trackable task or to-do item that your AI agent will remember and follow up on. Set a title, priority, and optional due date to stay organized and never miss a deadline."
  },
  "bot": "Use this when the user mentions a task, to-do, or action item. Extract a clear title and optional details.",
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Create item",
        "de": "Aufgabe erstellen",
        "es": "Create item",
        "fr": "Create item",
        "ro": "Create item",
        "it": "Create item"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/items",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "A clear, actionable title",
            "de": "Ein klarer, umsetzbarer Titel",
            "es": "A clear, actionable title",
            "fr": "A clear, actionable title",
            "ro": "A clear, actionable title",
            "it": "A clear, actionable title"
          },
          "bot": "Short, clear title describing what needs to be done.",
          "type": "string",
          "source": "field",
          "required": true,
          "min": 3
        },
        {
          "name": "Description",
          "as": "description",
          "description": {
            "en": "Additional details",
            "de": "Zusätzliche Details",
            "es": "Additional details",
            "fr": "Additional details",
            "ro": "Additional details",
            "it": "Additional details"
          },
          "bot": "Optional extra context about this action item.",
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Priority",
          "as": "priority",
          "description": {
            "en": "How urgent is this?",
            "de": "Wie dringend ist das?",
            "es": "How urgent is this?",
            "fr": "How urgent is this?",
            "ro": "How urgent is this?",
            "it": "How urgent is this?"
          },
          "bot": "Priority level. Use 'normal' unless the user indicates urgency.",
          "type": "string",
          "source": "field",
          "required": false,
          "default": "normal",
          "options": {
            "low": "Low",
            "normal": "Normal",
            "high": {
              "en": "High",
              "de": "High",
              "es": "High",
              "fr": "High",
              "ro": "High",
              "it": "High"
            },
            "urgent": "Urgent"
          }
        },
        {
          "name": "Due Date",
          "as": "dueDate",
          "description": {
            "en": "When is this due?",
            "de": "Wann ist das fällig?",
            "es": "When is this due?",
            "fr": "When is this due?",
            "ro": "When is this due?",
            "it": "When is this due?"
          },
          "bot": "Optional due date in ISO format (YYYY-MM-DD), if mentioned.",
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Tags",
          "as": "tags",
          "description": {
            "en": "Tags for categorization",
            "de": "Tags zur Kategorisierung",
            "es": "Tags for categorization",
            "fr": "Tags for categorization",
            "ro": "Tags for categorization",
            "it": "Tags for categorization"
          },
          "bot": "Array of stable slugs to group / filter items (e.g. outreach, nurture, kanzlei). Pass a JSON array of strings.",
          "type": "string",
          "source": "field",
          "required": false,
          "label": {
            "en": "Tags",
            "de": "Tags",
            "es": "Tags",
            "fr": "Tags",
            "ro": "Tags",
            "it": "Tags"
          }
        },
        {
          "name": "Goal ID",
          "as": "goalId",
          "description": {
            "en": "Link to a goal",
            "de": "Verknüpfung mit einem Ziel",
            "es": "Link to a goal",
            "fr": "Link to a goal",
            "ro": "Link to a goal",
            "it": "Link to a goal"
          },
          "bot": "Optional ID of a goal this item contributes to.",
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Status",
          "as": "status",
          "description": {
            "en": "Item status",
            "de": "Aufgabenstatus",
            "es": "Item status",
            "fr": "Item status",
            "ro": "Item status",
            "it": "Item status"
          },
          "bot": "Item status. Use 'done' for completed reports.",
          "type": "string",
          "source": "field",
          "required": false,
          "default": "backlog",
          "options": {
            "backlog": "Backlog",
            "active": "Active",
            "review": "Review",
            "done": {
              "en": "Done",
              "de": "Done",
              "es": "Done",
              "fr": "Done",
              "ro": "Done",
              "it": "Done"
            }
          }
        },
        {
          "name": "Contact IDs",
          "as": "contactIds",
          "description": {
            "en": "Link to contacts",
            "de": "Verknüpfung mit Kontakten",
            "es": "Link to contacts",
            "fr": "Link to contacts",
            "ro": "Link to contacts",
            "it": "Link to contacts"
          },
          "bot": "Array of contact hash IDs to assign to this item. Pass as JSON array.",
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Meta",
          "as": "meta",
          "description": {
            "en": "Metadata",
            "de": "Metadaten",
            "es": "Metadata",
            "fr": "Metadata",
            "ro": "Metadata",
            "it": "Metadata"
          },
          "bot": "Optional JSON object for structured data. Stored in the item's meta field. Pass as JSON object.",
          "type": "string",
          "source": "field",
          "required": false,
          "label": {
            "en": "Meta",
            "de": "Meta",
            "es": "Meta",
            "fr": "Meta",
            "ro": "Meta",
            "it": "Meta"
          }
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Action item '{{title}}' created!",
      "de": "Aufgabe '{{title}}' erstellt!",
      "es": "Action item '{{title}}' created!",
      "fr": "Action item '{{title}}' created!",
      "ro": "Action item '{{title}}' created!",
      "it": "Action item '{{title}}' created!"
    }
  }
}
