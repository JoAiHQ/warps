{
  "protocol": "warp:3.0.0",
  "name": "JoAi: Update Document",
  "title": {
    "en": "Update a document",
    "de": "Dokument aktualisieren",
    "es": "Update a document",
    "fr": "Update a document",
    "ro": "Update a document",
    "it": "Update a document"
  },
  "description": {
    "en": "Update the title, content, or metadata of an existing document in your agent's knowledge base. Useful for editing templates or correcting stored information.",
    "de": "Titel, Inhalt oder Metadaten eines bestehenden Dokuments in der Wissensdatenbank deines Agenten aktualisieren. Nützlich zum Bearbeiten von Templates oder Korrigieren gespeicherter Informationen.",
    "es": "Update the title, content, or metadata of an existing document in your agent's knowledge base. Useful for editing templates or correcting stored information.",
    "fr": "Update the title, content, or metadata of an existing document in your agent's knowledge base. Useful for editing templates or correcting stored information.",
    "ro": "Update the title, content, or metadata of an existing document in your agent's knowledge base. Useful for editing templates or correcting stored information.",
    "it": "Update the title, content, or metadata of an existing document in your agent's knowledge base. Useful for editing templates or correcting stored information."
  },
  "bot": "Use this when the user wants to edit an existing document or template, or when a workflow needs to update document metadata.",
  "vars": {
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Update document",
        "de": "Dokument aktualisieren",
        "es": "Update document",
        "fr": "Update document",
        "ro": "Update document",
        "it": "Update document"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/documents/{{documentId}}",
        "method": "PUT",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Document ID",
          "as": "documentId",
          "description": {
            "en": "The ID of the document to update",
            "de": "Die ID des zu aktualisierenden Dokuments",
            "es": "The ID of the document to update",
            "fr": "The ID of the document to update",
            "ro": "The ID of the document to update",
            "it": "The ID of the document to update"
          },
          "bot": "The hashid of the document to update.",
          "type": "string",
          "position": "url:documentId",
          "source": "field",
          "required": true
        },
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "New title (optional)",
            "de": "Neuer Titel (optional)",
            "es": "New title (optional)",
            "fr": "New title (optional)",
            "ro": "New title (optional)",
            "it": "New title (optional)"
          },
          "bot": "Updated document title. Omit to keep the current title.",
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Content",
          "as": "content",
          "description": {
            "en": "New content (optional)",
            "de": "Neuer Inhalt (optional)",
            "es": "New content (optional)",
            "fr": "New content (optional)",
            "ro": "New content (optional)",
            "it": "New content (optional)"
          },
          "bot": "Updated document content. Omit to keep the current content.",
          "type": "string",
          "source": "field",
          "required": false
        },
        {
          "name": "Meta Slug",
          "as": {
            "en": "slug",
            "de": "slug",
            "es": "slug",
            "fr": "slug",
            "ro": "slug",
            "it": "slug"
          },
          "description": {
            "en": "Template slug identifier",
            "de": "Template-Slug-Kennung",
            "es": "Template slug identifier",
            "fr": "Template slug identifier",
            "ro": "Template slug identifier",
            "it": "Template slug identifier"
          },
          "bot": "Updated slug for template documents.",
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:meta"
        },
        {
          "name": "Meta App",
          "as": "app",
          "description": {
            "en": "App this template belongs to",
            "de": "Zugehörige App",
            "es": "App this template belongs to",
            "fr": "App this template belongs to",
            "ro": "App this template belongs to",
            "it": "App this template belongs to"
          },
          "bot": "App name like 'outreach' or 'followups'.",
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:meta"
        },
        {
          "name": "Meta Channel",
          "as": "channel",
          "description": {
            "en": "Channel (whatsapp, email, linkedin, post)",
            "de": "Kanal (whatsapp, email, linkedin, post)",
            "es": "Channel (whatsapp, email, linkedin, post)",
            "fr": "Channel (whatsapp, email, linkedin, post)",
            "ro": "Channel (whatsapp, email, linkedin, post)",
            "it": "Channel (whatsapp, email, linkedin, post)"
          },
          "bot": "Communication channel for the template.",
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:meta"
        },
        {
          "name": "Meta Step",
          "as": {
            "en": "step",
            "de": "step",
            "es": "step",
            "fr": "step",
            "ro": "step",
            "it": "step"
          },
          "description": {
            "en": "Sequence step number",
            "de": "Sequenz-Schrittnummer",
            "es": "Sequence step number",
            "fr": "Sequence step number",
            "ro": "Sequence step number",
            "it": "Sequence step number"
          },
          "bot": "Integer step number in the sequence.",
          "type": "uint16",
          "source": "field",
          "required": false,
          "position": "payload:meta"
        },
        {
          "name": "Meta Delay Days",
          "as": "delay_days",
          "description": {
            "en": "Days to wait before this step",
            "de": "Tage Wartezeit vor diesem Schritt",
            "es": "Days to wait before this step",
            "fr": "Days to wait before this step",
            "ro": "Days to wait before this step",
            "it": "Days to wait before this step"
          },
          "bot": "Days after the previous step.",
          "type": "uint16",
          "source": "field",
          "required": false,
          "position": "payload:meta"
        },
        {
          "name": "Meta Variables",
          "as": "variables",
          "description": {
            "en": "Comma-separated template variables",
            "de": "Kommagetrennte Template-Variablen",
            "es": "Comma-separated template variables",
            "fr": "Comma-separated template variables",
            "ro": "Comma-separated template variables",
            "it": "Comma-separated template variables"
          },
          "bot": "Template variables like 'name,company'.",
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:meta"
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Document updated: {{title}}",
      "de": "Dokument aktualisiert: {{title}}",
      "es": "Document updated: {{title}}",
      "fr": "Document updated: {{title}}",
      "ro": "Document updated: {{title}}",
      "it": "Document updated: {{title}}"
    }
  }
}
