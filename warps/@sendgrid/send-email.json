{
  "protocol": "warp:3.0.0",
  "name": "SendGrid: Send Email",
  "title": {
    "en": "Send email",
    "de": "E-Mail senden",
    "es": "Send email",
    "fr": "Send email",
    "ro": "Send email",
    "it": "Send email"
  },
  "description": {
    "en": "Send an email using SendGrid's API.",
    "de": "Sende eine E-Mail über die SendGrid-API.",
    "es": "Send an email using SendGrid's API.",
    "fr": "Send an email using SendGrid's API.",
    "ro": "Send an email using SendGrid's API.",
    "it": "Send an email using SendGrid's API."
  },
  "vars": {
    "API_KEY": "env:SENDGRID_API_KEY|Get your API Key from https://app.sendgrid.com/settings/api_keys"
  },
  "actions": [
    {
      "type": "collect",
      "label": "Send Email",
      "destination": {
        "url": "https://api.sendgrid.com/v3/mail/send",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "To",
          "as": "to",
          "description": {
            "en": "Recipient email address.",
            "es": "Recipient email address.",
            "fr": "Recipient email address.",
            "ro": "Recipient email address.",
            "it": "Recipient email address."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:personalizations.0.to.0.email"
        },
        {
          "name": {
            "en": "From",
            "de": "From",
            "es": "From",
            "fr": "From",
            "ro": "From",
            "it": "From"
          },
          "as": {
            "en": "from",
            "de": "from",
            "es": "from",
            "fr": "from",
            "ro": "from",
            "it": "from"
          },
          "description": {
            "en": "Sender email address (must be verified).",
            "es": "Sender email address (must be verified).",
            "fr": "Sender email address (must be verified).",
            "ro": "Sender email address (must be verified).",
            "it": "Sender email address (must be verified)."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:from.email"
        },
        {
          "name": "Subject",
          "as": "subject",
          "description": {
            "en": "Email subject.",
            "es": "Email subject.",
            "fr": "Email subject.",
            "ro": "Email subject.",
            "it": "Email subject."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:personalizations.0.subject"
        },
        {
          "name": "Content Value",
          "as": "value",
          "description": {
            "en": "The body of the email (text/plain or text/html).",
            "es": "The body of the email (text/plain or text/html).",
            "fr": "The body of the email (text/plain or text/html).",
            "ro": "The body of the email (text/plain or text/html).",
            "it": "The body of the email (text/plain or text/html)."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:content.0.value"
        },
        {
          "name": "Content Type",
          "as": {
            "en": "type",
            "de": "type",
            "es": "type",
            "fr": "type",
            "ro": "type",
            "it": "type"
          },
          "description": {
            "en": "Mime type of the content (text/plain or text/html).",
            "es": "Mime type of the content (text/plain or text/html).",
            "fr": "Mime type of the content (text/plain or text/html).",
            "ro": "Mime type of the content (text/plain or text/html).",
            "it": "Mime type of the content (text/plain or text/html)."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:content.0.type",
          "default": "text/plain"
        }
      ]
    }
  ],
  "output": {
    "STATUS": "out.status"
  },
  "messages": {
    "success": {
      "en": "Email sent successfully.",
      "de": "E-Mail erfolgreich gesendet.",
      "es": "Email sent successfully.",
      "fr": "Email sent successfully.",
      "ro": "Email sent successfully.",
      "it": "Email sent successfully."
    }
  }
}
