{
  "protocol": "warp:3.0.0",
  "name": "Allowance: View Agent IDs",
  "title": {
    "en": "View Agent Allowance IDs",
    "es": "View Agent Allowance IDs",
    "fr": "View Agent Allowance IDs",
    "ro": "View Agent Allowance IDs",
    "it": "View Agent Allowance IDs"
  },
  "description": {
    "en": "Get all allowance IDs assigned to an agent address.",
    "es": "Get all allowance IDs assigned to an agent address.",
    "fr": "Get all allowance IDs assigned to an agent address.",
    "ro": "Get all allowance IDs assigned to an agent address.",
    "it": "Get all allowance IDs assigned to an agent address."
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "View",
        "es": "View",
        "fr": "View",
        "ro": "View",
        "it": "View"
      },
      "address": "INJECT:ALLOWANCE_SC",
      "func": "getAgentAllowanceIds",
      "gasLimit": 5000000,
      "abi": "INJECT:abis/allowance.abi.json",
      "inputs": [
        {
          "name": "Blockchain",
          "as": "chain",
          "bot": "The blockchain network.",
          "type": "string",
          "position": "chain",
          "source": "field",
          "required": true
        },
        {
          "name": "Agent Address",
          "as": "agent",
          "description": {
            "en": "The wallet address of the agent",
            "es": "The wallet address of the agent",
            "fr": "The wallet address of the agent",
            "ro": "The wallet address of the agent",
            "it": "The wallet address of the agent"
          },
          "type": "address",
          "position": "arg:1",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "IDS": "out",
    "COUNT": "transform:() => Array.isArray(results.IDS) ? results.IDS.length : 0"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} budget(s) for this agent.",
      "es": "Found {{COUNT}} budget(s) for this agent.",
      "fr": "Found {{COUNT}} budget(s) for this agent.",
      "ro": "Found {{COUNT}} budget(s) for this agent.",
      "it": "Found {{COUNT}} budget(s) for this agent."
    },
    "card": {
      "en": "{{COUNT}} Budget(s)",
      "es": "{{COUNT}} Budget(s)",
      "fr": "{{COUNT}} Budget(s)",
      "ro": "{{COUNT}} Budget(s)",
      "it": "{{COUNT}} Budget(s)"
    }
  }
}
