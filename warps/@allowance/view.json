{
  "protocol": "warp:3.0.0",
  "name": "Allowance: View",
  "title": {
    "en": "View Allowance",
    "es": "View Allowance",
    "fr": "View Allowance",
    "ro": "View Allowance",
    "it": "View Allowance"
  },
  "description": {
    "en": "View the details of an allowance including balance, spending limits, and usage.",
    "es": "View the details of an allowance including balance, spending limits, and usage.",
    "fr": "View the details of an allowance including balance, spending limits, and usage.",
    "ro": "View the details of an allowance including balance, spending limits, and usage.",
    "it": "View the details of an allowance including balance, spending limits, and usage."
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "View",
        "es": "View",
        "fr": "View",
        "ro": "View",
        "it": "View"
      },
      "address": "INJECT:ALLOWANCE_SC",
      "func": "getAllowance",
      "gasLimit": 5000000,
      "abi": "INJECT:abis/allowance.abi.json",
      "inputs": [
        {
          "name": "Blockchain",
          "as": "chain",
          "bot": "The blockchain network.",
          "type": "string",
          "position": "chain",
          "source": "field",
          "required": true
        },
        {
          "name": "Allowance ID",
          "as": "allowance_id",
          "description": {
            "en": "The ID of the allowance to view",
            "es": "The ID of the allowance to view",
            "fr": "The ID of the allowance to view",
            "ro": "The ID of the allowance to view",
            "it": "The ID of the allowance to view"
          },
          "type": "uint64",
          "position": "arg:1",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "ALLOWANCE": "out",
    "TOKEN": "transform:() => results.ALLOWANCE?.token || 'EGLD'",
    "BALANCE_RAW": "transform:() => results.ALLOWANCE?.balance || '0'",
    "BALANCE": "transform:() => Number(results.BALANCE_RAW) / 10 ** 18",
    "BALANCE_FORMATTED": "transform:() => results.BALANCE.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })",
    "STATUS": "transform:() => results.ALLOWANCE?.paused ? 'Paused' : 'Active'"
  },
  "messages": {
    "success": {
      "en": "{{STATUS}} allowance: {{BALANCE_FORMATTED}} {{TOKEN}} remaining.",
      "es": "{{STATUS}} allowance: {{BALANCE_FORMATTED}} {{TOKEN}} remaining.",
      "fr": "{{STATUS}} allowance: {{BALANCE_FORMATTED}} {{TOKEN}} remaining.",
      "ro": "{{STATUS}} allowance: {{BALANCE_FORMATTED}} {{TOKEN}} remaining.",
      "it": "{{STATUS}} allowance: {{BALANCE_FORMATTED}} {{TOKEN}} remaining."
    },
    "card": {
      "en": "{{BALANCE_FORMATTED}} {{TOKEN}} • {{STATUS}}",
      "es": "{{BALANCE_FORMATTED}} {{TOKEN}} • {{STATUS}}",
      "fr": "{{BALANCE_FORMATTED}} {{TOKEN}} • {{STATUS}}",
      "ro": "{{BALANCE_FORMATTED}} {{TOKEN}} • {{STATUS}}",
      "it": "{{BALANCE_FORMATTED}} {{TOKEN}} • {{STATUS}}"
    },
    "info": {
      "en": "Balance: {{BALANCE_FORMATTED}} {{TOKEN}}, Status: {{STATUS}}",
      "es": "Balance: {{BALANCE_FORMATTED}} {{TOKEN}}, Status: {{STATUS}}",
      "fr": "Balance: {{BALANCE_FORMATTED}} {{TOKEN}}, Status: {{STATUS}}",
      "ro": "Balance: {{BALANCE_FORMATTED}} {{TOKEN}}, Status: {{STATUS}}",
      "it": "Balance: {{BALANCE_FORMATTED}} {{TOKEN}}, Status: {{STATUS}}"
    }
  }
}
