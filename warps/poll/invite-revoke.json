{
  "protocol": "warp:3.0.0",
  "name": "Poll: Revoke Invite",
  "title": {
    "en": "Revoke Invite",
    "de": "Einladung widerrufen"
  },
  "description": {
    "en": "Revoke an active invite code so it can no longer be used.",
    "de": "Aktiven Einladungscode widerrufen, sodass er nicht mehr verwendet werden kann."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Revoke",
        "de": "Widerrufen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "revokeInvite",
      "args": [
        "string:{{SLUG}}",
        "string:{{CODE}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "CODE",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Invite code",
            "de": "Einladungscode"
          }
        }
      ],
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
