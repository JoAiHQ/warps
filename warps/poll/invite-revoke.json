{
  "protocol": "warp:3.0.0",
  "name": "Poll: Revoke Invite",
  "title": {
    "en": "Revoke Invite",
    "de": "Einladung widerrufen",
    "fr": "Revoquer l invitation",
    "es": "Revocar invitacion",
    "ro": "Revoca invitatia"
  },
  "description": {
    "en": "Revoke an active invite code so it can no longer be used.",
    "de": "Aktiven Einladungscode widerrufen, sodass er nicht mehr verwendet werden kann.",
    "fr": "Revoquez un code d invitation actif afin qu il ne puisse plus etre utilise.",
    "es": "Revoca un codigo de invitacion activo para que ya no pueda usarse.",
    "ro": "Revoca un cod de invitatie activ astfel incat sa nu mai poata fi folosit."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Revoke",
        "de": "Widerrufen",
        "fr": "Revoquer",
        "es": "Revocar",
        "ro": "Revoca"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "revokeInvite",
      "args": [
        "string:{{SLUG}}",
        "string:{{CODE}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "CODE",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Invite code",
            "de": "Einladungscode",
            "fr": "Code d invitation",
            "es": "Codigo de invitacion",
            "ro": "Cod de invitatie"
          }
        }
      ],
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ]
}
