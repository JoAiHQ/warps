{
  "protocol": "warp:3.0.0",
  "name": "Poll: Get Members",
  "title": {
    "en": "Group Members",
    "de": "Gruppenmitglieder",
    "fr": "Membres du groupe",
    "es": "Miembros del grupo",
    "ro": "Membrii grupului"
  },
  "description": {
    "en": "List all members of a group.",
    "de": "Alle Mitglieder einer Gruppe anzeigen.",
    "fr": "Afficher tous les membres d un groupe.",
    "es": "Muestra todos los miembros de un grupo.",
    "ro": "Afiseaza toti membrii unui grup."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS",
    "JOAI_TEAM_SLUG": "env:JOAI_TEAM_SLUG|Team identifier"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading members...",
        "de": "Mitglieder werden geladen...",
        "fr": "Chargement des membres...",
        "es": "Cargando miembros...",
        "ro": "Se incarca membrii..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getMembers",
      "args": [
        "string:{{GROUP_SLUG}}"
      ],
      "inputs": [
        {
          "name": "GROUP_SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "required": true,
          "default": "{{JOAI_TEAM_SLUG}}"
        }
      ],
      "auto": true,
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ]
}
