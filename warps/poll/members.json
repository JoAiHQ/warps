{
  "protocol": "warp:3.0.0",
  "name": "Poll: Get Members",
  "title": {
    "en": "Group Members",
    "de": "Gruppenmitglieder"
  },
  "description": {
    "en": "List all members of a group.",
    "de": "Alle Mitglieder einer Gruppe anzeigen."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading members...",
        "de": "Mitglieder werden geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getMembers",
      "args": [
        "string:{{SLUG}}"
      ],
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
