{
  "protocol": "warp:3.0.0",
  "name": "Poll: Active Polls",
  "title": {
    "en": "Active Polls",
    "de": "Aktive Abstimmungen",
    "fr": "Sondages actifs",
    "es": "Encuestas activas",
    "ro": "Sondaje active"
  },
  "description": {
    "en": "See all open polls in this space.",
    "de": "Alle offenen Abstimmungen in diesem Space anzeigen.",
    "fr": "Consultez tous les sondages ouverts dans cet espace.",
    "es": "Consulta todas las encuestas abiertas de este espacio.",
    "ro": "Vezi toate sondajele deschise din acest spatiu."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS",
    "JOAI_TEAM_SLUG": "env:JOAI_TEAM_SLUG|Team identifier"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading polls...",
        "de": "Abstimmungen werden geladen...",
        "fr": "Chargement des sondages...",
        "es": "Cargando encuestas...",
        "ro": "Se incarca sondajele..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getActivePolls",
      "args": [
        "string:{{GROUP_SLUG}}"
      ],
      "inputs": [
        {
          "name": "GROUP_SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "required": true,
          "default": "{{JOAI_TEAM_SLUG}}"
        }
      ],
      "auto": true,
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ],
  "next": "@poll-detail?POLL_ID={{RESULT}}"
}
