{
  "protocol": "warp:3.0.0",
  "name": "Poll: Active Polls",
  "title": {
    "en": "Active Polls",
    "de": "Aktive Abstimmungen"
  },
  "description": {
    "en": "See all open polls in this space.",
    "de": "Alle offenen Abstimmungen in diesem Space anzeigen."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading polls...",
        "de": "Abstimmungen werden geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getActivePolls",
      "args": [
        "string:{{SLUG}}"
      ],
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
