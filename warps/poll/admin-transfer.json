{
  "protocol": "warp:3.0.0",
  "name": "Poll: Transfer Admin",
  "title": {
    "en": "Transfer Admin",
    "de": "Admin übertragen",
    "fr": "Transferer l administration",
    "es": "Transferir administracion",
    "ro": "Transfera administrarea"
  },
  "description": {
    "en": "Hand over group admin rights to another member.",
    "de": "Admin-Rechte der Gruppe an ein anderes Mitglied übertragen.",
    "fr": "Transferez les droits d administration du groupe a un autre membre.",
    "es": "Traspasa los permisos de administracion del grupo a otra persona miembro.",
    "ro": "Transfera drepturile de administrator ale grupului unui alt membru."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Transfer",
        "de": "Übertragen",
        "fr": "Transferer",
        "es": "Transferir",
        "ro": "Transfera"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "transferAdmin",
      "args": [
        "string:{{SLUG}}",
        "address:{{NEW_ADMIN}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "NEW_ADMIN",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "New admin address",
            "de": "Neue Admin-Adresse",
            "fr": "Adresse du nouvel admin",
            "es": "Direccion del nuevo administrador",
            "ro": "Adresa noului administrator"
          }
        }
      ],
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ]
}
