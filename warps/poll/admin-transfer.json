{
  "protocol": "warp:3.0.0",
  "name": "Poll: Transfer Admin",
  "title": {
    "en": "Transfer Admin",
    "de": "Admin übertragen"
  },
  "description": {
    "en": "Hand over group admin rights to another member.",
    "de": "Admin-Rechte der Gruppe an ein anderes Mitglied übertragen."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Transfer",
        "de": "Übertragen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "transferAdmin",
      "args": [
        "string:{{SLUG}}",
        "address:{{NEW_ADMIN}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "NEW_ADMIN",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "New admin address",
            "de": "Neue Admin-Adresse"
          }
        }
      ],
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
