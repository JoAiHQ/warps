{
  "protocol": "warp:3.0.0",
  "name": "Poll: Approve Member",
  "title": {
    "en": "Approve Member",
    "de": "Mitglied genehmigen"
  },
  "description": {
    "en": "Approve a pending membership request and add the person to the group.",
    "de": "Ausstehende Mitgliedschaftsanfrage genehmigen und Person zur Gruppe hinzufügen."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Approve",
        "de": "Genehmigen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "approveMember",
      "args": [
        "string:{{SLUG}}",
        "address:{{ADDRESS}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "ADDRESS",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Member address",
            "de": "Mitglied-Adresse"
          }
        }
      ],
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
