{
  "protocol": "warp:3.0.0",
  "name": "Poll: Has Voted",
  "title": {
    "en": "Check Vote Status",
    "de": "Abstimmungsstatus prüfen",
    "fr": "Verifier le statut du vote",
    "es": "Comprobar estado del voto",
    "ro": "Verifica starea votului"
  },
  "description": {
    "en": "Check if an address has already voted on a poll.",
    "de": "Prüfen, ob eine Adresse bereits an einer Abstimmung teilgenommen hat.",
    "fr": "Verifiez si une adresse a deja vote dans un sondage.",
    "es": "Comprueba si una direccion ya ha votado en una encuesta.",
    "ro": "Verifica daca o adresa a votat deja intr-un sondaj."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Checking...",
        "de": "Wird geprüft...",
        "fr": "Verification...",
        "es": "Comprobando...",
        "ro": "Se verifica..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "hasVoted",
      "args": [
        "u64:{{POLL_ID}}",
        "address:{{ADDRESS}}"
      ],
      "inputs": [
        {
          "name": "POLL_ID",
          "type": "uint64",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Poll ID",
            "de": "Abstimmungs-ID",
            "fr": "ID du sondage",
            "es": "ID de la encuesta",
            "ro": "ID-ul sondajului"
          }
        },
        {
          "name": "ADDRESS",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Address",
            "de": "Adresse",
            "fr": "Adresse",
            "es": "Direccion",
            "ro": "Adresa"
          }
        }
      ],
      "auto": false,
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ]
}
