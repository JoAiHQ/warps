{
  "protocol": "warp:3.0.0",
  "name": "Poll: Get Invite",
  "title": {
    "en": "Invite Status",
    "de": "Einladungsstatus",
    "fr": "Statut de l invitation",
    "es": "Estado de la invitacion",
    "ro": "Starea invitatiei"
  },
  "description": {
    "en": "Check if an invite code is still valid and how many uses remain.",
    "de": "Prüfen, ob ein Einladungscode noch gültig ist und wie viele Nutzungen verbleiben.",
    "fr": "Verifiez si un code d invitation est encore valable et combien d utilisations il reste.",
    "es": "Comprueba si un codigo de invitacion sigue siendo valido y cuantas veces mas puede usarse.",
    "ro": "Verifica daca un cod de invitatie mai este valid si cate utilizari au ramas."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Checking invite...",
        "de": "Einladung wird geprüft...",
        "fr": "Verification de l invitation...",
        "es": "Comprobando invitacion...",
        "ro": "Se verifica invitatia..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getInvite",
      "args": [
        "string:{{SLUG}}",
        "string:{{CODE}}"
      ],
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "CODE",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Invite code",
            "de": "Einladungscode",
            "fr": "Code d invitation",
            "es": "Codigo de invitacion",
            "ro": "Cod de invitatie"
          }
        }
      ],
      "auto": false,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
