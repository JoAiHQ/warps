{
  "protocol": "warp:3.0.0",
  "name": "Poll: Get Invite",
  "title": {
    "en": "Invite Status",
    "de": "Einladungsstatus"
  },
  "description": {
    "en": "Check if an invite code is still valid and how many uses remain.",
    "de": "Prüfen, ob ein Einladungscode noch gültig ist und wie viele Nutzungen verbleiben."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Checking invite...",
        "de": "Einladung wird geprüft..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getInvite",
      "args": [
        "string:{{SLUG}}",
        "string:{{CODE}}"
      ],
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "CODE",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Invite code",
            "de": "Einladungscode"
          }
        }
      ],
      "auto": false,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
