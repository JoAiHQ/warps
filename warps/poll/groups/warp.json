{
  "protocol": "warp:3.0.0",
  "name": "Poll: Groups",
  "title": {
    "en": "Groups",
    "de": "Gruppen",
    "fr": "Groupes",
    "es": "Grupos",
    "ro": "Grupuri"
  },
  "description": {
    "en": "View your voting group and manage membership.",
    "de": "Abstimmungsgruppe anzeigen und Mitgliedschaft verwalten.",
    "fr": "Consultez votre groupe de vote et gerez les membres.",
    "es": "Consulta tu grupo de votacion y gestiona la membresia.",
    "ro": "Vizualizeaza grupul tau de vot si gestioneaza calitatea de membru."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS",
    "JOAI_TEAM_SLUG": "env:JOAI_TEAM_SLUG|Team identifier"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading group...",
        "de": "Gruppe wird geladen...",
        "fr": "Chargement du groupe...",
        "es": "Cargando grupo...",
        "ro": "Se incarca grupul..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getGroup",
      "args": [
        "string:{{GROUP_SLUG}}"
      ],
      "inputs": [
        {
          "name": "GROUP_SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "required": true,
          "default": "{{JOAI_TEAM_SLUG}}"
        }
      ],
      "auto": true,
      "abi": "INJECT:../contract/output/poll.abi.json"
    }
  ],
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/poll/groups/chatapp.9a0bbbc3.dist.html"
}