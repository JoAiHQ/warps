{
  "protocol": "warp:3.0.0",
  "name": "Poll: Has Voted",
  "title": {
    "en": "Check Vote Status",
    "de": "Abstimmungsstatus prüfen"
  },
  "description": {
    "en": "Check if an address has already voted on a poll.",
    "de": "Prüfen, ob eine Adresse bereits an einer Abstimmung teilgenommen hat."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Checking...",
        "de": "Wird geprüft..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "hasVoted",
      "args": [
        "u64:{{POLL_ID}}",
        "address:{{ADDRESS}}"
      ],
      "inputs": [
        {
          "name": "POLL_ID",
          "type": "uint64",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Poll ID",
            "de": "Abstimmungs-ID"
          }
        },
        {
          "name": "ADDRESS",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Address",
            "de": "Adresse"
          }
        }
      ],
      "auto": false,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
