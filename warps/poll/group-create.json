{
  "protocol": "warp:3.0.0",
  "name": "Poll: Create Group",
  "title": {
    "en": "Create Group",
    "de": "Gruppe erstellen"
  },
  "description": {
    "en": "Create a new voting group. You become the admin and first member.",
    "de": "Neue Abstimmungsgruppe erstellen. Du wirst Admin und erstes Mitglied."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Create Group",
        "de": "Gruppe erstellen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "createGroup",
      "args": [
        "string:{{SLUG}}",
        "string:{{NAME}}",
        "bool:{{OPEN_MEMBERSHIP}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Slug (e.g. my-building)",
            "de": "Slug (z.B. mein-gebaeude)"
          }
        },
        {
          "name": "NAME",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Group name",
            "de": "Gruppenname"
          }
        },
        {
          "name": "OPEN_MEMBERSHIP",
          "type": "bool",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "label": {
            "en": "Open membership (anyone can join)",
            "de": "Offene Mitgliedschaft (jeder kann beitreten)"
          }
        }
      ],
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
