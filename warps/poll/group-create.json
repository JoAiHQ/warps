{
  "protocol": "warp:3.0.0",
  "name": "Poll: Create Group",
  "title": {
    "en": "Create Group",
    "de": "Gruppe erstellen",
    "fr": "Creer un groupe",
    "es": "Crear grupo",
    "ro": "Creeaza grupul"
  },
  "description": {
    "en": "Create a new voting group. You become the admin and first member.",
    "de": "Neue Abstimmungsgruppe erstellen. Du wirst Admin und erstes Mitglied.",
    "fr": "Creez un nouveau groupe de vote. Vous en devenez l administrateur et le premier membre.",
    "es": "Crea un nuevo grupo de votacion. Seras la persona administradora y el primer miembro.",
    "ro": "Creeaza un nou grup de vot. Vei deveni administratorul si primul membru."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS",
    "JOAI_TEAM_SLUG": "env:JOAI_TEAM_SLUG|Team identifier"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Create Group",
        "de": "Gruppe erstellen",
        "fr": "Creer le groupe",
        "es": "Crear grupo",
        "ro": "Creeaza grupul"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "createGroup",
      "args": [
        "string:{{GROUP_SLUG}}",
        "string:{{NAME}}",
        "bool:{{OPEN_MEMBERSHIP}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "GROUP_SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Slug (e.g. my-building)",
            "de": "Slug (z.B. mein-gebaeude)",
            "fr": "Slug (par ex. ma-copropriete)",
            "es": "Slug (p. ej. mi-edificio)",
            "ro": "Slug (de ex. blocul-meu)"
          }
        },
        {
          "name": "NAME",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Group name",
            "de": "Gruppenname",
            "fr": "Nom du groupe",
            "es": "Nombre del grupo",
            "ro": "Numele grupului"
          }
        },
        {
          "name": "OPEN_MEMBERSHIP",
          "type": "bool",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "label": {
            "en": "Open membership (anyone can join)",
            "de": "Offene Mitgliedschaft (jeder kann beitreten)",
            "fr": "Adhesion ouverte (tout le monde peut rejoindre)",
            "es": "Membresia abierta (cualquiera puede unirse)",
            "ro": "Membru deschis (oricine se poate alatura)"
          }
        }
      ],
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ],
  "next": "@joai-site-provision?brand=poll&team={{JOAI_TEAM_SLUG}}&settings={\"GROUP_SLUG\":\"{{GROUP_SLUG}}\"}"
}
