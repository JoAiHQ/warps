{
  "protocol": "warp:3.0.0",
  "name": "Poll: Get Group Polls",
  "title": {
    "en": "All Group Polls",
    "de": "Alle Gruppenabstimmungen"
  },
  "description": {
    "en": "Query all poll IDs belonging to a group (active and expired).",
    "de": "Alle Abstimmungs-IDs einer Gruppe abfragen (aktive und abgelaufene)."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading polls...",
        "de": "Abstimmungen werden geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getGroupPolls",
      "args": [
        "string:{{SLUG}}"
      ],
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
