{
  "protocol": "warp:3.0.0",
  "name": "Poll: Create Poll",
  "title": {
    "en": "Create Poll",
    "de": "Abstimmung erstellen",
    "fr": "Creer un sondage",
    "es": "Crear encuesta",
    "ro": "Creeaza sondaj"
  },
  "description": {
    "en": "Create a new poll in your group. Provide a question, deadline (Unix timestamp), and up to 4 answer options.",
    "de": "Neue Abstimmung in der Gruppe erstellen. Frage, Deadline (Unix-Timestamp) und bis zu 4 Antwortoptionen angeben.",
    "fr": "Creez un nouveau sondage dans votre groupe. Indiquez la question, l echeance (timestamp Unix) et jusqu a 4 reponses possibles.",
    "es": "Crea una nueva encuesta en tu grupo. Indica la pregunta, la fecha limite (timestamp Unix) y hasta 4 opciones de respuesta.",
    "ro": "Creeaza un nou sondaj in grup. Introdu intrebarea, termenul limita (timestamp Unix) si pana la 4 optiuni de raspuns."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Create Poll",
        "de": "Abstimmung erstellen",
        "fr": "Creer le sondage",
        "es": "Crear encuesta",
        "ro": "Creeaza sondajul"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "createPoll",
      "args": [
        "string:{{GROUP_SLUG}}",
        "string:{{QUESTION}}",
        "u64:{{DEADLINE}}",
        "string:{{OPTION_1}}",
        "string:{{OPTION_2}}",
        "string:{{OPTION_3}}",
        "string:{{OPTION_4}}"
      ],
      "gasLimit": 15000000,
      "inputs": [
        {
          "name": "GROUP_SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "QUESTION",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Question",
            "de": "Frage",
            "fr": "Question",
            "es": "Pregunta",
            "ro": "Intrebare"
          }
        },
        {
          "name": "DEADLINE",
          "type": "uint64",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "label": {
            "en": "Deadline (Unix timestamp)",
            "de": "Deadline (Unix-Timestamp)",
            "fr": "Echeance (timestamp Unix)",
            "es": "Fecha limite (timestamp Unix)",
            "ro": "Termen limita (timestamp Unix)"
          }
        },
        {
          "name": "OPTION_1",
          "type": "string",
          "position": "arg:4",
          "source": "field",
          "required": true,
          "label": {
            "en": "Option 1",
            "de": "Option 1",
            "fr": "Option 1",
            "es": "Opcion 1",
            "ro": "Optiunea 1"
          }
        },
        {
          "name": "OPTION_2",
          "type": "string",
          "position": "arg:5",
          "source": "field",
          "required": true,
          "label": {
            "en": "Option 2",
            "de": "Option 2",
            "fr": "Option 2",
            "es": "Opcion 2",
            "ro": "Optiunea 2"
          }
        },
        {
          "name": "OPTION_3",
          "type": "string",
          "position": "arg:6",
          "source": "field",
          "required": false,
          "label": {
            "en": "Option 3 (optional)",
            "de": "Option 3 (optional)",
            "fr": "Option 3 (facultative)",
            "es": "Opcion 3 (opcional)",
            "ro": "Optiunea 3 (optional)"
          }
        },
        {
          "name": "OPTION_4",
          "type": "string",
          "position": "arg:7",
          "source": "field",
          "required": false,
          "label": {
            "en": "Option 4 (optional)",
            "de": "Option 4 (optional)",
            "fr": "Option 4 (facultative)",
            "es": "Opcion 4 (opcional)",
            "ro": "Optiunea 4 (optional)"
          }
        }
      ],
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ]
}
