{
  "protocol": "warp:3.0.0",
  "name": "Poll: Create Poll",
  "title": {
    "en": "Create Poll",
    "de": "Abstimmung erstellen",
    "fr": "Creer un sondage",
    "es": "Crear encuesta",
    "ro": "Creeaza sondaj"
  },
  "description": {
    "en": "Add a new question to an existing group for members to vote on. Requires a group to already exist. Provide a question, optional deadline, and 2–7 answer options.",
    "de": "Neue Frage zu einer bestehenden Gruppe hinzufuegen, ueber die Mitglieder abstimmen koennen. Gruppe muss bereits existieren.",
    "fr": "Ajoutez une nouvelle question a un groupe existant pour que les membres puissent voter. Necessite qu un groupe existe deja.",
    "es": "Anade una nueva pregunta a un grupo existente para que los miembros voten. Requiere que el grupo ya exista.",
    "ro": "Adauga o noua intrebare unui grup existent pentru ca membrii sa voteze. Necesita ca grupul sa existe deja."
  },
  "bot": "Only run this after a group exists and the caller is a member. Requires GROUP_SLUG of an existing on-chain group. Deadline is a Unix timestamp (0 = no deadline). Provide 2–7 short answer options. After creation the user lands directly on the voting screen.",
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS",
    "JOAI_TEAM_SLUG": "env:JOAI_TEAM_SLUG|Team identifier"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Create Poll",
        "de": "Abstimmung erstellen",
        "fr": "Creer le sondage",
        "es": "Crear encuesta",
        "ro": "Creeaza sondajul"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "createPoll",
      "args": [
        "string:{{GROUP_SLUG}}",
        "string:{{QUESTION}}",
        "u64:{{DEADLINE}}",
        "string:{{OPTION_1}}",
        "string:{{OPTION_2}}"
      ],
      "gasLimit": 15000000,
      "inputs": [
        {
          "name": "GROUP_SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "required": true,
          "default": "{{JOAI_TEAM_SLUG}}"
        },
        {
          "name": "QUESTION",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Question",
            "de": "Frage",
            "fr": "Question",
            "es": "Pregunta",
            "ro": "Intrebare"
          }
        },
        {
          "name": "DEADLINE",
          "type": "uint64",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "label": {
            "en": "Deadline (Unix timestamp)",
            "de": "Deadline (Unix-Timestamp)",
            "fr": "Echeance (timestamp Unix)",
            "es": "Fecha limite (timestamp Unix)",
            "ro": "Termen limita (timestamp Unix)"
          }
        },
        {
          "name": "OPTION_1",
          "type": "string",
          "position": "arg:4",
          "source": "field",
          "required": true,
          "label": {
            "en": "Option 1",
            "de": "Option 1",
            "fr": "Option 1",
            "es": "Opcion 1",
            "ro": "Optiunea 1"
          }
        },
        {
          "name": "OPTION_2",
          "type": "string",
          "position": "arg:5",
          "source": "field",
          "required": true,
          "label": {
            "en": "Option 2",
            "de": "Option 2",
            "fr": "Option 2",
            "es": "Opcion 2",
            "ro": "Optiunea 2"
          }
        },
        {
          "name": "OPTION_3",
          "type": "string",
          "position": "arg:6",
          "source": "field",
          "required": false,
          "label": {
            "en": "Option 3 (optional)",
            "de": "Option 3 (optional)",
            "fr": "Option 3 (facultative)",
            "es": "Opcion 3 (opcional)",
            "ro": "Optiunea 3 (optional)"
          }
        },
        {
          "name": "OPTION_4",
          "type": "string",
          "position": "arg:7",
          "source": "field",
          "required": false,
          "label": {
            "en": "Option 4 (optional)",
            "de": "Option 4 (optional)",
            "fr": "Option 4 (facultative)",
            "es": "Opcion 4 (opcional)",
            "ro": "Optiunea 4 (optional)"
          }
        },
        {
          "name": "OPTION_5",
          "type": "string",
          "position": "arg:8",
          "source": "field",
          "required": false,
          "label": {
            "en": "Option 5 (optional)",
            "de": "Option 5 (optional)",
            "fr": "Option 5 (facultative)",
            "es": "Opcion 5 (opcional)",
            "ro": "Optiunea 5 (optional)"
          }
        },
        {
          "name": "OPTION_6",
          "type": "string",
          "position": "arg:9",
          "source": "field",
          "required": false,
          "label": {
            "en": "Option 6 (optional)",
            "de": "Option 6 (optional)",
            "fr": "Option 6 (facultative)",
            "es": "Opcion 6 (opcional)",
            "ro": "Optiunea 6 (optional)"
          }
        },
        {
          "name": "OPTION_7",
          "type": "string",
          "position": "arg:10",
          "source": "field",
          "required": false,
          "label": {
            "en": "Option 7 (optional)",
            "de": "Option 7 (optional)",
            "fr": "Option 7 (facultative)",
            "es": "Opcion 7 (opcional)",
            "ro": "Optiunea 7 (optional)"
          }
        }
      ],
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ],
  "output": {
    "RESULT": "out.1"
  },
  "next": "@poll-vote?POLL_ID={{RESULT}}"
}
