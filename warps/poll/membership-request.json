{
  "protocol": "warp:3.0.0",
  "name": "Poll: Join Space",
  "title": {
    "en": "Join This Space",
    "de": "Space beitreten"
  },
  "description": {
    "en": "Request membership to participate in polls. The admin will approve your request.",
    "de": "Mitgliedschaft beantragen, um an Abstimmungen teilzunehmen. Der Admin genehmigt deine Anfrage."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Send Request",
        "de": "Anfrage senden"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "requestMembership",
      "args": [
        "string:{{SLUG}}",
        "string:{{DISPLAY_NAME}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "DISPLAY_NAME",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Your display name",
            "de": "Dein Anzeigename"
          }
        }
      ],
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
