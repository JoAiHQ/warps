{
  "protocol": "warp:3.0.0",
  "name": "Poll: Join Space",
  "title": {
    "en": "Join This Space",
    "de": "Space beitreten",
    "fr": "Rejoindre cet espace",
    "es": "Unirse a este espacio",
    "ro": "Alatura-te acestui spatiu"
  },
  "description": {
    "en": "Request membership to participate in polls. The admin will approve your request.",
    "de": "Mitgliedschaft beantragen, um an Abstimmungen teilzunehmen. Der Admin genehmigt deine Anfrage.",
    "fr": "Demandez a rejoindre cet espace pour participer aux sondages. Un administrateur examinera votre demande.",
    "es": "Solicita unirte para participar en las encuestas. La persona administradora aprobara tu solicitud.",
    "ro": "Solicita aderarea pentru a putea participa la sondaje. Administratorul iti va aproba cererea."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Send Request",
        "de": "Anfrage senden",
        "fr": "Envoyer la demande",
        "es": "Enviar solicitud",
        "ro": "Trimite cererea"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "requestMembership",
      "args": [
        "string:{{SLUG}}",
        "string:{{DISPLAY_NAME}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "DISPLAY_NAME",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Your display name",
            "de": "Dein Anzeigename",
            "fr": "Votre nom affiche",
            "es": "Tu nombre para mostrar",
            "ro": "Numele tau afisat"
          }
        }
      ],
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
