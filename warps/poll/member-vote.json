{
  "protocol": "warp:3.0.0",
  "name": "Poll: Get Member Vote",
  "title": {
    "en": "Member's Vote",
    "de": "Stimme des Mitglieds"
  },
  "description": {
    "en": "Query which option an address voted for on a poll.",
    "de": "Abfragen, für welche Option eine Adresse bei einer Abstimmung gestimmt hat."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading vote...",
        "de": "Stimme wird geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getMemberVote",
      "args": [
        "u64:{{POLL_ID}}",
        "address:{{ADDRESS}}"
      ],
      "inputs": [
        {
          "name": "POLL_ID",
          "type": "uint64",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Poll ID",
            "de": "Abstimmungs-ID"
          }
        },
        {
          "name": "ADDRESS",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Address",
            "de": "Adresse"
          }
        }
      ],
      "auto": false,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
