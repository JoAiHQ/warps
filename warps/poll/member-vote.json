{
  "protocol": "warp:3.0.0",
  "name": "Poll: Get Member Vote",
  "title": {
    "en": "Member's Vote",
    "de": "Stimme des Mitglieds",
    "fr": "Vote du membre",
    "es": "Voto del miembro",
    "ro": "Votul membrului"
  },
  "description": {
    "en": "Query which option an address voted for on a poll.",
    "de": "Abfragen, für welche Option eine Adresse bei einer Abstimmung gestimmt hat.",
    "fr": "Consultez pour quelle option une adresse a vote dans un sondage.",
    "es": "Consulta por que opcion voto una direccion en una encuesta.",
    "ro": "Afla pentru ce optiune a votat o adresa intr-un sondaj."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading vote...",
        "de": "Stimme wird geladen...",
        "fr": "Chargement du vote...",
        "es": "Cargando voto...",
        "ro": "Se incarca votul..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getMemberVote",
      "args": [
        "u64:{{POLL_ID}}",
        "address:{{ADDRESS}}"
      ],
      "inputs": [
        {
          "name": "POLL_ID",
          "type": "uint64",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Poll ID",
            "de": "Abstimmungs-ID",
            "fr": "ID du sondage",
            "es": "ID de la encuesta",
            "ro": "ID-ul sondajului"
          }
        },
        {
          "name": "ADDRESS",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Address",
            "de": "Adresse",
            "fr": "Adresse",
            "es": "Direccion",
            "ro": "Adresa"
          }
        }
      ],
      "auto": false,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
