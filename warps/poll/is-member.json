{
  "protocol": "warp:3.0.0",
  "name": "Poll: Is Member",
  "title": {
    "en": "Check Membership",
    "de": "Mitgliedschaft prüfen"
  },
  "description": {
    "en": "Check if an address is a member of a group.",
    "de": "Prüfen, ob eine Adresse Mitglied einer Gruppe ist."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Checking...",
        "de": "Wird geprüft..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "isMember",
      "args": [
        "string:{{SLUG}}",
        "address:{{ADDRESS}}"
      ],
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "ADDRESS",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Address",
            "de": "Adresse"
          }
        }
      ],
      "auto": false,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
