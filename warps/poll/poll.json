{
  "protocol": "warp:3.0.0",
  "name": "Poll: Get Poll",
  "title": {
    "en": "Poll Details",
    "de": "Abstimmungsdetails",
    "fr": "Details du sondage",
    "es": "Detalles de la encuesta",
    "ro": "Detaliile sondajului"
  },
  "description": {
    "en": "Query details of a specific poll.",
    "de": "Details einer bestimmten Abstimmung abfragen.",
    "fr": "Consultez les details d un sondage precis.",
    "es": "Consulta los detalles de una encuesta concreta.",
    "ro": "Consulta detaliile unui anumit sondaj."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading poll...",
        "de": "Abstimmung wird geladen...",
        "fr": "Chargement du sondage...",
        "es": "Cargando encuesta...",
        "ro": "Se incarca sondajul..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getPoll",
      "args": [
        "u64:{{POLL_ID}}"
      ],
      "inputs": [
        {
          "name": "POLL_ID",
          "type": "uint64",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Poll ID",
            "de": "Abstimmungs-ID",
            "fr": "ID du sondage",
            "es": "ID de la encuesta",
            "ro": "ID-ul sondajului"
          }
        }
      ],
      "auto": false,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
