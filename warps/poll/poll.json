{
  "protocol": "warp:3.0.0",
  "name": "Poll: Get Poll",
  "title": {
    "en": "Poll Details",
    "de": "Abstimmungsdetails"
  },
  "description": {
    "en": "Query details of a specific poll.",
    "de": "Details einer bestimmten Abstimmung abfragen."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading poll...",
        "de": "Abstimmung wird geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getPoll",
      "args": [
        "u64:{{POLL_ID}}"
      ],
      "inputs": [
        {
          "name": "POLL_ID",
          "type": "uint64",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Poll ID",
            "de": "Abstimmungs-ID"
          }
        }
      ],
      "auto": false,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
