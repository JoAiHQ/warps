{
  "protocol": "warp:3.0.0",
  "name": "Poll: Approve Member",
  "title": {
    "en": "Approve Member",
    "de": "Mitglied genehmigen",
    "fr": "Approuver le membre",
    "es": "Aprobar miembro",
    "ro": "Aproba membrul"
  },
  "description": {
    "en": "Approve a pending membership request and add the person to the group.",
    "de": "Ausstehende Mitgliedschaftsanfrage genehmigen und Person zur Gruppe hinzufügen.",
    "fr": "Approuvez une demande d adhesion en attente et ajoutez la personne au groupe.",
    "es": "Aprueba una solicitud pendiente y anade a esa persona al grupo.",
    "ro": "Aproba o cerere de aderare aflata in asteptare si adauga persoana in grup."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS",
    "JOAI_TEAM_SLUG": "env:JOAI_TEAM_SLUG|Team identifier"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Approve",
        "de": "Genehmigen",
        "fr": "Approuver",
        "es": "Aprobar",
        "ro": "Aproba"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "approveMember",
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "GROUP_SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "required": true,
          "default": "{{JOAI_TEAM_SLUG}}"
        },
        {
          "name": "ADDRESS",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Member address",
            "de": "Mitglied-Adresse",
            "fr": "Adresse du membre",
            "es": "Direccion del miembro",
            "ro": "Adresa membrului"
          }
        }
      ],
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ]
}
