{
  "protocol": "warp:3.0.0",
  "name": "Poll: Join With Invite",
  "title": {
    "en": "Join With Invite Code",
    "de": "Mit Einladungscode beitreten",
    "fr": "Rejoindre avec un code d invitation",
    "es": "Unirse con codigo de invitacion",
    "ro": "Alatura-te cu cod de invitatie"
  },
  "description": {
    "en": "Use an invite code to join a group instantly without waiting for approval.",
    "de": "Mit einem Einladungscode sofort einer Gruppe beitreten, ohne auf Genehmigung zu warten.",
    "fr": "Utilisez un code d invitation pour rejoindre un groupe sans attendre de validation.",
    "es": "Usa un codigo de invitacion para unirte al grupo al instante, sin esperar aprobacion.",
    "ro": "Foloseste un cod de invitatie pentru a intra imediat intr-un grup, fara sa astepti aprobare."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Join",
        "de": "Beitreten",
        "fr": "Rejoindre",
        "es": "Unirse",
        "ro": "Alatura-te"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "joinWithInvite",
      "args": [
        "string:{{SLUG}}",
        "string:{{CODE}}",
        "string:{{DISPLAY_NAME}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "CODE",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Invite code",
            "de": "Einladungscode",
            "fr": "Code d invitation",
            "es": "Codigo de invitacion",
            "ro": "Cod de invitatie"
          }
        },
        {
          "name": "DISPLAY_NAME",
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "label": {
            "en": "Your display name",
            "de": "Dein Anzeigename",
            "fr": "Votre nom affiche",
            "es": "Tu nombre para mostrar",
            "ro": "Numele tau afisat"
          }
        }
      ],
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
