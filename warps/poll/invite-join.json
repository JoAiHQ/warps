{
  "protocol": "warp:3.0.0",
  "name": "Poll: Join With Invite",
  "title": {
    "en": "Join With Invite Code",
    "de": "Mit Einladungscode beitreten"
  },
  "description": {
    "en": "Use an invite code to join a group instantly without waiting for approval.",
    "de": "Mit einem Einladungscode sofort einer Gruppe beitreten, ohne auf Genehmigung zu warten."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Join",
        "de": "Beitreten"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "joinWithInvite",
      "args": [
        "string:{{SLUG}}",
        "string:{{CODE}}",
        "string:{{DISPLAY_NAME}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "CODE",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Invite code",
            "de": "Einladungscode"
          }
        },
        {
          "name": "DISPLAY_NAME",
          "type": "string",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "label": {
            "en": "Your display name",
            "de": "Dein Anzeigename"
          }
        }
      ],
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
