{
  "protocol": "warp:3.0.0",
  "name": "Poll: Is Member",
  "title": {
    "en": "Check Membership",
    "de": "Mitgliedschaft prüfen",
    "fr": "Verifier l adhesion",
    "es": "Comprobar membresia",
    "ro": "Verifica apartenenta"
  },
  "description": {
    "en": "Check if an address is a member of a group.",
    "de": "Prüfen, ob eine Adresse Mitglied einer Gruppe ist.",
    "fr": "Verifiez si une adresse appartient a un groupe.",
    "es": "Comprueba si una direccion pertenece a un grupo.",
    "ro": "Verifica daca o adresa este membra a grupului."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Checking...",
        "de": "Wird geprüft...",
        "fr": "Verification...",
        "es": "Comprobando...",
        "ro": "Se verifica..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "isMember",
      "args": [
        "string:{{SLUG}}",
        "address:{{ADDRESS}}"
      ],
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "ADDRESS",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Address",
            "de": "Adresse",
            "fr": "Adresse",
            "es": "Direccion",
            "ro": "Adresa"
          }
        }
      ],
      "auto": false,
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ]
}
