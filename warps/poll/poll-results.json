{
  "protocol": "warp:3.0.0",
  "name": "Poll: Results",
  "title": {
    "en": "Poll Results",
    "de": "Abstimmungsergebnis"
  },
  "description": {
    "en": "View the current vote counts for each option.",
    "de": "Die aktuellen Stimmen pro Option anzeigen."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading results...",
        "de": "Ergebnisse werden geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getPollResults",
      "args": [
        "u64:{{POLL_ID}}"
      ],
      "inputs": [
        {
          "name": "POLL_ID",
          "type": "uint64",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Poll ID",
            "de": "Abstimmungs-ID"
          }
        }
      ],
      "auto": false,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
