{
  "protocol": "warp:3.0.0",
  "name": "Poll: Results",
  "title": {
    "en": "Poll Results",
    "de": "Abstimmungsergebnis",
    "fr": "Resultats du sondage",
    "es": "Resultados de la encuesta",
    "ro": "Rezultatele sondajului"
  },
  "description": {
    "en": "View the current vote counts for each option.",
    "de": "Die aktuellen Stimmen pro Option anzeigen.",
    "fr": "Consultez le nombre actuel de voix pour chaque option.",
    "es": "Consulta el numero actual de votos de cada opcion.",
    "ro": "Vezi numarul curent de voturi pentru fiecare optiune."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading results...",
        "de": "Ergebnisse werden geladen...",
        "fr": "Chargement des resultats...",
        "es": "Cargando resultados...",
        "ro": "Se incarca rezultatele..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getPollResults",
      "args": [
        "u64:{{POLL_ID}}"
      ],
      "inputs": [
        {
          "name": "POLL_ID",
          "type": "uint64",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Poll ID",
            "de": "Abstimmungs-ID",
            "fr": "ID du sondage",
            "es": "ID de la encuesta",
            "ro": "ID-ul sondajului"
          }
        }
      ],
      "auto": false,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
