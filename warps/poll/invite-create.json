{
  "protocol": "warp:3.0.0",
  "name": "Poll: Create Invite",
  "title": {
    "en": "Create Invite Link",
    "de": "Einladungslink erstellen",
    "fr": "Creer un lien d invitation",
    "es": "Crear enlace de invitacion",
    "ro": "Creeaza linkul de invitatie"
  },
  "description": {
    "en": "Generate an invite code that lets people join your space directly without approval.",
    "de": "Einladungscode generieren, mit dem Personen ohne Genehmigung beitreten können.",
    "fr": "Generez un code d invitation qui permet de rejoindre votre espace sans approbation.",
    "es": "Genera un codigo de invitacion para que otras personas puedan unirse sin aprobacion previa.",
    "ro": "Genereaza un cod de invitatie care permite intrarea directa in spatiu fara aprobare."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS",
    "JOAI_TEAM_SLUG": "env:JOAI_TEAM_SLUG|Team identifier"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Create Invite",
        "de": "Einladung erstellen",
        "fr": "Creer l invitation",
        "es": "Crear invitacion",
        "ro": "Creeaza invitatia"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "createInvite",
      "args": [
        "string:{{GROUP_SLUG}}",
        "string:{{CODE}}",
        "u32:{{MAX_USES}}",
        "u64:{{EXPIRES_AT}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "GROUP_SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "required": true,
          "default": "{{JOAI_TEAM_SLUG}}"
        },
        {
          "name": "CODE",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Invite code",
            "de": "Einladungscode",
            "fr": "Code d invitation",
            "es": "Codigo de invitacion",
            "ro": "Cod de invitatie"
          }
        },
        {
          "name": "MAX_USES",
          "type": "uint32",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "label": {
            "en": "Max uses",
            "de": "Maximale Nutzungen",
            "fr": "Nombre maximal d utilisations",
            "es": "Usos maximos",
            "ro": "Numar maxim de utilizari"
          }
        },
        {
          "name": "EXPIRES_AT",
          "type": "uint64",
          "position": "arg:4",
          "source": "field",
          "required": true,
          "label": {
            "en": "Expires at (Unix timestamp)",
            "de": "Läuft ab (Unix-Timestamp)",
            "fr": "Expiration (timestamp Unix)",
            "es": "Caduca el (timestamp Unix)",
            "ro": "Expira la (timestamp Unix)"
          }
        }
      ],
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ]
}
