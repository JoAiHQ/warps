{
  "protocol": "warp:3.0.0",
  "name": "Poll: Pending Requests",
  "title": {
    "en": "Membership Requests",
    "de": "Mitgliedschaftsanfragen"
  },
  "description": {
    "en": "View all pending membership requests for your space.",
    "de": "Alle offenen Mitgliedschaftsanfragen im Space anzeigen."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading requests...",
        "de": "Anfragen werden geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getPendingRequests",
      "args": [
        "string:{{SLUG}}"
      ],
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
