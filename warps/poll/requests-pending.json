{
  "protocol": "warp:3.0.0",
  "name": "Poll: Pending Requests",
  "title": {
    "en": "Membership Requests",
    "de": "Mitgliedschaftsanfragen",
    "fr": "Demandes d adhesion",
    "es": "Solicitudes de membresia",
    "ro": "Cereri de aderare"
  },
  "description": {
    "en": "View all pending membership requests for your space.",
    "de": "Alle offenen Mitgliedschaftsanfragen im Space anzeigen.",
    "fr": "Consultez toutes les demandes d adhesion en attente pour votre espace.",
    "es": "Consulta todas las solicitudes de membresia pendientes de tu espacio.",
    "ro": "Vezi toate cererile de aderare aflate in asteptare pentru spatiul tau."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading requests...",
        "de": "Anfragen werden geladen...",
        "fr": "Chargement des demandes...",
        "es": "Cargando solicitudes...",
        "ro": "Se incarca cererile..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getPendingRequests",
      "args": [
        "string:{{GROUP_SLUG}}"
      ],
      "inputs": [
        {
          "name": "GROUP_SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ]
}
