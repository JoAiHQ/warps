{
  "protocol": "warp:3.0.0",
  "name": "Poll: Deny Request",
  "title": {
    "en": "Deny Request",
    "de": "Anfrage ablehnen"
  },
  "description": {
    "en": "Deny a pending membership request.",
    "de": "Ausstehende Mitgliedschaftsanfrage ablehnen."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Deny",
        "de": "Ablehnen"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "denyRequest",
      "args": [
        "string:{{SLUG}}",
        "address:{{ADDRESS}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "ADDRESS",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Member address",
            "de": "Mitglied-Adresse"
          }
        }
      ],
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
