{
  "protocol": "warp:3.0.0",
  "name": "Poll: Deny Request",
  "title": {
    "en": "Deny Request",
    "de": "Anfrage ablehnen",
    "fr": "Refuser la demande",
    "es": "Rechazar solicitud",
    "ro": "Respinge cererea"
  },
  "description": {
    "en": "Deny a pending membership request.",
    "de": "Ausstehende Mitgliedschaftsanfrage ablehnen.",
    "fr": "Refusez une demande d adhesion en attente.",
    "es": "Rechaza una solicitud de acceso pendiente.",
    "ro": "Respinge o cerere de aderare aflata in asteptare."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS",
    "JOAI_TEAM_SLUG": "env:JOAI_TEAM_SLUG|Team identifier"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Deny",
        "de": "Ablehnen",
        "fr": "Refuser",
        "es": "Rechazar",
        "ro": "Respinge"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "denyRequest",
      "args": [
        "string:{{GROUP_SLUG}}",
        "address:{{ADDRESS}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "GROUP_SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "hidden",
          "required": true,
          "default": "{{JOAI_TEAM_SLUG}}"
        },
        {
          "name": "ADDRESS",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Member address",
            "de": "Mitglied-Adresse",
            "fr": "Adresse du membre",
            "es": "Direccion del miembro",
            "ro": "Adresa membrului"
          }
        }
      ],
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ]
}
