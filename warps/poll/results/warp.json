{
  "protocol": "warp:3.0.0",
  "name": "Poll: Results",
  "title": {
    "en": "Poll Results",
    "de": "Abstimmungsergebnis",
    "fr": "Resultats du sondage",
    "es": "Resultados de la encuesta",
    "ro": "Rezultatele sondajului"
  },
  "description": {
    "en": "View the live vote counts and percentages for a poll.",
    "de": "Aktuelle Stimmenverteilung und Prozentsätze einer Abstimmung anzeigen.",
    "fr": "Consultez les votes et pourcentages en temps reel pour un sondage.",
    "es": "Consulta los votos y porcentajes en tiempo real de una encuesta.",
    "ro": "Vizualizeaza voturile si procentele live ale unui sondaj."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading results...",
        "de": "Ergebnisse werden geladen...",
        "fr": "Chargement des resultats...",
        "es": "Cargando resultados...",
        "ro": "Se incarca rezultatele..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getPollResults",
      "args": [
        "u64:{{POLL_ID}}"
      ],
      "inputs": [
        {
          "name": "POLL_ID",
          "type": "uint64",
          "position": "arg:1",
          "source": "query",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:../contract/output/poll.abi.json"
    }
  ],
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/poll/results/chatapp.8a77d20.dist.html"
}