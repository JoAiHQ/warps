{
  "protocol": "warp:3.0.0",
  "name": "Poll: Vote",
  "title": {
    "en": "Cast Your Vote",
    "de": "Abstimmen",
    "fr": "Voter",
    "es": "Emitir tu voto",
    "ro": "Voteaza"
  },
  "description": {
    "en": "Vote on an open poll. You need to be a member of the space to vote.",
    "de": "An einer offenen Abstimmung teilnehmen. Du musst Mitglied des Spaces sein.",
    "fr": "Votez dans un sondage ouvert. Vous devez etre membre de l espace pour voter.",
    "es": "Vota en una encuesta abierta. Tienes que ser miembro del espacio para poder votar.",
    "ro": "Voteaza intr-un sondaj deschis. Trebuie sa fii membru al spatiului pentru a putea vota."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Submit Vote",
        "de": "Stimme abgeben",
        "fr": "Envoyer le vote",
        "es": "Enviar voto",
        "ro": "Trimite votul"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "vote",
      "args": [
        "u64:{{POLL_ID}}",
        "u32:{{OPTION_INDEX}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "POLL_ID",
          "type": "uint64",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Poll ID",
            "de": "Abstimmungs-ID",
            "fr": "ID du sondage",
            "es": "ID de la encuesta",
            "ro": "ID-ul sondajului"
          }
        },
        {
          "name": "OPTION_INDEX",
          "type": "uint32",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Option (0 = first option)",
            "de": "Option (0 = erste Option)",
            "fr": "Option (0 = premiere option)",
            "es": "Opcion (0 = primera opcion)",
            "ro": "Optiune (0 = prima optiune)"
          }
        }
      ],
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
