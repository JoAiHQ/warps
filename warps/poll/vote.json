{
  "protocol": "warp:3.0.0",
  "name": "Poll: Vote",
  "title": {
    "en": "Cast Your Vote",
    "de": "Abstimmen"
  },
  "description": {
    "en": "Vote on an open poll. You need to be a member of the space to vote.",
    "de": "An einer offenen Abstimmung teilnehmen. Du musst Mitglied des Spaces sein."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Submit Vote",
        "de": "Stimme abgeben"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "vote",
      "args": [
        "u64:{{POLL_ID}}",
        "u32:{{OPTION_INDEX}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "POLL_ID",
          "type": "uint64",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "label": {
            "en": "Poll ID",
            "de": "Abstimmungs-ID"
          }
        },
        {
          "name": "OPTION_INDEX",
          "type": "uint32",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Option (0 = first option)",
            "de": "Option (0 = erste Option)"
          }
        }
      ],
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
