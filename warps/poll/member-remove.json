{
  "protocol": "warp:3.0.0",
  "name": "Poll: Remove Member",
  "title": {
    "en": "Remove Member",
    "de": "Mitglied entfernen",
    "fr": "Retirer le membre",
    "es": "Eliminar miembro",
    "ro": "Elimina membrul"
  },
  "description": {
    "en": "Remove a member from the group. Admin cannot remove themselves.",
    "de": "Mitglied aus der Gruppe entfernen. Admin kann sich nicht selbst entfernen.",
    "fr": "Retirez un membre du groupe. L administrateur ne peut pas se retirer lui-meme.",
    "es": "Elimina a una persona miembro del grupo. La persona administradora no puede eliminarse a si misma.",
    "ro": "Elimina un membru din grup. Administratorul nu se poate elimina singur."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Remove",
        "de": "Entfernen",
        "fr": "Retirer",
        "es": "Eliminar",
        "ro": "Elimina"
      },
      "address": "{{SC_ADDRESS}}",
      "func": "removeMember",
      "args": [
        "string:{{SLUG}}",
        "address:{{ADDRESS}}"
      ],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "ADDRESS",
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "label": {
            "en": "Member address",
            "de": "Mitglied-Adresse",
            "fr": "Adresse du membre",
            "es": "Direccion del miembro",
            "ro": "Adresa membrului"
          }
        }
      ],
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ]
}
