{
  "protocol": "warp:3.0.0",
  "name": "Poll: Get Group",
  "title": {
    "en": "Group Info",
    "de": "Gruppeninfo"
  },
  "description": {
    "en": "Query details about a voting group.",
    "de": "Details einer Abstimmungsgruppe abfragen."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading group...",
        "de": "Gruppe wird geladen..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getGroup",
      "args": [
        "string:{{SLUG}}"
      ],
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:abis/poll.abi.json"
    }
  ]
}
