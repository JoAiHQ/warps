{
  "protocol": "warp:3.0.0",
  "name": "Poll: Get Group",
  "title": {
    "en": "Group Info",
    "de": "Gruppeninfo",
    "fr": "Infos du groupe",
    "es": "Informacion del grupo",
    "ro": "Informatii despre grup"
  },
  "description": {
    "en": "Query details about a voting group.",
    "de": "Details einer Abstimmungsgruppe abfragen.",
    "fr": "Consultez les details d un groupe de vote.",
    "es": "Consulta los detalles de un grupo de votacion.",
    "ro": "Consulta detaliile unui grup de vot."
  },
  "vars": {
    "SC_ADDRESS": "INJECT:POLL_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading group...",
        "de": "Gruppe wird geladen...",
        "fr": "Chargement du groupe...",
        "es": "Cargando grupo...",
        "ro": "Se incarca grupul..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getGroup",
      "args": [
        "string:{{SLUG}}"
      ],
      "inputs": [
        {
          "name": "SLUG",
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:contract/output/poll.abi.json"
    }
  ]
}
