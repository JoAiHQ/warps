{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "Colombia Staking: Stake eGold",
  "title": {
    "en": "Stake eGold with Colombia Staking",
    "de": "eGold bei Colombia Staking staken"
  },
  "description": {
    "en": "Delegate your EGLD to Colombia Staking and earn staking rewards on the MultiversX network. Colombia Staking helps secure the blockchain while giving you a reliable way to grow your eGold holdings through delegation.",
    "de": "Delegiere dein EGLD an Colombia Staking und verdiene Staking-Belohnungen im MultiversX-Netzwerk. Colombia Staking hilft, die Blockchain zu sichern, und bietet dir eine zuverlaessige Moeglichkeit, deine eGold-Bestaende durch Delegation zu vermehren."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Stake now",
        "de": "Jetzt staken"
      },
      "address": "INJECT:PROVIDER",
      "func": "delegate",
      "args": [],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "value",
          "description": {
            "en": "Amount of eGold to delegate.",
            "de": "Betrag an eGold zum Delegieren."
          },
          "type": "biguint",
          "position": "value",
          "source": "field",
          "required": true,
          "min": 1,
          "modifier": "scale:18"
        }
      ]
    },
    {
      "type": "link",
      "label": {
        "en": "Learn more",
        "de": "Mehr erfahren"
      },
      "description": {
        "en": "Find more information about staking eGold.",
        "de": "Weitere Informationen zum Staking von eGold finden."
      },
      "url": "https://multiversx.com/egld"
    }
  ],
  "output": {
    "TX_HASH": "out",
    "AMOUNT_EGLD": "transform:() => Number(inputs.value) / 10 ** 18"
  },
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/colombia-staking/stake-egld/chatapp.dd8bb72.dist.html",
  "messages": {
    "success": {
      "en": "eGold staked successfully",
      "de": "eGold erfolgreich gestaked"
    }
  },
  "related": [
    "multiversx-staking-claimable-rewards",
    "multiversx-staking-redelegate-all"
  ]
}