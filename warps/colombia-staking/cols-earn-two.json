{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "Colombia Staking: Buyback with EGLD",
  "title": { "en": "Buyback: Wrap EGLD", "de": "Rückkauf: EGLD wrappen" },
  "description": { "en": "Wrap EGLD to WEGLD and buyback the tokens of the stakers.", "de": "Wrapple EGLD zu WEGLD und kaufe die Token der Staker zurück." },
  "preview": "https://vleap.ai/images/external/warps/staking-colombia.jpg",
  "actions": [
    {
      "type": "contract",
      "label": { "en": "Wrap EGLD", "de": "EGLD wrappen" },
      "address": "INJECT:WEGLD/SHARD1",
      "func": "wrapEgld",
      "args": [],
      "gasLimit": 5000000,
      "inputs": [
        {
          "as": "amount",
          "name": "EGLD Amount",
          "type": "biguint",
          "position": "value",
          "source": "field",
          "modifier": "scale:18",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "WEGLD_AMOUNT": "in.amount"
  },
  "messages": {
    "success": { "en": "Wrapped EGLD to WEGLD", "de": "EGLD zu WEGLD gewrapped" }
  },
  "next": "@colombia-staking-cols-earn-three?amount={{WEGLD_AMOUNT}}"
}
