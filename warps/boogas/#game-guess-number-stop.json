{
  "protocol": "warp:3.0.0",
  "name": "game-guess-number-stop",
  "title": {
    "en": "Stop Guessing Game"
  },
  "description": {
    "en": "Stops the active guessing game and clears all game state."
  },
  "messages": {
    "success": "🛑 Game stopped."
  },
  "actions": [
    {
      "type": "state",
      "label": "Clear game state",
      "op": "clear",
      "store": "guessing-game"
    },
    {
      "type": "unmount",
      "label": "Unmount guess listener",
      "warp": "@boogas-game-guess-number-check"
    },
    {
      "type": "collect",
      "label": "Announce",
      "inputs": []
    }
  ]
}
