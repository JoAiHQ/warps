{
  "protocol": "warp:3.0.0",
  "name": "game-guess-number-check",
  "title": {
    "en": "Check Guess",
    "es": "Check Guess",
    "fr": "Check Guess",
    "ro": "Check Guess",
    "it": "Check Guess"
  },
  "description": {
    "en": "Checks a numeric guess against the active guessing game secret.",
    "es": "Checks a numeric guess against the active guessing game secret.",
    "fr": "Checks a numeric guess against the active guessing game secret.",
    "ro": "Checks a numeric guess against the active guessing game secret.",
    "it": "Checks a numeric guess against the active guessing game secret."
  },
  "trigger": {
    "type": "message",
    "pattern": "^\\d+$"
  },
  "messages": {
    "success": "{{message}}"
  },
  "actions": [
    {
      "type": "state",
      "label": "Load game state",
      "op": {
        "en": "read",
        "de": "read",
        "es": "read",
        "fr": "read",
        "ro": "read",
        "it": "read"
      },
      "store": "guessing-game",
      "keys": [
        "secret",
        "active"
      ]
    },
    {
      "type": "compute",
      "label": "Evaluate guess",
      "when": "{{state.active}} === true",
      "inputs": [
        {
          "name": "correct",
          "type": {
            "en": "bool",
            "de": "bool",
            "es": "bool",
            "fr": "bool",
            "ro": "bool",
            "it": "bool"
          },
          "source": "hidden",
          "modifier": "transform:() => parseInt('{{JOAI_MESSAGE_TEXT}}') === parseInt('{{state.secret}}')"
        },
        {
          "name": "message",
          "type": "string",
          "source": "hidden",
          "modifier": "transform:() => parseInt('{{JOAI_MESSAGE_TEXT}}') === parseInt('{{state.secret}}') ? '🎉 {{JOAI_SENDER_NAME}} got it! The number was {{state.secret}}.' : '❌ Nope, try again!'"
        }
      ]
    },
    {
      "type": "state",
      "label": "Mark game inactive",
      "op": "write",
      "store": "guessing-game",
      "data": {
        "active": false
      },
      "when": "{{correct}} === true"
    },
    {
      "type": "unmount",
      "label": "Unmount guess listener",
      "warp": "@boogas-game-guess-number-check",
      "when": "{{correct}} === true"
    }
  ]
}
