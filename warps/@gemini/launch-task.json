{
  "protocol": "warp:3.0.0",
  "name": "Gemini: Launch Task",
  "title": {
    "en": "Launch task",
    "es": "Iniciar tarea",
    "fr": "Lancer la tâche",
    "ro": "Lansați sarcina",
    "it": "Avvia attività"
  },
  "description": {
    "en": "Launch a new Gemini batch generation task.",
    "es": "Launch a new Gemini batch generation task.",
    "fr": "Launch a new Gemini batch generation task.",
    "ro": "Launch a new Gemini batch generation task.",
    "it": "Launch a new Gemini batch generation task."
  },
  "vars": {
    "API_KEY": "env:GEMINI_API_KEY|Gemini API key"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Launch Task",
        "es": "Iniciar tarea",
        "fr": "Lancer la tâche",
        "ro": "Lansați Sarcina",
        "it": "Avvia attività"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1beta/{{MODEL}}:batchGenerateContent?key={{API_KEY}}",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Model",
          "as": "MODEL",
          "description": {
            "en": "Model path, e.g. models/gemini-2.5-flash.",
            "es": "Model path, e.g. models/gemini-2.5-flash.",
            "fr": "Model path, e.g. models/gemini-2.5-flash.",
            "ro": "Model path, e.g. models/gemini-2.5-flash.",
            "it": "Model path, e.g. models/gemini-2.5-flash."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "default": "models/gemini-2.5-flash",
          "position": "path:MODEL"
        },
        {
          "name": "Task",
          "as": "TASK",
          "description": {
            "en": "Task instruction to execute.",
            "es": "Instrucción de tarea a ejecutar.",
            "fr": "Instruction de tâche à exécuter.",
            "ro": "Instrucțiune de sarcină de executat.",
            "it": "Istruzione dell'attività da eseguire."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:inputConfig.inlinedRequests.requests.0.request.contents.0.parts.0.text",
          "label": {
            "en": "Task",
            "de": "Task",
            "es": "Task",
            "fr": "Task",
            "ro": "Task",
            "it": "Task"
          }
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "out.name",
    "RUN_STATUS": "transform:() => out.done ? 'completed' : (out.state || out.metadata?.state || 'running')",
    "SUMMARY": "transform:() => out.done ? 'Batch run completed' : 'Batch run in progress'"
  },
  "messages": {
    "success": {
      "en": "Gemini run {{RUN_ID}} launched with status {{RUN_STATUS}}.",
      "es": "Gemini run {{RUN_ID}} launched with status {{RUN_STATUS}}.",
      "fr": "Gemini run {{RUN_ID}} launched with status {{RUN_STATUS}}.",
      "ro": "Gemini run {{RUN_ID}} launched with status {{RUN_STATUS}}.",
      "it": "Gemini run {{RUN_ID}} launched with status {{RUN_STATUS}}."
    }
  }
}
