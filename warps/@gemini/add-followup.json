{
  "protocol": "warp:3.0.0",
  "name": "Gemini: Add Followup",
  "title": {
    "en": "Add followup"
  },
  "description": {
    "en": "Launch a followup Gemini batch task with additional instruction context."
  },
  "vars": {
    "API_KEY": "env:GEMINI_API_KEY|Gemini API key"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Add Followup"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1beta/{{MODEL}}:batchGenerateContent?key={{API_KEY}}",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Model",
          "as": "MODEL",
          "description": {
            "en": "Model path, e.g. models/gemini-2.5-flash."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "default": "models/gemini-2.5-flash",
          "position": "path:MODEL"
        },
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "Previous run ID for traceability."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:inputConfig.inlinedRequests.requests.0.request.contents.0.parts.0.text"
        },
        {
          "name": "Followup",
          "as": "FOLLOWUP",
          "description": {
            "en": "Followup instruction."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:inputConfig.inlinedRequests.requests.0.request.contents.0.parts.1.text"
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "out.name",
    "RUN_STATUS": "transform:() => out.done ? 'completed' : (out.state || out.metadata?.state || 'running')",
    "SUMMARY": "transform:() => out.done ? 'Followup batch completed' : 'Followup batch in progress'"
  },
  "messages": {
    "success": {
      "en": "Gemini followup run {{RUN_ID}} created with status {{RUN_STATUS}}."
    }
  }
}
