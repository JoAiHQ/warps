{
  "protocol": "warp:3.0.0",
  "name": "Email: Send",
  "title": {
    "en": "Send email",
    "de": "E-Mail senden",
    "es": "Send email",
    "fr": "Send email",
    "ro": "Send email",
    "it": "Send email"
  },
  "description": {
    "en": "Send an email to a contact. Resolves or creates a conversation room for the recipient so replies are tracked.",
    "de": "Sendet eine E-Mail an einen Kontakt. Erstellt einen Gesprächsraum für den Empfänger, damit Antworten verfolgt werden.",
    "es": "Send an email to a contact. Resolves or creates a conversation room for the recipient so replies are tracked.",
    "fr": "Send an email to a contact. Resolves or creates a conversation room for the recipient so replies are tracked.",
    "ro": "Send an email to a contact. Resolves or creates a conversation room for the recipient so replies are tracked.",
    "it": "Send an email to a contact. Resolves or creates a conversation room for the recipient so replies are tracked."
  },
  "bot": "Use this to send emails through the agent's email integration. Creates a persistent conversation room for the recipient — replies will route back to that room. The success CTA exposes a mailto: link so the user can always send from their own mail client if preferred.",
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Send email",
        "de": "E-Mail senden",
        "es": "Send email",
        "fr": "Send email",
        "ro": "Send email",
        "it": "Send email"
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/agents/{{JOAI_AGENT_UUID}}/room/message",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [
        {
          "name": "Integration",
          "as": "integration",
          "type": "string",
          "source": "value",
          "value": "email",
          "required": true
        },
        {
          "name": "To",
          "as": "recipientId",
          "description": {
            "en": "Recipient email address",
            "de": "E-Mail-Adresse des Empfängers",
            "es": "Recipient email address",
            "fr": "Recipient email address",
            "ro": "Recipient email address",
            "it": "Recipient email address"
          },
          "bot": "The recipient's email address.",
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Subject",
          "as": "subject",
          "description": {
            "en": "Email subject line",
            "de": "E-Mail-Betreff",
            "es": "Email subject line",
            "fr": "Email subject line",
            "ro": "Email subject line",
            "it": "Email subject line"
          },
          "bot": "Concise, specific subject line.",
          "type": "string",
          "source": "field",
          "required": false,
          "max": 500
        },
        {
          "name": "Message",
          "as": "message",
          "description": {
            "en": "Email body content",
            "de": "E-Mail-Inhalt",
            "es": "Email body content",
            "fr": "Email body content",
            "ro": "Email body content",
            "it": "Email body content"
          },
          "bot": "The body content of the email.",
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "EMAIL_ROOM_ID": "out.data.roomId",
    "EMAIL_MESSAGE_ID": "out.data.externalMessageId",
    "EMAIL_MAILTO_URL": "transform:`mailto:${inputs.recipientId}${inputs.subject || inputs.message ? '?' : ''}${inputs.subject ? `subject=${encodeURIComponent(inputs.subject)}` : ''}${inputs.subject && inputs.message ? '&' : ''}${inputs.message ? `body=${encodeURIComponent(inputs.message)}` : ''}`"
  },
  "messages": {
    "success": {
      "en": "Logged in conversation room.",
      "de": "Im Gesprächsraum protokolliert.",
      "es": "Logged in conversation room.",
      "fr": "Logged in conversation room.",
      "ro": "Logged in conversation room.",
      "it": "Logged in conversation room."
    },
    "cta": {
      "en": "[Open in your mail app →]({{EMAIL_MAILTO_URL}})",
      "de": "[In deiner Mail-App öffnen →]({{EMAIL_MAILTO_URL}})",
      "es": "[Open in your mail app →]({{EMAIL_MAILTO_URL}})",
      "fr": "[Open in your mail app →]({{EMAIL_MAILTO_URL}})",
      "ro": "[Open in your mail app →]({{EMAIL_MAILTO_URL}})",
      "it": "[Open in your mail app →]({{EMAIL_MAILTO_URL}})"
    }
  }
}
