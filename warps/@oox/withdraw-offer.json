{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "OOX: Withdraw Offer",
  "title": {
    "en": "Withdraw Offer",
    "de": "Angebot zurückziehen"
  },
  "description": {
    "en": "Withdraw your offer before it expires or is accepted. Your payment will be returned to you.",
    "de": "Dein Angebot zurückziehen, bevor es abläuft oder angenommen wird. Deine Zahlung wird dir zurückerstattet."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Withdraw offer",
        "de": "Angebot zurückziehen"
      },
      "address": "INJECT:MARKETPLACE",
      "func": "withdrawOffer",
      "args": [],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/marketplace.abi.json",
      "inputs": [
        {
          "name": "Offer ID",
          "description": {
            "en": "The ID of the offer to withdraw.",
            "de": "Die ID des zurückzuziehenden Angebots."
          },
          "type": "number",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 0
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Offer withdrawn successfully",
      "de": "Angebot erfolgreich zurückgezogen"
    }
  }
}