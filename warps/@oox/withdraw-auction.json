{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "OOX: Withdraw from Auction",
  "title": {
    "en": "Withdraw NFT from Auction",
    "de": "NFT aus Auktion abheben"
  },
  "description": {
    "en": "Withdraw your NFT from an auction before it ends. This cancels the auction and returns the NFT to you.",
    "de": "Ihr NFT vor Auktionsende abheben. Dies bricht die Auktion ab und gibt Ihnen das NFT zurück."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Withdraw",
        "de": "Abheben"
      },
      "address": "INJECT:MARKETPLACE",
      "func": "withdraw",
      "args": [],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/marketplace.abi.json",
      "inputs": [
        {
          "name": "Auction ID",
          "description": {
            "en": "The ID of the auction to withdraw from.",
            "de": "Die ID der Auktion, aus der abgehoben werden soll."
          },
          "type": "number",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 0
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "NFT withdrawn from auction successfully",
      "de": "NFT erfolgreich aus Auktion abgehoben"
    }
  }
}