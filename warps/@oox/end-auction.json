{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "OOX: End Auction",
  "title": {
    "en": "End Auction",
    "de": "Auktion beenden"
  },
  "description": {
    "en": "End an active auction. If there are bids, the highest bidder wins. If no bids, the NFT is returned to the seller.",
    "de": "Eine aktive Auktion beenden. Bei Geboten gewinnt der Höchstbietende. Ohne Gebote wird das NFT an den Verkäufer zurückgegeben."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "End auction",
        "de": "Auktion beenden"
      },
      "address": "INJECT:MARKETPLACE",
      "func": "endAuction",
      "args": [],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/marketplace.abi.json",
      "inputs": [
        {
          "name": "Auction ID",
          "description": {
            "en": "The ID of the auction to end.",
            "de": "Die ID der zu beendenden Auktion."
          },
          "type": "number",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 0
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Auction ended successfully",
      "de": "Auktion erfolgreich beendet"
    }
  }
}