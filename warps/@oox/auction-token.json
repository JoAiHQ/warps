{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "OOX: Create Auction",
  "title": {
    "en": "Create NFT Auction",
    "de": "NFT-Auktion erstellen"
  },
  "description": {
    "en": "Create an auction for your NFT or SFT on OOX marketplace. Set minimum and maximum bid prices, deadline, and accepted payment token.",
    "de": "Eine Auktion für Ihr NFT oder SFT auf dem OOX-Marktplatz erstellen. Legen Sie Mindest- und Höchstgebote, Frist und akzeptiertes Zahlungstoken fest."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Create auction",
        "de": "Auktion erstellen"
      },
      "address": "INJECT:MARKETPLACE",
      "func": "auctionToken",
      "args": [],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/marketplace.abi.json",
      "inputs": [
        {
          "name": "NFT",
          "description": {
            "en": "The NFT or SFT to auction.",
            "de": "Das zu versteigernde NFT oder SFT."
          },
          "type": "asset",
          "position": "transfer",
          "source": "field",
          "required": true
        },
        {
          "name": "Min Bid",
          "description": {
            "en": "Minimum bid amount in the accepted payment token.",
            "de": "Mindestgebot in dem akzeptierten Zahlungstoken."
          },
          "type": "biguint",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Max Bid",
          "description": {
            "en": "Maximum bid amount (set to 0 for no maximum).",
            "de": "Höchstgebot (0 für kein Maximum)."
          },
          "type": "biguint",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "min": 0
        },
        {
          "name": "Deadline",
          "description": {
            "en": "Auction deadline timestamp (Unix timestamp in seconds).",
            "de": "Auktionsfrist (Unix-Zeitstempel in Sekunden)."
          },
          "type": "number",
          "position": "arg:3",
          "source": "field",
          "required": true
        },
        {
          "name": "Payment Token",
          "description": {
            "en": "Accepted payment token identifier (EGLD for eGold, or ESDT token identifier).",
            "de": "Akzeptiertes Zahlungstoken (EGLD für eGold oder ESDT-Token-Kennung)."
          },
          "type": "string",
          "position": "arg:4",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Auction created successfully",
      "de": "Auktion erfolgreich erstellt"
    }
  }
}