{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "OOX: Get Auction Data",
  "title": {
    "en": "Get Auction Information",
    "de": "Auktionsinformationen abrufen"
  },
  "description": {
    "en": "Retrieve detailed information about an auction including current bid, deadline, and auction details.",
    "de": "Detaillierte Informationen über eine Auktion abrufen, einschließlich aktuellem Gebot, Frist und Auktionsdetails."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Get auction data",
        "de": "Auktionsdaten abrufen"
      },
      "address": "INJECT:MARKETPLACE",
      "func": "getFullAuctionData",
      "args": [],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/marketplace.abi.json",
      "inputs": [
        {
          "name": "Auction ID",
          "description": {
            "en": "The ID of the auction to query.",
            "de": "Die ID der abzufragenden Auktion."
          },
          "type": "number",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 0
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Auction data retrieved successfully",
      "de": "Auktionsdaten erfolgreich abgerufen"
    }
  }
}