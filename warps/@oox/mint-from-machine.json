{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "OOX: Mint from Vending Machine",
  "title": {
    "en": "Mint NFT from Vending Machine",
    "de": "NFT aus Verkaufsautomat prägen"
  },
  "description": {
    "en": "Purchase and mint an NFT from a vending machine at the fixed price.",
    "de": "Ein NFT aus einem Verkaufsautomat zum Festpreis kaufen und prägen."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Mint NFT",
        "de": "NFT prägen"
      },
      "address": "INJECT:MARKETPLACE",
      "func": "mintFromMachine",
      "args": [],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/marketplace.abi.json",
      "inputs": [
        {
          "name": "Machine ID",
          "description": {
            "en": "The ID of the vending machine to mint from.",
            "de": "Die ID des Verkaufsautomaten, aus dem geprägt werden soll."
          },
          "type": "number",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 0
        },
        {
          "name": "Payment",
          "description": {
            "en": "Payment amount in the accepted payment token.",
            "de": "Zahlungsbetrag in dem akzeptierten Zahlungstoken."
          },
          "type": "asset",
          "position": "transfer",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "NFT minted successfully",
      "de": "NFT erfolgreich geprägt"
    }
  }
}