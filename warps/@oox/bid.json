{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "OOX: Place Bid",
  "title": {
    "en": "Place Bid on Auction",
    "de": "Gebot auf Auktion abgeben"
  },
  "description": {
    "en": "Place a bid on an active auction. Your bid must be higher than the current highest bid.",
    "de": "Ein Gebot auf eine aktive Auktion abgeben. Ihr Gebot muss höher sein als das aktuelle Höchstgebot."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Place bid",
        "de": "Gebot abgeben"
      },
      "address": "INJECT:MARKETPLACE",
      "func": "bid",
      "args": [],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/marketplace.abi.json",
      "inputs": [
        {
          "name": "Auction ID",
          "description": {
            "en": "The ID of the auction to bid on.",
            "de": "Die ID der Auktion, auf die geboten werden soll."
          },
          "type": "number",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 0
        },
        {
          "name": "NFT Type",
          "description": {
            "en": "The token identifier of the NFT being auctioned.",
            "de": "Die Token-Kennung des versteigerten NFT."
          },
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        },
        {
          "name": "NFT Nonce",
          "description": {
            "en": "The nonce of the NFT being auctioned.",
            "de": "Die Nonce des versteigerten NFT."
          },
          "type": "number",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "min": 0
        },
        {
          "name": "Bid Amount",
          "description": {
            "en": "Your bid amount in the accepted payment token.",
            "de": "Ihr Gebotsbetrag in dem akzeptierten Zahlungstoken."
          },
          "type": "asset",
          "position": "transfer",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Bid placed successfully",
      "de": "Gebot erfolgreich abgegeben"
    }
  }
}