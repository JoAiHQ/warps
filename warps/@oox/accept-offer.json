{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "OOX: Accept Offer",
  "title": {
    "en": "Accept Offer for NFT",
    "de": "Angebot für NFT annehmen"
  },
  "description": {
    "en": "Accept an offer made for your NFT. The NFT will be transferred to the buyer and you will receive the payment.",
    "de": "Ein Angebot für dein NFT annehmen. Das NFT wird an den Käufer übertragen und du erhältst die Zahlung."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Accept offer",
        "de": "Angebot annehmen"
      },
      "address": "INJECT:MARKETPLACE",
      "func": "acceptOffer",
      "args": [],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/marketplace.abi.json",
      "inputs": [
        {
          "name": "Offer ID",
          "description": {
            "en": "The ID of the offer to accept.",
            "de": "Die ID des anzunehmenden Angebots."
          },
          "type": "number",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 0
        },
        {
          "name": "NFT",
          "description": {
            "en": "The NFT to transfer to the buyer.",
            "de": "Das NFT, das an den Käufer übertragen werden soll."
          },
          "type": "asset",
          "position": "transfer",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Offer accepted successfully",
      "de": "Angebot erfolgreich angenommen"
    }
  }
}