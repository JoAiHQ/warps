{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "OOX: Send Offer",
  "title": {
    "en": "Send Offer for NFT",
    "de": "Angebot für NFT senden"
  },
  "description": {
    "en": "Send an offer to purchase a specific NFT. The NFT owner can accept your offer.",
    "de": "Ein Angebot zum Kauf eines bestimmten NFT senden. Der NFT-Besitzer kann Ihr Angebot annehmen."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Send offer",
        "de": "Angebot senden"
      },
      "address": "INJECT:MARKETPLACE",
      "func": "sendOffer",
      "args": [],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/marketplace.abi.json",
      "inputs": [
        {
          "name": "NFT Identifier",
          "description": {
            "en": "The token identifier of the NFT you want to buy.",
            "de": "Die Token-Kennung des NFT, das Sie kaufen möchten."
          },
          "type": "string",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "NFT Nonce",
          "description": {
            "en": "The nonce of the NFT you want to buy.",
            "de": "Die Nonce des NFT, das Sie kaufen möchten."
          },
          "type": "number",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "min": 0
        },
        {
          "name": "NFT Amount",
          "description": {
            "en": "The amount of NFTs to buy (for SFTs, use 1 for NFTs).",
            "de": "Die Anzahl der zu kaufenden NFTs (für SFTs, verwenden Sie 1 für NFTs)."
          },
          "type": "biguint",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "Deadline",
          "description": {
            "en": "Offer deadline timestamp (Unix timestamp in seconds).",
            "de": "Angebotsfrist (Unix-Zeitstempel in Sekunden)."
          },
          "type": "number",
          "position": "arg:4",
          "source": "field",
          "required": true
        },
        {
          "name": "NFT Owner",
          "description": {
            "en": "The address of the NFT owner.",
            "de": "Die Adresse des NFT-Besitzers."
          },
          "type": "address",
          "position": "arg:5",
          "source": "field",
          "required": true
        },
        {
          "name": "Payment",
          "description": {
            "en": "Your offer payment amount in the payment token.",
            "de": "Ihr Angebotszahlungsbetrag im Zahlungstoken."
          },
          "type": "asset",
          "position": "transfer",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Offer sent successfully",
      "de": "Angebot erfolgreich gesendet"
    }
  }
}