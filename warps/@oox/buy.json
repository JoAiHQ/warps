{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "OOX: Buy Now",
  "title": {
    "en": "Buy NFT from Auction",
    "de": "NFT aus Auktion kaufen"
  },
  "description": {
    "en": "Buy an NFT directly from an auction at the buy-now price (if available).",
    "de": "Ein NFT direkt aus einer Auktion zum Sofortkauf-Preis kaufen (falls verfügbar)."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Buy now",
        "de": "Sofort kaufen"
      },
      "address": "INJECT:MARKETPLACE",
      "func": "buy",
      "args": [],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/marketplace.abi.json",
      "inputs": [
        {
          "name": "Auction ID",
          "description": {
            "en": "The ID of the auction to buy from.",
            "de": "Die ID der Auktion, aus der gekauft werden soll."
          },
          "type": "number",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 0
        },
        {
          "name": "NFT Type",
          "description": {
            "en": "The token identifier of the NFT being sold.",
            "de": "Die Token-Kennung des verkauften NFT."
          },
          "type": "string",
          "position": "arg:2",
          "source": "field",
          "required": true
        },
        {
          "name": "NFT Nonce",
          "description": {
            "en": "The nonce of the NFT being sold.",
            "de": "Die Nonce des verkauften NFT."
          },
          "type": "number",
          "position": "arg:3",
          "source": "field",
          "required": true,
          "min": 0
        },
        {
          "name": "Payment",
          "description": {
            "en": "Payment amount in the accepted payment token.",
            "de": "Zahlungsbetrag in dem akzeptierten Zahlungstoken."
          },
          "type": "asset",
          "position": "transfer",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Purchase completed successfully",
      "de": "Kauf erfolgreich abgeschlossen"
    }
  }
}