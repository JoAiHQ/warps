{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "OOX: Modify Auction Price",
  "title": {
    "en": "Modify Auction Price",
    "de": "Auktionspreis ändern"
  },
  "description": {
    "en": "Update the minimum and/or maximum bid price for your active auction.",
    "de": "Den Mindest- und/oder Höchstgebotspreis deiner aktiven Auktion aktualisieren."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Modify price",
        "de": "Preis ändern"
      },
      "address": "INJECT:MARKETPLACE",
      "func": "modifyAuctionPrice",
      "args": [],
      "gasLimit": 10000000,
      "abi": "INJECT:abis/marketplace.abi.json",
      "inputs": [
        {
          "name": "Auction ID",
          "description": {
            "en": "The ID of the auction to modify.",
            "de": "Die ID der zu ändernden Auktion."
          },
          "type": "number",
          "position": "arg:1",
          "source": "field",
          "required": true,
          "min": 0
        },
        {
          "name": "New Min Bid",
          "description": {
            "en": "New minimum bid amount.",
            "de": "Neuer Mindestgebotsbetrag."
          },
          "type": "biguint",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "min": 1
        },
        {
          "name": "New Max Bid",
          "description": {
            "en": "New maximum bid amount (optional, leave empty to keep current).",
            "de": "Neuer Höchstgebotsbetrag (optional, leer lassen um aktuellen zu behalten)."
          },
          "type": "biguint",
          "position": "arg:3",
          "source": "field",
          "required": false,
          "min": 1
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Auction price modified successfully",
      "de": "Auktionspreis erfolgreich geändert"
    }
  }
}