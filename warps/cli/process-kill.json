{
  "protocol": "warp:3.0.0",
  "name": "CLI: Kill Process",
  "title": {
    "en": "Kill a process",
    "de": "Prozess beenden"
  },
  "description": {
    "en": "Terminate a running process by its process ID.",
    "de": "Einen laufenden Prozess anhand seiner Prozess-ID beenden."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Kill Process",
        "de": "Prozess beenden"
      },
      "prompt": {
        "macos": "/kill {{PID}}",
        "linux": "/kill {{PID}}",
        "windows": "/taskkill /PID {{PID}} /F"
      },
      "inputs": [
        {
          "name": "Process ID",
          "as": "PID",
          "description": {
            "en": "The process ID to terminate",
            "de": "Die zu beendende Prozess-ID"
          },
          "bot": "The PID (process ID) of the process to kill. Use the process-list warp first to find the PID.",
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
