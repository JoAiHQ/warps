{
  "protocol": "warp:3.0.0",
  "name": "CLI: Compress (ZIP)",
  "title": {
    "en": "Compress files into a ZIP archive",
    "de": "Dateien in ein ZIP-Archiv komprimieren"
  },
  "description": {
    "en": "Compress files or directories into a ZIP archive.",
    "de": "Dateien oder Verzeichnisse in ein ZIP-Archiv komprimieren."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Compress",
        "de": "Komprimieren"
      },
      "prompt": {
        "macos": "/zip -r \"{{OUTPUT}}\" \"{{INPUT}}\"",
        "linux": "/zip -r \"{{OUTPUT}}\" \"{{INPUT}}\"",
        "windows": "/powershell -command \"Compress-Archive -Path '{{INPUT}}' -DestinationPath '{{OUTPUT}}'\""
      },
      "inputs": [
        {
          "name": "Input",
          "as": "INPUT",
          "description": {
            "en": "The file or directory to compress",
            "de": "Die zu komprimierende Datei oder das Verzeichnis"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Output",
          "as": "OUTPUT",
          "description": {
            "en": "The output archive file path (.zip)",
            "de": "Der Pfad der Ausgabe-Archivdatei (.zip)"
          },
          "bot": "The output .zip file path. If the user doesn't specify, derive from the input name.",
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
