{
  "protocol": "warp:3.0.0",
  "name": "CLI: Copy File",
  "title": {
    "en": "Copy a file or directory",
    "de": "Datei oder Verzeichnis kopieren"
  },
  "description": {
    "en": "Copy a file or directory to a new location.",
    "de": "Eine Datei oder ein Verzeichnis an einen neuen Ort kopieren."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Copy",
        "de": "Kopieren"
      },
      "prompt": {
        "macos": "/cp -r \"{{SOURCE}}\" \"{{DESTINATION}}\"",
        "linux": "/cp -r \"{{SOURCE}}\" \"{{DESTINATION}}\"",
        "windows": "/xcopy \"{{SOURCE}}\" \"{{DESTINATION}}\" /E /I /Y"
      },
      "inputs": [
        {
          "name": "Source",
          "as": "SOURCE",
          "description": {
            "en": "The file or directory to copy",
            "de": "Die zu kopierende Datei oder das Verzeichnis"
          },
          "bot": "The source file or directory path.",
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Destination",
          "as": "DESTINATION",
          "description": {
            "en": "The destination path",
            "de": "Der Zielpfad"
          },
          "bot": "The destination path for the copy.",
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
