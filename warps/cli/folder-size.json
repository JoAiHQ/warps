{
  "protocol": "warp:3.0.0",
  "name": "CLI: Folder Size",
  "title": {
    "en": "Show folder size",
    "de": "Ordnergröße anzeigen"
  },
  "description": {
    "en": "Show the total size of a file or directory.",
    "de": "Die Gesamtgröße einer Datei oder eines Verzeichnisses anzeigen."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Show Size",
        "de": "Größe anzeigen"
      },
      "prompt": {
        "macos": "/du -sh \"{{PATH}}\"",
        "linux": "/du -sh \"{{PATH}}\"",
        "windows": "/powershell -command \"(Get-ChildItem -Recurse '{{PATH}}' | Measure-Object -Property Length -Sum).Sum / 1MB\""
      },
      "inputs": [
        {
          "name": "Path",
          "as": "PATH",
          "description": {
            "en": "The file or directory to check",
            "de": "Die zu überprüfende Datei oder das Verzeichnis"
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
