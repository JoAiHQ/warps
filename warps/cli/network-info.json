{
  "protocol": "warp:3.0.0",
  "name": "CLI: Network Info",
  "title": {
    "en": "Show network information",
    "de": "Netzwerkinformationen anzeigen"
  },
  "description": {
    "en": "Show IP address and network interface information.",
    "de": "IP-Adresse und Netzwerkschnittstellen-Informationen anzeigen."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Show Network Info",
        "de": "Netzwerkinfo anzeigen"
      },
      "prompt": {
        "macos": "/ifconfig | grep -E 'inet |flags'",
        "linux": "/ip addr show",
        "windows": "/ipconfig"
      }
    }
  ]
}
