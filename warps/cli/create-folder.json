{
  "protocol": "warp:3.0.0",
  "name": "CLI: Create Folder",
  "title": {
    "en": "Create a folder",
    "de": "Ordner erstellen"
  },
  "description": {
    "en": "Create a new folder, including any parent directories.",
    "de": "Einen neuen Ordner erstellen, einschließlich übergeordneter Verzeichnisse."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Create Folder",
        "de": "Ordner erstellen"
      },
      "prompt": {
        "macos": "/mkdir -p \"{{PATH}}\"",
        "linux": "/mkdir -p \"{{PATH}}\"",
        "windows": "/mkdir \"{{PATH}}\""
      },
      "inputs": [
        {
          "name": "Path",
          "as": "PATH",
          "description": {
            "en": "The folder path to create",
            "de": "Der zu erstellende Ordnerpfad"
          },
          "bot": "The folder path to create. Creates parent directories as needed.",
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
