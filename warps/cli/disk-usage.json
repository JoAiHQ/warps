{
  "protocol": "warp:3.0.0",
  "name": "CLI: Disk Usage",
  "title": {
    "en": "Show disk usage overview",
    "de": "Festplattennutzung anzeigen"
  },
  "description": {
    "en": "Show available and used disk space on the system.",
    "de": "Verfügbaren und belegten Speicherplatz auf dem System anzeigen."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Show Disk Usage",
        "de": "Festplattennutzung anzeigen"
      },
      "prompt": {
        "macos": "/df -h",
        "linux": "/df -h",
        "windows": "/wmic logicaldisk get size,freespace,caption"
      }
    }
  ]
}
