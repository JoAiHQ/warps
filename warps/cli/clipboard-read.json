{
  "protocol": "warp:3.0.0",
  "name": "CLI: Read Clipboard",
  "title": {
    "en": "Read clipboard contents",
    "de": "Zwischenablage-Inhalt lesen"
  },
  "description": {
    "en": "Read and display the current contents of the system clipboard.",
    "de": "Den aktuellen Inhalt der System-Zwischenablage lesen und anzeigen."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Read Clipboard",
        "de": "Zwischenablage lesen"
      },
      "prompt": {
        "macos": "/pbpaste",
        "linux": "/xclip -selection clipboard -o",
        "windows": "/powershell -command Get-Clipboard"
      }
    }
  ]
}
