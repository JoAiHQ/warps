{
  "protocol": "warp:3.0.0",
  "name": "CLI: Decompress (ZIP)",
  "title": {
    "en": "Extract a ZIP archive",
    "de": "Ein ZIP-Archiv entpacken"
  },
  "description": {
    "en": "Extract files from a ZIP archive.",
    "de": "Dateien aus einem ZIP-Archiv entpacken."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Extract",
        "de": "Entpacken"
      },
      "prompt": {
        "macos": "/unzip \"{{ARCHIVE}}\" -d \"{{DESTINATION}}\"",
        "linux": "/unzip \"{{ARCHIVE}}\" -d \"{{DESTINATION}}\"",
        "windows": "/powershell -command \"Expand-Archive -Path '{{ARCHIVE}}' -DestinationPath '{{DESTINATION}}'\""
      },
      "inputs": [
        {
          "name": "Archive",
          "as": "ARCHIVE",
          "description": {
            "en": "The archive file to extract",
            "de": "Die zu entpackende Archivdatei"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Destination",
          "as": "DESTINATION",
          "description": {
            "en": "The directory to extract files into",
            "de": "Das Verzeichnis, in das die Dateien entpackt werden"
          },
          "bot": "The destination directory. If not specified by the user, use the current directory.",
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
