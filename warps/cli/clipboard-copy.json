{
  "protocol": "warp:3.0.0",
  "name": "CLI: Copy to Clipboard",
  "title": {
    "en": "Copy text to clipboard",
    "de": "Text in Zwischenablage kopieren"
  },
  "description": {
    "en": "Copy text content to the system clipboard.",
    "de": "Textinhalt in die Zwischenablage des Systems kopieren."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Copy to Clipboard",
        "de": "In Zwischenablage kopieren"
      },
      "prompt": {
        "macos": "/echo \"{{TEXT}}\" | pbcopy",
        "linux": "/echo \"{{TEXT}}\" | xclip -selection clipboard",
        "windows": "/echo {{TEXT}} | clip"
      },
      "inputs": [
        {
          "name": "Text",
          "as": "TEXT",
          "description": {
            "en": "The text to copy to clipboard",
            "de": "Der in die Zwischenablage zu kopierende Text"
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
