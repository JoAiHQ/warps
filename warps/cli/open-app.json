{
  "protocol": "warp:3.0.0",
  "name": "CLI: Open App",
  "title": {
    "en": "Open an application",
    "de": "Eine Anwendung öffnen"
  },
  "description": {
    "en": "Open an application by name.",
    "de": "Eine Anwendung nach Name öffnen."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Open App",
        "de": "App öffnen"
      },
      "prompt": {
        "macos": "/open -a \"{{APP_NAME}}\"",
        "linux": "/xdg-open {{APP_NAME}}",
        "windows": "/start \"\" \"{{APP_NAME}}\""
      },
      "inputs": [
        {
          "name": "Application",
          "as": "APP_NAME",
          "description": {
            "en": "The application name to open",
            "de": "Der Name der zu öffnenden Anwendung"
          },
          "bot": "The application name. On macOS use the app name (e.g. 'Safari', 'Visual Studio Code'). On Linux use the executable name. On Windows use the executable or app name.",
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
