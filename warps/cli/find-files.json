{
  "protocol": "warp:3.0.0",
  "name": "CLI: Find Files",
  "title": {
    "en": "Find files by name",
    "de": "Dateien nach Name suchen"
  },
  "description": {
    "en": "Search for files matching a name pattern in a directory.",
    "de": "Nach Dateien suchen, die einem Namensmuster in einem Verzeichnis entsprechen."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Find Files",
        "de": "Dateien finden"
      },
      "prompt": {
        "macos": "/find \"{{PATH}}\" -iname \"{{PATTERN}}\"",
        "linux": "/find \"{{PATH}}\" -iname \"{{PATTERN}}\"",
        "windows": "/dir /S /B \"{{PATH}}\\{{PATTERN}}\""
      },
      "inputs": [
        {
          "name": "Pattern",
          "as": "PATTERN",
          "description": {
            "en": "The filename pattern to search for (e.g. *.pdf, report*)",
            "de": "Das Dateinamensmuster (z.B. *.pdf, bericht*)"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Path",
          "as": "PATH",
          "description": {
            "en": "The directory to search in",
            "de": "Das zu durchsuchende Verzeichnis"
          },
          "bot": "The directory to search in. Default to the user's home directory if not specified.",
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
