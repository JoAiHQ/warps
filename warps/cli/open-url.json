{
  "protocol": "warp:3.0.0",
  "name": "CLI: Open URL",
  "title": {
    "en": "Open a URL in the browser",
    "de": "Eine URL im Browser öffnen"
  },
  "description": {
    "en": "Open a URL in the default web browser.",
    "de": "Eine URL im Standard-Webbrowser öffnen."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Open URL",
        "de": "URL öffnen"
      },
      "prompt": {
        "macos": "/open \"{{URL}}\"",
        "linux": "/xdg-open \"{{URL}}\"",
        "windows": "/start \"\" \"{{URL}}\""
      },
      "inputs": [
        {
          "name": "URL",
          "as": "URL",
          "description": {
            "en": "The URL to open",
            "de": "Die zu öffnende URL"
          },
          "bot": "The full URL to open (including https://).",
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
