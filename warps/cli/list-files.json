{
  "protocol": "warp:3.0.0",
  "name": "CLI: List Files",
  "title": {
    "en": "List files in a directory",
    "de": "Dateien in einem Verzeichnis auflisten"
  },
  "description": {
    "en": "List files and directories with details.",
    "de": "Dateien und Verzeichnisse mit Details auflisten."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "List Files",
        "de": "Dateien auflisten"
      },
      "prompt": {
        "macos": "/ls -lah \"{{PATH}}\"",
        "linux": "/ls -lah \"{{PATH}}\"",
        "windows": "/dir \"{{PATH}}\""
      },
      "inputs": [
        {
          "name": "Path",
          "as": "PATH",
          "description": {
            "en": "The directory to list",
            "de": "Das aufzulistende Verzeichnis"
          },
          "bot": "The directory path. Default to current directory or user's home if not specified.",
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
