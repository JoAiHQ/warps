{
  "protocol": "warp:3.0.0",
  "name": "CLI: Download File",
  "title": {
    "en": "Download a file from URL",
    "de": "Datei von URL herunterladen"
  },
  "description": {
    "en": "Download a file from a URL and save it locally.",
    "de": "Eine Datei von einer URL herunterladen und lokal speichern."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Download",
        "de": "Herunterladen"
      },
      "prompt": {
        "macos": "/curl -L -o \"{{OUTPUT}}\" \"{{URL}}\"",
        "linux": "/curl -L -o \"{{OUTPUT}}\" \"{{URL}}\"",
        "windows": "/powershell -command \"Invoke-WebRequest -Uri '{{URL}}' -OutFile '{{OUTPUT}}'\""
      },
      "inputs": [
        {
          "name": "URL",
          "as": "URL",
          "description": {
            "en": "The URL to download from",
            "de": "Die URL, von der heruntergeladen werden soll"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Output",
          "as": "OUTPUT",
          "description": {
            "en": "The local file path to save to",
            "de": "Der lokale Dateipfad zum Speichern"
          },
          "bot": "The output file path. If not specified, derive from the URL filename.",
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
