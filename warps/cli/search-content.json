{
  "protocol": "warp:3.0.0",
  "name": "CLI: Search File Content",
  "title": {
    "en": "Search for text in files",
    "de": "Nach Text in Dateien suchen"
  },
  "description": {
    "en": "Search for a text pattern in files within a directory.",
    "de": "Nach einem Textmuster in Dateien innerhalb eines Verzeichnisses suchen."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Search",
        "de": "Suchen"
      },
      "prompt": {
        "macos": "/grep -r \"{{PATTERN}}\" \"{{PATH}}\"",
        "linux": "/grep -r \"{{PATTERN}}\" \"{{PATH}}\"",
        "windows": "/findstr /S /I \"{{PATTERN}}\" \"{{PATH}}\\*\""
      },
      "inputs": [
        {
          "name": "Pattern",
          "as": "PATTERN",
          "description": {
            "en": "The text pattern to search for",
            "de": "Das zu suchende Textmuster"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Path",
          "as": "PATH",
          "description": {
            "en": "The directory to search in",
            "de": "Das zu durchsuchende Verzeichnis"
          },
          "bot": "The directory to search in. Default to current directory if not specified.",
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
