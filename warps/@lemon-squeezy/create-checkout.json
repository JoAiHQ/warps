{
  "protocol": "warp:3.0.0",
  "name": "Lemon Squeezy: Create Checkout",
  "title": {
    "en": "Create checkout",
    "de": "Checkout erstellen",
    "es": "Create checkout",
    "fr": "Create checkout",
    "ro": "Create checkout",
    "it": "Create checkout"
  },
  "description": {
    "en": "Create a checkout link for a specific product variant in your Lemon Squeezy store.",
    "de": "Erstelle einen Checkout-Link für eine bestimmte Produktvariante in deinem Lemon Squeezy Store.",
    "es": "Create a checkout link for a specific product variant in your Lemon Squeezy store.",
    "fr": "Create a checkout link for a specific product variant in your Lemon Squeezy store.",
    "ro": "Create a checkout link for a specific product variant in your Lemon Squeezy store.",
    "it": "Create a checkout link for a specific product variant in your Lemon Squeezy store."
  },
  "vars": {
    "API_KEY": "env:LEMON_SQUEEZY_API_KEY|Get your API key from https://app.lemonsqueezy.com/settings/api"
  },
  "actions": [
    {
      "type": "collect",
      "label": "Create Checkout",
      "destination": {
        "url": "INJECT:API_CHECKOUTS",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Accept": "application/vnd.api+json",
          "Content-Type": "application/vnd.api+json"
        }
      },
      "inputs": [
        {
          "name": "Store ID",
          "as": "store_id",
          "description": {
            "en": "The ID of the store this checkout belongs to.",
            "es": "The ID of the store this checkout belongs to.",
            "fr": "The ID of the store this checkout belongs to.",
            "ro": "The ID of the store this checkout belongs to.",
            "it": "The ID of the store this checkout belongs to."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:data.relationships.store.data.id"
        },
        {
          "name": "Variant ID",
          "as": "variant_id",
          "description": {
            "en": "The ID of the product variant for the checkout.",
            "es": "The ID of the product variant for the checkout.",
            "fr": "The ID of the product variant for the checkout.",
            "ro": "The ID of the product variant for the checkout.",
            "it": "The ID of the product variant for the checkout."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:data.relationships.variant.data.id"
        },
        {
          "name": "Data Type",
          "as": "data_type",
          "description": {
            "en": "Resource type",
            "es": "Resource type",
            "fr": "Resource type",
            "ro": "Resource type",
            "it": "Resource type"
          },
          "type": "string",
          "source": "hidden",
          "position": "payload:data.type",
          "default": "checkouts"
        },
        {
          "name": "Store Type",
          "as": "store_type",
          "description": {
            "en": "Store relationship type",
            "es": "Store relationship type",
            "fr": "Store relationship type",
            "ro": "Store relationship type",
            "it": "Store relationship type"
          },
          "type": "string",
          "source": "hidden",
          "position": "payload:data.relationships.store.data.type",
          "default": "stores"
        },
        {
          "name": "Variant Type",
          "as": "variant_type",
          "description": {
            "en": "Variant relationship type",
            "es": "Variant relationship type",
            "fr": "Variant relationship type",
            "ro": "Variant relationship type",
            "it": "Variant relationship type"
          },
          "type": "string",
          "source": "hidden",
          "position": "payload:data.relationships.variant.data.type",
          "default": "variants"
        }
      ]
    }
  ],
  "output": {
    "CHECKOUT_URL": "out.data.attributes.url",
    "ID": "out.data.id"
  },
  "messages": {
    "success": {
      "en": "Checkout created: {{CHECKOUT_URL}}",
      "de": "Checkout erstellt: {{CHECKOUT_URL}}",
      "es": "Checkout created: {{CHECKOUT_URL}}",
      "fr": "Checkout created: {{CHECKOUT_URL}}",
      "ro": "Checkout created: {{CHECKOUT_URL}}",
      "it": "Checkout created: {{CHECKOUT_URL}}"
    }
  }
}
