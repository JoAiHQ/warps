{
  "protocol": "warp:3.0.0",
  "name": "Lemon Squeezy: List Subscriptions",
  "title": {
    "en": "List subscriptions",
    "de": "Abonnements auflisten"
  },
  "description": {
    "en": "Retrieve a list of subscriptions from your Lemon Squeezy store.",
    "de": "Rufe eine Liste von Abonnements aus deinem Lemon Squeezy Store ab."
  },
  "vars": {
    "API_KEY": "env:LEMON_SQUEEZY_API_KEY|Get your API key from https://app.lemonsqueezy.com/settings/api"
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Subscriptions",
      "destination": {
        "url": "INJECT:API_SUBSCRIPTIONS",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Accept": "application/vnd.api+json"
        }
      },
      "inputs": [
        {
          "name": "Store ID",
          "as": "store_id",
          "description": {
            "en": "Filter subscriptions by store ID."
          },
          "bot": "Filter subscriptions by a specific store ID.",
          "type": "string",
          "source": "field",
          "required": false,
          "position": "query:filter[store_id]"
        },
        {
          "name": "Status",
          "as": "status",
          "description": {
            "en": "Filter subscriptions by status (e.g., 'active', 'paused', 'past_due', 'unpaid', 'cancelled', 'expired')."
          },
          "bot": "Filter subscriptions by status. Options: active, paused, past_due, unpaid, cancelled, expired.",
          "type": "string",
          "source": "field",
          "required": false,
          "position": "query:filter[status]"
        }
      ]
    }
  ],
  "output": {
    "SUBSCRIPTIONS": "out.data",
    "COUNT": "out.meta.page.total"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} subscription(s).",
      "de": "{{COUNT}} Abonnement(s) gefunden."
    }
  }
}
