{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "xAlliance: Experience - Add Points",
  "title": {
    "en": "Assign Experience Points (XP)",
    "de": "Erfahrungspunkte (XP) zuweisen",
    "es": "Asignar puntos de experiencia (XP)",
    "fr": "Attribuer des points d'expérience (XP)",
    "ro": "Atribuie puncte de experiență (XP)",
    "it": "Assegna punti esperienza (XP)"
  },
  "description": {
    "en": "Assign experience points to an xAlliance member.",
    "de": "Weise einem xAlliance-Mitglied Erfahrungspunkte zu."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Add",
        "de": "Hinzufügen",
        "es": "Agregar",
        "fr": "Ajouter",
        "ro": "Adaugă",
        "it": "Aggiungi"
      },
      "address": "INJECT:XP",
      "func": "addPoints",
      "args": [],
      "gasLimit": 5000000,
      "inputs": [
        {
          "name": "user",
          "description": {
            "en": "The address of the user to assign XP to.",
            "de": "Die Adresse des Benutzers, dem XP zugewiesen werden soll."
          },
          "type": "address",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "amount",
          "description": {
            "en": "The amount of XP to assign.",
            "de": "Die Menge an XP, die zugewiesen werden soll."
          },
          "type": "biguint",
          "position": "arg:2",
          "source": "field",
          "required": true,
          "min": 1
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "XP added successfully",
      "de": "XP erfolgreich hinzugefügt",
      "es": "XP agregado con éxito",
      "fr": "XP ajouté avec succès",
      "ro": "XP adăugat cu succes",
      "it": "XP aggiunto con successo"
    }
  }
}
