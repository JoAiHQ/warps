{
  "protocol": "warp:3.0.0",
  "name": "Supabase: Update Rows",
  "title": {
    "en": "Update rows in table",
    "de": "Zeilen in Tabelle aktualisieren"
  },
  "description": {
    "en": "Update rows in a Supabase table matching a filter condition.",
    "de": "Zeilen in einer Supabase-Tabelle aktualisieren, die einer Filterbedingung entsprechen."
  },
  "vars": {
    "SUPABASE_URL": "env:SUPABASE_URL|Your Supabase project URL (e.g., https://xxxx.supabase.co).",
    "SUPABASE_KEY": "env:SUPABASE_KEY|Your Supabase anon or service_role key from Project Settings > API."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Update",
      "destination": {
        "url": "{{SUPABASE_URL}}/rest/v1/{{TABLE}}?{{FILTER}}",
        "method": "PATCH",
        "headers": {
          "apikey": "{{SUPABASE_KEY}}",
          "Authorization": "Bearer {{SUPABASE_KEY}}",
          "Content-Type": "application/json",
          "Prefer": "return=representation"
        }
      },
      "inputs": [
        {
          "name": "Table",
          "as": "TABLE",
          "description": {
            "en": "The table name."
          },
          "bot": "The name of the Supabase/PostgreSQL table.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:TABLE"
        },
        {
          "name": "Filter",
          "as": "FILTER",
          "description": {
            "en": "PostgREST filter to match rows (e.g., 'id=eq.123')."
          },
          "bot": "PostgREST filter to identify which rows to update. Example: 'id=eq.123' or 'status=eq.pending'. REQUIRED to avoid updating all rows.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:FILTER"
        },
        {
          "name": "Data",
          "as": "data",
          "description": {
            "en": "JSON object with columns to update."
          },
          "bot": "JSON object with the columns and values to update. Example: {\"status\": \"completed\", \"updated_at\": \"2024-01-01\"}",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "body"
        }
      ]
    }
  ],
  "output": {
    "ROWS": "out",
    "COUNT": "out.length"
  },
  "messages": {
    "success": {
      "en": "Updated {{COUNT}} row(s).",
      "de": "{{COUNT}} Zeile(n) aktualisiert."
    }
  }
}
