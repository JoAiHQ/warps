{
  "protocol": "warp:3.0.0",
  "name": "Supabase: Update Rows",
  "title": {
    "en": "Update rows in table",
    "de": "Zeilen in Tabelle aktualisieren",
    "es": "Update rows in table",
    "fr": "Update rows in table",
    "ro": "Update rows in table",
    "it": "Update rows in table"
  },
  "description": {
    "en": "Update rows in a Supabase table matching a filter condition.",
    "de": "Zeilen in einer Supabase-Tabelle aktualisieren, die einer Filterbedingung entsprechen.",
    "es": "Update rows in a Supabase table matching a filter condition.",
    "fr": "Update rows in a Supabase table matching a filter condition.",
    "ro": "Update rows in a Supabase table matching a filter condition.",
    "it": "Update rows in a Supabase table matching a filter condition."
  },
  "vars": {
    "SUPABASE_URL": "env:SUPABASE_URL|Your Supabase project URL (e.g., https://xxxx.supabase.co).",
    "SUPABASE_KEY": "env:SUPABASE_KEY|Your Supabase anon or service_role key from Project Settings > API."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Update",
      "destination": {
        "url": "{{SUPABASE_URL}}/rest/v1/{{TABLE}}?{{FILTER}}",
        "method": "PATCH",
        "headers": {
          "apikey": "{{SUPABASE_KEY}}",
          "Authorization": "Bearer {{SUPABASE_KEY}}",
          "Content-Type": "application/json",
          "Prefer": "return=representation"
        }
      },
      "inputs": [
        {
          "name": "Table",
          "as": "TABLE",
          "description": {
            "en": "The table name.",
            "es": "The table name.",
            "fr": "The table name.",
            "ro": "The table name.",
            "it": "The table name."
          },
          "bot": "The name of the Supabase/PostgreSQL table.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:TABLE"
        },
        {
          "name": "Filter",
          "as": "FILTER",
          "description": {
            "en": "PostgREST filter to match rows (e.g., 'id=eq.123').",
            "es": "PostgREST filter to match rows (e.g., 'id=eq.123').",
            "fr": "PostgREST filter to match rows (e.g., 'id=eq.123').",
            "ro": "PostgREST filter to match rows (e.g., 'id=eq.123').",
            "it": "PostgREST filter to match rows (e.g., 'id=eq.123')."
          },
          "bot": "PostgREST filter to identify which rows to update. Example: 'id=eq.123' or 'status=eq.pending'. REQUIRED to avoid updating all rows.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:FILTER"
        },
        {
          "name": {
            "en": "Data",
            "de": "Data",
            "es": "Data",
            "fr": "Data",
            "ro": "Data",
            "it": "Data"
          },
          "as": {
            "en": "data",
            "de": "data",
            "es": "data",
            "fr": "data",
            "ro": "data",
            "it": "data"
          },
          "description": {
            "en": "JSON object with columns to update.",
            "es": "JSON object with columns to update.",
            "fr": "JSON object with columns to update.",
            "ro": "JSON object with columns to update.",
            "it": "JSON object with columns to update."
          },
          "bot": "JSON object with the columns and values to update. Example: {\"status\": \"completed\", \"updated_at\": \"2024-01-01\"}",
          "type": "string",
          "source": "field",
          "required": true,
          "position": {
            "en": "body",
            "de": "body",
            "es": "body",
            "fr": "body",
            "ro": "body",
            "it": "body"
          }
        }
      ]
    }
  ],
  "output": {
    "ROWS": "out",
    "COUNT": "out.length"
  },
  "messages": {
    "success": {
      "en": "Updated {{COUNT}} row(s).",
      "de": "{{COUNT}} Zeile(n) aktualisiert.",
      "es": "Updated {{COUNT}} row(s).",
      "fr": "Updated {{COUNT}} row(s).",
      "ro": "Updated {{COUNT}} row(s).",
      "it": "Updated {{COUNT}} row(s)."
    }
  }
}
