{
  "protocol": "warp:3.0.0",
  "name": "Supabase: Delete Rows",
  "title": {
    "en": "Delete rows from table",
    "de": "Zeilen aus Tabelle löschen",
    "es": "Delete rows from table",
    "fr": "Delete rows from table",
    "ro": "Delete rows from table",
    "it": "Delete rows from table"
  },
  "description": {
    "en": "Delete rows from a Supabase table matching a filter condition.",
    "de": "Zeilen aus einer Supabase-Tabelle löschen, die einer Filterbedingung entsprechen.",
    "es": "Delete rows from a Supabase table matching a filter condition.",
    "fr": "Delete rows from a Supabase table matching a filter condition.",
    "ro": "Delete rows from a Supabase table matching a filter condition.",
    "it": "Delete rows from a Supabase table matching a filter condition."
  },
  "vars": {
    "SUPABASE_URL": "env:SUPABASE_URL|Your Supabase project URL (e.g., https://xxxx.supabase.co).",
    "SUPABASE_KEY": "env:SUPABASE_KEY|Your Supabase anon or service_role key from Project Settings > API."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Delete",
      "destination": {
        "url": "{{SUPABASE_URL}}/rest/v1/{{TABLE}}?{{FILTER}}",
        "method": "DELETE",
        "headers": {
          "apikey": "{{SUPABASE_KEY}}",
          "Authorization": "Bearer {{SUPABASE_KEY}}",
          "Prefer": "return=representation"
        }
      },
      "inputs": [
        {
          "name": "Table",
          "as": "TABLE",
          "description": {
            "en": "The table name.",
            "es": "The table name.",
            "fr": "The table name.",
            "ro": "The table name.",
            "it": "The table name."
          },
          "bot": "The name of the Supabase/PostgreSQL table.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:TABLE"
        },
        {
          "name": "Filter",
          "as": "FILTER",
          "description": {
            "en": "PostgREST filter to match rows (e.g., 'id=eq.123').",
            "es": "PostgREST filter to match rows (e.g., 'id=eq.123').",
            "fr": "PostgREST filter to match rows (e.g., 'id=eq.123').",
            "ro": "PostgREST filter to match rows (e.g., 'id=eq.123').",
            "it": "PostgREST filter to match rows (e.g., 'id=eq.123')."
          },
          "bot": "PostgREST filter to identify which rows to delete. Example: 'id=eq.123'. REQUIRED to avoid deleting all rows.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:FILTER"
        }
      ]
    }
  ],
  "output": {
    "ROWS": "out",
    "COUNT": "out.length"
  },
  "messages": {
    "success": {
      "en": "Deleted {{COUNT}} row(s).",
      "de": "{{COUNT}} Zeile(n) gelöscht.",
      "es": "Deleted {{COUNT}} row(s).",
      "fr": "Deleted {{COUNT}} row(s).",
      "ro": "Deleted {{COUNT}} row(s).",
      "it": "Deleted {{COUNT}} row(s)."
    }
  }
}
