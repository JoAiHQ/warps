{
  "protocol": "warp:3.0.0",
  "name": "Pipedrive: Add Person",
  "title": {
    "en": "Add person",
    "de": "Person hinzufügen",
    "es": "Add person",
    "fr": "Add person",
    "ro": "Add person",
    "it": "Add person"
  },
  "description": {
    "en": "Add a new person to Pipedrive.",
    "de": "Füge eine neue Person zu Pipedrive hinzu.",
    "es": "Add a new person to Pipedrive.",
    "fr": "Add a new person to Pipedrive.",
    "ro": "Add a new person to Pipedrive.",
    "it": "Add a new person to Pipedrive."
  },
  "vars": {
    "API_TOKEN": "env:PIPEDRIVE_API_TOKEN|Your Pipedrive API Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Add Person",
      "destination": {
        "url": "https://api.pipedrive.com/v1/persons?api_token={{API_TOKEN}}",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Name",
          "as": "name",
          "description": {
            "en": "The name of the person.",
            "es": "The name of the person.",
            "fr": "The name of the person.",
            "ro": "The name of the person.",
            "it": "The name of the person."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:name",
          "label": {
            "en": "Name",
            "de": "Name",
            "es": "Name",
            "fr": "Name",
            "ro": "Name",
            "it": "Name"
          }
        },
        {
          "name": "Email",
          "as": "email",
          "description": {
            "en": "The email address.",
            "es": "The email address.",
            "fr": "The email address.",
            "ro": "The email address.",
            "it": "The email address."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:email.0.value"
        },
        {
          "name": "Phone",
          "as": "phone",
          "description": {
            "en": "The phone number.",
            "es": "The phone number.",
            "fr": "The phone number.",
            "ro": "The phone number.",
            "it": "The phone number."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:phone.0.value"
        }
      ]
    }
  ],
  "output": {
    "PERSON_ID": "out.data.id",
    "NAME": "out.data.name"
  },
  "messages": {
    "success": {
      "en": "Person added! ID: {{PERSON_ID}}",
      "de": "Person hinzugefügt! ID: {{PERSON_ID}}",
      "es": "Person added! ID: {{PERSON_ID}}",
      "fr": "Person added! ID: {{PERSON_ID}}",
      "ro": "Person added! ID: {{PERSON_ID}}",
      "it": "Person added! ID: {{PERSON_ID}}"
    }
  }
}
