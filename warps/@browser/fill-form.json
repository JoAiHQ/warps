{
  "protocol": "warp:3.0.0",
  "name": "Browser: Fill Form",
  "title": {
    "en": "Fill form"
  },
  "description": {
    "en": "Fill form fields on the current browser page."
  },
  "actions": [
    {
      "type": "mcp",
      "label": {
        "en": "Fill Form"
      },
      "destination": {
        "url": "browser://devtools",
        "tool": "fill_form"
      },
      "inputs": [
        {
          "name": "Elements",
          "as": "ELEMENTS",
          "description": {
            "en": "JSON array of {uid, value} objects to fill"
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Form filled successfully."
    },
    "error": {
      "en": "Failed to fill form."
    }
  }
}
