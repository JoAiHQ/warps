{
  "protocol": "warp:3.0.0",
  "name": "Browser: Evaluate Script",
  "title": {
    "en": "Evaluate script"
  },
  "description": {
    "en": "Execute JavaScript in the current browser tab and return the result."
  },
  "actions": [
    {
      "type": "mcp",
      "label": {
        "en": "Evaluate Script"
      },
      "destination": {
        "url": "browser://devtools",
        "tool": "evaluate_script"
      },
      "inputs": [
        {
          "name": "Script",
          "as": "SCRIPT",
          "description": {
            "en": "JavaScript function to evaluate in the page context. Must be a function declaration, e.g. function() { return document.title; }"
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Script evaluated successfully."
    },
    "error": {
      "en": "Failed to evaluate script."
    }
  }
}
