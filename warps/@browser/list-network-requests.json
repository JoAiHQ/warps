{
  "protocol": "warp:3.0.0",
  "name": "Browser: List Network Requests",
  "title": {
    "en": "List network requests"
  },
  "description": {
    "en": "List all network requests captured from the current browser tab."
  },
  "actions": [
    {
      "type": "mcp",
      "label": {
        "en": "List Network Requests"
      },
      "destination": {
        "url": "browser://devtools",
        "tool": "list_network_requests"
      },
      "auto": true,
      "inputs": []
    }
  ],
  "messages": {
    "success": {
      "en": "Network requests retrieved."
    },
    "error": {
      "en": "Failed to retrieve network requests."
    }
  }
}
