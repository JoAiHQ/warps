{
  "protocol": "warp:3.0.0",
  "name": "Browser: List Console Messages",
  "title": {
    "en": "List console messages"
  },
  "description": {
    "en": "List all console messages captured from the current browser tab."
  },
  "actions": [
    {
      "type": "mcp",
      "label": {
        "en": "List Console Messages"
      },
      "destination": {
        "url": "browser://devtools",
        "tool": "list_console_messages"
      },
      "auto": true,
      "inputs": []
    }
  ],
  "messages": {
    "success": {
      "en": "Console messages retrieved."
    },
    "error": {
      "en": "Failed to retrieve console messages."
    }
  }
}
