{
  "protocol": "warp:3.0.0",
  "name": "Browser: Navigate",
  "title": {
    "en": "Navigate to URL"
  },
  "description": {
    "en": "Navigate Chrome to a specific URL."
  },
  "actions": [
    {
      "type": "mcp",
      "label": {
        "en": "Navigate"
      },
      "destination": {
        "url": "browser://devtools",
        "tool": "navigate_page"
      },
      "inputs": [
        {
          "name": "URL",
          "as": "url",
          "description": {
            "en": "The full URL to navigate to (including https://)"
          },
          "type": "url",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Navigated to {{URL}}."
    },
    "error": {
      "en": "Failed to navigate to {{URL}}."
    }
  }
}
