{
  "protocol": "warp:3.0.0",
  "name": "Browser: Screenshot",
  "title": {
    "en": "Take screenshot"
  },
  "description": {
    "en": "Capture a screenshot of the current browser tab."
  },
  "actions": [
    {
      "type": "mcp",
      "label": {
        "en": "Take Screenshot"
      },
      "destination": {
        "url": "browser://devtools",
        "tool": "take_screenshot"
      },
      "auto": true,
      "inputs": []
    }
  ],
  "messages": {
    "success": {
      "en": "Screenshot captured."
    },
    "error": {
      "en": "Failed to capture screenshot."
    }
  }
}
