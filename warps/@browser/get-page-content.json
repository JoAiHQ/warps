{
  "protocol": "warp:3.0.0",
  "name": "Browser: Get Page Content",
  "title": {
    "en": "Get page content"
  },
  "description": {
    "en": "Retrieve the accessibility snapshot of the current browser page."
  },
  "actions": [
    {
      "type": "mcp",
      "label": {
        "en": "Get Page Content"
      },
      "destination": {
        "url": "browser://devtools",
        "tool": "take_snapshot"
      },
      "auto": true,
      "inputs": []
    }
  ],
  "messages": {
    "success": {
      "en": "Page content retrieved."
    },
    "error": {
      "en": "Failed to retrieve page content."
    }
  }
}
