{
  "protocol": "warp:3.0.0",
  "name": "Browser: Click Element",
  "title": {
    "en": "Click element"
  },
  "description": {
    "en": "Click a specific element on the current browser page."
  },
  "actions": [
    {
      "type": "mcp",
      "label": {
        "en": "Click Element"
      },
      "destination": {
        "url": "browser://devtools",
        "tool": "click"
      },
      "inputs": [
        {
          "name": "Element UID",
          "as": "uid",
          "description": {
            "en": "The UID of the element to click, obtained from the page snapshot (use Get Page Content first)"
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Element clicked successfully."
    },
    "error": {
      "en": "Failed to click element."
    }
  }
}
