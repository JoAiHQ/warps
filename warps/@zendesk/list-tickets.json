{
  "protocol": "warp:3.0.0",
  "name": "Zendesk: List Tickets",
  "title": {
    "en": "List tickets",
    "de": "Tickets auflisten"
  },
  "description": {
    "en": "List support tickets from Zendesk.",
    "de": "Liste Support-Tickets aus Zendesk auf."
  },
  "vars": {
    "SUBDOMAIN": "env:ZENDESK_SUBDOMAIN|Your Zendesk subdomain (e.g., 'your-company').",
    "AUTH": "env:ZENDESK_AUTH|Your Base64-encoded 'email/token:api_token' for Basic authentication."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Tickets",
      "destination": {
        "url": "https://{{SUBDOMAIN}}.zendesk.com/api/v2/tickets.json?page={{PAGE}}&per_page={{PER_PAGE}}",
        "method": "GET",
        "headers": {
          "Authorization": "Basic {{AUTH}}"
        }
      },
      "inputs": [
        {
          "name": "Page",
          "as": "PAGE",
          "description": {
            "en": "Page number."
          },
          "type": "number",
          "source": "field",
          "required": false,
          "default": 1
        },
        {
          "name": "Per Page",
          "as": "PER_PAGE",
          "description": {
            "en": "Number of tickets per page."
          },
          "type": "number",
          "source": "field",
          "required": false,
          "default": 20
        }
      ]
    }
  ],
  "output": {
    "TICKETS": "out.tickets",
    "COUNT": "out.count"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} ticket(s).",
      "de": "{{COUNT}} Ticket(s) gefunden."
    }
  }
}
