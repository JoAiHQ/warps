{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "MultiversX: Arena Send Loop",
  "title": {
    "en": "Arena: Send loop"
  },
  "description": {
    "en": "Continuously sends 0 EGLD to the target wallet while the arena active flag is set. Stops when the flag is cleared by a RED command."
  },
  "actions": [
    {
      "type": "state",
      "label": {
        "en": "Load active flag"
      },
      "op": "read",
      "store": "arena",
      "keys": ["active"]
    },
    {
      "type": "transfer",
      "label": {
        "en": "Send to target"
      },
      "address": "TARGET_WALLET_ADDRESS",
      "value": "0",
      "when": "{{state.active}} == 1"
    },
    {
      "type": "loop",
      "label": {
        "en": "Repeat"
      },
      "maxIterations": 10000
    }
  ]
}
