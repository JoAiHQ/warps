{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "MultiversX: Account Transaction Count",
  "title": {
    "en": "View MultiversX transaction count",
    "de": "MultiversX-Transaktionsanzahl anzeigen",
    "es": "Ver conteo de transacciones de MultiversX",
    "fr": "Voir le nombre de transactions MultiversX",
    "ro": "Vezi numărul de tranzacții MultiversX",
    "it": "Visualizza il conteggio delle transazioni MultiversX"
  },
  "description": {
    "en": "View the total number of transactions for a MultiversX blockchain account.",
    "de": "Zeige die Gesamtzahl der Transaktionen für ein MultiversX-Blockchain-Konto an.",
    "es": "Ver el número total de transacciones de una cuenta MultiversX.",
    "fr": "Voir le nombre total de transactions d'un compte MultiversX.",
    "ro": "Vezi numărul total de tranzacții ale unui cont MultiversX.",
    "it": "Visualizza il numero totale di transazioni di un account MultiversX."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Check now",
        "de": "Jetzt prüfen",
        "es": "Verificar ahora",
        "fr": "Vérifier maintenant",
        "ro": "Verifică acum",
        "it": "Verifica ora"
      },
      "destination": {
        "url": "{{CHAIN_API}}/accounts/{{ADDRESS}}/transactions/count"
      },
      "inputs": [
        {
          "name": "Address",
          "as": "ADDRESS",
          "description": {
            "en": "The wallet address to check transaction count for.",
            "de": "Die Wallet-Adresse, für die die Transaktionsanzahl überprüft werden soll.",
            "es": "The wallet address to check transaction count for.",
            "fr": "The wallet address to check transaction count for.",
            "ro": "The wallet address to check transaction count for.",
            "it": "The wallet address to check transaction count for."
          },
          "type": "address",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "COUNT": "transform:() => Number(out || 0)",
    "COUNT_FORMATTED": "transform:() => results.COUNT.toLocaleString('en-US')"
  },
  "messages": {
    "success": {
      "en": "The address has made {{COUNT_FORMATTED}} transactions.",
      "de": "Die Adresse hat {{COUNT_FORMATTED}} Transaktionen durchgeführt.",
      "es": "The address has made {{COUNT_FORMATTED}} transactions.",
      "fr": "The address has made {{COUNT_FORMATTED}} transactions.",
      "ro": "The address has made {{COUNT_FORMATTED}} transactions.",
      "it": "The address has made {{COUNT_FORMATTED}} transactions."
    },
    "card": {
      "en": "Transaction: {{COUNT_FORMATTED}}",
      "de": "Transaktion: {{COUNT_FORMATTED}}",
      "es": "Transaction: {{COUNT_FORMATTED}}",
      "fr": "Transaction: {{COUNT_FORMATTED}}",
      "ro": "Transaction: {{COUNT_FORMATTED}}",
      "it": "Transaction: {{COUNT_FORMATTED}}"
    },
    "info": {
      "en": "This account has executed {{COUNT_FORMATTED}} transactions",
      "de": "Dieses Konto hat {{COUNT_FORMATTED}} Transaktionen ausgeführt",
      "es": "This account has executed {{COUNT_FORMATTED}} transactions",
      "fr": "This account has executed {{COUNT_FORMATTED}} transactions",
      "ro": "This account has executed {{COUNT_FORMATTED}} transactions",
      "it": "This account has executed {{COUNT_FORMATTED}} transactions"
    },
    "invoking": {
      "en": "Loading ...",
      "de": "Wird geladen ...",
      "es": "Loading ...",
      "fr": "Loading ...",
      "ro": "Loading ...",
      "it": "Loading ..."
    },
    "invoked": {
      "en": "Loaded",
      "de": "Geladen",
      "es": "Loaded",
      "fr": "Loaded",
      "ro": "Loaded",
      "it": "Loaded"
    }
  }
}
