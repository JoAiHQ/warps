{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "MultiversX: View NFT",
  "title": {
    "en": "View an NFT on MultiversX",
    "de": "NFT auf MultiversX anzeigen"
  },
  "description": {
    "en": "View detailed information about a specific NFT from a MultiversX collection. Shows the NFT image, name, collection, attributes, royalties, and creator.",
    "de": "Zeige detaillierte Informationen zu einem bestimmten NFT aus einer MultiversX-Kollektion. Zeigt NFT-Bild, Name, Kollektion, Attribute, Royalties und Ersteller."
  },
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/multiversx/esdt-nft-view/chatapp.9a73980.dist.html",
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "View NFT",
        "de": "NFT anzeigen"
      },
      "destination": {
        "url": "{{CHAIN_API}}/nfts/{{NFT_IDENTIFIER}}"
      },
      "inputs": [
        {
          "name": "NFT Identifier",
          "as": "NFT_IDENTIFIER",
          "description": {
            "en": "The full NFT identifier including nonce (e.g. 'MYNFT-a1b2c3-01').",
            "de": "Der vollständige NFT-Identifier inklusive Nonce (z.B. 'MEINNFT-a1b2c3-01')."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "NFT_IDENTIFIER": "transform:() => (out?.identifier || '')",
    "NFT_NAME": "transform:() => (out?.name || '')",
    "COLLECTION": "transform:() => (out?.collection || '')",
    "NONCE": "transform:() => (out?.nonce || 0)",
    "ROYALTIES": "transform:() => (out?.royalties || 0)",
    "MEDIA_URL": "transform:() => (out?.url || out?.media?.[0]?.url || '')",
    "THUMBNAIL_URL": "transform:() => (out?.media?.[0]?.thumbnailUrl || out?.url || '')",
    "ATTRIBUTES": "transform:() => (out?.metadata?.attributes || out?.attributes || '')",
    "CREATOR": "transform:() => (out?.creator || '')",
    "OWNER": "transform:() => (out?.owner || '')"
  },
  "messages": {
    "success": {
      "en": "NFT '{{NFT_NAME}}' ({{NFT_IDENTIFIER}}) from collection {{COLLECTION}}.",
      "de": "NFT '{{NFT_NAME}}' ({{NFT_IDENTIFIER}}) aus Kollektion {{COLLECTION}}."
    }
  },
  "related": [
    "@multiversx-esdt-nft-create",
    "@multiversx-esdt-issue-nft-collection"
  ]
}