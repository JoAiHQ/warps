{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "MultiversX: Arena Monitor",
  "title": {
    "en": "Arena: Monitor admin wallet"
  },
  "description": {
    "en": "Fires when the admin wallet sends a transaction. Reads the base64-encoded command from the data field and dispatches it for processing."
  },
  "trigger": {
    "type": "webhook",
    "source": "kepler",
    "inputs": {
      "TX_DATA": "event.data",
      "TX_HASH": "event.txHash"
    }
  },
  "next": "multiversx/#arena-command?TX_DATA={{TX_DATA}}"
}
