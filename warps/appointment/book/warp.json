{
  "protocol": "warp:3.0.0",
  "name": "Appointments: Book",
  "title": {
    "en": "Book an Appointment",
    "de": "Termin buchen"
  },
  "description": {
    "en": "Browse available time slots and book an appointment.",
    "de": "Verfügbare Zeitfenster ansehen und Termin buchen."
  },
  "vars": {
    "JOAI_AGENT_UUID": "env:JOAI_AGENT_UUID",
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "auto": true,
      "label": {
        "en": "Load",
        "de": "Laden"
      },
      "inputs": [],
      "destination": {
        "url": "INJECT:API_BASE/v1/agents/{{JOAI_AGENT_UUID}}/appointments/policy",
        "method": "GET",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "output": {
        "policy": "out.data.policy",
        "availableStaff": "out.data.availableStaff"
      }
    }
  ],
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/appointment/book/chatapp.dd8bb72.dist.html"
}