{
  "protocol": "warp:3.0.0",
  "name": "Appointments: Book",
  "title": {
    "en": "Book an Appointment",
    "de": "Termin buchen",
    "es": "Book an Appointment",
    "fr": "Book an Appointment",
    "ro": "Book an Appointment",
    "it": "Book an Appointment"
  },
  "description": {
    "en": "Browse available time slots and book an appointment.",
    "de": "Verfügbare Zeitfenster ansehen und Termin buchen.",
    "es": "Browse available time slots and book an appointment.",
    "fr": "Browse available time slots and book an appointment.",
    "ro": "Browse available time slots and book an appointment.",
    "it": "Browse available time slots and book an appointment."
  },
  "vars": {
    "JOAI_TEAM_SLUG": "env:JOAI_TEAM_SLUG|Team identifier"
  },
  "actions": [
    {
      "type": "collect",
      "auto": true,
      "label": {
        "en": "Load",
        "de": "Laden",
        "es": "Load",
        "fr": "Load",
        "ro": "Load",
        "it": "Load"
      },
      "inputs": [],
      "destination": {
        "url": "INJECT:API_BASE/v1/teams/{{JOAI_TEAM_SLUG}}/appointments/policy",
        "method": "GET"
      },
      "output": {
        "policy": "out.data"
      }
    }
  ],
  "messages": {
    "error": {
      "en": "Failed to load appointment configuration: {{MESSAGE}}"
    }
  },
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/appointment/book/chatapp.7246899c.dist.html"
}
