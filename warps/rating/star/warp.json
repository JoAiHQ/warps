{
  "protocol": "warp:3.0.0",
  "name": "Review: Star Rating",
  "title": {
    "en": "Rate your visit",
    "de": "Bewerte deinen Besuch"
  },
  "description": {
    "en": "Rate your visit and help the team improve. Your feedback is stored on your contact profile so the team can follow up personally.",
    "de": "Bewerte deinen Besuch und hilf dem Team, besser zu werden. Dein Feedback wird auf deinem Kontaktprofil gespeichert, damit das Team persönlich nachfassen kann."
  },
  "bot": "Use this when a customer wants to leave a review or rate their experience at a restaurant, cafe, or shop.",
  "ui": "INJECT:UI_BASE/rating/star/chatapp.dist.html",
  "actions": [
    {
      "type": "collect",
      "name": "review",
      "label": {
        "en": "Submit review",
        "de": "Bewertung abschicken"
      },
      "inputs": [
        {
          "name": "rating",
          "as": "rating",
          "label": {
            "en": "Rating",
            "de": "Bewertung"
          },
          "type": "uint8",
          "source": "field",
          "required": true,
          "min": 1,
          "max": 5
        },
        {
          "name": "name",
          "as": "name",
          "label": {
            "en": "Your name",
            "de": "Dein Name"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "phone",
          "as": "phone",
          "label": {
            "en": "Phone number",
            "de": "Telefonnummer"
          },
          "type": "string",
          "source": "field",
          "required": false
        }
      ]
    }
  ],
  "next": "joai/contact-find-or-create?name={{name}}&phone={{phone}}",
  "output": {
    "RATING": "out.rating",
    "NAME": "out.name",
    "PHONE": "out.phone"
  },
  "messages": {
    "success": {
      "en": "Thanks {{name}}! You rated {{RATING}}/5.",
      "de": "Danke {{name}}! Du hast {{RATING}}/5 bewertet."
    }
  },
}
