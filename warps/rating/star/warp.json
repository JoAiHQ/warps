{
  "protocol": "warp:3.0.0",
  "name": "Review: Star Rating",
  "title": {
    "en": "Rate your visit",
    "de": "Bewerte deinen Besuch"
  },
  "description": {
    "en": "Rate your visit. Your feedback is stored on your contact profile so the team can follow up personally.",
    "de": "Bewerte deinen Besuch. Dein Feedback wird auf deinem Kontaktprofil gespeichert, damit das Team persönlich nachfassen kann."
  },
  "bot": "Use this when a customer wants to leave a review or rate their experience at a restaurant, cafe, or shop.",
  "vars": {
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "name": "review",
      "label": {
        "en": "Submit review",
        "de": "Bewertung abschicken"
      },
      "inputs": [
        {
          "name": "rating",
          "as": "rating",
          "label": {
            "en": "Rating",
            "de": "Bewertung"
          },
          "type": "uint8",
          "source": "field",
          "required": true,
          "min": 1,
          "max": 5
        },
        {
          "name": "name",
          "as": "name",
          "label": {
            "en": "Your name",
            "de": "Dein Name"
          },
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "phone",
          "as": "phone",
          "label": {
            "en": "Phone number",
            "de": "Telefonnummer"
          },
          "type": "string",
          "source": "field",
          "required": false
        }
      ]
    }
  ],
  "next": [
    {
      "type": "collect",
      "name": "create-contact",
      "label": {
        "en": "Creating contact...",
        "de": "Kontakt wird erstellt..."
      },
      "destination": {
        "url": "INJECT:API_BASE/v1/contacts/find-or-create",
        "method": "POST",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      },
      "inputs": [],
      "body": {
        "name": "{{NAME}}",
        "phone": "{{PHONE}}",
        "props": {
          "rating": "{{RATING}}"
        }
      }
    }
  ],
  "output": {
    "RATING": "out.rating",
    "NAME": "out.name",
    "PHONE": "out.phone"
  },
  "messages": {
    "success": {
      "en": "Thanks {{NAME}}! You rated {{RATING}}/5.",
      "de": "Danke {{NAME}}! Du hast {{RATING}}/5 bewertet."
    }
  },
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/rating/star/chatapp.e4dae0a8.dist.html"
}