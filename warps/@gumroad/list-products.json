{
  "protocol": "warp:3.0.0",
  "name": "Gumroad: List Products",
  "title": {
    "en": "List products",
    "de": "Produkte auflisten"
  },
  "description": {
    "en": "Retrieve all products from your Gumroad account.",
    "de": "Rufe alle Produkte aus deinem Gumroad-Konto ab."
  },
  "vars": {
    "ACCESS_TOKEN": "env:GUMROAD_ACCESS_TOKEN|Get your access token from https://app.gumroad.com/settings/advanced#application-form"
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Products",
      "destination": {
        "url": "INJECT:API_PRODUCTS",
        "method": "GET",
        "headers": {}
      },
      "inputs": [
        {
          "name": "Access Token",
          "as": "access_token",
          "type": "string",
          "source": "hidden",
          "default": "{{ACCESS_TOKEN}}",
          "position": "query:access_token"
        }
      ]
    }
  ],
  "output": {
    "PRODUCTS": "out.products",
    "COUNT": "out.products.length"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} product(s).",
      "de": "{{COUNT}} Produkt(e) gefunden."
    }
  }
}
