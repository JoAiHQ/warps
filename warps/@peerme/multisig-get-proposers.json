{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "PeerMe MultiSig: Get Proposers",
  "title": { "en": "View all proposers", "de": "Alle Vorschlagenden anzeigen" },
  "description": { "en": "Use when a user wants to see who has proposer permissions in a multi-sig wallet. Lists all addresses that can create proposals.", "de": "Verwenden, wenn ein Benutzer sehen möchte, wer Vorschlagsberechtigungen in einer Multi-Sig-Wallet hat. Listet alle Adressen auf, die Vorschläge erstellen können." },
  "actions": [
    {
      "type": "query",
      "label": { "en": "Get proposers", "de": "Vorschlagende abrufen" },
      "address": "{{multisig}}",
      "func": "getAllProposers",
      "args": [],
      "abi": "INJECT:abis/multisig.abi.json",
      "inputs": [
        {
          "name": { "en": "MultiSig address", "de": "MultiSig-Adresse" },
          "as": "multisig",
          "type": "address",
          "source": "query"
        }
      ]
    },
    {
      "type": "query",
      "label": { "en": "Get count", "de": "Anzahl abrufen" },
      "address": "{{multisig}}",
      "func": "getNumProposers",
      "args": [],
      "abi": "INJECT:abis/multisig.abi.json"
    }
  ],
  "output": {
    "PROPOSERS": "out[0]",
    "COUNT": "out[1]",
    "COUNT_NUMBER": "transform:() => Number(results.COUNT)",
    "PROPOSERS_LIST": "transform:() => Array.isArray(results.PROPOSERS) ? results.PROPOSERS.join(', ') : 'No proposers'"
  },
  "messages": {
    "success": { "en": "Found {{COUNT_NUMBER}} proposer(s): {{PROPOSERS_LIST}}", "de": "{{COUNT_NUMBER}} Vorschlagende(r) gefunden: {{PROPOSERS_LIST}}" },
    "card": { "en": "Proposers: {{COUNT_NUMBER}}", "de": "Vorschlagende: {{COUNT_NUMBER}}" },
    "info": { "en": "This MultiSig has {{COUNT_NUMBER}} proposer(s) who can create proposals but cannot sign them", "de": "Diese MultiSig hat {{COUNT_NUMBER}} Vorschlagende(r), die Vorschläge erstellen, aber nicht signieren können" }
  }
}
