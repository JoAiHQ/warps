{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "PeerMe MultiSig: Get Board Members",
  "title": { "en": "View all board members", "de": "Alle Vorstandsmitglieder anzeigen" },
  "description": { "en": "List all board members who can sign and execute proposals in a MultiSig wallet. Board members have full voting rights and can both propose and sign actions.", "de": "Liste aller Vorstandsmitglieder, die Vorschläge in einer MultiSig-Wallet signieren und ausführen können. Vorstandsmitglieder haben volle Stimmrechte und können sowohl vorschlagen als auch Aktionen signieren." },
  "actions": [
    {
      "type": "query",
      "label": { "en": "Get board members", "de": "Vorstandsmitglieder abrufen" },
      "address": "{{multisig}}",
      "func": "getAllBoardMembers",
      "args": [],
      "abi": "INJECT:abis/multisig.abi.json",
      "inputs": [
        {
          "name": { "en": "MultiSig address", "de": "MultiSig-Adresse" },
          "as": "multisig",
          "type": "address",
          "source": "query"
        }
      ]
    },
    {
      "type": "query",
      "label": { "en": "Get count", "de": "Anzahl abrufen" },
      "address": "{{multisig}}",
      "func": "getNumBoardMembers",
      "args": [],
      "abi": "INJECT:abis/multisig.abi.json"
    }
  ],
  "output": {
    "BOARD_MEMBERS": "out[0]",
    "COUNT": "out[1]",
    "COUNT_NUMBER": "transform:() => Number(results.COUNT)",
    "MEMBERS_LIST": "transform:() => Array.isArray(results.BOARD_MEMBERS) ? results.BOARD_MEMBERS.join(', ') : 'No members'"
  },
  "messages": {
    "success": { "en": "Found {{COUNT_NUMBER}} board member(s): {{MEMBERS_LIST}}", "de": "{{COUNT_NUMBER}} Vorstandsmitglied(er) gefunden: {{MEMBERS_LIST}}" },
    "card": { "en": "Board Members: {{COUNT_NUMBER}}", "de": "Vorstandsmitglieder: {{COUNT_NUMBER}}" },
    "info": { "en": "This MultiSig has {{COUNT_NUMBER}} board member(s) who can sign and execute proposals", "de": "Diese MultiSig hat {{COUNT_NUMBER}} Vorstandsmitglied(er), die Vorschläge signieren und ausführen können" }
  }
}
