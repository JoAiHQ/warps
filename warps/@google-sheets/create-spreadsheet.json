{
  "protocol": "warp:3.0.0",
  "name": "Google Sheets: Create Spreadsheet",
  "title": {
    "en": "Create a spreadsheet",
    "de": "Eine Tabelle erstellen",
    "es": "Create a spreadsheet",
    "fr": "Create a spreadsheet",
    "ro": "Create a spreadsheet",
    "it": "Create a spreadsheet"
  },
  "description": {
    "en": "Create a new Google Sheets spreadsheet.",
    "de": "Erstelle eine neue Google Sheets-Tabelle.",
    "es": "Create a new Google Sheets spreadsheet.",
    "fr": "Create a new Google Sheets spreadsheet.",
    "ro": "Create a new Google Sheets spreadsheet.",
    "it": "Create a new Google Sheets spreadsheet."
  },
  "vars": {
    "ACCESS_TOKEN": "env:GOOGLE_SHEETS_ACCESS_TOKEN|OAuth 2.0 access token with https://www.googleapis.com/auth/spreadsheets scope."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Create Spreadsheet",
      "destination": {
        "url": "https://sheets.googleapis.com/v4/spreadsheets",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Title",
          "as": "title",
          "description": {
            "en": "The title of the new spreadsheet.",
            "es": "The title of the new spreadsheet.",
            "fr": "The title of the new spreadsheet.",
            "ro": "The title of the new spreadsheet.",
            "it": "The title of the new spreadsheet."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:properties.title"
        }
      ]
    }
  ],
  "output": {
    "SPREADSHEET_ID": "out.spreadsheetId",
    "SPREADSHEET_URL": "out.spreadsheetUrl"
  },
  "messages": {
    "success": {
      "en": "Spreadsheet created: {{SPREADSHEET_URL}}",
      "de": "Tabelle erstellt: {{SPREADSHEET_URL}}",
      "es": "Spreadsheet created: {{SPREADSHEET_URL}}",
      "fr": "Spreadsheet created: {{SPREADSHEET_URL}}",
      "ro": "Spreadsheet created: {{SPREADSHEET_URL}}",
      "it": "Spreadsheet created: {{SPREADSHEET_URL}}"
    }
  }
}
