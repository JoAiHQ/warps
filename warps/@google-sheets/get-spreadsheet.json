{
  "protocol": "warp:3.0.0",
  "name": "Google Sheets: Get Spreadsheet",
  "title": {
    "en": "Get spreadsheet details",
    "de": "Tabellendetails abrufen",
    "es": "Get spreadsheet details",
    "fr": "Get spreadsheet details",
    "ro": "Get spreadsheet details",
    "it": "Get spreadsheet details"
  },
  "description": {
    "en": "Get metadata and properties of a Google Sheets spreadsheet.",
    "de": "Rufe Metadaten und Eigenschaften einer Google Sheets-Tabelle ab.",
    "es": "Get metadata and properties of a Google Sheets spreadsheet.",
    "fr": "Get metadata and properties of a Google Sheets spreadsheet.",
    "ro": "Get metadata and properties of a Google Sheets spreadsheet.",
    "it": "Get metadata and properties of a Google Sheets spreadsheet."
  },
  "vars": {
    "ACCESS_TOKEN": "env:GOOGLE_SHEETS_ACCESS_TOKEN|OAuth 2.0 access token with https://www.googleapis.com/auth/spreadsheets.readonly scope."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Get Spreadsheet",
      "destination": {
        "url": "https://sheets.googleapis.com/v4/spreadsheets/{{SPREADSHEET_ID}}",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Spreadsheet ID",
          "as": "SPREADSHEET_ID",
          "description": {
            "en": "The ID of the spreadsheet.",
            "es": "The ID of the spreadsheet.",
            "fr": "The ID of the spreadsheet.",
            "ro": "The ID of the spreadsheet.",
            "it": "The ID of the spreadsheet."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:SPREADSHEET_ID"
        }
      ]
    }
  ],
  "output": {
    "TITLE": "out.properties.title",
    "LOCALE": "out.properties.locale",
    "SPREADSHEET_URL": "out.spreadsheetUrl",
    "SHEETS": "out.sheets"
  },
  "messages": {
    "success": {
      "en": "Spreadsheet: {{TITLE}}",
      "de": "Tabelle: {{TITLE}}",
      "es": "Spreadsheet: {{TITLE}}",
      "fr": "Spreadsheet: {{TITLE}}",
      "ro": "Spreadsheet: {{TITLE}}",
      "it": "Spreadsheet: {{TITLE}}"
    }
  }
}
