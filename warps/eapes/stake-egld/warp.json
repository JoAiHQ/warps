{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "EAPES: Stake eGold",
  "title": {
    "en": "Stake eGold with EAPES",
    "de": "eGold bei EAPES staken"
  },
  "description": {
    "en": "Stake your EGLD with EAPES, where capital meets culture on MultiversX. Earn staking rewards while supporting a community-driven validator that powers the chain and strengthens the tribe.",
    "de": "Stake dein EGLD bei EAPES, wo Kapital auf Kultur im MultiversX-Netzwerk trifft. Verdiene Staking-Belohnungen und unterstuetze einen community-getriebenen Validator, der die Blockchain antreibt und den Stamm staerkt."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Stake now",
        "de": "Jetzt staken"
      },
      "address": "INJECT:PROVIDER",
      "func": "delegate",
      "args": [],
      "gasLimit": 10000000,
      "inputs": [
        {
          "name": "value",
          "description": {
            "en": "Amount of eGold to delegate.",
            "de": "Betrag an eGold zum Delegieren."
          },
          "type": "biguint",
          "position": "value",
          "source": "field",
          "required": true,
          "min": 1,
          "modifier": "scale:18"
        }
      ]
    },
    {
      "type": "link",
      "label": {
        "en": "Learn more",
        "de": "Mehr erfahren"
      },
      "description": {
        "en": "Find more information about staking eGold.",
        "de": "Weitere Informationen zum Staking von eGold finden."
      },
      "url": "https://multiversx.com/egld"
    }
  ],
  "output": {
    "TX_HASH": "out",
    "AMOUNT_EGLD": "transform:() => Number(inputs.value) / 10 ** 18"
  },
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/eapes/stake-egld/chatapp.678081d.dist.html",
  "messages": {
    "success": {
      "en": "eGold staked successfully",
      "de": "eGold erfolgreich gestaked"
    }
  },
  "related": [
    "multiversx-staking-claimable-rewards",
    "multiversx-staking-redelegate-all"
  ]
}