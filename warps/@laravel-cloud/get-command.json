{
  "protocol": "warp:3.0.0",
  "name": "Laravel Cloud: Get Command",
  "title": {
    "en": "Get command details",
    "de": "Befehlsdetails abrufen",
    "es": "Get command details",
    "fr": "Get command details",
    "ro": "Get command details",
    "it": "Get command details"
  },
  "description": {
    "en": "Retrieve the status and details of a specific CLI command.",
    "de": "Ruft den Status und die Details eines bestimmten CLI-Befehls ab.",
    "es": "Retrieve the status and details of a specific CLI command.",
    "fr": "Retrieve the status and details of a specific CLI command.",
    "ro": "Retrieve the status and details of a specific CLI command.",
    "it": "Retrieve the status and details of a specific CLI command."
  },
  "vars": {
    "API_KEY": "env:LARAVEL_CLOUD_TOKEN|Get your API token from Organization Settings in Laravel Cloud"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Command",
        "de": "Befehl abrufen",
        "es": "Get Command",
        "fr": "Get Command",
        "ro": "Get Command",
        "it": "Get Command"
      },
      "destination": {
        "url": "INJECT:API_BASE/commands/{{COMMAND_ID}}",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{API_KEY}}",
          "Accept": "application/vnd.api+json"
        }
      },
      "inputs": [
        {
          "name": "Command ID",
          "as": "COMMAND_ID",
          "description": {
            "en": "The ID of the command.",
            "es": "The ID of the command.",
            "fr": "The ID of the command.",
            "ro": "The ID of the command.",
            "it": "The ID of the command."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "COMMAND": "out.data.attributes.command",
    "STATUS": "out.data.attributes.status",
    "FINISHED_AT": "out.data.attributes.finished_at"
  },
  "messages": {
    "success": {
      "en": "Command '{{COMMAND}}' status: {{STATUS}}.",
      "de": "Befehl '{{COMMAND}}' Status: {{STATUS}}.",
      "es": "Command '{{COMMAND}}' status: {{STATUS}}.",
      "fr": "Command '{{COMMAND}}' status: {{STATUS}}.",
      "ro": "Command '{{COMMAND}}' status: {{STATUS}}.",
      "it": "Command '{{COMMAND}}' status: {{STATUS}}."
    }
  }
}
