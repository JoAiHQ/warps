{
  "protocol": "warp:3.0.0",
  "name": "Spotify: Get Track",
  "title": {
    "en": "Get track",
    "de": "Song abrufen",
    "es": "Obtener seguimiento",
    "fr": "Obtenir une trace",
    "ro": "Obțineți urmări",
    "it": "Ottieni traccia"
  },
  "description": {
    "en": "Get detailed information about a single track from Spotify.",
    "de": "Erhalte detaillierte Informationen über einen einzelnen Song von Spotify.",
    "es": "Obtén información detallada sobre una sola pista de Spotify.",
    "fr": "Obtenez des informations détaillées sur une seule piste de Spotify.",
    "ro": "Obțineți informații detaliate despre o singură piesă de la Spotify.",
    "it": "Ottieni informazioni dettagliate su una singola traccia da Spotify."
  },
  "vars": {
    "ACCESS_TOKEN": "env:SPOTIFY_ACCESS_TOKEN|OAuth access token from Spotify Developer Dashboard."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Track",
        "de": "Song abrufen",
        "es": "Obtener seguimiento",
        "fr": "Obtenir une trace",
        "ro": "Obțineți urmări",
        "it": "Ottieni traccia"
      },
      "destination": {
        "url": "https://api.spotify.com/v1/tracks/{{ID}}",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Track ID",
          "as": "ID",
          "description": {
            "en": "The Spotify ID for the track.",
            "es": "El ID de Spotify de la pista.",
            "fr": "L'identifiant Spotify de la piste.",
            "ro": "ID-ul Spotify al piesei.",
            "it": "L'ID Spotify della traccia."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:ID"
        }
      ]
    }
  ],
  "output": {
    "NAME": "out.name",
    "ARTIST": "out.artists.0.name",
    "ALBUM": "out.album.name",
    "URL": "out.external_urls.spotify",
    "PREVIEW": "out.preview_url"
  },
  "messages": {
    "success": {
      "en": "Track found: {{NAME}} by {{ARTIST}}. Listen: {{URL}}",
      "de": "Song gefunden: {{NAME}} von {{ARTIST}}. Anhören: {{URL}}",
      "es": "Pista encontrada: {{NAME}} por {{ARTIST}}. Escuche: {{URL}}",
      "fr": "Piste trouvée : {{NAME}} par {{ARTIST}}. Écoutez : {{URL}}",
      "ro": "Piesa găsită: {{NAME}} de {{ARTIST}}. Ascultă: {{URL}}",
      "it": "Traccia trovata: {{NAME}} di {{ARTIST}}. Ascolta: {{URL}}"
    }
  }
}
