{
  "protocol": "warp:3.0.0",
  "name": "Spotify: Get Artist",
  "title": {
    "en": "Get artist",
    "de": "Künstler abrufen",
    "es": "conseguir artista",
    "fr": "Obtenir un artiste",
    "ro": "Ia artist",
    "it": "Ottieni artista"
  },
  "description": {
    "en": "Get detailed information about an artist on Spotify.",
    "de": "Erhalte detaillierte Informationen über einen Künstler auf Spotify.",
    "es": "Obtén información detallada sobre un artista en Spotify.",
    "fr": "Obtenez des informations détaillées sur un artiste sur Spotify.",
    "ro": "Obțineți informații detaliate despre un artist pe Spotify.",
    "it": "Ottieni informazioni dettagliate su un artista su Spotify."
  },
  "vars": {
    "ACCESS_TOKEN": "env:SPOTIFY_ACCESS_TOKEN|OAuth access token from Spotify Developer Dashboard."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Artist",
        "de": "Künstler abrufen",
        "es": "Obtener artista",
        "fr": "Obtenir un artiste",
        "ro": "Obțineți artist",
        "it": "Ottieni Artista"
      },
      "destination": {
        "url": "https://api.spotify.com/v1/artists/{{ID}}",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}"
        }
      },
      "inputs": [
        {
          "name": "Artist ID",
          "as": "ID",
          "description": {
            "en": "The Spotify ID for the artist.",
            "es": "El ID de Spotify del artista.",
            "fr": "L'identifiant Spotify de l'artiste.",
            "ro": "ID-ul Spotify pentru artist.",
            "it": "L'ID Spotify dell'artista."
          },
          "bot": "The Spotify artist ID. You can get this from search results or a Spotify URL.",
          "type": "string",
          "source": "field",
          "required": true,
          "position": "url:ID"
        }
      ]
    }
  ],
  "output": {
    "NAME": "out.name",
    "GENRES": "out.genres",
    "FOLLOWERS": "out.followers.total",
    "POPULARITY": "out.popularity",
    "URL": "out.external_urls.spotify",
    "IMAGE": "out.images.0.url"
  },
  "messages": {
    "success": {
      "en": "Artist: {{NAME}} ({{FOLLOWERS}} followers). {{URL}}",
      "de": "Künstler: {{NAME}} ({{FOLLOWERS}} Follower). {{URL}}",
      "es": "Artista: {{NAME}} ({{FOLLOWERS}} seguidores). {{URL}}",
      "fr": "Artiste : {{NAME}} ({{FOLLOWERS}} abonnés). {{URL}}",
      "ro": "Artist: {{NAME}} ({{FOLLOWERS}} urmăritori). {{URL}}",
      "it": "Artista: {{NAME}} ({{FOLLOWERS}} follower). {{URL}}"
    }
  }
}
