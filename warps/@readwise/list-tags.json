{
  "protocol": "warp:3.0.0",
  "name": "Readwise: List Tags",
  "title": {
    "en": "List reader tags",
    "de": "Reader-Tags auflisten",
    "es": "List reader tags",
    "fr": "List reader tags",
    "ro": "List reader tags",
    "it": "List reader tags"
  },
  "description": {
    "en": "List available Readwise Reader tags.",
    "de": "Listet verfügbare Tags in Readwise Reader auf.",
    "es": "List available Readwise Reader tags.",
    "fr": "List available Readwise Reader tags.",
    "ro": "List available Readwise Reader tags.",
    "it": "List available Readwise Reader tags."
  },
  "vars": {
    "API_KEY": "env:READWISE_API_KEY|Get your Reader API token from https://readwise.io/reader_api"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "List tags",
        "de": "Tags auflisten",
        "es": "List tags",
        "fr": "List tags",
        "ro": "List tags",
        "it": "List tags"
      },
      "destination": {
        "url": "INJECT:API_BASE/tags/",
        "method": "GET",
        "headers": {
          "Authorization": "Token {{API_KEY}}",
          "Accept": "application/json"
        }
      }
    }
  ],
  "output": {
    "TAGS": "out || []",
    "COUNT": "transform:() => { return Array.isArray(out) ? out.length : 0; }"
  },
  "messages": {
    "success": {
      "en": "Retrieved {{COUNT}} tag(s).",
      "de": "{{COUNT}} Tag(s) abgerufen.",
      "es": "Retrieved {{COUNT}} tag(s).",
      "fr": "Retrieved {{COUNT}} tag(s).",
      "ro": "Retrieved {{COUNT}} tag(s).",
      "it": "Retrieved {{COUNT}} tag(s)."
    }
  }
}
