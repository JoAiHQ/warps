{
  "protocol": "warp:3.0.0",
  "name": "Readwise: Get Document",
  "title": {
    "en": "Get a reader document",
    "de": "Reader-Dokument abrufen",
    "es": "Get a reader document",
    "fr": "Get a reader document",
    "ro": "Get a reader document",
    "it": "Get a reader document"
  },
  "description": {
    "en": "Retrieve a single Readwise Reader document by ID.",
    "de": "Ruft ein einzelnes Readwise Reader-Dokument per ID ab.",
    "es": "Retrieve a single Readwise Reader document by ID.",
    "fr": "Retrieve a single Readwise Reader document by ID.",
    "ro": "Retrieve a single Readwise Reader document by ID.",
    "it": "Retrieve a single Readwise Reader document by ID."
  },
  "vars": {
    "API_KEY": "env:READWISE_API_KEY|Get your Reader API token from https://readwise.io/reader_api"
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get document",
        "de": "Dokument abrufen",
        "es": "Get document",
        "fr": "Get document",
        "ro": "Get document",
        "it": "Get document"
      },
      "destination": {
        "url": "INJECT:API_BASE/get/{{DOCUMENT_ID}}/",
        "method": "GET",
        "headers": {
          "Authorization": "Token {{API_KEY}}",
          "Accept": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Document ID",
          "as": "DOCUMENT_ID",
          "description": {
            "en": "Readwise Reader document ID.",
            "es": "Readwise Reader document ID.",
            "fr": "Readwise Reader document ID.",
            "ro": "Readwise Reader document ID.",
            "it": "Readwise Reader document ID."
          },
          "type": "string",
          "source": "field",
          "position": "arg:1",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "TITLE": "out.title || null",
    "URL": "out.url || null",
    "CATEGORY": "out.category || null",
    "LOCATION": "out.location || null"
  },
  "messages": {
    "success": {
      "en": "Fetched document '{{TITLE}}'.",
      "de": "Dokument '{{TITLE}}' abgerufen.",
      "es": "Fetched document '{{TITLE}}'.",
      "fr": "Fetched document '{{TITLE}}'.",
      "ro": "Fetched document '{{TITLE}}'.",
      "it": "Fetched document '{{TITLE}}'."
    }
  }
}
