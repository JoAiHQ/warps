{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "xExchange Devnet: Swap USDC to HTM",
  "title": {
    "en": "Swap USDC to HTM",
    "de": "USDC gegen HTM tauschen",
    "es": "Intercambiar USDC por HTM",
    "fr": "Échanger USDC contre HTM",
    "ro": "Schimbă USDC în HTM",
    "it": "Scambia USDC in HTM"
  },
  "description": {
    "en": "Swap USDC to HTM tokens on xExchange Devnet.",
    "de": "USDC gegen HTM Token auf xExchange Devnet tauschen.",
    "es": "Intercambia USDC por HTM en xExchange Devnet.",
    "fr": "Échange USDC contre HTM sur xExchange Devnet.",
    "ro": "Schimbă USDC în HTM pe xExchange Devnet.",
    "it": "Scambia USDC in HTM su xExchange Devnet."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Swap to HTM",
        "de": "Gegen HTM tauschen",
        "es": "Intercambiar a HTM",
        "fr": "Échanger en HTM",
        "ro": "Schimbă în HTM",
        "it": "Scambia in HTM"
      },
      "address": "erd1qqqqqqqqqqqqqpgqmj807dvlfh0tvmgf5ztx0t79xn8nfct60n4sw0d6vy",
      "func": "swapTokensFixedInput",
      "args": [
        "string:INJECT:TOKEN/HTM"
      ],
      "gasLimit": 25000000,
      "abi": "INJECT:abis/pair.abi.json",
      "inputs": [
        {
          "name": "USDC Asset",
          "as": "asset",
          "description": {
            "en": "USDC tokens to swap.",
            "de": "USDC Token zum Tauschen.",
            "es": "Tokens USDC para intercambiar.",
            "fr": "Tokens USDC à échanger.",
            "ro": "Token-uri USDC de schimbat.",
            "it": "Token USDC da scambiare."
          },
          "type": "asset",
          "position": "transfer",
          "source": "field",
          "required": true,
          "options": [
            "INJECT:TOKEN/USDC"
          ]
        },
        {
          "name": "Minimum Amount Out",
          "description": {
            "en": "Minimum HTM to receive.",
            "de": "Minimales HTM zum Erhalten.",
            "es": "HTM mínimo a recibir.",
            "fr": "HTM minimum à recevoir.",
            "ro": "HTM minim de primit.",
            "it": "HTM minimo da ricevere."
          },
          "type": "biguint",
          "position": "arg:2",
          "source": "field",
          "default": "1",
          "min": 1
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Swap completed. Received {{AMOUNT_OUT}} HTM",
      "de": "Tausch abgeschlossen. Erhalten {{AMOUNT_OUT}} HTM",
      "es": "Intercambio completado. Recibido {{AMOUNT_OUT}} HTM",
      "fr": "Échange terminé. Reçu {{AMOUNT_OUT}} HTM",
      "ro": "Schimb completat. Primit {{AMOUNT_OUT}} HTM",
      "it": "Scambio completato. Ricevuto {{AMOUNT_OUT}} HTM"
    }
  },
  "output": {
    "OUT": "out.1",
    "AMOUNT_OUT": "out.1.amount"
  }
}
