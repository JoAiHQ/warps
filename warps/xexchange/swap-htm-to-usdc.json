{
  "protocol": "warp:3.0.0",
  "chain": "multiversx",
  "name": "xExchange Devnet: Swap HTM to USDC",
  "title": {
    "en": "Swap HTM to USDC",
    "de": "HTM gegen USDC tauschen",
    "es": "Intercambiar HTM por USDC",
    "fr": "Échanger HTM contre USDC",
