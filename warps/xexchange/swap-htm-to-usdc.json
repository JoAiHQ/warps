    "it": "Scambia HTM in USDC"
  },
  "description": {
    "en": "Swap HTM to USDC tokens on xExchange Devnet.",
    "de": "HTM gegen USDC Token auf xExchange Devnet tauschen.",
    "es": "Intercambia HTM por USDC en xExchange Devnet.",
    "fr": "Échange HTM contre USDC sur xExchange Devnet.",
    "ro": "Schimbă HTM în USDC pe xExchange Devnet.",
    "it": "Scambia HTM in USDC su xExchange Devnet."
  },
  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Swap to USDC",
        "de": "Gegen USDC tauschen",
        "es": "Intercambiar a USDC",
        "fr": "Échanger en USDC",
        "ro": "Schimbă în USDC",
        "it": "Scambia in USDC"
      },
      "address": "erd1qqqqqqqqqqqqqpgqmj807dvlfh0tvmgf5ztx0t79xn8nfct60n4sw0d6vy",
      "func": "swapTokensFixedInput",
      "args": [
        "string:INJECT:TOKEN/USDC"
      ],
      "gasLimit": 25000000,
      "abi": "INJECT:abis/pair.abi.json",
      "inputs": [
        {
          "name": "HTM Asset",
          "as": "asset",
          "description": {
            "en": "HTM tokens to swap.",
            "de": "HTM Token zum Tauschen.",
            "es": "Tokens HTM para intercambiar.",
            "fr": "Tokens HTM à échanger.",
            "ro": "Token-uri HTM de schimbat.",
            "it": "Token HTM da scambiare."
          },
          "type": "asset",
          "position": "transfer",
          "source": "field",
          "required": true,
          "options": [
            "INJECT:TOKEN/HTM"
          ]
        },
        {
          "name": "Minimum Amount Out",
          "description": {
            "en": "Minimum USDC to receive.",
            "de": "Minimales USDC zum Erhalten.",
            "es": "USDC mínimo a recibir.",
            "fr": "USDC minimum à recevoir.",
            "ro": "USDC minim de primit.",
            "it": "USDC minimo da ricevere."
          },
          "type": "biguint",
          "position": "arg:2",
          "source": "field",
          "default": "1",
          "min": 1
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Swap completed. Received {{AMOUNT_OUT}} USDC",
      "de": "Tausch abgeschlossen. Erhalten {{AMOUNT_OUT}} USDC",
      "es": "Intercambio completado. Recibido {{AMOUNT_OUT}} USDC",
      "fr": "Échange terminé. Reçu {{AMOUNT_OUT}} USDC",
      "ro": "Schimb completat. Primit {{AMOUNT_OUT}} USDC",
      "it": "Scambio completato. Ricevuto {{AMOUNT_OUT}} USDC"
    }
  },
  "output": {
    "OUT": "out.1",
    "AMOUNT_OUT": "out.1.amount"
  }
