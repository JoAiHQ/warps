  "actions": [
    {
      "type": "contract",
      "label": {
        "en": "Swap to EMR",
        "de": "Gegen EMR tauschen",
        "es": "Intercambiar a EMR",
        "fr": "Échanger en EMR",
        "ro": "Schimbă în EMR",
        "it": "Scambia in EMR"
      },
      "address": "erd1qqqqqqqqqqqqqpgqhlnuj8dpru7zs4mm49pudr2uk53w74px0n4snd2495",
      "func": "swapTokensFixedInput",
      "args": [
        "string:INJECT:TOKEN/EMR"
      ],
      "gasLimit": 25000000,
      "abi": "INJECT:abis/pair.abi.json",
      "inputs": [
        {
          "name": "USDC Asset",
          "as": "asset",
          "description": {
            "en": "USDC tokens to swap.",
            "de": "USDC Token zum Tauschen.",
            "es": "Tokens USDC para intercambiar.",
            "fr": "Tokens USDC à échanger.",
            "ro": "Token-uri USDC de schimbat.",
            "it": "Token USDC da scambiare."
          },
          "type": "asset",
          "position": "transfer",
          "source": "field",
          "required": true,
          "options": [
            "INJECT:TOKEN/USDC"
          ]
        },
        {
          "name": "Minimum Amount Out",
          "description": {
            "en": "Minimum EMR to receive.",
            "de": "Minimales EMR zum Erhalten.",
            "es": "EMR mínimo a recibir.",
            "fr": "EMR minimum à recevoir.",
            "ro": "EMR minim de primit.",
            "it": "EMR minimo da ricevere."
          },
          "type": "biguint",
          "position": "arg:2",
          "source": "field",
          "default": "1",
          "min": 1
        }
      ]
    }
  ],
  "messages": {
    "success": {
      "en": "Swap completed. Received {{AMOUNT_OUT}} EMR",
      "de": "Tausch abgeschlossen. Erhalten {{AMOUNT_OUT}} EMR",
      "es": "Intercambio completado. Recibido {{AMOUNT_OUT}} EMR",
      "fr": "Échange terminé. Reçu {{AMOUNT_OUT}} EMR",
      "ro": "Schimb completat. Primit {{AMOUNT_OUT}} EMR",
      "it": "Scambio completato. Ricevuto {{AMOUNT_OUT}} EMR"
