{
  "protocol": "warp:3.0.0",
  "name": "YouTube: Get Video",
  "title": {
    "en": "Get video details",
    "de": "Video-Details abrufen"
  },
  "description": {
    "en": "Retrieve information about a specific YouTube video.",
    "de": "Rufe Informationen über ein bestimmtes YouTube-Video ab."
  },
  "vars": {
    "API_KEY": "env:YOUTUBE_API_KEY|Get your API Key from Google Cloud Console."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Get Video",
      "destination": {
        "url": "https://www.googleapis.com/youtube/v3/videos?key={{API_KEY}}&id={{VIDEO_ID}}&part={{PART}}",
        "method": "GET"
      },
      "inputs": [
        {
          "name": "Video ID",
          "as": "VIDEO_ID",
          "description": "The ID of the video.",
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Part",
          "as": "PART",
          "type": "string",
          "source": "hidden",
          "default": "snippet,statistics,contentDetails"
        }
      ]
    }
  ],
  "output": {
    "TITLE": "out.items.0.snippet.title",
    "CHANNEL": "out.items.0.snippet.channelTitle",
    "VIEWS": "out.items.0.statistics.viewCount",
    "LIKES": "out.items.0.statistics.likeCount",
    "COMMENTS": "out.items.0.statistics.commentCount",
    "DESCRIPTION": "out.items.0.snippet.description",
    "PUBLISHED_AT": "out.items.0.snippet.publishedAt"
  },
  "messages": {
    "success": {
      "en": "Video: {{TITLE}} by {{CHANNEL}}. Views: {{VIEWS}}, Likes: {{LIKES}}, Comments: {{COMMENTS}}.",
      "de": "Video: {{TITLE}} von {{CHANNEL}}. Aufrufe: {{VIEWS}}, Likes: {{LIKES}}, Kommentare: {{COMMENTS}}."
    }
  }
}
