{
  "protocol": "warp:3.0.0",
  "name": "YouTube: Search",
  "title": {
    "en": "Search YouTube",
    "de": "YouTube durchsuchen"
  },
  "description": {
    "en": "Search for videos, channels, or playlists on YouTube.",
    "de": "Suche nach Videos, Kanälen oder Playlists auf YouTube."
  },
  "vars": {
    "API_KEY": "env:YOUTUBE_API_KEY|Get your API Key from Google Cloud Console."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Search",
      "destination": {
        "url": "https://www.googleapis.com/youtube/v3/search?key={{API_KEY}}&q={{QUERY}}&part={{PART}}&type={{TYPE}}&maxResults={{MAX_RESULTS}}",
        "method": "GET"
      },
      "inputs": [
        {
          "name": "Query",
          "as": "QUERY",
          "description": "The search query.",
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Part",
          "as": "PART",
          "type": "string",
          "source": "hidden",
          "default": "snippet"
        },
        {
          "name": "Type",
          "as": "TYPE",
          "description": "Type of resource to search for (video, channel, playlist).",
          "type": "string",
          "source": "field",
          "default": "video"
        },
        {
          "name": "Max Results",
          "as": "MAX_RESULTS",
          "description": "Maximum number of results to return.",
          "type": "number",
          "source": "field",
          "default": 10
        }
      ]
    }
  ],
  "output": {
    "ITEMS": "out.items",
    "COUNT": "out.items.length"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} result(s).",
      "de": "{{COUNT}} Ergebnis(se) gefunden."
    }
  }
}
