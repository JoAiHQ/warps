{
  "protocol": "warp:3.0.0",
  "name": "YouTube: List Channel Videos",
  "title": {
    "en": "List channel videos",
    "de": "Kanal-Videos auflisten",
    "es": "Listar vídeos del canal",
    "fr": "Répertorier les vidéos de la chaîne",
    "ro": "Listează videoclipurile canalului",
    "it": "Elenca i video dei canali"
  },
  "description": {
    "en": "Search and list videos from a specific YouTube channel.",
    "de": "Videos eines bestimmten YouTube-Kanals suchen und auflisten.",
    "es": "Busque y enumere videos de un canal de YouTube específico.",
    "fr": "Recherchez et répertoriez les vidéos d'une chaîne YouTube spécifique.",
    "ro": "Căutați și enumerați videoclipuri de pe un anumit canal YouTube.",
    "it": "Cerca ed elenca i video da un canale YouTube specifico."
  },
  "vars": {
    "API_KEY": "env:YOUTUBE_API_KEY|Get your API Key from Google Cloud Console."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Videos",
      "destination": {
        "url": "https://www.googleapis.com/youtube/v3/search?key={{API_KEY}}&channelId={{CHANNEL_ID}}&part=snippet&type=video&order={{ORDER}}&maxResults={{MAX_RESULTS}}",
        "method": "GET"
      },
      "inputs": [
        {
          "name": "Channel ID",
          "as": "CHANNEL_ID",
          "description": {
            "en": "The YouTube channel ID.",
            "es": "El ID del canal de YouTube.",
            "fr": "L'identifiant de la chaîne YouTube.",
            "ro": "ID-ul canalului YouTube.",
            "it": "L'ID del canale YouTube."
          },
          "bot": "The YouTube channel ID (starts with UC...). You can get this from the channel URL.",
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Order",
          "as": "ORDER",
          "description": {
            "en": "Sort order: 'date', 'rating', 'viewCount', or 'relevance'.",
            "es": "Orden de clasificación: 'fecha', 'calificación', 'viewCount' o 'relevancia'.",
            "fr": "Ordre de tri : « date », « note », « viewCount » ou « pertinence ».",
            "ro": "Ordinea de sortare: „data”, „evaluare”, „viewCount” sau „relevanță”.",
            "it": "Ordinamento: \"data\", \"valutazione\", \"viewCount\" o \"pertinenza\"."
          },
          "bot": "Sort order for results. Use 'date' for newest first, 'viewCount' for most viewed.",
          "type": "string",
          "source": "field",
          "default": {
            "en": "date",
            "de": "date",
            "es": "date",
            "fr": "date",
            "ro": "date",
            "it": "date"
          }
        },
        {
          "name": "Max Results",
          "as": "MAX_RESULTS",
          "description": {
            "en": "Number of videos to return (max 50).",
            "es": "Número de vídeos a devolver (máximo 50).",
            "fr": "Nombre de vidéos à renvoyer (max 50).",
            "ro": "Numărul de videoclipuri de returnat (maximum 50).",
            "it": "Numero di video da restituire (max 50)."
          },
          "type": "number",
          "source": "field",
          "default": "10"
        }
      ]
    }
  ],
  "output": {
    "VIDEOS": "out.items",
    "COUNT": "out.pageInfo.totalResults"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} video(s).",
      "de": "{{COUNT}} Video(s) gefunden.",
      "es": "Se encontraron {{COUNT}} videos.",
      "fr": "{{COUNT}} vidéo(s) trouvée(s).",
      "ro": "S-au găsit {{COUNT}} videoclipuri.",
      "it": "Trovati {{COUNT}} video/i."
    }
  }
}
