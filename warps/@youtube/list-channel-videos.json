{
  "protocol": "warp:3.0.0",
  "name": "YouTube: List Channel Videos",
  "title": {
    "en": "List channel videos",
    "de": "Kanal-Videos auflisten"
  },
  "description": {
    "en": "Search and list videos from a specific YouTube channel.",
    "de": "Videos eines bestimmten YouTube-Kanals suchen und auflisten."
  },
  "vars": {
    "API_KEY": "env:YOUTUBE_API_KEY|Get your API Key from Google Cloud Console."
  },
  "actions": [
    {
      "type": "collect",
      "label": "List Videos",
      "destination": {
        "url": "https://www.googleapis.com/youtube/v3/search?key={{API_KEY}}&channelId={{CHANNEL_ID}}&part=snippet&type=video&order={{ORDER}}&maxResults={{MAX_RESULTS}}",
        "method": "GET"
      },
      "inputs": [
        {
          "name": "Channel ID",
          "as": "CHANNEL_ID",
          "description": {
            "en": "The YouTube channel ID."
          },
          "bot": "The YouTube channel ID (starts with UC...). You can get this from the channel URL.",
          "type": "string",
          "source": "field",
          "required": true
        },
        {
          "name": "Order",
          "as": "ORDER",
          "description": {
            "en": "Sort order: 'date', 'rating', 'viewCount', or 'relevance'."
          },
          "bot": "Sort order for results. Use 'date' for newest first, 'viewCount' for most viewed.",
          "type": "string",
          "source": "field",
          "default": "date"
        },
        {
          "name": "Max Results",
          "as": "MAX_RESULTS",
          "description": {
            "en": "Number of videos to return (max 50)."
          },
          "type": "number",
          "source": "field",
          "default": "10"
        }
      ]
    }
  ],
  "output": {
    "VIDEOS": "out.items",
    "COUNT": "out.pageInfo.totalResults"
  },
  "messages": {
    "success": {
      "en": "Found {{COUNT}} video(s).",
      "de": "{{COUNT}} Video(s) gefunden."
    }
  }
}
