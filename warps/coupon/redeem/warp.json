{
  "protocol": "warp:3.0.0",
  "name": "Coupon: Redeem",
  "title": {
    "en": "Redeem Coupon",
    "de": "Gutschein einlösen"
  },
  "description": {
    "en": "Select a coupon from your wallet and redeem it for a discount.",
    "de": "Wähle einen Gutschein aus deiner Wallet und löse ihn ein."
  },
  "vars": {
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "auto": true,
      "label": {
        "en": "Load",
        "de": "Laden"
      },
      "inputs": [],
      "destination": {
        "url": "INJECT:API_BASE/v1/passes?source=coupon",
        "method": "GET",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      }
    }
  ],
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/coupon/redeem/chatapp.63690fb.dist.html"
}