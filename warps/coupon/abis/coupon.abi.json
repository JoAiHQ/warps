{
    "name": "CouponContract",
    "constructor": {
        "inputs": [],
        "outputs": []
    },
    "upgradeConstructor": {
        "inputs": [],
        "outputs": []
    },
    "endpoints": [
        {
            "name": "createCoupon",
            "mutability": "mutable",
            "inputs": [
                { "name": "code", "type": "bytes" },
                { "name": "discount_percent", "type": "u8" },
                { "name": "max_uses", "type": "u64" },
                { "name": "expires_at", "type": "u64" }
            ],
            "outputs": [
                { "type": "u64" }
            ]
        },
        {
            "name": "redeemCoupon",
            "mutability": "mutable",
            "inputs": [
                { "name": "code", "type": "bytes" }
            ],
            "outputs": []
        },
        {
            "name": "revokeCoupon",
            "mutability": "mutable",
            "inputs": [
                { "name": "code", "type": "bytes" }
            ],
            "outputs": []
        },
        {
            "name": "getCoupon",
            "mutability": "readonly",
            "inputs": [
                { "name": "code", "type": "bytes" }
            ],
            "outputs": [
                { "type": "Coupon" }
            ]
        },
        {
            "name": "getCouponById",
            "mutability": "readonly",
            "inputs": [
                { "name": "id", "type": "u64" }
            ],
            "outputs": [
                { "type": "Coupon" }
            ]
        },
        {
            "name": "hasRedeemed",
            "mutability": "readonly",
            "inputs": [
                { "name": "code", "type": "bytes" },
                { "name": "address", "type": "Address" }
            ],
            "outputs": [
                { "type": "bool" }
            ]
        },
        {
            "name": "getCouponsByCreator",
            "mutability": "readonly",
            "inputs": [
                { "name": "creator", "type": "Address" },
                { "name": "offset", "type": "u32" },
                { "name": "limit", "type": "u32" }
            ],
            "outputs": [
                { "type": "variadic<multi<u64,Coupon>>", "multi_result": true }
            ]
        },
        {
            "name": "getNextCouponId",
            "mutability": "readonly",
            "inputs": [],
            "outputs": [
                { "type": "u64" }
            ]
        }
    ],
    "events": [
        {
            "identifier": "couponCreated",
            "inputs": [
                { "name": "id", "type": "u64", "indexed": true },
                { "name": "creator", "type": "Address", "indexed": true },
                { "name": "code", "type": "bytes" },
                { "name": "discount_percent", "type": "u8" },
                { "name": "max_uses", "type": "u64" }
            ]
        },
        {
            "identifier": "couponRedeemed",
            "inputs": [
                { "name": "id", "type": "u64", "indexed": true },
                { "name": "redeemer", "type": "Address", "indexed": true },
                { "name": "used_count", "type": "u64" }
            ]
        },
        {
            "identifier": "couponRevoked",
            "inputs": [
                { "name": "id", "type": "u64", "indexed": true },
                { "name": "creator", "type": "Address", "indexed": true }
            ]
        }
    ],
    "types": {
        "CouponStatus": {
            "type": "enum",
            "variants": [
                { "name": "Active", "discriminant": 0 },
                { "name": "Revoked", "discriminant": 1 }
            ]
        },
        "Coupon": {
            "type": "struct",
            "fields": [
                { "name": "id", "type": "u64" },
                { "name": "creator", "type": "Address" },
                { "name": "code", "type": "bytes" },
                { "name": "discount_percent", "type": "u8" },
                { "name": "max_uses", "type": "u64" },
                { "name": "used_count", "type": "u64" },
                { "name": "expires_at", "type": "u64" },
                { "name": "created_at", "type": "u64" },
                { "name": "status", "type": "CouponStatus" }
            ]
        }
    }
}
