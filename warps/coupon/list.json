{
  "protocol": "warp:3.0.0",
  "name": "Coupon: My Coupons",
  "title": {
    "en": "My coupons",
    "de": "Meine Gutscheine",
    "fr": "Mes coupons",
    "es": "Mis cupones",
    "ro": "Cupoanele mele"
  },
  "description": {
    "en": "View all discount coupons you have created on-chain.",
    "de": "Alle on-chain erstellten Rabattgutscheine ansehen.",
    "fr": "Voir tous les coupons de réduction que vous avez créés on-chain.",
    "es": "Ver todos los cupones de descuento que has creado on-chain.",
    "ro": "Vezi toate cupoanele de reducere create de tine on-chain."
  },
  "bot": "Lists all coupons created by the given wallet address. Provide the owner's address to see their coupons.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:COUPON_SC_ADDRESS"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading your coupons...",
        "de": "Gutscheine werden geladen...",
        "fr": "Chargement de vos coupons...",
        "es": "Cargando tus cupones...",
        "ro": "Se încarcă cupoanele tale..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getOwnerCoupons",
      "abi": "INJECT:contract/output/coupon.abi.json",
      "inputs": [
        {
          "name": "Owner Address",
          "as": "owner",
          "description": {
            "en": "Your wallet address",
            "de": "Deine Wallet-Adresse",
            "fr": "Votre adresse de portefeuille",
            "es": "Tu dirección de wallet",
            "ro": "Adresa ta de wallet"
          },
          "bot": "The wallet address to list coupons for. Use the connected wallet address.",
          "type": "address",
          "position": "arg:1",
          "source": "field",
          "required": true
        },
        {
          "name": "Offset",
          "as": "offset",
          "type": "uint32",
          "position": "arg:2",
          "source": "hidden",
          "default": "0",
          "required": true
        },
        {
          "name": "Limit",
          "as": "limit",
          "type": "uint32",
          "position": "arg:3",
          "source": "hidden",
          "default": "50",
          "required": true
        }
      ],
      "auto": false
    }
  ],
  "output": {
    "COUPONS": "out.data"
  },
  "messages": {
    "success": {
      "en": "Your coupons loaded.",
      "de": "Deine Gutscheine geladen.",
      "fr": "Vos coupons sont chargés.",
      "es": "Tus cupones cargados.",
      "ro": "Cupoanele tale au fost încărcate."
    }
  }
}
