{
  "protocol": "warp:3.0.0",
  "name": "Coupon: View",
  "title": {
    "en": "View coupon",
    "de": "Gutschein ansehen",
    "fr": "Voir le coupon",
    "es": "Ver cupon",
    "ro": "Vezi cuponul"
  },
  "description": {
    "en": "Check the details, discount, and remaining uses of a coupon code.",
    "de": "Details, Rabatt und verbleibende Nutzungen eines Gutscheincodes prüfen.",
    "fr": "Consultez les details, la reduction et le nombre d utilisations restantes d un coupon.",
    "es": "Consulta los detalles, el descuento y los usos restantes de un cupon.",
    "ro": "Verifica detaliile, reducerea si utilizarile ramase ale unui cupon."
  },
  "bot": "Fetches coupon details by code. Shows the discount percentage, usage limits, remaining uses, and current status.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:COUPON_SC_ADDRESS",
    "CODE": "query:code"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading coupon...",
        "de": "Gutschein wird geladen...",
        "fr": "Chargement du coupon...",
        "es": "Cargando cupon...",
        "ro": "Se incarca cuponul..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getCoupon",
      "args": [],
      "inputs": [
        {
          "name": "Coupon Code",
          "as": "code",
          "type": "string",
          "position": "arg:1",
          "source": "var",
          "default": "{{CODE}}",
          "required": true
        }
      ],
      "auto": true,
      "abi": "INJECT:contract/output/coupon.abi.json"
    }
  ],
  "output": {
    "DISCOUNT": "out.discount_percent",
    "MAX_USES": "out.max_uses",
    "USED_COUNT": "out.used_count",
    "STATUS": "out.status"
  },
  "messages": {
    "success": {
      "en": "{{DISCOUNT}}% discount — {{USED_COUNT}}/{{MAX_USES}} uses",
      "de": "{{DISCOUNT}}% Rabatt — {{USED_COUNT}}/{{MAX_USES}} Nutzungen",
      "fr": "{{DISCOUNT}}% de reduction — {{USED_COUNT}}/{{MAX_USES}} utilisations",
      "es": "{{DISCOUNT}}% de descuento — {{USED_COUNT}}/{{MAX_USES}} usos",
      "ro": "{{DISCOUNT}}% reducere — {{USED_COUNT}}/{{MAX_USES}} utilizari"
    }
  }
}
