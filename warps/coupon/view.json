{
  "protocol": "warp:3.0.0",
  "name": "Coupon: View",
  "title": {
    "en": "View coupon",
    "de": "Gutschein ansehen",
    "fr": "Voir le coupon",
    "es": "Ver cupón",
    "ro": "Vezi cuponul"
  },
  "description": {
    "en": "Look up a coupon by code — see the discount, usage count, expiry, and status.",
    "de": "Gutscheincode nachschlagen — Rabatt, Nutzungsanzahl, Ablaufdatum und Status ansehen.",
    "fr": "Recherchez un coupon par code — voyez la réduction, les utilisations, l'expiration et le statut.",
    "es": "Consulta un cupón por código — ve el descuento, usos, vencimiento y estado.",
    "ro": "Caută un cupon după cod — vezi reducerea, numărul de utilizări, expirarea și statusul."
  },
  "bot": "Fetches coupon details by code. Shows discount percentage, usage limits, how many times it's been redeemed, expiry, and whether it's active or revoked.",
  "chain": "multiversx",
  "vars": {
    "SC_ADDRESS": "INJECT:COUPON_SC_ADDRESS",
    "CODE": "query:code"
  },
  "actions": [
    {
      "type": "query",
      "label": {
        "en": "Loading coupon...",
        "de": "Gutschein wird geladen...",
        "fr": "Chargement du coupon...",
        "es": "Cargando cupón...",
        "ro": "Se încarcă cuponul..."
      },
      "address": "{{SC_ADDRESS}}",
      "func": "getCoupon",
      "abi": "INJECT:contract/output/coupon.abi.json",
      "inputs": [
        {
          "name": "Coupon Code",
          "as": "code",
          "type": "string",
          "position": "arg:1",
          "source": "var",
          "default": "{{CODE}}",
          "required": true
        }
      ],
      "auto": true
    }
  ],
  "output": {
    "COUPON_ID": "out.data.id",
    "COLLECTION_ID": "out.data.collection_id",
    "DISCOUNT": "out.data.discount_percent",
    "MAX_USES": "out.data.max_uses",
    "USED_COUNT": "out.data.used_count",
    "EXPIRES_AT": "out.data.expires_at",
    "CREATED_AT": "out.data.created_at",
    "STATUS": "out.data.status"
  },
  "messages": {
    "success": {
      "en": "{{DISCOUNT}}% off · {{USED_COUNT}}/{{MAX_USES}} redeemed (0 = unlimited) · status: {{STATUS}}",
      "de": "{{DISCOUNT}}% Rabatt · {{USED_COUNT}}/{{MAX_USES}} eingelöst (0 = unbegrenzt) · Status: {{STATUS}}",
      "fr": "{{DISCOUNT}}% de réduction · {{USED_COUNT}}/{{MAX_USES}} utilisés (0 = illimité) · statut : {{STATUS}}",
      "es": "{{DISCOUNT}}% de descuento · {{USED_COUNT}}/{{MAX_USES}} canjeados (0 = ilimitado) · estado: {{STATUS}}",
      "ro": "{{DISCOUNT}}% reducere · {{USED_COUNT}}/{{MAX_USES}} folosite (0 = nelimitat) · status: {{STATUS}}"
    }
  }
}
