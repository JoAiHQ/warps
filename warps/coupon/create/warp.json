{
  "protocol": "warp:3.0.0",
  "name": "Coupon: Create",
  "title": {
    "en": "Create a Coupon",
    "de": "Gutschein erstellen"
  },
  "description": {
    "en": "Create a new discount coupon in your collection.",
    "de": "Erstelle einen neuen Rabattgutschein in deiner Kollektion."
  },
  "vars": {
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "auto": true,
      "label": {
        "en": "Load",
        "de": "Laden"
      },
      "inputs": [],
      "destination": {
        "url": "INJECT:API_BASE/v1/passes?source=coupon",
        "method": "GET",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      }
    }
  ],
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/coupon/create/chatapp.63690fb.dist.html"
}