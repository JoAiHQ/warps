{
  "protocol": "warp:3.0.0",
  "name": "Coupon: Browse",
  "title": {
    "en": "Browse Coupons",
    "de": "Gutscheine durchsuchen"
  },
  "description": {
    "en": "Browse available discount coupons and claim one to your wallet.",
    "de": "Durchsuche verfügbare Rabattgutscheine und beanspruche einen."
  },
  "vars": {
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "auto": true,
      "label": {
        "en": "Load",
        "de": "Laden"
      },
      "inputs": [],
      "destination": {
        "url": "INJECT:API_BASE/v1/passes?source=coupon",
        "method": "GET",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      }
    }
  ],
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/coupon/browse/chatapp.517cbd4.dist.html"
}