{
  "protocol": "warp:3.0.0",
  "name": "Coupon: Manage",
  "title": {
    "en": "Manage Coupons",
    "de": "Gutscheine verwalten"
  },
  "description": {
    "en": "View and manage your discount coupons — revoke, check status.",
    "de": "Rabattgutscheine anzeigen und verwalten — widerrufen, Status prüfen."
  },
  "vars": {
    "JOAI_AGENT_AUTH_KEY": "env:JOAI_AGENT_AUTH_KEY"
  },
  "actions": [
    {
      "type": "collect",
      "auto": true,
      "label": {
        "en": "Load",
        "de": "Laden"
      },
      "inputs": [],
      "destination": {
        "url": "INJECT:API_BASE/v1/passes?source=coupon",
        "method": "GET",
        "headers": {
          "X-Agent-Auth-Key": "{{JOAI_AGENT_AUTH_KEY}}"
        }
      }
    }
  ],
  "ui": "https://raw.githubusercontent.com/JoAiHQ/warps/main/warps/coupon/manage/chatapp.3b44437.dist.html"
}