{
  "protocol": "warp:3.0.0",
  "name": "OpenCode: Add Followup",
  "title": {
    "en": "Add followup",
    "es": "Agregar seguimiento",
    "fr": "Ajouter un suivi",
    "ro": "Adăugați continuarea",
    "it": "Aggiungi il follow-up"
  },
  "description": {
    "en": "Send a followup message to an existing OpenCode session.",
    "es": "Send a followup message to an existing OpenCode session.",
    "fr": "Send a followup message to an existing OpenCode session.",
    "ro": "Send a followup message to an existing OpenCode session.",
    "it": "Send a followup message to an existing OpenCode session."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Add Followup",
        "es": "Agregar seguimiento",
        "fr": "Ajouter un suivi",
        "ro": "Adăugați urmărire",
        "it": "Aggiungi follow-up"
      },
      "destination": {
        "url": "INJECT:API_BASE/session/{{RUN_ID}}/message",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "OpenCode session ID.",
            "es": "OpenCode session ID.",
            "fr": "OpenCode session ID.",
            "ro": "OpenCode session ID.",
            "it": "OpenCode session ID."
          },
          "type": "string",
          "position": "path:RUN_ID",
          "source": "field",
          "required": true
        },
        {
          "name": "Followup",
          "as": "FOLLOWUP",
          "description": {
            "en": "Followup instruction text.",
            "es": "Followup instruction text.",
            "fr": "Followup instruction text.",
            "ro": "Followup instruction text.",
            "it": "Followup instruction text."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:parts.0.text"
        },
        {
          "name": "Part Type",
          "as": "PART_TYPE",
          "description": {
            "en": "Message part type.",
            "es": "Message part type.",
            "fr": "Message part type.",
            "ro": "Message part type.",
            "it": "Message part type."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "default": {
            "en": "text",
            "de": "text",
            "es": "text",
            "fr": "text",
            "ro": "text",
            "it": "text"
          },
          "position": "payload:parts.0.type"
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "in.RUN_ID",
    "RUN_STATUS": "transform:() => out.status || 'updated'",
    "SUMMARY": "transform:() => out.summary || 'Followup sent'"
  },
  "messages": {
    "success": {
      "en": "Followup sent to OpenCode session {{RUN_ID}}.",
      "es": "Followup sent to OpenCode session {{RUN_ID}}.",
      "fr": "Followup sent to OpenCode session {{RUN_ID}}.",
      "ro": "Followup sent to OpenCode session {{RUN_ID}}.",
      "it": "Followup sent to OpenCode session {{RUN_ID}}."
    }
  }
}
