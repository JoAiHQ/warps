{
  "protocol": "warp:3.0.0",
  "name": "OpenCode: Get Task Status",
  "title": {
    "en": "Get task status",
    "es": "Obtener el estado de la tarea",
    "fr": "Obtenir le statut de la tâche",
    "ro": "Obțineți starea sarcinii",
    "it": "Ottieni lo stato dell'attività"
  },
  "description": {
    "en": "Get current status of an OpenCode session.",
    "es": "Get current status of an OpenCode session.",
    "fr": "Get current status of an OpenCode session.",
    "ro": "Get current status of an OpenCode session.",
    "it": "Get current status of an OpenCode session."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Get Status",
        "es": "Obtener estado",
        "fr": "Obtenir le statut",
        "ro": "Obține stare",
        "it": "Ottieni lo stato"
      },
      "destination": {
        "url": "INJECT:API_BASE/session/{{RUN_ID}}",
        "method": "GET",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "OpenCode session ID.",
            "es": "OpenCode session ID.",
            "fr": "OpenCode session ID.",
            "ro": "OpenCode session ID.",
            "it": "OpenCode session ID."
          },
          "type": "string",
          "position": "path:RUN_ID",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "out.id",
    "RUN_STATUS": "transform:() => out.status || 'unknown'",
    "RUN_URL": "transform:() => out.id ? `opencode://session/${out.id}` : null",
    "SUMMARY": "transform:() => out.title || 'Session loaded'"
  },
  "messages": {
    "success": {
      "en": "OpenCode session {{RUN_ID}} is {{RUN_STATUS}}.",
      "es": "OpenCode session {{RUN_ID}} is {{RUN_STATUS}}.",
      "fr": "OpenCode session {{RUN_ID}} is {{RUN_STATUS}}.",
      "ro": "OpenCode session {{RUN_ID}} is {{RUN_STATUS}}.",
      "it": "OpenCode session {{RUN_ID}} is {{RUN_STATUS}}."
    }
  }
}
