{
  "protocol": "warp:3.0.0",
  "name": "OpenCode: Launch Task",
  "title": {
    "en": "Launch task",
    "es": "Iniciar tarea",
    "fr": "Lancer la tâche",
    "ro": "Lansați sarcina",
    "it": "Avvia attività"
  },
  "description": {
    "en": "Create a new OpenCode session for task execution.",
    "es": "Create a new OpenCode session for task execution.",
    "fr": "Create a new OpenCode session for task execution.",
    "ro": "Create a new OpenCode session for task execution.",
    "it": "Create a new OpenCode session for task execution."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Launch Task",
        "es": "Iniciar tarea",
        "fr": "Lancer la tâche",
        "ro": "Lansați Sarcina",
        "it": "Avvia attività"
      },
      "destination": {
        "url": "INJECT:API_BASE/session",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": {
            "en": "Task",
            "de": "Task",
            "es": "Task",
            "fr": "Task",
            "ro": "Task",
            "it": "Task"
          },
          "as": "TASK",
          "description": {
            "en": "Initial task title for the session.",
            "es": "Initial task title for the session.",
            "fr": "Initial task title for the session.",
            "ro": "Initial task title for the session.",
            "it": "Initial task title for the session."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:title"
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "out.id",
    "RUN_STATUS": "transform:() => out.status || 'created'",
    "RUN_URL": "transform:() => out.id ? `opencode://session/${out.id}` : null",
    "SUMMARY": "transform:() => out.title || 'Session created'"
  },
  "messages": {
    "success": {
      "en": "OpenCode session {{RUN_ID}} created ({{RUN_STATUS}}).",
      "es": "OpenCode session {{RUN_ID}} created ({{RUN_STATUS}}).",
      "fr": "OpenCode session {{RUN_ID}} created ({{RUN_STATUS}}).",
      "ro": "OpenCode session {{RUN_ID}} created ({{RUN_STATUS}}).",
      "it": "OpenCode session {{RUN_ID}} created ({{RUN_STATUS}})."
    }
  }
}
