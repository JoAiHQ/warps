{
  "protocol": "warp:3.0.0",
  "name": "OpenCode: Cancel Task",
  "title": {
    "en": "Cancel task",
    "es": "Cancelar tarea",
    "fr": "Annuler la tâche",
    "ro": "Anulați sarcina",
    "it": "Annulla attività"
  },
  "description": {
    "en": "Abort and close an OpenCode session.",
    "es": "Abort and close an OpenCode session.",
    "fr": "Abort and close an OpenCode session.",
    "ro": "Abort and close an OpenCode session.",
    "it": "Abort and close an OpenCode session."
  },
  "actions": [
    {
      "type": "collect",
      "label": {
        "en": "Cancel Task",
        "es": "Cancelar tarea",
        "fr": "Annuler la tâche",
        "ro": "Anulează sarcina",
        "it": "Annulla attività"
      },
      "destination": {
        "url": "INJECT:API_BASE/session/{{RUN_ID}}/abort",
        "method": "POST",
        "headers": {
          "Content-Type": "application/json"
        }
      },
      "inputs": [
        {
          "name": "Run ID",
          "as": "RUN_ID",
          "description": {
            "en": "OpenCode session ID.",
            "es": "OpenCode session ID.",
            "fr": "OpenCode session ID.",
            "ro": "OpenCode session ID.",
            "it": "OpenCode session ID."
          },
          "type": "string",
          "position": "path:RUN_ID",
          "source": "field",
          "required": true
        }
      ]
    }
  ],
  "output": {
    "RUN_ID": "in.RUN_ID",
    "RUN_STATUS": "transform:() => 'aborted'",
    "SUMMARY": "transform:() => 'Session aborted'"
  },
  "messages": {
    "success": {
      "en": "OpenCode session {{RUN_ID}} aborted.",
      "es": "OpenCode session {{RUN_ID}} aborted.",
      "fr": "OpenCode session {{RUN_ID}} aborted.",
      "ro": "OpenCode session {{RUN_ID}} aborted.",
      "it": "OpenCode session {{RUN_ID}} aborted."
    }
  }
}
