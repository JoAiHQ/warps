{
  "protocol": "warp:3.0.0",
  "name": "Anthropic: Install JoAi Plugin",
  "title": {
    "en": "Install JoAi plugin for Claude"
  },
  "description": {
    "en": "Connects your Claude to a JoAi agent via MCP."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Install"
      },
      "prompt": "/claude mcp add -s user --transport http joai https://cortex.joai.ai/mcp/agents/{{JOAI_AGENT_UUID}}"
    }
  ]
}
