{
  "protocol": "warp:3.0.0",
  "name": "Anthropic: Install JoAi Plugin",
  "title": {
    "en": "Install JoAi plugin for Claude"
  },
  "description": {
    "en": "Connects your Claude to a JoAi agent via MCP."
  },
  "actions": [
    {
      "type": "prompt",
      "label": {
        "en": "Install"
      },
      "prompt": "/claude mcp add -s user --transport http joai https://cortex.joai.ai/mcp/agents/{{AGENT_UUID}}",
      "inputs": [
        {
          "name": "Agent UUID",
          "as": "AGENT_UUID",
          "description": {
            "en": "The UUID of your JoAi agent."
          },
          "type": "string",
          "source": "field",
          "required": true
        }
      ]
    }
  ]
}
