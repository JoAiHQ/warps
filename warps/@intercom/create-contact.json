{
  "protocol": "warp:3.0.0",
  "name": "Intercom: Create Contact",
  "title": {
    "en": "Create contact",
    "de": "Kontakt erstellen",
    "es": "Create contact",
    "fr": "Create contact",
    "ro": "Create contact",
    "it": "Create contact"
  },
  "description": {
    "en": "Create a new contact in Intercom.",
    "de": "Erstelle einen neuen Kontakt in Intercom.",
    "es": "Create a new contact in Intercom.",
    "fr": "Create a new contact in Intercom.",
    "ro": "Create a new contact in Intercom.",
    "it": "Create a new contact in Intercom."
  },
  "vars": {
    "ACCESS_TOKEN": "env:INTERCOM_ACCESS_TOKEN|Your Intercom Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Create Contact",
      "destination": {
        "url": "https://api.intercom.io/contacts",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/json",
          "Intercom-Version": "2.9"
        }
      },
      "inputs": [
        {
          "name": "Email",
          "as": "email",
          "description": {
            "en": "The contact's email.",
            "es": "The contact's email.",
            "fr": "The contact's email.",
            "ro": "The contact's email.",
            "it": "The contact's email."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:email"
        },
        {
          "name": {
            "en": "Name",
            "de": "Name",
            "es": "Name",
            "fr": "Name",
            "ro": "Name",
            "it": "Name"
          },
          "as": {
            "en": "name",
            "de": "name",
            "es": "name",
            "fr": "name",
            "ro": "name",
            "it": "name"
          },
          "description": {
            "en": "The contact's name.",
            "es": "The contact's name.",
            "fr": "The contact's name.",
            "ro": "The contact's name.",
            "it": "The contact's name."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:name"
        },
        {
          "name": {
            "en": "Role",
            "de": "Role",
            "es": "Role",
            "fr": "Role",
            "ro": "Role",
            "it": "Role"
          },
          "as": {
            "en": "role",
            "de": "role",
            "es": "role",
            "fr": "role",
            "ro": "role",
            "it": "role"
          },
          "description": {
            "en": "Role: 'user' or 'lead'.",
            "es": "Role: 'user' or 'lead'.",
            "fr": "Role: 'user' or 'lead'.",
            "ro": "Role: 'user' or 'lead'.",
            "it": "Role: 'user' or 'lead'."
          },
          "type": "string",
          "source": "hidden",
          "position": "payload:role",
          "default": {
            "en": "user",
            "de": "user",
            "es": "user",
            "fr": "user",
            "ro": "user",
            "it": "user"
          }
        }
      ]
    }
  ],
  "output": {
    "CONTACT_ID": "out.id",
    "EMAIL": "out.email",
    "NAME": "out.name"
  },
  "messages": {
    "success": {
      "en": "Contact created! ID: {{CONTACT_ID}}",
      "de": "Kontakt erstellt! ID: {{CONTACT_ID}}",
      "es": "Contact created! ID: {{CONTACT_ID}}",
      "fr": "Contact created! ID: {{CONTACT_ID}}",
      "ro": "Contact created! ID: {{CONTACT_ID}}",
      "it": "Contact created! ID: {{CONTACT_ID}}"
    }
  }
}
