{
  "protocol": "warp:3.0.0",
  "name": "Intercom: Create Conversation",
  "title": {
    "en": "Create conversation",
    "de": "Konversation erstellen",
    "es": "Create conversation",
    "fr": "Create conversation",
    "ro": "Create conversation",
    "it": "Create conversation"
  },
  "description": {
    "en": "Create a new conversation in Intercom on behalf of a user.",
    "de": "Erstelle eine neue Konversation in Intercom im Namen eines Benutzers.",
    "es": "Create a new conversation in Intercom on behalf of a user.",
    "fr": "Create a new conversation in Intercom on behalf of a user.",
    "ro": "Create a new conversation in Intercom on behalf of a user.",
    "it": "Create a new conversation in Intercom on behalf of a user."
  },
  "vars": {
    "ACCESS_TOKEN": "env:INTERCOM_ACCESS_TOKEN|Your Intercom Access Token."
  },
  "actions": [
    {
      "type": "collect",
      "label": "Create Conversation",
      "destination": {
        "url": "https://api.intercom.io/conversations",
        "method": "POST",
        "headers": {
          "Authorization": "Bearer {{ACCESS_TOKEN}}",
          "Content-Type": "application/json",
          "Intercom-Version": "2.9"
        }
      },
      "inputs": [
        {
          "name": "User ID",
          "as": "userId",
          "description": {
            "en": "The Intercom User ID of the sender.",
            "es": "The Intercom User ID of the sender.",
            "fr": "The Intercom User ID of the sender.",
            "ro": "The Intercom User ID of the sender.",
            "it": "The Intercom User ID of the sender."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:from.id"
        },
        {
          "name": "Email",
          "as": "email",
          "description": {
            "en": "The email of the sender (use if User ID is not known).",
            "es": "The email of the sender (use if User ID is not known).",
            "fr": "The email of the sender (use if User ID is not known).",
            "ro": "The email of the sender (use if User ID is not known).",
            "it": "The email of the sender (use if User ID is not known)."
          },
          "type": "string",
          "source": "field",
          "required": false,
          "position": "payload:from.email"
        },
        {
          "name": "Type",
          "as": "type",
          "description": {
            "en": "Type of sender ('user' or 'lead').",
            "es": "Type of sender ('user' or 'lead').",
            "fr": "Type of sender ('user' or 'lead').",
            "ro": "Type of sender ('user' or 'lead').",
            "it": "Type of sender ('user' or 'lead')."
          },
          "type": "string",
          "source": "hidden",
          "position": "payload:from.type",
          "default": {
            "en": "user",
            "de": "user",
            "es": "user",
            "fr": "user",
            "ro": "user",
            "it": "user"
          },
          "label": {
            "en": "Type",
            "de": "Type",
            "es": "Type",
            "fr": "Type",
            "ro": "Type",
            "it": "Type"
          }
        },
        {
          "name": "Body",
          "as": "body",
          "description": {
            "en": "The message body.",
            "es": "The message body.",
            "fr": "The message body.",
            "ro": "The message body.",
            "it": "The message body."
          },
          "type": "string",
          "source": "field",
          "required": true,
          "position": "payload:body",
          "label": {
            "en": "Body",
            "de": "Body",
            "es": "Body",
            "fr": "Body",
            "ro": "Body",
            "it": "Body"
          }
        }
      ]
    }
  ],
  "output": {
    "CONVERSATION_ID": "out.id"
  },
  "messages": {
    "success": {
      "en": "Conversation created! ID: {{CONVERSATION_ID}}",
      "de": "Konversation erstellt! ID: {{CONVERSATION_ID}}",
      "es": "Conversation created! ID: {{CONVERSATION_ID}}",
      "fr": "Conversation created! ID: {{CONVERSATION_ID}}",
      "ro": "Conversation created! ID: {{CONVERSATION_ID}}",
      "it": "Conversation created! ID: {{CONVERSATION_ID}}"
    }
  }
}
